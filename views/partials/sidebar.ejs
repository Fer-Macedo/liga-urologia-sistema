<%
const pa = typeof paginaAtual !== 'undefined' ? paginaAtual : '';
const usuarioPerfil = (typeof usuario !== 'undefined' && usuario && usuario.perfil) ? usuario.perfil : 'visualizador';
const orgLogo = (typeof config !== 'undefined' && config && config.org_logo) ? config.org_logo : null;
const orgNome = (typeof config !== 'undefined' && config && config.org_nome) ? config.org_nome : 'LAURO';
%>
<aside class="sidebar">

  <div class="sidebar-brand">
    <div class="sidebar-brand-logo <%= orgLogo ? 'sidebar-brand-logo--img' : '' %>">
      <% if (orgLogo) { %>
        <img src="<%= orgLogo %>" alt="Logo" style="width:34px;height:34px;object-fit:contain;display:block;border-radius:8px;">
      <% } else { %>LU<% } %>
    </div>
    <div class="sidebar-brand-text">
      <strong><%= orgNome %></strong>
      <span>Painel Interno</span>
    </div>
  </div>

  <nav class="sidebar-nav">

    <div class="nav-group">
      <div class="nav-group-title">Visão geral</div>
      <a href="/dashboard" class="nav-item <%= pa === 'dashboard' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></span>
        <span>Dashboard</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Pessoas</div>
      <a href="/ligantes" class="nav-item <%= pa === 'ligantes' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
        <span>Ligantes</span>
      </a>
      <a href="/diretivos" class="nav-item <%= pa === 'diretivos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
        <span>Diretivos</span>
      </a>
      <a href="/membros" class="nav-item <%= pa === 'membros' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></span>
        <span>Cadastro Financeiro</span>
      </a>
      <a href="/aniversarios" class="nav-item <%= pa === 'aniversarios' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3v4M8 3v4M3 11h18"/></svg></span>
        <span>Aniversários</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Acadêmico</div>
      <a href="/frequencia" class="nav-item <%= pa === 'frequencia' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></span>
        <span>Frequência Ligantes</span>
      </a>
      <a href="/frequencia-diretivos" class="nav-item <%= pa === 'frequencia-diretivos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
        <span>Frequência Diretivos</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Eventos</div>
      <a href="/eventos" class="nav-item <%= pa === 'eventos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3v4M8 3v4"/></svg></span>
        <span>Eventos</span>
      </a>
      <a href="/lista-assinaturas" class="nav-item <%= pa === 'lista-assinaturas' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></span>
        <span>Listas de Assinatura</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Financeiro</div>
      <a href="/cobrancas" class="nav-item <%= pa === 'cobrancas' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
        <span>Cobranças</span>
      </a>
      <a href="/carta-cobranca" class="nav-item <%= pa === 'carta-cobranca' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
        <span>Cartas de Cobrança</span>
      </a>
      <a href="/financeiro-arquivos" class="nav-item <%= pa === 'financeiro-arquivos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span>
        <span>Arquivos Financeiros</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Gestão</div>
      <a href="/desligamentos" class="nav-item <%= pa === 'desligamentos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
        <span>Desligamentos</span>
      </a>
      <a href="/desvinculacoes" class="nav-item <%= pa === 'desvinculacoes' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></span>
        <span>Desvinculações</span>
      </a>
      <a href="/arquivos" class="nav-item <%= pa === 'arquivos' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span>
        <span>Arquivos</span>
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-group-title">Comunicação</div>
      <a href="/marketing" class="nav-item <%= pa === 'marketing' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>
        <span>Marketing</span>
      </a>
      <a href="/notificacoes" class="nav-item <%= pa === 'notificacoes' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></span>
        <span>Notificações</span>
      </a>
    </div>

    <% if (usuarioPerfil === 'admin') { %>
    <div class="nav-group">
      <div class="nav-group-title">Administração</div>
      <a href="/usuarios" class="nav-item <%= pa === 'usuarios' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
        <span>Usuários</span>
      </a>
      <a href="/auditoria" class="nav-item <%= pa === 'auditoria' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        <span>Auditoria</span>
      </a>
      <a href="/configuracoes" class="nav-item <%= pa === 'configuracoes' ? 'ativo' : '' %>">
        <span class="nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
        <span>Configurações</span>
      </a>
    </div>
    <% } %>

  </nav>

  <div class="sidebar-footer">
    <% if (typeof usuario !== 'undefined' && usuario) { %>
      <div class="sidebar-user">
        <div class="sidebar-user-avatar"><%= (usuario.nome || '?').substring(0,1).toUpperCase() %></div>
        <div class="sidebar-user-info">
          <strong><%= (usuario.nome || '').split(' ')[0] %></strong>
          <span><%= usuario.perfil %></span>
        </div>
      </div>
    <% } %>
    <a href="/logout" class="sidebar-logout">Sair</a>
  </div>
</aside>
