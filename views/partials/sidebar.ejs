<script>
// Polling automático de pendências a cada 30 segundos
(function() {
  function verificarPendencias() {
    fetch('/api/pendencias')
      .then(r => r.json())
      .then(data => {
        const badgeLig = document.getElementById('badge-pendentes-ligantes');
        if (badgeLig) { badgeLig.textContent = data.ligantes; badgeLig.style.display = data.ligantes > 0 ? 'inline-flex' : 'none'; }
        const badgeDir = document.getElementById('badge-pendentes-diretivos');
        if (badgeDir) { badgeDir.textContent = data.diretivos; badgeDir.style.display = data.diretivos > 0 ? 'inline-flex' : 'none'; }
        const badgePal = document.getElementById('badge-pendentes-palestrantes');
        if (badgePal) { badgePal.textContent = data.palestrantes; badgePal.style.display = data.palestrantes > 0 ? 'inline-flex' : 'none'; }
        let alertaGlobal = document.getElementById('alerta-pendencias-global');
        if (data.total > 0) {
          if (!alertaGlobal) {
            alertaGlobal = document.createElement('div');
            alertaGlobal.id = 'alerta-pendencias-global';
            alertaGlobal.style.cssText = 'position:fixed;top:16px;right:16px;background:#C98A1E;color:#fff;padding:12px 18px;font-size:13px;font-weight:700;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.25);cursor:pointer';
            alertaGlobal.onclick = () => alertaGlobal.style.display = 'none';
            document.body.appendChild(alertaGlobal);
          }
          alertaGlobal.textContent = data.total + ' pendencia(s) aguardando aprovacao - clique para fechar';
          alertaGlobal.style.display = 'block';
        } else if (alertaGlobal) {
          alertaGlobal.style.display = 'none';
        }
      })
      .catch(() => {});
  }
  verificarPendencias();
  setInterval(verificarPendencias, 30000);
})();
</script>
