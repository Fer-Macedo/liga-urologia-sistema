<%
// Parcial de notificações de pendências. Incluído no layout.
// Busca as pendências via /api/minhas-pendencias e mostra: sino flutuante + modal ao logar.
%>
<style>
  .notif-sino-wrap{position:fixed;top:16px;right:20px;z-index:80}
  .notif-sino{position:relative;width:42px;height:42px;border-radius:3px;background:#fff;border:1px solid #DDE3DF;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#2A4034;box-shadow:0 1px 4px rgba(0,0,0,.06)}
  .notif-sino:hover{border-color:#0F6E56}
  .notif-sino.tem-pend{animation:notifPisca 1.3s ease-in-out infinite}
  @keyframes notifPisca{0%,100%{box-shadow:0 0 0 0 rgba(194,57,43,.5)}50%{box-shadow:0 0 0 6px rgba(194,57,43,0)}}
  .notif-badge{position:absolute;top:-6px;right:-6px;min-width:18px;height:18px;padding:0 4px;border-radius:3px;background:#C0392B;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center}
  .notif-modal-bg{display:none;position:fixed;inset:0;background:rgba(10,25,18,.55);z-index:200;align-items:center;justify-content:center;padding:16px}
  .notif-modal-bg.show{display:flex}
  .notif-modal{background:#fff;border-radius:4px;max-width:440px;width:100%;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,.25)}
  .notif-modal-h{background:#0C231B;color:#fff;padding:16px 20px;display:flex;align-items:center;gap:10px;font-weight:700;font-size:15px}
  .notif-modal-b{padding:16px 20px;max-height:50vh;overflow-y:auto}
  .notif-modal-f{padding:12px 20px;border-top:1px solid #EEF0ED;display:flex;justify-content:flex-end;gap:8px}
  .notif-item{display:flex;align-items:flex-start;gap:10px;padding:11px 12px;border:1px solid #EEF0ED;border-radius:3px;margin-bottom:8px;text-decoration:none;color:inherit;transition:.15s}
  .notif-item:hover{border-color:#0F6E56;background:#F6FAF8}
  .notif-item-ico{width:30px;height:30px;border-radius:3px;background:#FBF3E0;color:#C98A1E;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .notif-item-nome{font-size:13px;font-weight:600;color:#1E2D25;line-height:1.3}
  .notif-item-motivo{font-size:11.5px;color:#6B7A72;margin-top:2px}
  .notif-btn{padding:8px 16px;border-radius:3px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid #DDE3DF;background:#fff;color:#2A4034}
  .notif-btn-pri{background:#0F6E56;color:#fff;border-color:#0F6E56}
  .notif-vazio{text-align:center;color:#6B7A72;font-size:13px;padding:20px}
</style>

<div class="notif-sino-wrap">
  <div class="notif-sino" id="notifSino" onclick="abrirNotifModal()" title="Pendências">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
    <span class="notif-badge" id="notifBadge" style="display:none">0</span>
  </div>
</div>

<div class="notif-modal-bg" id="notifModalBg">
  <div class="notif-modal">
    <div class="notif-modal-h">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
      <span id="notifModalTitulo">Você tem pendências para resolver</span>
    </div>
    <div class="notif-modal-b" id="notifModalBody">
      <div class="notif-vazio">Carregando…</div>
    </div>
    <div class="notif-modal-f">
      <button class="notif-btn" onclick="fecharNotifModal()">Fechar</button>
    </div>
  </div>
</div>

<script>
(function(){
  var jaAbriu = false;
  function render(d){
    var badge = document.getElementById('notifBadge');
    var sino = document.getElementById('notifSino');
    var body = document.getElementById('notifModalBody');
    var titulo = document.getElementById('notifModalTitulo');
    if (d.count > 0) {
      badge.style.display = 'flex'; badge.textContent = d.count;
      sino.classList.add('tem-pend');
      titulo.textContent = 'Você tem ' + d.count + ' pendência' + (d.count>1?'s':'') + ' para resolver';
    } else {
      badge.style.display = 'none';
      sino.classList.remove('tem-pend');
      titulo.textContent = 'Sem pendências';
    }
    if (!d.itens || !d.itens.length) {
      body.innerHTML = '<div class="notif-vazio">Você não tem pendências no momento.</div>';
      return;
    }
    var html = '';
    d.itens.forEach(function(it){
      html += '<a class="notif-item" href="/projetos/'+it.id+'">'
        + '<div class="notif-item-ico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="9"/></svg></div>'
        + '<div><div class="notif-item-nome">'+ (it.nome||'Proyecto') +'</div><div class="notif-item-motivo">'+ (it.motivo||'') +'</div></div>'
        + '</a>';
    });
    body.innerHTML = html;
  }
  window.abrirNotifModal = function(){ document.getElementById('notifModalBg').classList.add('show'); };
  window.fecharNotifModal = function(){ document.getElementById('notifModalBg').classList.remove('show'); };
  document.getElementById('notifModalBg').addEventListener('click', function(e){ if(e.target===this) window.fecharNotifModal(); });

  var ultimoCount = -1;
  var primeiraVez = true;

  function checar(){
    fetch('/api/minhas-pendencias').then(function(r){return r.json();}).then(function(d){
      render(d);
      // Na primeira carga: abre o modal uma vez por sessão se houver pendência
      if (primeiraVez) {
        primeiraVez = false;
        if (d.count > 0 && !sessionStorage.getItem('notifVista')) {
          window.abrirNotifModal();
          sessionStorage.setItem('notifVista','1');
        }
      } else {
        // Enquanto trabalha: se CHEGOU uma pendência nova (count aumentou), avisa na hora
        if (d.count > ultimoCount && ultimoCount >= 0) {
          window.abrirNotifModal();
          // som/atenção: faz o sino piscar com destaque (já tem a classe tem-pend)
          try { document.title = '(' + d.count + ') ' + document.title.replace(/^\(\d+\)\s*/, ''); } catch(e){}
        }
      }
      ultimoCount = d.count;
    }).catch(function(){});
  }

  checar();                       // verifica ao abrir
  setInterval(checar, 45000);     // e a cada 45 segundos enquanto está logado
})();
</script>
