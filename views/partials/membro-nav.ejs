<div style="background:#0C231B;padding:0 16px;height:56px;display:flex;align-items:center;justify-content:space-between">
  <div style="display:flex;align-items:center;gap:10px">
    <img src="/img/logo-lauro.png" style="width:32px;height:32px;border-radius:50%;object-fit:cover" onerror="this.style.display='none'">
    <span style="color:#fff;font-size:14px;font-weight:500">LAURO — Portal do Membro</span>
  </div>
  <div style="display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.7);font-size:13px">
    <span><%=membro.nome.split(' ')[0]%></span>
    <a href="/membro/logout" style="color:#4ade80;text-decoration:none;font-size:12px;border:1px solid #1a3d2e;padding:4px 10px">Sair</a>
  </div>
</div>
<nav style="background:#fff;border-bottom:0.5px solid #E5EBE8;overflow-x:auto;white-space:nowrap">
  <a href="/membro/dashboard" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='dashboard'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='dashboard'?'#0F6E56':'transparent'%>">Inicio</a>
  <a href="/membro/financeiro" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='financeiro'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='financeiro'?'#0F6E56':'transparent'%>">Financeiro</a>
  <a href="/membro/frequencia" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='frequencia'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='frequencia'?'#0F6E56':'transparent'%>">Frequencia</a>
  <a href="/membro/eventos" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='eventos'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='eventos'?'#0F6E56':'transparent'%>">Eventos</a>
  <a href="/membro/agenda" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='agenda'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='agenda'?'#0F6E56':'transparent'%>">Agenda</a>
  <a href="/membro/materiais" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='materiais'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='materiais'?'#0F6E56':'transparent'%>">Materiais</a>
  <a href="/membro/comunicados" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:<%=paginaAtiva==='comunicados'?'#0F6E56':'#6B7A72'%>;text-decoration:none;border-bottom:2px solid <%=paginaAtiva==='comunicados'?'#0F6E56':'transparent'%>;position:relative">
    Comunicados
    <%if(locals.comunicadosNaoLidos && comunicadosNaoLidos>0){%>
    <span style="position:absolute;top:10px;right:2px;background:#ef4444;color:#fff;font-size:9px;font-weight:700;min-width:16px;height:16px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;padding:0 3px;animation:pisca 1.2s ease-in-out infinite"><%=comunicadosNaoLidos%></span>
    <%}%>
  </a>
  <%if(locals.grupos && grupos && grupos.length>0){%>
  <a href="https://cientifico.lauroucpcde.com" target="_blank" style="display:inline-block;padding:14px 16px;font-size:13px;font-weight:500;color:#6B7A72;text-decoration:none;border-bottom:2px solid transparent">Cientifico</a>
  <%}%>
</nav>
<style>@keyframes pisca{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.2)}}</style>
