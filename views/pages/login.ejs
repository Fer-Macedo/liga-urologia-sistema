<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — <%= config.org_nome || 'Liga Urologia' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>:root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }</style>
</head>
<body class="login-body">
  <div class="login-container">
    <div class="login-card">
      <div class="login-logo">
        <% if (config.org_logo) { %>
          <img src="<%= config.org_logo %>" alt="Logo" class="login-logo-img">
        <% } else { %>
          <div class="login-logo-icone">LU</div>
        <% } %>
        <h1 class="login-titulo"><%= config.org_nome || 'Liga Acadêmica de Urologia' %></h1>
        <p class="login-sub">Sistema de Gestão de Liga Acadêmica</p>
      </div>

      <% if (msg && msg.length > 0) { %>
        <div class="alerta alerta-ok">✅ <%= msg[0] %></div>
      <% } %>
      <% if (erro && erro.length > 0) { %>
        <div class="alerta alerta-erro">❌ <%= erro[0] %></div>
      <% } %>

      <form action="/login" method="POST" class="login-form">
        <div class="campo">
          <label class="label">E-mail</label>
          <input type="email" name="email" class="input" placeholder="seu@email.com.br" required autofocus>
        </div>
        <div class="campo">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
            <label class="label" style="margin:0">Senha</label>
            <a href="/recuperar-senha" style="font-size:12px;color:var(--cor-primaria);text-decoration:none">
              Esqueceu a senha?
            </a>
          </div>
          <input type="password" name="senha" class="input" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primario" style="width:100%;justify-content:center;padding:12px">
          Entrar no sistema
        </button>
      </form>
    </div>
  </div>
</body>
</html>
