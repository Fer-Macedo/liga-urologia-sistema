<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — <%= config.org_nome || 'Liga Urologia' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root { --cor: <%= config.org_cor || '#1a56db' %>; }

    body {
      font-family: 'Outfit', system-ui, sans-serif;
      background: #f1f5f9;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    /* CARD CENTRAL */
    .card {
      background: white;
      border-radius: 20px;
      padding: 48px 44px;
      width: 100%;
      max-width: 420px;
      box-shadow:
        0 1px 3px rgba(0,0,0,.06),
        0 8px 32px rgba(0,0,0,.08),
        0 24px 64px rgba(0,0,0,.05);
      animation: slideUp .4s cubic-bezier(.16,1,.3,1) both;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* LOGO */
    .logo-area {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 32px;
    }

    .logo-box {
      width: 72px; height: 72px;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--cor), #1e3a8a);
      display: grid;
      place-items: center;
      margin-bottom: 16px;
      box-shadow: 0 6px 20px rgba(26,86,219,.25);
      overflow: hidden;
    }
    .logo-box img {
      width: 60px; height: 60px;
      object-fit: contain;
    }
    .logo-initials {
      font-size: 26px;
      font-weight: 800;
      color: white;
    }

    .org-nome {
      font-size: 17px;
      font-weight: 700;
      color: #0f172a;
      text-align: center;
      letter-spacing: -.01em;
      margin-bottom: 4px;
    }
    .org-sub {
      font-size: 13px;
      color: #94a3b8;
      text-align: center;
      font-weight: 400;
    }

    /* DIVISOR */
    .divisor {
      height: 1px;
      background: #f1f5f9;
      margin: 0 0 28px;
    }

    /* TÍTULO DO FORM */
    .form-titulo {
      font-size: 20px;
      font-weight: 700;
      color: #0f172a;
      margin-bottom: 4px;
      letter-spacing: -.01em;
    }
    .form-sub {
      font-size: 13px;
      color: #94a3b8;
      margin-bottom: 24px;
    }

    /* ALERTAS */
    .alerta {
      border-radius: 10px;
      padding: 11px 14px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .alerta-ok   { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .alerta-erro { background: #fff1f2; color: #be123c; border: 1px solid #fecdd3; }

    /* CAMPOS */
    .campo { margin-bottom: 18px; }

    .label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 7px;
    }

    .input-wrap { position: relative; }

    .input-icon {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      color: #cbd5e1;
      pointer-events: none;
    }

    .input {
      width: 100%;
      padding: 12px 14px 12px 40px;
      background: #f8fafc;
      border: 1.5px solid #e2e8f0;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      color: #0f172a;
      outline: none;
      transition: all .2s ease;
    }
    .input::placeholder { color: #cbd5e1; }
    .input:focus {
      background: white;
      border-color: var(--cor);
      box-shadow: 0 0 0 3px rgba(26,86,219,.10);
    }

    .toggle-senha {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      font-size: 15px;
      color: #cbd5e1;
      padding: 0;
      line-height: 1;
      transition: color .15s;
    }
    .toggle-senha:hover { color: #64748b; }

    .campo-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 7px;
    }
    .link-esqueceu {
      font-size: 12.5px;
      color: var(--cor);
      text-decoration: none;
      font-weight: 500;
    }
    .link-esqueceu:hover { text-decoration: underline; }

    /* BOTÃO */
    .btn-login {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #1a56db, #1e3a8a);
      color: white;
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      font-weight: 700;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all .2s ease;
      box-shadow: 0 4px 14px rgba(26,86,219,.3);
      margin-top: 4px;
      position: relative;
      overflow: hidden;
    }
    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 22px rgba(26,86,219,.4);
    }
    .btn-login:active { transform: translateY(0); }
    .btn-login.loading { pointer-events: none; opacity: .8; }
    .btn-login .btn-text { transition: opacity .2s; }
    .btn-login .spinner { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; }
    .btn-login.loading .btn-text { opacity: 0; }
    .btn-login.loading .spinner { display: flex; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner-ring {
      width: 20px; height: 20px;
      border: 2px solid rgba(255,255,255,.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    .rodape {
      margin-top: 28px;
      text-align: center;
      font-size: 12px;
      color: #cbd5e1;
    }
  </style>
</head>
<body>

  <div class="card">

    <!-- LOGO -->
    <div class="logo-area">
      <div class="logo-box">
        <% if (config.org_logo) { %>
          <img src="<%= config.org_logo %>" alt="Logo">
        <% } else { %>
          <span class="logo-initials">LU</span>
        <% } %>
      </div>
      <div class="org-nome"><%= config.org_nome || 'Liga Acadêmica de Urologia' %></div>
      <div class="org-sub">Sistema de Gestão Interno</div>
    </div>

    <div class="divisor"></div>

    <div class="form-titulo">Entrar na sua conta</div>
    <div class="form-sub">Preencha suas credenciais para acessar o painel.</div>

    <!-- ALERTAS -->
    <% if (msg && msg.length > 0) { %>
      <div class="alerta alerta-ok">✅ <%= msg[0] %></div>
    <% } %>
    <% if (erro && erro.length > 0) { %>
      <div class="alerta alerta-erro">❌ <%= erro[0] %></div>
    <% } %>

    <!-- FORMULÁRIO -->
    <form action="/login" method="POST" id="form-login">
      <div class="campo">
        <label class="label">E-mail</label>
        <div class="input-wrap">
          <span class="input-icon">✉️</span>
          <input type="email" name="email" class="input"
            placeholder="seu@email.com" required autofocus>
        </div>
      </div>

      <div class="campo">
        <div class="campo-row">
          <label class="label" style="margin:0">Senha</label>
          <a href="/recuperar-senha" class="link-esqueceu">Esqueceu a senha?</a>
        </div>
        <div class="input-wrap">
          <span class="input-icon">🔒</span>
          <input type="password" name="senha" class="input" id="campo-senha"
            placeholder="••••••••" required>
          <button type="button" class="toggle-senha" id="toggle-senha">👁️</button>
        </div>
      </div>

      <button type="submit" class="btn-login" id="btn-entrar">
        <span class="btn-text">Entrar no sistema →</span>
        <span class="spinner"><div class="spinner-ring"></div></span>
      </button>
    </form>

    <div class="rodape"><%= config.org_nome || 'LAURO' %> · Painel Interno</div>
  </div>

  <script>
    document.getElementById('toggle-senha').addEventListener('click', function() {
      const input = document.getElementById('campo-senha');
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      this.textContent = isText ? '👁️' : '🙈';
    });
    document.getElementById('form-login').addEventListener('submit', function() {
      document.getElementById('btn-entrar').classList.add('loading');
    });
  </script>
</body>
</html>
