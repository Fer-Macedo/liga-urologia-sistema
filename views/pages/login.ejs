<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — <%= config.org_nome || 'Liga Urologia' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cor: <%= config.org_cor || '#1a56db' %>;
    }

    body {
      font-family: 'Outfit', system-ui, sans-serif;
      background: #f0f4ff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* LAYOUT SPLIT */
    .login-wrap {
      display: flex;
      width: 100%;
      min-height: 100vh;
    }

    /* PAINEL ESQUERDO — decorativo */
    .painel-esq {
      flex: 1;
      background: linear-gradient(145deg, #1a56db 0%, #1e3a8a 60%, #0f2460 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 48px;
      position: relative;
      overflow: hidden;
    }

    .painel-esq::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: rgba(255,255,255,.05);
      top: -150px; right: -150px;
    }
    .painel-esq::after {
      content: '';
      position: absolute;
      width: 320px; height: 320px;
      border-radius: 50%;
      background: rgba(255,255,255,.04);
      bottom: -80px; left: -80px;
    }

    .painel-esq-content {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 380px;
    }

    .logo-wrap-esq {
      width: 88px; height: 88px;
      border-radius: 24px;
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.2);
      display: grid;
      place-items: center;
      margin: 0 auto 28px;
      backdrop-filter: blur(8px);
      overflow: hidden;
    }
    .logo-wrap-esq img {
      width: 72px; height: 72px;
      object-fit: contain;
    }
    .logo-initials {
      font-size: 30px;
      font-weight: 800;
      color: white;
    }

    .painel-titulo {
      font-size: 26px;
      font-weight: 800;
      color: white;
      line-height: 1.2;
      margin-bottom: 12px;
      letter-spacing: -.02em;
    }
    .painel-sub {
      font-size: 14px;
      color: rgba(255,255,255,.6);
      font-weight: 400;
      line-height: 1.6;
    }

    .painel-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-top: 32px;
    }
    .badge {
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.15);
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 600;
      color: rgba(255,255,255,.8);
    }

    /* PAINEL DIREITO — formulário */
    .painel-dir {
      width: 480px;
      background: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 48px;
    }

    .form-wrap {
      width: 100%;
      max-width: 360px;
    }

    .form-titulo {
      font-size: 24px;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: 6px;
      letter-spacing: -.02em;
    }
    .form-sub {
      font-size: 14px;
      color: #64748b;
      margin-bottom: 32px;
      font-weight: 400;
    }

    /* ALERTAS */
    .alerta {
      border-radius: 10px;
      padding: 11px 14px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .alerta-ok   { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .alerta-erro { background: #fff1f2; color: #be123c; border: 1px solid #fecdd3; }

    /* CAMPOS */
    .campo { margin-bottom: 20px; }

    .label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 7px;
    }

    .input-wrap { position: relative; }

    .input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      color: #94a3b8;
      pointer-events: none;
    }

    .input {
      width: 100%;
      padding: 12px 14px 12px 42px;
      background: #f8fafc;
      border: 1.5px solid #e2e8f0;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      color: #0f172a;
      outline: none;
      transition: all .2s ease;
    }
    .input::placeholder { color: #cbd5e1; }
    .input:focus {
      background: white;
      border-color: var(--cor);
      box-shadow: 0 0 0 3px rgba(26,86,219,.12);
    }

    .toggle-senha {
      position: absolute;
      right: 13px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      font-size: 15px;
      color: #94a3b8;
      padding: 0;
      line-height: 1;
      transition: color .15s;
    }
    .toggle-senha:hover { color: #475569; }

    .campo-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 7px;
    }
    .link-esqueceu {
      font-size: 12.5px;
      color: var(--cor);
      text-decoration: none;
      font-weight: 500;
    }
    .link-esqueceu:hover { text-decoration: underline; }

    /* BOTÃO */
    .btn-login {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #1a56db, #1e3a8a);
      color: white;
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      font-weight: 700;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all .2s ease;
      box-shadow: 0 4px 14px rgba(26,86,219,.35);
      margin-top: 4px;
      position: relative;
      overflow: hidden;
      letter-spacing: .01em;
    }
    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 22px rgba(26,86,219,.45);
    }
    .btn-login:active { transform: translateY(0); }
    .btn-login.loading { pointer-events: none; opacity: .8; }
    .btn-login .btn-text { transition: opacity .2s; }
    .btn-login .spinner { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; }
    .btn-login.loading .btn-text { opacity: 0; }
    .btn-login.loading .spinner { display: flex; }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner-ring {
      width: 20px; height: 20px;
      border: 2px solid rgba(255,255,255,.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    .rodape {
      margin-top: 32px;
      text-align: center;
      font-size: 12px;
      color: #cbd5e1;
    }

    /* RESPONSIVO */
    @media (max-width: 768px) {
      .painel-esq { display: none; }
      .painel-dir { width: 100%; padding: 40px 24px; }
    }
  </style>
</head>
<body>

<div class="login-wrap">

  <!-- ESQUERDA -->
  <div class="painel-esq">
    <div class="painel-esq-content">
      <div class="logo-wrap-esq">
        <% if (config.org_logo) { %>
          <img src="<%= config.org_logo %>" alt="Logo">
        <% } else { %>
          <span class="logo-initials">LU</span>
        <% } %>
      </div>
      <div class="painel-titulo"><%= config.org_nome || 'Liga Acadêmica de Urologia' %></div>
      <div class="painel-sub">Plataforma de gestão interna para ligantes, diretivos, cobranças e eventos.</div>
      <div class="painel-badges">
        <span class="badge">🎓 Ligantes</span>
        <span class="badge">👥 Diretivos</span>
        <span class="badge">💰 Cobranças</span>
        <span class="badge">📅 Eventos</span>
        <span class="badge">📊 Relatórios</span>
      </div>
    </div>
  </div>

  <!-- DIREITA -->
  <div class="painel-dir">
    <div class="form-wrap">
      <div class="form-titulo">Bem-vindo de volta 👋</div>
      <div class="form-sub">Acesse com suas credenciais para continuar.</div>

      <% if (msg && msg.length > 0) { %>
        <div class="alerta alerta-ok">✅ <%= msg[0] %></div>
      <% } %>
      <% if (erro && erro.length > 0) { %>
        <div class="alerta alerta-erro">❌ <%= erro[0] %></div>
      <% } %>

      <form action="/login" method="POST" id="form-login">
        <div class="campo">
          <label class="label">E-mail</label>
          <div class="input-wrap">
            <span class="input-icon">✉️</span>
            <input type="email" name="email" class="input"
              placeholder="seu@email.com" required autofocus>
          </div>
        </div>

        <div class="campo">
          <div class="campo-row">
            <label class="label" style="margin:0">Senha</label>
            <a href="/recuperar-senha" class="link-esqueceu">Esqueceu a senha?</a>
          </div>
          <div class="input-wrap">
            <span class="input-icon">🔒</span>
            <input type="password" name="senha" class="input" id="campo-senha"
              placeholder="••••••••" required>
            <button type="button" class="toggle-senha" id="toggle-senha">👁️</button>
          </div>
        </div>

        <button type="submit" class="btn-login" id="btn-entrar">
          <span class="btn-text">Entrar no sistema →</span>
          <span class="spinner"><div class="spinner-ring"></div></span>
        </button>
      </form>

      <div class="rodape"><%= config.org_nome || 'LAURO' %> · Painel Interno</div>
    </div>
  </div>

</div>

<script>
  document.getElementById('toggle-senha').addEventListener('click', function() {
    const input = document.getElementById('campo-senha');
    const isText = input.type === 'text';
    input.type = isText ? 'password' : 'text';
    this.textContent = isText ? '👁️' : '🙈';
  });
  document.getElementById('form-login').addEventListener('submit', function() {
    document.getElementById('btn-entrar').classList.add('loading');
  });
</script>
</body>
</html>
