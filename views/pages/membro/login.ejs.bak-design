<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portal do Membro — LAURO</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',sans-serif;background:#0C231B;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.box{background:#fff;width:100%;max-width:420px;padding:40px}
.logo{text-align:center;margin-bottom:28px}
.logo img{width:80px;margin-bottom:12px}
.logo h1{font-size:20px;font-weight:700;color:#0C231B}
.logo p{font-size:12px;color:#6B7A72;text-transform:uppercase;letter-spacing:1px;margin-top:4px}
label{display:block;font-size:12px;font-weight:600;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
input{width:100%;padding:10px 12px;border:1px solid #DDE3DF;font-size:14px;font-family:inherit;outline:none;margin-bottom:16px}
input:focus{border-color:#0F6E56}
.btn{width:100%;padding:12px;background:#0F6E56;color:#fff;border:none;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:.5px}
.btn:hover{background:#0C5C47}
.erro{background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;padding:10px 14px;font-size:13px;margin-bottom:16px}
.esqueci{text-align:center;margin-top:16px;font-size:13px;color:#6B7A72}
.esqueci a{color:#0F6E56;text-decoration:none}
.rodape{text-align:center;margin-top:32px;font-size:11px;color:rgba(255,255,255,.4)}
</style>
</head>
<body>
<div>
  <div class="box">
    <div class="logo">
      <img src="/img/logo-lauro.png" alt="LAURO" style="width:90px;height:90px;border-radius:50%;object-fit:cover;border:3px solid #0F6E56" onerror="this.style.display='none'">
      <h1>LAURO - Liga Acadêmica de Urologia</h1>
      <p>Portal do Membro</p>
    </div>
    <%if(locals.erro){%><div class="erro"><%=erro%></div><%}%>
    <%if(locals.msg){%><div style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;padding:10px 14px;font-size:13px;margin-bottom:16px"><%=locals.msg%></div><%}%>
    <form method="POST" action="/membro/login">
      <label>Email</label>
      <input type="email" name="email" placeholder="seu@email.com" required autofocus>
      <label>Senha</label>
      <input type="password" name="senha" placeholder="Sua senha" required>
      <button type="submit" class="btn">Entrar</button>
    </form>
    <div class="esqueci"><a href="/membro/esqueci-senha">Esqueci minha senha</a></div>
  </div>
  <div class="rodape">Acesso exclusivo para membros da liga</div>
</div>
</body>
</html>
