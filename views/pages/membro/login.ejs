<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Iniciar sesión — Portal do Membro LAURO</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--v:#0C231B;--vm:#0F6E56;--vl:#E8F5F0;--bg:#F4F6F5;--card:#fff;--brd:#E5EBE8;--t:#0C231B;--ts:#6B7A72;--ti:#A0ADA8;--ff:'Plus Jakarta Sans',system-ui,sans-serif}
html,body{height:100%;font-family:var(--ff)}
body{display:flex;min-height:100vh;background:var(--v)}
.left{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:60px 64px;position:relative;overflow:hidden;min-height:100vh}
.left-bg{position:absolute;inset:0;background:linear-gradient(145deg,#0d2a1b,#0C231B 55%,#071610);z-index:0}
.left-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:48px 48px;z-index:1}
.left-orb{position:absolute;width:480px;height:480px;top:-80px;right:-100px;background:radial-gradient(circle,rgba(15,110,86,.3),transparent 65%);z-index:2;pointer-events:none;animation:orb 8s ease-in-out infinite}
.left-orb2{position:absolute;width:320px;height:320px;bottom:-60px;left:-60px;background:radial-gradient(circle,rgba(15,110,86,.15),transparent 65%);z-index:2;pointer-events:none;animation:orb 6s ease-in-out infinite reverse}
@keyframes orb{0%,100%{transform:translate(0,0)}50%{transform:translate(20px,-20px)}}
.left-content{position:relative;z-index:3;max-width:440px}
.left-logo{display:flex;align-items:center;gap:14px;margin-bottom:48px}
.left-logo img{width:52px;height:52px;border-radius:50%;object-fit:contain}
.left-logo-fb{width:52px;height:52px;border-radius:50%;background:var(--vm);display:none;align-items:center;justify-content:center;font-weight:800;font-size:20px;color:#fff}
.left-logo-text strong{font-size:20px;font-weight:800;color:#fff;letter-spacing:.06em;display:block}
.left-logo-text span{font-size:11px;color:rgba(255,255,255,.45);letter-spacing:.06em;text-transform:uppercase}
.left-title{font-size:clamp(28px,3.5vw,40px);font-weight:800;color:#fff;line-height:1.1;margin-bottom:16px;letter-spacing:-.02em}
.left-title em{color:var(--vm);font-style:normal}
.left-sub{font-size:14px;color:rgba(255,255,255,.55);line-height:1.65;margin-bottom:40px;max-width:360px}
.left-features{display:flex;flex-direction:column;gap:12px}
.feat{display:flex;align-items:center;gap:12px}
.feat-icon{width:34px;height:34px;background:rgba(15,110,86,.2);border:1px solid rgba(15,110,86,.3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.feat-icon svg{width:16px;height:16px;color:#4ade80}
.feat-text{font-size:13px;color:rgba(255,255,255,.65)}
.feat-text strong{color:rgba(255,255,255,.9);font-weight:600;display:block}
.left-footer{position:absolute;bottom:28px;left:64px;right:64px;z-index:3;display:flex;align-items:center;justify-content:space-between}
.left-footer-logo img{height:20px;opacity:.3;filter:brightness(0) invert(1);object-fit:contain}
.left-footer-text{font-size:10.5px;color:rgba(255,255,255,.25)}
.right{width:420px;flex-shrink:0;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px 44px;background:var(--bg);min-height:100vh;position:relative}
.form-wrap{width:100%;max-width:340px}
.form-title{font-size:22px;font-weight:800;color:var(--t);margin-bottom:6px}
.form-sub{font-size:13px;color:var(--ts);margin-bottom:32px}
.form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
.form-label{font-size:11.5px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em}
.form-input{background:var(--card);border:1.5px solid var(--brd);padding:11px 14px;font-family:var(--ff);font-size:14px;color:var(--t);transition:border-color .2s,box-shadow .2s;outline:none;width:100%}
.form-input:focus{border-color:var(--vm);box-shadow:0 0 0 3px rgba(15,110,86,.1)}
.form-input::placeholder{color:var(--ti)}
.form-pw-wrap{position:relative}
.form-pw-wrap .form-input{padding-right:44px}
.pw-toggle{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--ti);padding:4px;display:flex}
.pw-toggle svg{width:16px;height:16px}
.form-footer{display:flex;justify-content:flex-end;margin-bottom:20px}
.form-link{font-size:12.5px;color:var(--vm);text-decoration:none;font-weight:600}
.btn-login{width:100%;background:var(--v);color:#fff;border:none;font-family:var(--ff);font-size:14px;font-weight:700;padding:13px;cursor:pointer;transition:background .2s,transform .15s;letter-spacing:.02em;margin-bottom:20px;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-login:hover{background:var(--vm);transform:translateY(-1px)}
.btn-login svg{width:16px;height:16px}
.divider{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--brd)}
.divider span{font-size:11px;color:var(--ti);white-space:nowrap}
.btn-cientifico{width:100%;background:var(--card);color:var(--vm);border:1.5px solid var(--vm);font-family:var(--ff);font-size:13px;font-weight:600;padding:11px;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none}
.btn-cientifico:hover{background:var(--vl)}
.btn-cientifico svg{width:14px;height:14px}
.form-help{font-size:12px;color:var(--ti);text-align:center;margin-top:28px;line-height:1.6}
.form-help a{color:var(--vm);text-decoration:none;font-weight:600}
.right-footer{position:absolute;bottom:20px;left:0;right:0;text-align:center;font-size:11px;color:var(--ti)}
.login-error{background:#FEF2F2;border:1px solid #FECACA;padding:10px 14px;font-size:13px;color:#B91C1C;margin-bottom:16px}
.login-success{background:#F0FDF4;border:1px solid #BBF7D0;padding:10px 14px;font-size:13px;color:#166534;margin-bottom:16px}
@media(max-width:820px){body{flex-direction:column}.left{min-height:auto;padding:40px 28px 32px;justify-content:flex-start}.left-footer{display:none}.left-features{display:none}.left-sub{margin-bottom:0}.right{width:100%;padding:32px 24px 60px}.left-title{font-size:26px}}
@media(max-width:480px){.left{padding:28px 20px 24px}.right{padding:24px 16px 48px}}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="left">
  <div class="left-bg"></div>
  <div class="left-grid"></div>
  <div class="left-orb"></div>
  <div class="left-orb2"></div>
  <div class="left-content">
    <div class="left-logo">
      <img src="/img/logo-lauro.png" alt="LAURO" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
      <div class="left-logo-fb">L</div>
      <div class="left-logo-text">
        <strong>LAURO</strong>
        <span>Liga Académica de Urología</span>
      </div>
    </div>
    <h1 class="left-title">Portal del<br><em>Miembro</em></h1>
    <p class="left-sub">Accede a tu área exclusiva: frecuencia, financiero, materiales, agenda y comunicados — todo en un solo lugar.</p>
    <div class="left-features">
      <div class="feat">
        <div class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div>
        <div class="feat-text"><strong>Frecuencia en tiempo real</strong>Acompañá tu asistencia en todas las actividades</div>
      </div>
      <div class="feat">
        <div class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14"/><path d="M2 10h20"/></svg></div>
        <div class="feat-text"><strong>Financiero: PIX y tarjeta</strong>Cuotas con código PIX o pago con tarjeta integrado</div>
      </div>
      <div class="feat">
        <div class="feat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></div>
        <div class="feat-text"><strong>Agenda y comunicados</strong>Calendario completo con eventos y comunicados de la liga</div>
      </div>
    </div>
  </div>
  <div class="left-footer">
    <div class="left-footer-logo">
      <img src="/img/logo-ucp.png" alt="UCP">
    </div>
    <span class="left-footer-text">Universidad Central del Paraguay · Ciudad del Este · © <%= new Date().getFullYear() %></span>
  </div>
</div>

<div class="right">
  <div class="form-wrap">
    <div class="form-title">Iniciar sesión</div>
    <div class="form-sub">Usá tus credenciales registradas en LAURO</div>

    <% if(locals.erro){ %>
    <div class="login-error">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-right:5px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%=erro%>
    </div>
    <% } %>
    <% if(locals.msg && msg.length){ %>
    <div class="login-success"><%=msg[0]%></div>
    <% } %>

    <form method="POST" action="/membro/login">
      <div class="form-group">
        <label class="form-label">Correo electrónico</label>
        <input class="form-input" type="email" name="email" placeholder="tu@correo.com" autocomplete="username" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Contraseña</label>
        <div class="form-pw-wrap">
          <input class="form-input" type="password" name="senha" placeholder="Tu contraseña" autocomplete="current-password" required id="senhaInp">
          <button type="button" class="pw-toggle" id="pwToggle">
            <svg id="pwEye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>
      <div class="form-footer">
        <a href="/membro/esqueci-senha" class="form-link">Olvidé mi contraseña</a>
      </div>
      <button type="submit" class="btn-login" id="loginBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
        Ingresar al portal
      </button>
    </form>

    <div class="divider"><span>o accedé por</span></div>
    <a href="/portal/login" class="btn-cientifico">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
      Portal Científico
    </a>

    <p class="form-help">
      ¿Problemas para acceder? Contactanos por<br>
      <a href="https://wa.me/595994868368" target="_blank">WhatsApp</a> ou por <a href="mailto:lauroucpcde@lauroucpcde.com">correo electrónico</a>
    </p>
  </div>
  <div class="right-footer">Universidad Central del Paraguay · Ciudad del Este · © <%= new Date().getFullYear() %></div>
</div>

<script>
document.getElementById('pwToggle').addEventListener('click', function(){
  var inp = document.getElementById('senhaInp');
  var ico = document.getElementById('pwEye');
  if(inp.type==='password'){
    inp.type='text';
    ico.innerHTML='<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
  } else {
    inp.type='password';
    ico.innerHTML='<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  }
});
document.querySelector('form').addEventListener('submit', function(){
  var btn = document.getElementById('loginBtn');
  btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="animation:spin .7s linear infinite"><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-dasharray="30" stroke-dashoffset="10"/></svg> Verificando...';
  btn.disabled = true;
});
</script>
</body>
</html>
