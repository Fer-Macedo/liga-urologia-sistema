<div class="mob-ov" id="mobOv"></div>

<script>
const TITLES = {dashboard:'Inicio',financeiro:'Financeiro',frequencia:'Frequencia',materiais:'Materiais',agenda:'Agenda',eventos:'Eventos',comunicados:'Comunicados',perfil:'Meu Perfil',estatuto:'Estatuto',regulamento:'Regulamento',contrato:'Contrato'};
const SUBS = {dashboard:'Bem-vindo, <%=membro.nome.split(" ")[0]%>',financeiro:'Historico de cobrancas',frequencia:'Sua presenca nas atividades',materiais:'Documentos e videos da Liga',agenda:'Calendario de atividades',eventos:'Proximos eventos',comunicados:'Avisos da Liga',perfil:'Seus dados cadastrais',estatuto:'Documento oficial da Liga',regulamento:'Normas e regras da Liga',contrato:'Seu contrato com a Liga'};

var matLoaded = false;
var evLoaded = false;

function renderEventos(eventos) {
  var wrap = document.getElementById('ev-conteudo');
  if(!wrap) return;
  var MESES = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  var MESES_FULL = ['Janeiro','Fevereiro','Marco','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  if(!eventos || eventos.length === 0) {
    wrap.innerHTML = '<div class="card" style="padding:32px;text-align:center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36" style="margin:0 auto 10px;display:block;opacity:.3"><rect x="3" y="4" width="18" height="18"/><path d="M16 2v4M8 2v4M3 10h18"/></svg><div style="font-weight:700;margin-bottom:4px">Nenhum evento cadastrado</div><div style="font-size:12px;color:var(--ts)">Em breve novos eventos serao anunciados</div></div>';
    return;
  }
  var agora = new Date();
  var proximos = eventos.filter(function(e){ return new Date(e.data_inicio) >= agora; });
  var anteriores = eventos.filter(function(e){ return new Date(e.data_inicio) < agora; });
  var html = '';
  if(proximos.length) {
    html += '<div style="font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">Proximos</div>';
    proximos.forEach(function(ev){
      var dt = new Date(ev.data_inicio);
      var isPub = ev.status === 'publicado';
      html += '<div class="ev" style="margin-bottom:12px;border-left:4px solid var(--vm)">'
        + '<div class="ev-dt" style="background:var(--vm)"><div class="ev-dy">'+dt.getDate()+'</div><div class="ev-mo">'+MESES[dt.getMonth()]+'</div></div>'
        + '<div style="flex:1;min-width:0">'
        + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;flex-wrap:wrap;gap:6px">'
        + '<div class="ev-nm">'+ev.nome+'</div>'
        + '<span style="font-size:10px;font-weight:700;padding:2px 8px;background:'+(isPub?'var(--okb)':'var(--bg)')+';color:'+(isPub?'var(--ok)':'var(--ts)')+'">'+((ev.status||'agendado').toUpperCase())+'</span>'
        + '</div>'
        + (ev.local ? '<div class="ev-mi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>'+ev.local+'</div>' : '')
        + '<div class="ev-mi" style="margin-top:4px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>'+dt.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})+'</div>'
        + (ev.descricao ? '<div style="font-size:12px;color:var(--ts);margin-top:8px;line-height:1.5">'+ev.descricao.substring(0,120)+'...</div>' : '')
        + '</div></div>';
    });
  }
  if(anteriores.length) {
    html += '<div style="font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em;margin:20px 0 12px">Eventos anteriores</div>';
    anteriores.forEach(function(ev){
      var dt = new Date(ev.data_inicio);
      html += '<div class="ev" style="margin-bottom:12px;opacity:.7">'
        + '<div class="ev-dt" style="background:var(--ts)"><div class="ev-dy">'+dt.getDate()+'</div><div class="ev-mo">'+MESES[dt.getMonth()]+'</div></div>'
        + '<div style="flex:1;min-width:0">'
        + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;flex-wrap:wrap;gap:6px">'
        + '<div class="ev-nm">'+ev.nome+'</div>'
        + '<span style="font-size:10px;font-weight:700;padding:2px 8px;background:var(--bg);color:var(--ts)">ENCERRADO</span>'
        + '</div>'
        + (ev.local ? '<div class="ev-mi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>'+ev.local+'</div>' : '')
        + '</div></div>';
    });
  }
  wrap.innerHTML = html;
}

function renderMateriais(materiais) {
  var wrap = document.getElementById('mat-conteudo');
  if(!wrap) return;
  if(!materiais || materiais.length === 0) {
    wrap.innerHTML = '<div class="card" style="padding:32px;text-align:center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="36" height="36" style="margin:0 auto 10px;display:block;opacity:.3"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><div style="font-weight:700;margin-bottom:4px">Nenhum material disponivel</div><div style="font-size:12px;color:var(--ts)">Em breve novos materiais serao adicionados</div></div>';
    return;
  }
  var cats = {};
  materiais.forEach(function(m){ var c=m.categoria||'Geral'; if(!cats[c]) cats[c]=[]; cats[c].push(m); });
  var html = '';
  Object.keys(cats).forEach(function(cat){
    html += '<div style="margin-bottom:24px"><div style="font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;padding-bottom:8px;border-bottom:2px solid var(--brd)">'+cat+'</div>';
    html += '<div class="mat-grid">';
    cats[cat].forEach(function(m){
      var isPdf = m.arquivo_tipo && m.arquivo_tipo.includes('pdf');
      var isVideo = m.arquivo_tipo && m.arquivo_tipo.startsWith('video/');
      var isImg = m.arquivo_tipo && m.arquivo_tipo.startsWith('image/');
      var ico = isPdf
        ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>'
        : isVideo
        ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>'
        : isImg
        ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>'
        : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>';
      html += '<div class="mat-card"><div style="display:flex;gap:10px;align-items:flex-start"><div class="mat-icone">'+ico+'</div><div class="mat-info"><div class="mat-titulo">'+m.titulo+'</div>'+(m.descricao?'<div class="mat-desc">'+m.descricao+'</div>':'')+'</div></div>';
      if(m.arquivo_chave) {
        var tipoSafe = (m.arquivo_tipo||'').split('"').join('');
        html += '<div class="mat-acoes"><button data-mid="'+m.id+'" data-mtipo="'+tipoSafe+'" class="btn btn-v btn-mat-ver" style="font-size:12px;flex:1;justify-content:center">'+(isVideo?'Assistir':'Visualizar')+'</button>';
        if(m.permite_download) html += '<a href="/membro/materiais/'+m.id+'/arquivo?download=1" class="btn" style="font-size:12px">Baixar</a>';
        html += '</div>';
      }
      html += '</div>';
    });
    html += '</div></div>';
  });
  wrap.innerHTML = html;
}

function go(id) {
  document.querySelectorAll('.sc').forEach(s => s.classList.remove('act'));
  document.querySelectorAll('.ni').forEach(n => n.classList.remove('act'));
  const sc = document.getElementById('sc-'+id);
  if(sc) sc.classList.add('act');
  const ni = document.getElementById('ni-'+id);
  if(ni) ni.classList.add('act');
  document.getElementById('tbTit').textContent = TITLES[id]||id;
  document.getElementById('tbSub').textContent = SUBS[id]||'';
  closeMob();
  if(id === 'agenda') {
    setTimeout(function(){ if(!calAgData) loadAgenda(); }, 50);
  }
  if(id === 'perfil') loadPerfil();
  if(id === 'financeiro') loadFinanceiro();
  if(id === 'estatuto') loadEstatuto();
  if(id === 'regulamento') loadRegulamento();
  if(id === 'contrato') loadContrato();
  if(id === 'eventos' && !evLoaded) {
    evLoaded = true;
    var wrap = document.getElementById('ev-conteudo');
    if(wrap) wrap.innerHTML = '<div style="text-align:center;padding:32px;color:var(--ti);font-size:13px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="animation:spin .7s linear infinite;margin:0 auto 8px;display:block"><circle cx="12" cy="12" r="10" stroke-dasharray="30" stroke-dashoffset="10"/></svg>Carregando...</div>';
    fetch('/membro/eventos/dados', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){ renderEventos(data.eventos); })
      .catch(function(){ if(wrap) wrap.innerHTML = '<div style="padding:20px;text-align:center;color:var(--er)">Erro ao carregar</div>'; });
  }
  if(id === 'materiais' && !matLoaded) {
    matLoaded = true;
    var wrap = document.getElementById('mat-conteudo');
    if(wrap) wrap.innerHTML = '<div style="text-align:center;padding:32px;color:var(--ti);font-size:13px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" style="animation:spin .7s linear infinite;margin:0 auto 8px;display:block"><circle cx="12" cy="12" r="10" stroke-dasharray="30" stroke-dashoffset="10"/></svg>Carregando...</div>';
    fetch('/membro/materiais/dados', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){ renderMateriais(data.materiais); })
      .catch(function(){ if(wrap) wrap.innerHTML = '<div style="padding:20px;text-align:center;color:var(--er)">Erro ao carregar materiais</div>'; });
  }
}

// Nav items
document.querySelectorAll('.ni[data-sc]').forEach(function(btn){
  btn.addEventListener('click', function(){ go(this.dataset.sc); });
});

// Card shortcuts
document.getElementById('card-freq') && document.getElementById('card-freq').addEventListener('click', function(){ go('frequencia'); });
document.getElementById('card-com') && document.getElementById('card-com').addEventListener('click', function(){ go('comunicados'); });
document.getElementById('card-ev') && document.getElementById('card-ev').addEventListener('click', function(){ go('eventos'); });
document.getElementById('card-ev2') && document.getElementById('card-ev2').addEventListener('click', function(){ go('eventos'); });

// Comunicados no dashboard
document.querySelectorAll('[data-sc="comunicados"]').forEach(function(el){
  el.addEventListener('click', function(){ go('comunicados'); });
});

// Comunicados accordion
document.querySelectorAll('.cm').forEach(function(el){
  el.addEventListener('click', function(){ this.classList.toggle('open'); });
});

// SIDEBAR
let sbCol = false;
function toggleSb() { sbCol=!sbCol; document.getElementById('sb').classList.toggle('col',sbCol); }
function openMob() { document.getElementById('sb').classList.add('mob-open'); document.getElementById('mobOv').classList.add('open'); }
function closeMob() { document.getElementById('sb').classList.remove('mob-open'); document.getElementById('mobOv').classList.remove('open'); }
document.getElementById('sbTog').addEventListener('click', toggleSb);
document.getElementById('mobBtn').addEventListener('click', openMob);
document.getElementById('mobOv').addEventListener('click', closeMob);

// DARK MODE
let dark = localStorage.getItem('lauro-membro-dark')==='1';
function applyDark() {
  document.documentElement.classList.toggle('dark', dark);
  document.getElementById('dkIco').innerHTML = dark
    ? '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>'
    : '<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>';
}
document.getElementById('dkBtn').addEventListener('click', function(){ dark=!dark; localStorage.setItem('lauro-membro-dark',dark?'1':'0'); applyDark(); });
applyDark();

// PIX COPY
function copyPix(btnId, codeId) {
  var el = document.getElementById(codeId);
  if(!el) return;
  navigator.clipboard.writeText(el.textContent.trim()).then(function(){
    var btn = document.getElementById(btnId);
    var orig = btn.innerHTML;
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="20 6 9 17 4 12"/></svg> Copiado!';
    btn.style.background = '#047857';
    setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; }, 2500);
  });
}
document.getElementById('btnCopyPix') && document.getElementById('btnCopyPix').addEventListener('click', function(){ copyPix('btnCopyPix','pixCode'); });
document.getElementById('btnCopyPix2') && document.getElementById('btnCopyPix2').addEventListener('click', function(){ copyPix('btnCopyPix2','pixCode2'); });

// HISTORICO FREQUENCIA inline
var freqLoaded = false;
var btnFreqHist = document.getElementById('btn-freq-historico');
if(btnFreqHist) {
  btnFreqHist.addEventListener('click', function(){
    if(freqLoaded) {
      var wrap = document.getElementById('freq-historico-wrap');
      wrap.style.display = wrap.style.display === 'none' ? 'block' : 'none';
      btnFreqHist.querySelector('span') && (btnFreqHist.querySelector('span').textContent = wrap.style.display === 'none' ? 'Ver historico completo' : 'Ocultar historico');
      return;
    }
    btnFreqHist.disabled = true;
    btnFreqHist.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" style="animation:spin .7s linear infinite"><circle cx="12" cy="12" r="10" stroke-dasharray="30" stroke-dashoffset="10"/></svg> Carregando...';
    fetch('/membro/frequencia/dados', { credentials: 'same-origin' })
      .then(function(r){ return r.json(); })
      .then(function(data){
        freqLoaded = true;
        var wrap = document.getElementById('freq-historico-wrap');
        if(!data || !data.registros || data.registros.length === 0) {
          wrap.innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--ti)">Nenhum registro encontrado</div>';
        } else {
          var html = '<div class="card" style="padding:0;margin-bottom:12px">';
          data.registros.forEach(function(r){
            var pres = parseInt(r.presente) === 1;
            var d = new Date(r.data);
            var ds = d.toLocaleDateString("pt-BR",{weekday:"long",day:"2-digit",month:"long",year:"numeric"});
            html += '<div class="freq-item"><div><div class="freq-data">'+ds+'</div>'+(r.descricao?'<div class="freq-desc">'+r.descricao+'</div>':'')+'</div><span class="'+(pres?'presente':'ausente')+'">'+(pres?'Presente':'Ausente')+'</span></div>';
          });
          html += '</div>';
          wrap.innerHTML = html;
        }
        btnFreqHist.disabled = false;
        btnFreqHist.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><polyline points="18 15 12 9 6 15"/></svg> Ocultar historico';
      })
      .catch(function(){
        btnFreqHist.disabled = false;
        btnFreqHist.innerHTML = 'Erro ao carregar. Tentar novamente';
      });
  });
}

// DATA HOJE
var d = new Date();
var dias = ['Domingo','Segunda-feira','Terca-feira','Quarta-feira','Quinta-feira','Sexta-feira','Sabado'];
var meses = ['janeiro','fevereiro','marco','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
var dEl = document.getElementById('dataHoje');
if(dEl) dEl.textContent = dias[d.getDay()] + ', ' + d.getDate() + ' de ' + meses[d.getMonth()] + ' de ' + d.getFullYear();

// CALENDARIO AGENDA
var MONTHS_CAL = ['Janeiro','Fevereiro','Marco','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
var TODAY_CAL = new Date();
var calY = TODAY_CAL.getFullYear(), calM = TODAY_CAL.getMonth();
var calAgData = null;

function pad2(n){ return String(n).padStart(2,'0'); }

function renderCalendar() {
  var lbl = document.getElementById('calMonthLbl');
  var grid = document.getElementById('calGrid');
  if(!lbl||!grid) return;
  lbl.textContent = MONTHS_CAL[calM] + ' ' + calY;
  grid.querySelectorAll('.cal-cell').forEach(function(c){ c.remove(); });
  var firstDay = new Date(calY,calM,1).getDay();
  var daysInMonth = new Date(calY,calM+1,0).getDate();
  var daysInPrev = new Date(calY,calM,0).getDate();
  var mk = pad2(calM+1);
  var bdays = calAgData ? (calAgData.aniversariantes||[]) : [];
  var evMap = {};
  if(calAgData && calAgData.eventos) {
    calAgData.eventos.forEach(function(ev){
      var dk = ev.data_inicio ? ev.data_inicio.substring(0,10) : '';
      if(dk) { if(!evMap[dk]) evMap[dk]=[]; evMap[dk].push(ev); }
    });
  }
  for(var i=0;i<firstDay;i++){
    var d=document.createElement('div'); d.className='cal-cell off';
    d.innerHTML='<span class="cal-num">'+(daysInPrev-firstDay+i+1)+'</span>'; grid.appendChild(d);
  }
  for(var day=1;day<=daysInMonth;day++){
    var d=document.createElement('div');
    var dk=calY+'-'+pad2(calM+1)+'-'+pad2(day);
    var isToday=(calY===TODAY_CAL.getFullYear()&&calM===TODAY_CAL.getMonth()&&day===TODAY_CAL.getDate());
    d.className='cal-cell'+(isToday?' today':'');
    var inner='<span class="cal-num">'+day+'</span><div class="cal-chips">';
    (evMap[dk]||[]).forEach(function(ev){ inner+='<div class="cc-ev green">'+ev.titulo+'</div>'; });
    bdays.filter(function(b){ return b.data_nascimento && parseInt(b.data_nascimento.substring(8,10))===day; })
      .forEach(function(b){ inner+='<div class="cc-bd">'+b.nome.split(' ')[0]+'</div>'; });
    inner+='</div>'; d.innerHTML=inner; grid.appendChild(d);
  }
  var total=firstDay+daysInMonth;
  var rem=total%7===0?0:7-(total%7);
  for(var i=1;i<=rem;i++){
    var d=document.createElement('div'); d.className='cal-cell off';
    d.innerHTML='<span class="cal-num">'+i+'</span>'; grid.appendChild(d);
  }
  renderAgSide();
}

function renderAgSide() {
  var evDiv = document.getElementById('agNextEvs');
  var bdDiv = document.getElementById('agBdays');
  if(!calAgData) return;
  var eventos = calAgData.eventos||[];
  var bdays = calAgData.aniversariantes||[];
  if(evDiv) {
    if(!eventos.length) { evDiv.innerHTML='<div style="font-size:12px;color:var(--ti)">Nenhum evento futuro</div>'; }
    else { evDiv.innerHTML = eventos.slice(0,5).map(function(ev){
      var dt = new Date(ev.data_inicio);
      return '<div class="ag-ev"><div class="ag-ev-dot" style="background:var(--vm)"></div><div><div class="ag-ev-n">'+ev.titulo+'</div><div class="ag-ev-d">'+dt.getDate()+' de '+MONTHS_CAL[dt.getMonth()]+'</div></div></div>';
    }).join(''); }
  }
  if(bdDiv) {
    if(!bdays.length) { bdDiv.innerHTML='<div style="font-size:12px;color:var(--ti)">Nenhum aniversariante</div>'; }
    else {
      var cores = ['#7C3AED','#0F6E56','#B45309','#1D4ED8','#BE185D','#0C231B','#DC2626','#0369A1'];
      bdDiv.innerHTML = bdays.map(function(b, idx){
        var day = b.data_nascimento ? parseInt(b.data_nascimento.substring(8,10)) : '?';
        var todayDay = new Date().getDate();
        var todayMon = new Date().getMonth()+1;
        var bMon = b.data_nascimento ? parseInt(b.data_nascimento.substring(5,7)) : 0;
        var isHoje = (day === todayDay && bMon === todayMon);
        var cor = cores[idx % cores.length];
        var ini = b.nome.trim().split(' ').filter(function(n){return n;}).map(function(n){return n[0];}).join('').substring(0,2).toUpperCase();
        var avatarConteudo = b.foto_chave
          ? '<img src="/membro/foto/'+(b.tipo||'ligante')+'/'+b.id+'" alt="'+ini+'" onerror="this.style.display=\'none\'">'
          : '<span>'+ini+'</span>';
        return '<div class="ag-bday"><div class="ag-bav" style="background:'+cor+'">'+avatarConteudo+'</div>'
          + '<div style="flex:1"><div class="ag-bday-n">'+b.nome+'</div>'
          + '<div class="ag-bday-d">Dia '+day+(isHoje?' &middot; Hoje!':'')+'</div></div>'
          + (isHoje?'<span class="ag-bday-today">Hoje</span>':'')+'</div>';
      }).join('');
    }
  }
}

function loadAgenda() {
  fetch('/membro/agenda/dados?mes='+(calM+1)+'&ano='+calY, { credentials: 'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(data){ calAgData=data; renderCalendar(); })
    .catch(function(){ calAgData={eventos:[],aniversariantes:[]}; renderCalendar(); });
}

document.getElementById('calPrev') && document.getElementById('calPrev').addEventListener('click', function(){
  calM--; if(calM<0){calM=11;calY--;} calAgData=null;
  document.getElementById('agNextEvs').innerHTML='<div style="font-size:12px;color:var(--ti)">Carregando...</div>';
  document.getElementById('agBdays').innerHTML='<div style="font-size:12px;color:var(--ti)">Carregando...</div>';
  loadAgenda();
});
document.getElementById('calNext') && document.getElementById('calNext').addEventListener('click', function(){
  calM++; if(calM>11){calM=0;calY++;} calAgData=null;
  document.getElementById('agNextEvs').innerHTML='<div style="font-size:12px;color:var(--ti)">Carregando...</div>';
  document.getElementById('agBdays').innerHTML='<div style="font-size:12px;color:var(--ti)">Carregando...</div>';
  loadAgenda();
});

