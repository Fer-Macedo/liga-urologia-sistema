<script src="/socket.io/socket.io.js"></script>
<script>
// ── CHAT INTERNO ──────────────────────────────────────────────
var chatOpen = false;
var chatMsgs = [];
var chatUnread = 0;
var socket = null;

var MEMBRO_TIPO = '<%=membro.tipo%>';
var MEMBRO_ID = <%=membro.id%>;
var MEMBRO_INI = '<%=(function(n){return n.trim().split(" ").filter(function(x){return x;}).map(function(x){return x[0];}).join("").substring(0,2).toUpperCase();})(membro.nome||"?")%>';

function initSocket() {
  try {
    socket = io({ auth: { tipo: MEMBRO_TIPO, id: MEMBRO_ID } });
    socket.on('chat_msg_ok', function(msg) {
      addMsgToBody(msg);
      if(!chatOpen && msg.autor === 'admin') {
        chatUnread++;
        updateChatDot();
      }
    });
  } catch(e) {}
}

function updateChatDot() {
  var dot = document.getElementById('chatDot');
  if(!dot) return;
  if(chatUnread > 0) { dot.textContent = chatUnread; dot.style.display = 'flex'; }
  else { dot.style.display = 'none'; }
}

function formatTime(dt) {
  var d = new Date(dt);
  return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
}

function addMsgToBody(msg) {
  var body = document.getElementById('chatBody');
  if(!body) return;
  var empty = body.querySelector('.chat-empty');
  if(empty) empty.remove();
  var isOut = msg.autor === 'membro';
  var div = document.createElement('div');
  div.className = 'msg ' + (isOut ? 'out' : 'in');
  div.innerHTML = '<div class="msg-b">' + escHtml(msg.texto) + '</div><div class="msg-t">' + formatTime(msg.criado_em) + (isOut ? '' : ' · LAURO') + '</div>';
  body.appendChild(div);
  body.scrollTop = body.scrollHeight;
}

function escHtml(t) {
  return String(t).split('&').join('&amp;').split('<').join('&lt;').split('>').join('&gt;');
}

function loadChat() {
  fetch('/membro/chat/mensagens', { credentials: 'same-origin' })
    .then(function(r){ return r.json(); })
    .then(function(data) {
      var body = document.getElementById('chatBody');
      chatMsgs = data.mensagens || [];
      if(!chatMsgs.length) {
        body.innerHTML = '<div class="chat-empty">Nenhuma mensagem ainda.<br>Envie uma mensagem para a Diretoria.</div>';
        return;
      }
      body.innerHTML = '';
      chatMsgs.forEach(function(m){ addMsgToBody(m); });
    })
    .catch(function(){ });
}

function sendMsg() {
  var inp = document.getElementById('chatInp');
  if(!inp || !inp.value.trim()) return;
  var texto = inp.value.trim();
  inp.value = '';
  var tmpMsg = { texto: texto, autor: 'membro', criado_em: new Date() };
  addMsgToBody(tmpMsg);
  if(socket && socket.connected) {
    socket.emit('chat_msg', { texto: texto });
  } else {
    fetch('/membro/chat/enviar', {
      method: 'POST',
      headers: {'Content-Type':'application/x-www-form-urlencoded'},
      body: 'texto=' + encodeURIComponent(texto)
    }).catch(function(){});
  }
}

document.getElementById('chatBtn').addEventListener('click', function(){
  chatOpen = !chatOpen;
  document.getElementById('chatPanel').classList.toggle('open', chatOpen);
  if(chatOpen) { chatUnread = 0; updateChatDot(); loadChat(); }
});
document.getElementById('chatClose').addEventListener('click', function(){
  chatOpen = false;
  document.getElementById('chatPanel').classList.remove('open');
});
document.getElementById('chatSend').addEventListener('click', sendMsg);
document.getElementById('chatInp').addEventListener('keydown', function(e){
  if(e.key === 'Enter') sendMsg();
});
initSocket();

// ── PERFIL ────────────────────────────────────────────────────
var finLoaded = false;
var perfilLoaded = false;
