      <div class="pg-s">Seus dados cadastrais na LAURO</div>
      <div id="perfil-conteudo">
        <div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">Carregando...</div>
      </div>
    </section>

    <!-- ESTATUTO -->
    <section class="sc" id="sc-estatuto">
      <div class="pg-t">Estatuto</div>
      <div class="pg-s">Documento oficial da Liga Academica de Urologia</div>
      <div id="estatuto-conteudo">
        <div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">Carregando...</div>
      </div>
    </section>

    <!-- REGULAMENTO -->
    <section class="sc" id="sc-regulamento">
      <div class="pg-t">Regulamento</div>
      <div class="pg-s">Normas e regras da Liga Academica de Urologia</div>
      <div id="regulamento-conteudo">
        <div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">Carregando...</div>
