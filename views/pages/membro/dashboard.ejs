      var fotoUrl = '/membro/foto/' + d.tipo + '/' + d.id;
      var locked = !data.edicaoLiberada;
      var nascFormatado = d.data_nascimento ? new Date(d.data_nascimento).toLocaleDateString('pt-BR') : '—';
      if(nascFormatado === 'Invalid Date') nascFormatado = '—';

      var camposLigante = secao('Dados Pessoais') +
        campo('Nome completo', d.nome) +
        campo('Data de nascimento', nascFormatado) +
        campo('Sexo', d.sexo) +
        campo('RG', d.rg) +
        campo('CPF', d.cpf) +
        campo('Catraca UCP', d.catraca) +
        '<div class="prof-field"><div class="prof-label">WhatsApp</div>' +
          (locked ? '<div class="prof-val">'+fv(d.whatsapp)+'</div>' :
           '<input class="prof-input" id="perfil-wapp" value="'+(d.whatsapp||'')+'" placeholder="+595 9...">') +
        '</div>' +
        campo('Email', d.email) +
        campo('Email alternativo', d.email_alternativo) +
        campo('ORCID', d.orcid) +
        secao('Dados Academicos') +
        campo('Semestre atual', d.semestre) +
        campo('Turma', d.turma) +
        campo('Semestre de ingresso', d.semestre_ingresso) +
        campo('Tem formacao anterior?', d.tem_formacao) +
        campo('Qual formacao?', d.qual_formacao) +
        secao('Perfil na Liga') +
        campo('Habilidades', d.habilidades) +
        campo('Aceita cargo?', d.aceita_cargo) +
        campo('Qual cargo?', d.qual_cargo) +
        campo('Contribuicao para o grupo', d.contribuicao_grupo) +
        campo('Ideia inovadora', d.ideia_inovadora) +
        campo('Tema de interesse', d.tema_interesse) +
        campo('Por que a LAURO?', d.porque_lauro) +
        campo('Apresentacao', d.apresentacao);

      var camposDiretivo = secao('Dados Pessoais') +
        campo('Nome completo', d.nome) +
        campo('Data de nascimento', nascFormatado) +
        campo('RG', d.rg) +
        campo('CPF', d.cpf) +
        campo('Catraca UCP', d.catraca) +
        '<div class="prof-field"><div class="prof-label">WhatsApp</div>' +
          (locked ? '<div class="prof-val">'+fv(d.whatsapp)+'</div>' :
           '<input class="prof-input" id="perfil-wapp" value="'+(d.whatsapp||'')+'" placeholder="+595 9...">') +
        '</div>' +
        campo('Email', d.email) +
        campo('Instagram', d.instagram) +
        campo('ORCID', d.orcid) +
        campo('Onde reside', d.onde_reside) +
        secao('Dados na Liga') +
        campo('Cargo', d.cargo) +
        campo('Semestre / Turma', d.semestre_turma) +
        campo('Ano de ingresso', d.ano_ingresso) +
        campo('Graduacao', d.graduacao) +
        secao('Disponibilidade') +
        campo('Disponibilidade', d.disponibilidade) +
        campo('Transporte proprio', d.transporte_proprio) +
        campo('Tipo de transporte', d.tipo_transporte) +
        campo('Experiencia em Urologia', d.experiencia_urologia);

      var campos = d.tipo === 'ligante' ? camposLigante : camposDiretivo;

      wrap.innerHTML =
        '<div class="prof-header">' +
          '<div class="prof-photo"><img src="' + fotoUrl + '" alt="' + ini + '" onerror="this.style.display=&quot;none&quot;"></div>' +
          '<div><div class="prof-nome">' + d.nome + '</div>' +
          '<div class="prof-tipo">' + (d.tipo==='ligante'?'Ligante':'Diretivo') + (d.cargo?' · '+d.cargo:'') + (d.semestre?' · '+d.semestre:'') + '</div>' +
          (locked ? '<div style="font-size:11px;color:var(--ti);margin-top:4px">Visualizacao somente · editar? Contate a secretaria</div>' :
                    '<div style="font-size:11px;color:var(--ok);margin-top:4px">Edicao liberada</div>') +
          '</div></div>' +
        '<div class="card" style="padding:20px">' +
          '<div class="prof-grid">' + campos + '</div>' +
          (!locked ? '<button class="btn btn-p" style="margin-top:16px" id="salvarPerfil"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><polyline points="20 6 9 17 4 12"/></svg> Salvar alteracoes</button>' : '') +
        '</div>';

      if(!locked) {
        var btn = document.getElementById('salvarPerfil');
        if(btn) btn.addEventListener('click', function(){
          var wapp = document.getElementById('perfil-wapp');
          if(!wapp) return;
          fetch('/membro/perfil/atualizar', {
            method: 'POST',
            headers: {'Content-Type':'application/x-www-form-urlencoded'},
            body: 'whatsapp=' + encodeURIComponent(wapp.value)
          }).then(function(r){ return r.json(); }).then(function(res){
            if(res.ok) { btn.textContent = 'Salvo!'; setTimeout(function(){ btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><polyline points="20 6 9 17 4 12"/></svg> Salvar alteracoes'; }, 2000); }
          });
        });
      }
    })
    .catch(function(){ perfilLoaded=false; });
}

