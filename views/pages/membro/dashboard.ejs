<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="theme-color" content="#0C231B">
<title>Portal do Membro — LAURO</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
<%
var orgCor = (typeof config !== 'undefined' && config && config.org_cor) ? config.org_cor : '#0F6E56';
%>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --v:#0C231B;--vm:#0F6E56;--vl:#E8F5F0;--vll:#F4FAF7;
  --bg:#F4F6F5;--card:#fff;--brd:#E5EBE8;
  --t:#0C231B;--ts:#6B7A72;--ti:#A0ADA8;
  --ok:#047857;--okb:#ECFDF5;--okr:#A7F3D0;
  --wa:#B45309;--wab:#FFF7ED;--war:#FDE68A;
  --er:#B91C1C;--erb:#FEF2F2;--err:#FECACA;
  --in:#1D4ED8;--inb:#EFF6FF;
  --sw:240px;--th:52px;--ff:'Plus Jakarta Sans',system-ui,sans-serif;--tr:0.16s ease
}
html.dark{--bg:#091410;--card:#0D1C16;--brd:#183025;--t:#DEF0E7;--ts:#7A9988;--ti:#3D6050;--vll:#0B1911;--vl:#0F2820}
html,body{height:100%;overflow:hidden}
body{font-family:var(--ff);background:var(--bg);color:var(--t);display:flex;font-size:14px;line-height:1.5;transition:background .2s,color .2s}

/* SIDEBAR */
.sb{width:var(--sw);background:var(--v);display:flex;flex-direction:column;flex-shrink:0;height:100vh;transition:width .22s ease;z-index:100;position:relative;overflow:hidden}
.sb.col{width:60px}
.sb-top{padding:0 14px;height:var(--th);display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0}
.sb-mark{width:28px;height:28px;background:var(--vm);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden}
.sb-mark img{width:100%;height:100%;object-fit:contain;border-radius:2px}
.sb-brand{overflow:hidden}
.sb-brand strong{font-size:14px;font-weight:800;color:#fff;letter-spacing:.06em;white-space:nowrap;display:block}
.sb-brand span{font-size:10px;color:rgba(255,255,255,.35);white-space:nowrap;letter-spacing:.06em;text-transform:uppercase}
.sb-nav{flex:1;padding:6px 0;overflow-y:auto;overflow-x:hidden;min-height:0}
.sb-nav::-webkit-scrollbar{display:none}
.ni{display:flex;align-items:center;gap:10px;padding:9px 14px 9px 16px;color:rgba(255,255,255,.52);cursor:pointer;transition:background var(--tr),color var(--tr);border:none;background:none;width:100%;text-align:left;font-family:var(--ff);font-size:13px;font-weight:500;white-space:nowrap;position:relative;text-decoration:none}
.ni:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.88)}
.ni.act{background:var(--vm);color:#fff}
.ni svg{width:17px;height:17px;flex-shrink:0}
.ni-lbl{overflow:hidden}
.ni-bdg{background:#DC2626;color:#fff;font-size:10px;font-weight:700;padding:1px 6px;margin-left:auto;flex-shrink:0}
.sb-bot{padding:10px;border-top:1px solid rgba(255,255,255,.08);flex-shrink:0}
.sb-acts{display:flex;gap:2px;padding-bottom:6px}
.sa{background:transparent;border:none;color:rgba(255,255,255,.4);cursor:pointer;padding:7px;display:flex;transition:color var(--tr)}
.sa:hover{color:rgba(255,255,255,.9)}
.sa svg{width:15px;height:15px}
.sb-usr{display:flex;align-items:center;gap:8px;padding:7px 8px;cursor:pointer;border:none;background:none;width:100%;transition:background var(--tr);text-decoration:none}
.sb-usr:hover{background:rgba(255,255,255,.07)}
.sb-av{width:32px;height:32px;background:var(--vm);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#fff;flex-shrink:0;overflow:hidden}
.sb-av img{width:100%;height:100%;object-fit:cover}
.sb-ui{overflow:hidden;text-align:left}
.sb-un{font-size:12.5px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-ur{font-size:10.5px;color:rgba(255,255,255,.4)}
.sb-tog{position:absolute;right:0;top:50%;transform:translateY(-50%);background:var(--vm);border:none;width:22px;height:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;z-index:200}
.sb-tog svg{width:11px;height:11px;transition:transform .22s ease}
.sb.col .sb-tog svg{transform:rotate(180deg)}
.sb.col .ni-lbl,.sb.col .sb-brand,.sb.col .ni-bdg,.sb.col .sb-ui{opacity:0;pointer-events:none;width:0}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow:hidden}
.tb{height:var(--th);background:var(--card);border-bottom:1px solid var(--brd);display:flex;align-items:center;padding:0 20px;gap:10px;flex-shrink:0;transition:background .2s,border-color .2s}
.tb-tit{font-size:15px;font-weight:700;color:var(--t)}
.tb-sub{font-size:12px;color:var(--ts);margin-left:4px}
.tb-r{margin-left:auto;display:flex;align-items:center;gap:4px}
.ib{background:none;border:none;cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--ts);transition:background var(--tr),color var(--tr);position:relative}
.ib:hover{background:var(--bg);color:var(--t)}
.ib svg{width:18px;height:18px}
.nb{position:absolute;top:7px;right:7px;width:8px;height:8px;background:#DC2626;border-radius:50%;border:2px solid var(--card)}
.tb-av{width:32px;height:32px;background:var(--vm);cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:#fff;overflow:hidden;border:none}
.mob-btn{display:none;background:none;border:none;cursor:pointer;color:var(--t);padding:4px}
.mob-btn svg{width:22px;height:22px}

/* CONTENT */
.ct{flex:1;overflow-y:auto;overflow-x:hidden;padding:24px}
.ct::-webkit-scrollbar{width:4px}
.ct::-webkit-scrollbar-thumb{background:var(--brd)}

/* SECTIONS */
.sc{display:none}
.sc.act{display:block}

/* CARDS */
.card{background:var(--card);border:1px solid var(--brd);padding:20px;transition:background .2s,border-color .2s}
.g4{display:grid;grid-template-columns:repeat(4,1fr)}
.g3{display:grid;grid-template-columns:repeat(3,1fr)}
.g2{display:grid;grid-template-columns:repeat(2,1fr)}
.gap{gap:16px;margin-bottom:20px}
.sc-ico{width:36px;height:36px;display:flex;align-items:center;justify-content:center;margin-bottom:12px}
.sc-ico svg{width:18px;height:18px}
.sc-val{font-size:22px;font-weight:800;color:var(--t);line-height:1}
.sc-lbl{font-size:11px;color:var(--ts);margin-top:4px;margin-bottom:8px}
.chip{display:inline-flex;font-size:10.5px;font-weight:700;padding:2px 8px;letter-spacing:.02em}
.c-ok{background:var(--okb);color:var(--ok)}
.c-wa{background:var(--wab);color:var(--wa)}
.c-er{background:var(--erb);color:var(--er)}
.c-in{background:var(--inb);color:var(--in)}
.c-gr{background:var(--bg);color:var(--ts)}

/* WELCOME */
.wb{background:var(--v);padding:20px 24px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.wb h2{font-size:18px;font-weight:800;color:#fff}
.wb p{font-size:12px;color:rgba(255,255,255,.5);margin-top:3px}
.wb-r{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
.wb-d{font-size:11px;color:rgba(255,255,255,.4)}
.wchips{display:flex;gap:6px}
.wchip{font-size:10.5px;font-weight:700;padding:3px 10px;background:rgba(255,255,255,.1);color:rgba(255,255,255,.8)}

/* PIX */
.pix-wrap{display:flex;gap:16px;align-items:flex-start}
.pix-qr{width:92px;height:92px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:#fff;padding:4px}
.pix-ref{font-size:11px;color:var(--ts);margin-bottom:4px}
.pix-val{font-size:20px;font-weight:800;color:var(--t);margin-bottom:8px}
.pix-code{font-size:9px;font-family:monospace;color:var(--ts);word-break:break-all;background:var(--bg);padding:6px 8px;margin-bottom:8px;max-height:40px;overflow:hidden;line-height:1.4}

/* EVENTOS */
.ev{background:var(--card);border:1px solid var(--brd);padding:16px;display:flex;gap:14px;margin-bottom:12px;transition:background .2s}
.ev-dt{background:var(--v);color:#fff;padding:10px 12px;text-align:center;flex-shrink:0;min-width:52px}
.ev-dy{font-size:22px;font-weight:800;line-height:1}
.ev-mo{font-size:10px;text-transform:uppercase;letter-spacing:.5px;margin-top:2px;color:rgba(255,255,255,.7)}
.ev-nm{font-size:13px;font-weight:700;margin-bottom:6px}
.ev-mt{display:flex;flex-wrap:wrap;gap:10px}
.ev-mi{font-size:11px;color:var(--ts);display:flex;align-items:center;gap:4px}
.ev-mi svg{width:11px;height:11px;flex-shrink:0}

/* FREQUENCIA */
.resumo{background:var(--v);color:#fff;padding:20px 24px;margin-bottom:16px;display:flex;gap:28px;flex-wrap:wrap}
.resumo-item{text-align:center}
.resumo-valor{font-size:32px;font-weight:800;line-height:1}
.resumo-label{font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.5px;margin-top:4px}
.barra-wrap{background:var(--card);border:1px solid var(--brd);padding:16px;margin-bottom:16px}
.barra-label{font-size:12px;color:var(--ts);margin-bottom:8px;display:flex;justify-content:space-between}
.barra{background:var(--brd);height:10px}
.barra-fill{height:10px;transition:width .5s ease}
.freq-item{padding:12px 16px;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;gap:8px}
.freq-item:last-child{border-bottom:none}
.freq-data{font-size:13px;font-weight:600}
.freq-desc{font-size:12px;color:var(--ts);margin-top:2px}
.presente{background:var(--okb);color:var(--ok);font-size:11px;font-weight:700;padding:2px 8px}
.ausente{background:var(--erb);color:var(--er);font-size:11px;font-weight:700;padding:2px 8px}

/* COMUNICADOS */
.cm{padding:14px 16px;border-bottom:1px solid var(--brd);cursor:pointer}
.cm:last-child{border-bottom:none}
.cm-dot{width:8px;height:8px;flex-shrink:0;margin-top:4px}
.cm-title{font-size:13px;font-weight:700;color:var(--t)}
.cm-date{font-size:11px;color:var(--ti);margin-top:2px}
.cm-body{font-size:13px;color:var(--ts);margin-top:8px;line-height:1.6;display:none;white-space:pre-wrap}
.cm.open .cm-body{display:block}

/* MATERIAIS */
.mat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:20px}
.mat-card{background:var(--card);border:1px solid var(--brd);padding:16px;display:flex;flex-direction:column;gap:12px}
.mat-icone{width:38px;height:38px;background:var(--vll);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mat-titulo{font-size:14px;font-weight:700;color:var(--t);line-height:1.3}
.mat-desc{font-size:12px;color:var(--ts);margin-top:3px;line-height:1.4}
.mat-acoes{display:flex;gap:8px}

.cal-wrap{display:flex;gap:20px;align-items:flex-start}
.cal-main{flex:1;min-width:0}
.cal-side{width:236px;flex-shrink:0}
.cal-hdr-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.cal-month-lbl{font-size:16px;font-weight:700;color:var(--t)}
.cal-nav-btn{background:none;border:1px solid var(--brd);color:var(--ts);cursor:pointer;padding:5px 12px;font-family:var(--ff);font-size:13px;transition:all var(--tr)}
.cal-nav-btn:hover{background:var(--bg);border-color:var(--vm);color:var(--vm)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);background:var(--card);border:1px solid var(--brd);overflow:hidden}
.cal-dow{background:var(--v);color:rgba(255,255,255,.8);text-align:center;padding:9px 4px;font-size:10.5px;font-weight:700;letter-spacing:.06em;border-right:1px solid rgba(255,255,255,.08)}
.cal-dow:last-child{border-right:0}
.cal-cell{min-height:82px;padding:6px;border-right:1px solid var(--brd);border-bottom:1px solid var(--brd);position:relative;cursor:pointer}
.cal-cell:hover{background:var(--vll)}
.cal-cell:nth-child(7n){border-right:0}
.cal-cell.off{background:var(--vll);cursor:default}
.cal-cell.today{background:color-mix(in srgb,var(--vl) 60%,transparent)}
.cal-num{font-size:12px;font-weight:600;color:var(--t);margin-bottom:3px;width:22px;height:22px;display:flex;align-items:center;justify-content:center}
.cal-cell.today .cal-num{background:var(--vm);color:#fff;border-radius:50%;font-weight:700}
.cal-cell.off .cal-num{color:var(--ti)}
.cal-chips{display:flex;flex-direction:column;gap:2px}
.cc-ev{font-size:9.5px;font-weight:600;padding:2px 5px;background:#DBEAFE;color:#1D4ED8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cc-ev.green{background:var(--vl);color:var(--vm)}
.cc-ev.dark{background:#D1FAE5;color:#065F46}
.cc-bd{font-size:9.5px;font-weight:600;padding:2px 5px;background:#FEF9C3;color:#92400E;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ag-card{background:var(--card);border:1px solid var(--brd);padding:14px;margin-bottom:14px}
.ag-card-t{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ts);margin-bottom:10px}
.ag-ev{padding:7px 0;border-bottom:1px solid var(--brd);display:flex;gap:8px;align-items:flex-start}
.ag-ev:last-child{border-bottom:0}
.ag-ev-dot{width:8px;height:8px;flex-shrink:0;margin-top:5px;background:var(--vm)}
.ag-ev-n{font-size:12.5px;font-weight:600;color:var(--t)}
.ag-ev-d{font-size:11px;color:var(--ti)}
.ag-bday{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--brd)}
.ag-bday:last-child{border-bottom:0}
.ag-bav{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.ag-bav img{width:100%;height:100%;object-fit:cover}
.ag-bday-n{font-size:12.5px;font-weight:600;color:var(--t)}
.ag-bday-d{font-size:11px;color:var(--ti)}
.ag-bday-today{font-size:9.5px;font-weight:700;background:#F59E0B;color:#fff;padding:2px 7px;margin-left:auto;flex-shrink:0}
@media(max-width:960px){.cal-wrap{flex-direction:column}.cal-side{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:14px}}
@media(max-width:680px){.cal-cell{min-height:54px;padding:3px}.cc-ev,.cc-bd{display:none}}

/* PAGE TITLES */
.pg-t{font-size:18px;font-weight:800;margin-bottom:4px}
.pg-s{font-size:13px;color:var(--ts);margin-bottom:20px}
.st{font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}

/* BTNS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--brd);background:var(--card);color:var(--t);font-family:var(--ff);font-size:12.5px;font-weight:600;cursor:pointer;transition:all var(--tr);text-decoration:none}
.btn:hover{background:var(--bg)}
.btn-p{background:var(--vm);color:#fff;border-color:var(--vm)}
.btn-p:hover{background:#0d5e49}
.btn-v{background:var(--v);color:#fff;border-color:var(--v)}
.btn-v:hover{background:#1a3d2b}

/* FOOTER */
footer{background:var(--v);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;flex-wrap:wrap;gap:8px;position:relative;z-index:10}
.pf-logo-f{width:22px;height:22px;border-radius:50%;object-fit:cover}
.pf-n{font-size:12px;font-weight:700;color:#fff}
.pf-sep{color:rgba(255,255,255,.3);margin:0 4px}
.pf-inf{font-size:11px;color:rgba(255,255,255,.4)}
.pf-copy{font-size:11px;color:rgba(255,255,255,.25)}
.pf-socials{display:flex;gap:6px}
.pf-soc{width:28px;height:28px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);transition:all var(--tr);text-decoration:none}
.pf-soc:hover{background:var(--vm);color:#fff}
.pf-soc svg{width:13px;height:13px}

/* MOBILE */
.mob-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99}
.mob-ov.open{display:block}
@media(max-width:900px){
  .mob-btn{display:flex}
  .sb{position:fixed;left:-260px;transition:left .22s ease}
  .sb.mob-open{left:0}
  .sb-tog{display:none}
  .g4{grid-template-columns:repeat(2,1fr)}
  .g3{grid-template-columns:1fr}
  .g2{grid-template-columns:1fr}
  .cal-wrap{grid-template-columns:1fr}
}
@media(max-width:480px){
  .ct{padding:16px}
  .g4{grid-template-columns:repeat(2,1fr)}
  .pix-wrap{flex-direction:column}
  .pix-qr{width:100%}
}
@keyframes spin{to{transform:rotate(360deg)}}

/* CHAT */
.chat-btn{position:fixed;bottom:80px;right:24px;width:52px;height:52px;background:var(--vm);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;z-index:9990;box-shadow:0 4px 16px rgba(15,110,86,.4);pointer-events:all}
.chat-btn svg{width:22px;height:22px}
.chat-dot{position:absolute;top:-4px;right:-4px;min-width:18px;height:18px;background:#DC2626;border-radius:9px;color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 4px;border:2px solid var(--bg)}
.chat-panel{position:fixed;bottom:140px;right:24px;width:320px;height:420px;background:var(--card);border:1px solid var(--brd);z-index:9990;display:none;flex-direction:column;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.chat-panel.open{display:flex}
.chat-phd{height:48px;background:var(--v);display:flex;align-items:center;justify-content:space-between;padding:0 14px;flex-shrink:0}
.chat-ptit{font-size:13px;font-weight:700;color:#fff}
.chat-pcls{background:none;border:none;color:rgba(255,255,255,.6);cursor:pointer;padding:4px;display:flex}
.chat-pcls svg{width:16px;height:16px}
.cmbody{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px}
.cmbody::-webkit-scrollbar{width:3px}
.msg{max-width:85%;display:flex;flex-direction:column;gap:2px}
.msg.out{align-self:flex-end;align-items:flex-end}
.msg.in{align-self:flex-start;align-items:flex-start}
.msg-b{padding:8px 10px;font-size:13px;line-height:1.4}
.msg.out .msg-b{background:var(--vm);color:#fff}
.msg.in .msg-b{background:var(--bg);color:var(--t);border:1px solid var(--brd)}
.msg-t{font-size:10px;color:var(--ti)}
.cminp{display:flex;gap:0;border-top:1px solid var(--brd);flex-shrink:0}
.cminp input{flex:1;border:none;padding:10px 12px;font-family:var(--ff);font-size:13px;background:var(--card);color:var(--t);outline:none}
.cmsend{background:var(--vm);border:none;padding:0 14px;cursor:pointer;color:#fff;display:flex;align-items:center}
.cmsend svg{width:16px;height:16px}
.chat-empty{text-align:center;padding:24px;font-size:12px;color:var(--ti)}

/* PERFIL */
.prof-header{display:flex;align-items:center;gap:16px;margin-bottom:20px}
.prof-photo{width:64px;height:64px;border-radius:50%;background:var(--vm);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;color:#fff;flex-shrink:0;overflow:hidden}
.prof-photo img{width:100%;height:100%;object-fit:cover}
.prof-nome{font-size:18px;font-weight:800}
.prof-tipo{font-size:12px;color:var(--ts)}
.prof-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.prof-field{display:flex;flex-direction:column;gap:4px}
.prof-label{font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.05em}
.prof-val{font-size:14px;font-weight:500;color:var(--t)}
.prof-input{border:1.5px solid var(--brd);padding:8px 12px;font-family:var(--ff);font-size:14px;color:var(--t);background:var(--card);width:100%;outline:none}
.prof-input:focus{border-color:var(--vm)}
.prof-input:disabled{background:var(--bg);color:var(--ts);cursor:not-allowed}

/* PDF VIEWER */
.pdf-wrap{width:100%;height:70vh;border:1px solid var(--brd);background:var(--bg)}
.pdf-wrap iframe{width:100%;height:100%;border:none}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sb" id="sb">
  <div class="sb-top">
    <div class="sb-mark">
      <img src="/img/logo-lauro.png" alt="L" onerror="this.outerHTML='<svg viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'#fff\' stroke-width=\'2\'><path d=\'M12 2L2 7l10 5 10-5-10-5z\'/><path d=\'M2 17l10 5 10-5\'/></svg>'">
    </div>
    <div class="sb-brand">
      <strong>LAURO</strong>
      <span>Portal do Membro</span>
    </div>
    <button class="sb-tog" id="sbTog" title="Recolher menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
  </div>

  <nav class="sb-nav">
    <button class="ni act" id="ni-dashboard" data-sc="dashboard">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span class="ni-lbl">Inicio</span>
    </button>
    <button class="ni" id="ni-financeiro" data-sc="financeiro">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14"/><path d="M2 10h20"/></svg>
      <span class="ni-lbl">Financeiro</span>
    </button>
    <button class="ni" id="ni-frequencia" data-sc="frequencia">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      <span class="ni-lbl">Frequencia</span>
    </button>
    <button class="ni" id="ni-materiais" data-sc="materiais">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span class="ni-lbl">Materiais</span>
    </button>
    <button class="ni" id="ni-agenda" data-sc="agenda">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <span class="ni-lbl">Agenda</span>
    </button>
    <button class="ni" id="ni-eventos" data-sc="eventos">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span class="ni-lbl">Eventos</span>
    </button>
    <button class="ni" id="ni-comunicados" data-sc="comunicados">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <span class="ni-lbl">Comunicados</span>
      <% if(comunicadosNaoLidos > 0){ %><span class="ni-bdg" id="ni-bdg-comunicados"><%=comunicadosNaoLidos%></span><% } %>
    </button>
    <div style="height:1px;background:rgba(255,255,255,.08);margin:6px 0"></div>
    <button class="ni" id="ni-perfil" data-sc="perfil">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      <span class="ni-lbl">Meu Perfil</span>
    </button>
    <button class="ni" id="ni-estatuto" data-sc="estatuto">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      <span class="ni-lbl">Estatuto</span>
    </button>
    <button class="ni" id="ni-regulamento" data-sc="regulamento">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      <span class="ni-lbl">Regulamento</span>
    </button>
    <button class="ni" id="ni-contrato" data-sc="contrato">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      <span class="ni-lbl">Contrato</span>
    </button>
    <div style="height:1px;background:rgba(255,255,255,.08);margin:6px 0"></div>
    <a class="ni" href="https://cientifico.lauroucpcde.com" target="_blank">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
      <span class="ni-lbl">Portal Cientifico</span>
    </a>
  </nav>

  <div class="sb-bot">
    <div class="sb-acts">
      <button class="sa" id="dkBtn" title="Alternar modo escuro">
        <svg id="dkIco" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
      </button>
    </div>
    <a class="sb-usr" href="/membro/logout">
      <div class="sb-av"><%=(function(n){return n.trim().split(' ').filter(function(x){return x;}).map(function(x){return x[0];}).join('').substring(0,2).toUpperCase();})(membro.nome||'?')%></div>
      <div class="sb-ui">
        <div class="sb-un"><%=membro.nome.split(' ')[0]%></div>
        <div class="sb-ur"><%=membro.tipo==='ligante'?'Ligante':'Diretivo'%> · Sair</div>
      </div>
    </a>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="tb">
    <button class="mob-btn" id="mobBtn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    <span class="tb-tit" id="tbTit">Inicio</span>
    <span class="tb-sub" id="tbSub">Bem-vindo, <%=membro.nome.split(' ')[0]%></span>
    <div class="tb-r">
      <a class="ib" href="/membro/logout" title="Sair">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      </a>
    </div>
  </div>

  <div class="ct">

    <!-- DASHBOARD -->
    <section class="sc act" id="sc-dashboard">
      <div class="wb gap">
        <div>
          <h2>Ola, <%=membro.nome.split(' ')[0]%>!</h2>
          <p>Liga Academica de Urologia · Universidad Central del Paraguay · CDE</p>
        </div>
        <div class="wb-r">
          <div class="wb-d" id="dataHoje"></div>
          <div class="wchips">
            <span class="wchip"><%=membro.tipo==='ligante'?'Ligante':'Diretivo'%></span>
          </div>
        </div>
      </div>

      <div class="g4 gap">
        <div class="card">
          <div class="sc-ico" style="background:<%=!cobrancaAtual||cobrancaAtual.status==='pago'?'var(--okb)':cobrancaAtual.status==='atrasado'?'var(--erb)':'var(--wab)'%>">
            <svg viewBox="0 0 24 24" fill="none" stroke="<%=!cobrancaAtual||cobrancaAtual.status==='pago'?'#047857':cobrancaAtual.status==='atrasado'?'#B91C1C':'#B45309'%>" stroke-width="2"><rect x="2" y="5" width="20" height="14"/><path d="M2 10h20"/></svg>
          </div>
          <div class="sc-val"><%=!cobrancaAtual||cobrancaAtual.status==='pago'?'Em dia':cobrancaAtual.status==='atrasado'?'Atrasado':'Pendente'%></div>
          <div class="sc-lbl">Situacao financeira</div>
          <span class="chip <%=!cobrancaAtual||cobrancaAtual.status==='pago'?'c-ok':cobrancaAtual.status==='atrasado'?'c-er':'c-wa'%>"><%=!cobrancaAtual||cobrancaAtual.status==='pago'?'Adimplente':cobrancaAtual.status==='atrasado'?'Em atraso':'Pendente'%></span>
        </div>
        <div class="card" id="card-freq" style="cursor:pointer">
          <div class="sc-ico" style="background:<%=frequencia.percentual>=75?'var(--okb)':frequencia.percentual>=50?'var(--wab)':'var(--erb)'%>">
            <svg viewBox="0 0 24 24" fill="none" stroke="<%=frequencia.percentual>=75?'#047857':frequencia.percentual>=50?'#B45309':'#B91C1C'%>" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <div class="sc-val"><%=frequencia.percentual%>%</div>
          <div class="sc-lbl">Frequencia geral</div>
          <span class="chip <%=frequencia.percentual>=75?'c-ok':frequencia.percentual>=50?'c-wa':'c-er'%>"><%=frequencia.presencas%> de <%=frequencia.total%> atividades</span>
        </div>
        <div class="card" id="card-com" style="cursor:pointer">
          <div class="sc-ico" style="background:<%=comunicadosNaoLidos>0?'var(--wab)':'var(--bg)'%>">
            <svg viewBox="0 0 24 24" fill="none" stroke="<%=comunicadosNaoLidos>0?'#B45309':'var(--ts)'%>" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="sc-val"><%=comunicados.length%></div>
          <div class="sc-lbl">Comunicados</div>
          <span class="chip <%=comunicadosNaoLidos>0?'c-wa':'c-gr'%>"><%=comunicadosNaoLidos>0?comunicadosNaoLidos+' nao lidos':'Em dia'%></span>
        </div>
        <div class="card" id="card-ev" style="cursor:pointer">
          <div class="sc-ico" style="background:var(--inb)">
            <svg viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="2"><rect x="3" y="4" width="18" height="18"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div class="sc-val" style="font-size:14px"><%=proximoEvento?new Date(proximoEvento.data_inicio).toLocaleDateString('pt-BR',{day:'2-digit',month:'short'}):'—'%></div>
          <div class="sc-lbl">Proximo evento</div>
          <span class="chip c-in"><%=proximoEvento?proximoEvento.nome.substring(0,20)+'...':'Sem eventos'%></span>
        </div>
      </div>

      <div class="g2 gap">
        <div>
          <div class="st"><%=cobrancaAtual&&cobrancaAtual.status!=='pago'?'Mensalidade em aberto':'Situacao financeira'%></div>
          <% if(cobrancaAtual && cobrancaAtual.status !== 'pago'){ %>
          <div class="card pix-wrap">
            <div class="pix-qr" id="pix-qr-inicio">
              <canvas id="qr-canvas-inicio" style="width:84px;height:84px"></canvas>
            </div>
            <div style="flex:1;min-width:0">
              <%
                var _refDisp = cobrancaAtual.referencia;
                var _meses = ['JAN','FEV','MAR','ABR','MAI','JUN','JUL','AGO','SET','OUT','NOV','DEZ'];
                var _refMatch = cobrancaAtual.referencia.match(/^\d+-((\d{4})-(\d{2}))$/);
                if(_refMatch){ _refDisp = _meses[parseInt(_refMatch[3])-1]+'/'+_refMatch[2]; }
              %>
              <div class="pix-ref">Referencia: <%=_refDisp%> · Vence <%=new Date(cobrancaAtual.data_vencimento).toLocaleDateString('pt-BR')%></div>
              <%
                var hoje = new Date();
                var diaDesconto = parseInt(process.env.DIA_DESCONTO || '15');
                // Desconto valido SOMENTE se hoje <= dia 15 do mes atual
                var dentroDesconto = hoje.getDate() <= diaDesconto;
                var valorExibir = dentroDesconto ? cobrancaAtual.valor_desconto : cobrancaAtual.valor_cheio;
                var valorRiscado = dentroDesconto ? cobrancaAtual.valor_cheio : null;
              %>
              <div class="pix-val">R$ <%=Number(valorExibir).toFixed(2).replace('.',',')%> <% if(valorRiscado){ %><span style="font-size:12px;font-weight:400;color:var(--ts);text-decoration:line-through">R$ <%=Number(valorRiscado).toFixed(2).replace('.',',')%></span><% } %></div>
              <% if(cobrancaAtual.pix_copia_cola){ %>
              <div class="pix-code" id="pixCode"><%=cobrancaAtual.pix_copia_cola%></div>
              <button class="btn btn-p" id="btnCopyPix" style="font-size:11px;padding:6px 12px">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><rect x="9" y="9" width="13" height="13"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copiar codigo PIX
              </button>
              <% } %>
            </div>
          </div>
          <% } else { %>
          <div class="card" style="padding:20px;text-align:center">
            <svg viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" width="32" height="32" style="margin:0 auto 8px;display:block"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div style="font-size:14px;font-weight:700;color:var(--ok)">Mensalidade em dia</div>
            <div style="font-size:12px;color:var(--ts);margin-top:4px">Obrigado por manter sua situacao financeira regularizada!</div>
          </div>
          <% } %>
        </div>

        <div>
          <div class="st">Comunicados recentes</div>
          <div class="card" style="padding:0">
            <% if(comunicados.length === 0){ %>
            <div style="padding:20px;text-align:center;font-size:13px;color:var(--ti)">Nenhum comunicado</div>
            <% } %>
            <% comunicados.slice(0,3).forEach(function(c,i){ %>
            <div style="display:flex;align-items:flex-start;gap:8px;padding:12px 16px;border-bottom:1px solid var(--brd);cursor:pointer" id="cd-com" data-sc="comunicados">
              <div class="cm-dot" id="dot-cm-<%=comunicados[i].id%>" style="background:<%=!comunicados[i].lido?'#DC2626':'var(--brd)'%>;margin-top:5px"></div>
              <div>
                <div style="font-size:13px;font-weight:700"><%=c.titulo%></div>
                <div style="font-size:11px;color:var(--ti)"><%=new Date(c.criado_em).toLocaleDateString('pt-BR')%></div>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
      </div>

      <% if(proximoEvento){ %>
      <div class="st">Proximo evento</div>
      <div class="ev" id="card-ev2" style="cursor:pointer;margin-bottom:20px">
        <div class="ev-dt">
          <div class="ev-dy"><%=new Date(proximoEvento.data_inicio).getDate()%></div>
          <div class="ev-mo"><%=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][new Date(proximoEvento.data_inicio).getMonth()]%></div>
        </div>
        <div style="flex:1">
          <div class="ev-nm"><%=proximoEvento.nome%></div>
          <div class="ev-mt">
            <% if(proximoEvento.local){ %><div class="ev-mi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg><%=proximoEvento.local%></div><% } %>
          </div>
        </div>
      </div>
      <% } %>

      <% if(grupos && grupos.length > 0){ %>
      <div class="st">Grupo Cientifico</div>
      <div class="g2 gap">
        <% grupos.forEach(function(g){ %>
        <div class="card">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
            <div style="width:34px;height:34px;background:var(--vll);display:flex;align-items:center;justify-content:center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
            </div>
            <div>
              <div style="font-size:13px;font-weight:700"><%=g.gnome%></div>
              <div style="font-size:11px;color:var(--ts)">Grupo de Pesquisa</div>
            </div>
          </div>
          <div style="font-size:12px;color:var(--ts)"><%=g.ptitulo%></div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </section>

    <!-- FINANCEIRO -->
    <section class="sc" id="sc-financeiro">
      <div class="pg-t">Financeiro</div>
      <div class="pg-s">Situacao financeira do seu vinculo com a Liga</div>
      <% if(membro.tipo === 'diretivo'){ %>
      <div class="card" style="padding:24px;text-align:center">
        <svg viewBox="0 0 24 24" fill="none" stroke="#047857" stroke-width="2" width="40" height="40" style="margin:0 auto 12px;display:block"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <div style="font-size:16px;font-weight:800;color:var(--ok);margin-bottom:6px">Sin pendencias financieras</div>
        <div style="font-size:13px;color:var(--ts)">Como miembro de la Directiva, no tienes mensualidades asociadas.</div>
      </div>
      <% } else { %>
      <div id="fin-historico"><div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">Carregando...</div></div>
      <% } %>
    </section>

    <!-- FREQUENCIA -->
    <section class="sc" id="sc-frequencia">
      <div class="resumo">
        <div class="resumo-item"><div class="resumo-valor"><%=frequencia.percentual%>%</div><div class="resumo-label">Frequencia</div></div>
        <div class="resumo-item"><div class="resumo-valor"><%=frequencia.presencas%></div><div class="resumo-label">Presencas</div></div>
        <div class="resumo-item"><div class="resumo-valor"><%=frequencia.total-frequencia.presencas%></div><div class="resumo-label">Faltas</div></div>
        <div class="resumo-item"><div class="resumo-valor"><%=frequencia.total%></div><div class="resumo-label">Total</div></div>
      </div>
      <div class="barra-wrap">
        <div class="barra-label"><span>Frequencia acumulada</span><span>Minimo: 75%</span></div>
        <div class="barra"><div class="barra-fill" style="width:<%=Math.min(frequencia.percentual,100)%>%;background:<%=frequencia.percentual>=75?'#047857':frequencia.percentual>=50?'#f59e0b':'#DC2626'%>"></div></div>
        <% if(frequencia.percentual < 75){ %><div style="font-size:12px;color:#c2410c;margin-top:6px">Atencao: voce esta abaixo do minimo exigido de 75%</div><% } %>
      </div>
      <div id="freq-historico-wrap" style="margin-top:16px"></div>
      <button class="btn btn-v" id="btn-freq-historico" style="margin-bottom:16px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Ver historico completo
      </button>
    </section>

    <!-- MATERIAIS -->
    <section class="sc" id="sc-materiais">
      <div class="pg-t">Materiais de Estudo</div>
      <div class="pg-s">Acesse os materiais disponibilizados pela Liga</div>
      <div id="mat-conteudo">
        <div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32" style="margin:0 auto 10px;display:block;opacity:.4"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Clique em Materiais para carregar os conteudos
        </div>
      </div>
    </section>

    <!-- EVENTOS -->
    <section class="sc" id="sc-eventos">
      <div class="pg-t">Eventos</div>
      <div class="pg-s">Agenda de atividades e eventos da liga</div>
      <div id="ev-conteudo">
        <div style="text-align:center;padding:32px;color:var(--ti);font-size:13px">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32" style="margin:0 auto 10px;display:block;opacity:.4"><rect x="3" y="4" width="18" height="18"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Carregando eventos...
        </div>
      </div>
    </section>

    <!-- COMUNICADOS -->
    <section class="sc" id="sc-comunicados">
      <div class="pg-t">Comunicados</div>
