<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
// Gerar QR Code real do PIX na seção Inicio
(function() {
  function gerarQRInicio() {
    var pixText = document.getElementById('pixCode') ? document.getElementById('pixCode').textContent.trim() : '';
    var canvas = document.getElementById('qr-canvas-inicio');
    if (!canvas || !pixText) return;
    try {
      new QRCode(canvas.parentElement, {
        text: pixText,
        width: 84,
        height: 84,
        colorDark: '#0C231B',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
      canvas.style.display = 'none';
    } catch(e) { console.error('QR error:', e); }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', gerarQRInicio);
  } else {
    gerarQRInicio();
  }
})();
</script>

<!-- Modal Visualizador de Materiais -->
<div id="modalMaterial" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);flex-direction:column">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:#0C231B">
    <span id="modalMatTitulo" style="color:#fff;font-weight:600;font-size:15px">Visualizando material</span>
    <button onclick="fecharMaterial()" style="background:none;border:none;color:#fff;font-size:24px;cursor:pointer;line-height:1">&times;</button>
  </div>
  <div id="modalMatCorpo" style="flex:1;overflow:hidden;display:flex;align-items:center;justify-content:center;padding:0">
    <!-- conteúdo dinâmico -->
  </div>
</div>

<script>
function abrirMaterial(id, tipo) {
  var url = '/membro/materiais/' + id + '/arquivo';
  var corpo = document.getElementById('modalMatCorpo');
  var modal = document.getElementById('modalMaterial');
  corpo.innerHTML = '<div style="color:#fff;font-size:14px">Carregando...</div>';
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';

  // Busca URL assinada via fetch
  fetch(url + '?inline=1', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var finalUrl = data.url;
      tipo = data.tipo || tipo;
      var isVideo = tipo && tipo.startsWith('video/');
      var isPdf = tipo && tipo.includes('pdf');
      var isImg = tipo && tipo.startsWith('image/');
      var isDocx = tipo && (tipo.includes('word') || tipo.includes('officedocument'));

      if (isVideo) {
        corpo.innerHTML = '<video controls autoplay style="max-width:100%;max-height:calc(100vh - 60px);background:#000"><source src="'+finalUrl+'" type="'+tipo+'">Seu navegador nao suporta video.</video>';
      } else if (isPdf) {
        corpo.innerHTML = '<iframe src="'+finalUrl+'" style="width:100vw;height:calc(100vh - 60px);border:none;background:#fff" allowfullscreen></iframe>';
      } else if (isImg) {
        corpo.innerHTML = '<img src="'+finalUrl+'" style="max-width:100%;max-height:calc(100vh - 60px);object-fit:contain">';
      } else if (isDocx) {
        corpo.innerHTML = '<iframe src="https://view.officeapps.live.com/op/embed.aspx?src='+encodeURIComponent('https://membro.lauroucpcde.com'+finalUrl)+'" style="width:100vw;height:calc(100vh - 60px);border:none;background:#fff"></iframe>';
      } else {
        corpo.innerHTML = '<div style="color:#fff;text-align:center;padding:40px"><p style="font-size:16px;margin-bottom:20px">Pre-visualizacao nao disponivel.</p><a href="'+finalUrl+'" class="btn btn-v">Baixar arquivo</a></div>';
      }
    })
    .catch(function() {
      corpo.innerHTML = '<div style="color:#fff;padding:40px;text-align:center">Erro ao carregar o arquivo. Tente novamente.</div>';
    });
}

function fecharMaterial() {
  var modal = document.getElementById('modalMaterial');
  modal.style.display = 'none';
  document.getElementById('modalMatCorpo').innerHTML = '';
  document.body.style.overflow = '';
}

// Fechar com ESC
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') fecharMaterial();
});

// Marcar comunicado como lido
function marcarLido(el) {
  var cmid = el.getAttribute('data-cmid');
  if (!cmid || el.classList.contains('lido')) return;
  fetch('/membro/comunicado/' + cmid + '/lido', {
    method: 'POST', credentials: 'same-origin',
    headers: { 'Content-Type': 'application/json' }
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.ok) {
      el.classList.remove('unr');
      el.classList.add('lido');
      // Apagar dot vermelho
      var dot = document.getElementById('dot-cm-' + cmid);
      if (dot) dot.style.background = 'var(--brd)';
      var dot2 = document.getElementById('dot-cm2-' + cmid);
      if (dot2) dot2.style.background = 'var(--brd)';
      // Atualizar contador no sidebar
      var badge = document.getElementById('ni-bdg-comunicados');
      if (badge) {
        var n = parseInt(badge.textContent) - 1;
        if (n <= 0) badge.style.display = 'none';
        else badge.textContent = n;
      }
    }
  }).catch(function(){});
}

// Fechar clicando fora
document.getElementById('modalMaterial').addEventListener('click', function(e) {
  if (e.target === this) fecharMaterial();
});

// Delegacao de evento para botoes de visualizar
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.btn-mat-ver');
  if (btn) {
    var id = btn.getAttribute('data-mid');
    var tipo = btn.getAttribute('data-mtipo');
    abrirMaterial(id, tipo);
  }
});
</script>

</body>
</html>
