  wrap.innerHTML = '<div class="pdf-wrap"><iframe src="' + url + '#toolbar=0&navpanes=0&scrollbar=1" title="Documento"></iframe></div><div style="font-size:11px;color:var(--ti);margin-top:8px;text-align:center">Visualizacao somente — download nao permitido</div>';
}

function fv(v){ return v||'—'; }
function campo(label, val){ return '<div class="prof-field"><div class="prof-label">'+label+'</div><div class="prof-val">'+fv(val)+'</div></div>'; }
function secao(titulo){ return '<div style="grid-column:1/-1;font-size:11px;font-weight:700;color:var(--ts);text-transform:uppercase;letter-spacing:.06em;margin-top:8px;padding-bottom:6px;border-bottom:1px solid var(--brd)">'+titulo+'</div>'; }

function loadPerfil() {
