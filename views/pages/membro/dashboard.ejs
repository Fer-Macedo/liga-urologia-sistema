function loadFinanceiro() {
  var wrap = document.getElementById('fin-historico');
  if(!wrap) return;
  if(wrap.dataset.loaded) return;
  wrap.dataset.loaded = '1';
  wrap.innerHTML = '<div style="text-align:center;padding:20px;color:var(--ti)">Carregando...</div>';
  fetch('/membro/financeiro/dados', { credentials: 'same-origin' })
    .then(function(r){
      if(!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(data) {
      var cobs = data.cobrancas || [];
      if(!cobs.length) { wrap.innerHTML = '<div style="padding:20px;text-align:center;color:var(--ti)">Nenhuma cobranca encontrada.</div>'; return; }
      var hoje = new Date();
      var html = '';
      cobs.forEach(function(c) {
        var isPago = c.status === 'pago';
        var isAtrasado = c.status === 'atrasado';
        var statusCls = isPago ? 'c-ok' : isAtrasado ? 'c-er' : 'c-wa';
        var borderCor = isPago ? '#047857' : isAtrasado ? '#B91C1C' : '#B45309';
        var vencStr = (c.data_vencimento||'').substring(0,10);
        var vencParts = vencStr.split('-');
        // Desconto valido SOMENTE se hoje <= dia 15 do mes atual
        var dentroDesc = hoje.getDate() <= 15;
        var valorPagar = (!isPago && dentroDesc) ? c.valor_desconto : c.valor_cheio;
        html += '<div class="card" style="border-left:4px solid ' + borderCor + ';margin-bottom:12px;padding:16px">';
        html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">';
        var _mesesJs = ['JAN','FEV','MAR','ABR','MAI','JUN','JUL','AGO','SET','OUT','NOV','DEZ'];
        var _refParts = c.referencia.match(/^\d+-(\d{4})-(\d{2})$/);
        var _refLabel = _refParts ? _mesesJs[parseInt(_refParts[2])-1]+'/'+_refParts[1] : c.referencia;
        html += '<div style="font-size:15px;font-weight:800">' + _refLabel + '</div>';
        html += '<span class="chip ' + statusCls + '">' + (isPago ? 'Pago' : isAtrasado ? 'Atrasado' : 'Pendente') + '</span>';
        html += '</div>';
        html += '<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:12px">';
        html += '<div><div style="font-size:11px;color:var(--ts)">Vencimento</div><div style="font-weight:600">' + c.data_vencimento + '</div></div>';
        if(!isPago) {
          html += '<div><div style="font-size:11px;color:var(--ts)">' + (dentroDesc ? 'Com desconto (ate dia 15)' : 'Valor a pagar') + '</div>';
          html += '<div style="font-size:18px;font-weight:800;color:var(--ok)">R$ ' + Number(valorPagar).toFixed(2).replace('.', ',') + '</div></div>';
          if(dentroDesc) {
            html += '<div><div style="font-size:11px;color:var(--ts)">Sem desconto</div>';
            html += '<div style="font-size:13px;color:var(--ts);text-decoration:line-through">R$ ' + Number(c.valor_cheio).toFixed(2).replace('.', ',') + '</div></div>';
          }
        } else {
          html += '<div><div style="font-size:11px;color:var(--ts)">Valor pago</div>';
          html += '<div style="font-size:16px;font-weight:700;color:var(--ok)">R$ ' + Number(c.valor_cheio).toFixed(2).replace('.', ',') + '</div></div>';
          if(c.data_pagamento) {
            html += '<div><div style="font-size:11px;color:var(--ts)">Pago em</div><div style="color:var(--ok);font-weight:600">' + c.data_pagamento + '</div></div>';
          }
        }
        html += '</div>';
        if(!isPago && c.pix_copia_cola) {
          var pixEsc = c.pix_copia_cola.split("'").join("&apos;");
          html += '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px">';
          html += '<button class="btn btn-p" style="font-size:12px" onclick="copiarPixFin(this,this.dataset.pix)" data-pix="' + pixEsc + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><rect x="9" y="9" width="13" height="13"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copiar codigo PIX</button>';
          html += '<button class="btn" style="font-size:12px;opacity:.5;cursor:not-allowed" disabled title="Em breve"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Cartao <span style="font-size:9px;background:var(--vm);color:#fff;padding:1px 5px;margin-left:4px">Em breve</span></button>';
          html += '</div>';
          html += '<div style="font-size:9px;color:var(--ti);word-break:break-all;background:var(--bg);padding:6px;margin-top:4px">' + c.pix_copia_cola + '</div>';
        }
        html += '</div>';
      });
      wrap.innerHTML = html;
    })
    .catch(function(e) {
      wrap.dataset.loaded = '';
      wrap.innerHTML = '<div style="padding:20px;color:var(--er)">Erro ao carregar financeiro. Tente novamente.</div>';
      console.error('loadFinanceiro error:', e);
    });
}

