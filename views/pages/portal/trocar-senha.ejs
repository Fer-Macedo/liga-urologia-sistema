<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Trocar senha — Portal Cientifico</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Archivo:wght@700;800;900&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0;border-radius:0!important}
    body{font-family:'IBM Plex Sans',system-ui,sans-serif;background:#F0F4F2;color:#0C231B;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:32px 16px}
    input,button{font-family:inherit;border-radius:0!important}
    ::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:#C5D0C9}

    .wrap{width:100%;max-width:440px}
    .card{background:white;border:1px solid #DDE3DF;padding:24px}
    .card-header{display:flex;align-items:center;gap:10px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid #F0F4F2}
    .card-icon{width:36px;height:36px;background:#EBF5F0;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .card-title{font-size:15px;font-weight:700;color:#0C231B}
    .card-sub{font-size:12px;color:#6B7A72;margin-top:1px}

    .form-group{margin-bottom:14px}
    .form-label{display:block;font-size:10px;font-weight:700;color:#0C231B;margin-bottom:5px;text-transform:uppercase;letter-spacing:.08em}
    .form-input{width:100%;padding:10px 12px;border:1.5px solid #DDE3DF;font-size:14px;color:#0C231B;background:#F8FAF9;outline:none;transition:border-color .15s}
    .form-input:focus{border-color:#0F6E56;background:white}

    .form-actions{display:flex;gap:8px;margin-top:20px}
    .btn-green{flex:1;padding:10px;background:#0F6E56;color:white;border:none;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s}
    .btn-green:hover{background:#0d5e49}
    .btn-secondary{padding:10px 16px;background:white;color:#0C231B;border:1.5px solid #DDE3DF;font-size:13px;font-weight:500;cursor:pointer;transition:background .15s;text-decoration:none;display:inline-flex;align-items:center}
    .btn-secondary:hover{background:#F8FAF9}

    .alert-err{padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;font-size:13px;margin-bottom:16px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <div class="card-header">
        <div class="card-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0F6E56" stroke-width="2" stroke-linecap="square"><rect x="3" y="11" width="18" height="11" rx="0" ry="0"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <div class="card-title">Defina sua senha</div>
          <div class="card-sub">Este e seu primeiro acesso. Crie uma senha pessoal para continuar.</div>
        </div>
      </div>
      <%if(erro&&erro.length){%><div class="alert-err"><%=erro[0]%></div><%}%>
      <form method="POST" action="<%=baseUrl%>/trocar-senha">
        <div class="form-group">
          <label class="form-label">Nova senha</label>
          <input type="password" name="nova_senha" class="form-input" required minlength="6" placeholder="Minimo 6 caracteres">
        </div>
        <div class="form-group">
          <label class="form-label">Confirmar nova senha</label>
          <input type="password" name="confirmar_senha" class="form-input" required minlength="6" placeholder="Repita a senha">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-green">Salvar e entrar</button>
          <a href="/portal/login" class="btn-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
