<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="shortcut icon" href="/favicon.ico">
  <title>Portal Cientifico — Acesso</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Archivo:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'IBM Plex Sans',system-ui,sans-serif;background:#0C231B;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
    .login-wrap{width:100%;max-width:400px}
    .login-brand{text-align:center;margin-bottom:32px}
    .login-brand-logo{width:64px;height:64px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;overflow:hidden}
    .login-brand-logo img{width:100%;height:100%;object-fit:cover;border-radius:50%}
    .login-brand h1{font-family:'Archivo',sans-serif;font-size:20px;font-weight:800;color:#fff;letter-spacing:.3px}
    .login-brand p{font-size:12px;color:#5E7A6D;margin-top:4px;text-transform:uppercase;letter-spacing:2px}
    .login-card{background:#fff;padding:32px}
    .login-card h2{font-size:16px;font-weight:700;color:#0C231B;margin-bottom:6px}
    .login-card p{font-size:13px;color:#6B7A72;margin-bottom:24px}
    .form-group{margin-bottom:16px}
    .form-group label{display:block;font-size:11.5px;font-weight:600;color:#4A5568;text-transform:uppercase;letter-spacing:.7px;margin-bottom:6px}
    .form-group input{width:100%;padding:10px 13px;border:1.5px solid #DDE3DF;background:#F8FAF9;color:#0C231B;font-size:14px;font-family:inherit;border-radius:0;outline:none;transition:.15s}
    .form-group input:focus{border-color:#0F6E56;background:#fff}
    .btn-login{width:100%;padding:11px;background:#0F6E56;color:#fff;font-size:14px;font-weight:700;border:none;cursor:pointer;font-family:inherit;letter-spacing:.3px;margin-top:8px}
    .btn-login:hover{background:#0a5240}
    .forgot{text-align:center;margin-top:16px}
    .forgot a{font-size:12.5px;color:#0F6E56;text-decoration:none}
    .forgot a:hover{text-decoration:underline}
    .alert-err{padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;font-size:13px;margin-bottom:16px}
    .portal-info{text-align:center;margin-top:20px;font-size:12px;color:#5E7A6D}
  </style>
</head>
<body>
<div class="login-wrap">
  <div class="login-brand">
    <div class="login-brand-logo">
      <%if(config.org_logo){%><img src="<%=config.org_logo%>" alt="Logo"><%}else{%><span style="font-family:'Archivo';font-weight:800;color:#0F6E56;font-size:20px">LU</span><%}%>
    </div>
    <h1><%=config.org_nome||'LAURO'%></h1>
    <p>Portal Cientifico</p>
  </div>
  <div class="login-card">
    <h2>Acesso ao Portal</h2>
    <p>Use o email cadastrado no sistema para entrar</p>
    <%if(erro&&erro.length){%><div class="alert-err"><%=erro[0]%></div><%}%>
    <form method="POST" action="/portal/login">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" required placeholder="seu@email.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label>Senha</label>
        <input type="password" name="senha" required placeholder="Sua senha" autocomplete="current-password">
      </div>
      <button type="submit" class="btn-login">Entrar</button>
    </form>
    <div class="forgot"><a href="/portal/esqueci-senha">Esqueci minha senha</a></div>
  </div>
  <div class="portal-info">Acesso exclusivo para membros da liga</div>
</div>
</body></html>
