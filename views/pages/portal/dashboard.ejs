<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="shortcut icon" href="/favicon.ico">
  <title>Meus Grupos — Portal Cientifico</title>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Archivo:wght@700;800&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'IBM Plex Sans',system-ui,sans-serif;background:#F0F4F2;min-height:100vh}
    .topbar{background:#0C231B;padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
    .topbar-brand{display:flex;align-items:center;gap:10px}
    .topbar-logo{width:32px;height:32px;background:#fff;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center}
    .topbar-logo img{width:100%;height:100%;object-fit:cover;border-radius:50%}
    .topbar-nome{font-family:'Archivo',sans-serif;font-weight:800;font-size:14px;color:#fff}
    .topbar-sub{font-size:10px;color:#5E7A6D;text-transform:uppercase;letter-spacing:2px;margin-top:1px}
    .topbar-user{display:flex;align-items:center;gap:10px}
    .topbar-user span{font-size:12.5px;color:#CFE0D7}
    .topbar-logout{font-size:12px;color:#8FA89C;text-decoration:none;padding:5px 10px;border:1px solid rgba(255,255,255,.15)}
    .topbar-logout:hover{color:#fff;border-color:rgba(255,255,255,.4)}
    .main{max-width:900px;margin:0 auto;padding:32px 20px}
    .pg-title{font-size:20px;font-weight:700;color:#0C231B;margin-bottom:6px}
    .pg-sub{font-size:13px;color:#6B7A72;margin-bottom:28px}
    .grupos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .grupo-card{background:#fff;border:1px solid #DDE3DF;padding:22px;text-decoration:none;display:block;transition:.15s}
    .grupo-card:hover{border-color:#0F6E56;box-shadow:0 2px 12px rgba(15,110,86,.1)}
    .grupo-proj{font-size:11px;font-weight:600;color:#5E7A6D;text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px}
    .grupo-nome{font-size:15px;font-weight:700;color:#0C231B;margin-bottom:10px;line-height:1.3}
    .grupo-meta{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
    .grupo-meta span{font-size:12px;color:#6B7A72;display:flex;align-items:center;gap:5px}
    .vstatus{display:inline-flex;padding:3px 9px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid}
    .vstatus-aguardando{background:#f8fafc;color:#64748b;border-color:#cbd5e1}
    .vstatus-em_revisao{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
    .vstatus-devolvido{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .vstatus-aprovado{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
    .grupo-cta{font-size:12.5px;font-weight:600;color:#0F6E56;display:flex;align-items:center;gap:5px}
    .empty{text-align:center;padding:60px 20px;color:#6B7A72}
    .empty h3{font-size:16px;font-weight:600;color:#0C231B;margin:12px 0 8px}
    .alert-ok{padding:10px 14px;background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:13px;margin-bottom:20px}
    @media(max-width:600px){.grupos-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
<div class="topbar">
  <div class="topbar-brand">
    <div class="topbar-logo"><%if(config.org_logo){%><img src="<%=config.org_logo%>" alt=""><%}else{%><span style="font-family:'Archivo';font-weight:800;color:#0F6E56;font-size:13px">LU</span><%}%></div>
    <div><div class="topbar-nome"><%=config.org_nome||'LAURO'%></div><div class="topbar-sub">Portal Cientifico</div></div>
  </div>
  <div class="topbar-user">
    <span><%=membro.nome%></span>
    <a href="/portal/logout" class="topbar-logout">Sair</a>
  </div>
</div>
<div class="main">
  <%if(msg&&msg.length){%><div class="alert-ok"><%=msg[0]%></div><%}%>
  <div class="pg-title">Meus Grupos</div>
  <div class="pg-sub">Projetos cientificos nos quais voce esta participando</div>
  <%if(grupos.length===0){%>
  <div class="empty">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#DDE3DF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    <h3>Nenhum grupo ainda</h3>
    <p>Voce sera adicionado a grupos pela coordenacao da liga. Aguarde o contato.</p>
  </div>
  <%}else{%>
  <div class="grupos-grid">
    <%grupos.forEach(function(g){%>
    <a href="/portal/grupo/<%=g.grupo_id%>" class="grupo-card">
      <div class="grupo-proj"><%=g.projeto_titulo%></div>
      <div class="grupo-nome"><%=g.grupo_nome%></div>
      <div class="grupo-meta">
        <%if(g.prazo){%><span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><%=new Date(g.prazo).toLocaleDateString('pt-BR')%></span><%}%>
        <%if(g.ultimo_status){%><span class="vstatus vstatus-<%=g.ultimo_status%>"><%=g.ultimo_status.replace('_',' ')%></span><%}%>
      </div>
      <div class="grupo-cta">Acessar grupo <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
    </a>
    <%})%>
  </div>
  <%}%>
</div>
</body></html>
