<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro de Diretivo — <%= config.org_nome || 'Liga Acadêmica de Urologia' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
    body { background: #f0f4ff; min-height: 100vh; padding: 32px 16px; }
    .container { max-width: 720px; margin: 0 auto; }
    .header { text-align: center; margin-bottom: 32px; }
    .logo { max-height: 80px; max-width: 200px; object-fit: contain; margin-bottom: 16px; }
    .header h1 { font-size: 24px; font-weight: 700; color: #1a56db; margin-bottom: 6px; }
    .header p { color: #6b7280; font-size: 14px; }
    .card { background: white; border-radius: 16px; padding: 32px; box-shadow: 0 4px 24px rgba(0,0,0,0.07); margin-bottom: 20px; }
    .card-titulo { font-size: 15px; font-weight: 700; color: #1a56db; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e5e7eb; display: flex; align-items: center; gap: 8px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-1 { grid-template-columns: 1fr; }
    .grid-3 { grid-template-columns: 1fr 1fr 1fr; }
    .campo { display: flex; flex-direction: column; gap: 6px; }
    .campo.full { grid-column: 1 / -1; }
    label { font-size: 13px; font-weight: 600; color: #374151; }
    label span { color: #ef4444; margin-left: 2px; }
    input, select, textarea { padding: 10px 14px; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: 14px; color: #111827; background: #f9fafb; transition: border-color 0.2s, box-shadow 0.2s; font-family: 'Inter', sans-serif; }
    input:focus, select:focus, textarea:focus { outline: none; border-color: #1a56db; box-shadow: 0 0 0 3px rgba(26,86,219,0.1); background: white; }
    textarea { resize: vertical; min-height: 80px; }
    .radio-group { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 4px; }
    .radio-option { display: flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1.5px solid #e5e7eb; border-radius: 8px; cursor: pointer; font-size: 13px; transition: all 0.2s; }
    .radio-option input { width: auto; margin: 0; }
    .radio-option:has(input:checked) { border-color: #1a56db; background: #eff6ff; color: #1a56db; font-weight: 600; }
    .checkbox-group { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
    .checkbox-option { display: flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1.5px solid #e5e7eb; border-radius: 8px; cursor: pointer; font-size: 13px; transition: all 0.2s; }
    .checkbox-option input { width: auto; margin: 0; }
    .checkbox-option:has(input:checked) { border-color: #1a56db; background: #eff6ff; color: #1a56db; font-weight: 600; }
    .btn-submit { width: 100%; padding: 14px; background: linear-gradient(135deg, #1a56db, #1e40af); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s; margin-top: 8px; }
    .btn-submit:hover { opacity: 0.95; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(26,86,219,0.3); }
    .alerta { padding: 14px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 14px; font-weight: 500; }
    .alerta-ok { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
    .alerta-erro { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .footer { text-align: center; margin-top: 24px; color: #9ca3af; font-size: 12px; }
    #campos-transporte { display: none; margin-top: 12px; }
    @media (max-width: 600px) { .grid, .grid-3 { grid-template-columns: 1fr; } .card { padding: 20px; } }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <% if (config.org_logo) { %>
      <img src="<%= config.org_logo %>" alt="<%= config.org_nome %>" class="logo">
    <% } %>
    <h1>Cadastro de Diretivo</h1>
    <p><%= config.org_nome || 'Liga Acadêmica de Urologia' %> — Preencha todos os campos obrigatórios</p>
  </div>

  <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> <%= msg[0] %></div><% } %>
  <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> <%= erro[0] %></div><% } %>

  <form action="/cadastro-diretivo" method="POST" enctype="multipart/form-data" onsubmit="validarForm(event)">

    <!-- DADOS PESSOAIS -->
    <div class="card">
      <div class="card-titulo"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Dados Pessoais</div>
      <div class="grid">
        <div class="campo full">
          <label>Nome Completo <span>*</span></label>
          <input name="nome" required placeholder="Seu nome completo" value="<%= form.nome || '' %>">
        </div>
        <div class="campo">
          <label>RG / C.I. <span>*</span></label>
          <input name="rg" required placeholder="Número do RG ou CI" value="<%= form.rg || '' %>">
        </div>
        <div class="campo">
          <label>CPF</label>
          <input name="cpf" placeholder="000.000.000-00" oninput="this.value=mascaraCPF(this.value)" value="<%= form.cpf || '' %>">
        </div>
        <div class="campo">
          <label>Data de Nascimento <span>*</span></label>
          <input name="data_nascimento" type="date" required value="<%= form.data_nascimento || '' %>">
        </div>
        <div class="campo">
          <label>E-mail <span>*</span></label>
          <input name="email" type="email" required placeholder="seu@email.com" value="<%= form.email || '' %>">
        </div>
        <div class="campo">
          <label>WhatsApp / Telefone <span>*</span></label>
          <div style="display:flex;gap:8px">
            <select name="ddi" style="width:130px;flex-shrink:0;padding:10px 8px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:13px;background:#f9fafb">
              <option value="+595" <%= (form.ddi||'+595')==='+595'?'selected':'' %>>🇵🇾 +595</option>
              <option value="+55" <%= (form.ddi||'')==='+55'?'selected':'' %>>🇧🇷 +55</option>
              <option value="+54" <%= (form.ddi||'')==='+54'?'selected':'' %>>🇦🇷 +54</option>
              <option value="+1" <%= (form.ddi||'')==='+1'?'selected':'' %>>🇺🇸 +1</option>
              <option value="+351" <%= (form.ddi||'')==='+351'?'selected':'' %>>🇵🇹 +351</option>
              <option value="+598" <%= (form.ddi||'')==='+598'?'selected':'' %>>🇺🇾 +598</option>
              <option value="+56" <%= (form.ddi||'')==='+56'?'selected':'' %>>🇨🇱 +56</option>
              <option value="+57" <%= (form.ddi||'')==='+57'?'selected':'' %>>🇨🇴 +57</option>
            </select>
            <input name="whatsapp_num" required placeholder="(00) 00000-0000" value="<%= form.whatsapp_num || form.whatsapp || '' %>" style="flex:1">
          </div>
        </div>
        <div class="campo">
          <label>Instagram</label>
          <input name="instagram" placeholder="@seuinstagram" value="<%= form.instagram || '' %>">
        </div>
        <div class="campo">
          <label>Onde reside? <span>*</span></label>
          <input name="onde_reside" required placeholder="Cidade, Estado / País" value="<%= form.onde_reside || '' %>">
        </div>
      </div>
    </div>

    <!-- DADOS ACADÊMICOS -->
    <div class="card">
      <div class="card-titulo"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg> Dados Acadêmicos</div>
      <div class="grid">
        <div class="campo">
          <label>Catraca (matrícula)</label>
          <input name="catraca" placeholder="Número da catraca" value="<%= form.catraca || '' %>">
        </div>
        <div class="campo">
          <label>Ano de Ingresso na Universidade <span>*</span></label>
          <input name="ano_ingresso" required placeholder="Ex: 2025.1" value="<%= form.ano_ingresso || '' %>">
        </div>
        <div class="campo">
          <label>Semestre / Turma atual <span>*</span></label>
          <input name="semestre_turma" required placeholder="Ex: 2B, 5A, 7C..." value="<%= form.semestre_turma || '' %>">
        </div>
        <div class="campo">
          <label>ORCID</label>
          <input name="orcid" placeholder="0000-0000-0000-0000" value="<%= form.orcid || '' %>">
        </div>
        <div class="campo full">
          <label>Já possui alguma graduação ou curso técnico? Qual?</label>
          <input name="graduacao" placeholder="Ex: Técnico em Enfermagem, Bacharel em..." value="<%= form.graduacao || '' %>">
        </div>
        <div class="campo full">
          <label>Tem experiência com Urologia e afins?</label>
          <textarea name="experiencia_urologia" placeholder="Descreva sua experiência, se houver..."><%= form.experiencia_urologia || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- DADOS DA LIGA -->
    <div class="card">
      <div class="card-titulo">🏥 Dados na Liga</div>
      <div class="grid">
        <div class="campo full">
          <label>Cargo na Liga <span>*</span></label>
          <select name="cargo" required>
            <option value="">Selecione seu cargo...</option>
            <option value="Presidente(a)" <%= form.cargo === 'Presidente(a)' ? 'selected' : '' %>>👑 Presidente(a)</option>
            <option value="Vice-presidente(a)" <%= form.cargo === 'Vice-presidente(a)' ? 'selected' : '' %>>🥈 Vice-presidente(a)</option>
            <option value="Secretário(a)" <%= form.cargo === 'Secretário(a)' ? 'selected' : '' %>><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg> Secretário(a)</option>
            <option value="Diretor(a) Financeiro(a)" <%= form.cargo === 'Diretor(a) Financeiro(a)' ? 'selected' : '' %>>💰 Diretor(a) Financeiro(a)</option>
            <option value="Diretor(a) Científico" <%= form.cargo === 'Diretor(a) Científico' ? 'selected' : '' %>>🔬 Diretor(a) Científico</option>
            <option value="Vice Diretor(a) Científico" <%= form.cargo === 'Vice Diretor(a) Científico' ? 'selected' : '' %>>🔬 Vice Diretor(a) Científico</option>
            <option value="Diretor(a) de Extensão" <%= form.cargo === 'Diretor(a) de Extensão' ? 'selected' : '' %>>🌐 Diretor(a) de Extensão</option>
            <option value="Vice Diretor(a) de Extensão" <%= form.cargo === 'Vice Diretor(a) de Extensão' ? 'selected' : '' %>>🌐 Vice Diretor(a) de Extensão</option>
            <option value="Diretor(a) de Ensino" <%= form.cargo === 'Diretor(a) de Ensino' ? 'selected' : '' %>><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg> Diretor(a) de Ensino</option>
            <option value="Vice Diretor(a) de Ensino" <%= form.cargo === 'Vice Diretor(a) de Ensino' ? 'selected' : '' %>><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg> Vice Diretor(a) de Ensino</option>
            <option value="Diretor(a) de Marketing" <%= form.cargo === 'Diretor(a) de Marketing' ? 'selected' : '' %>>📣 Diretor(a) de Marketing</option>
            <option value="Vice Diretor(a) de Marketing" <%= form.cargo === 'Vice Diretor(a) de Marketing' ? 'selected' : '' %>>📣 Vice Diretor(a) de Marketing</option>
          </select>
        </div>
        <div class="campo full">
          <label>Disponibilidade <span>*</span></label>
          <div class="checkbox-group">
            <label class="checkbox-option"><input type="checkbox" name="disponibilidade" value="Manhã" <%= (form.disponibilidade||'').includes('Manhã') ? 'checked' : '' %>> 🌅 Manhã</label>
            <label class="checkbox-option"><input type="checkbox" name="disponibilidade" value="Tarde" <%= (form.disponibilidade||'').includes('Tarde') ? 'checked' : '' %>> ☀️ Tarde</label>
            <label class="checkbox-option"><input type="checkbox" name="disponibilidade" value="Noite" <%= (form.disponibilidade||'').includes('Noite') ? 'checked' : '' %>> 🌙 Noite</label>
            <label class="checkbox-option"><input type="checkbox" name="disponibilidade" value="Integral" <%= (form.disponibilidade||'').includes('Integral') ? 'checked' : '' %>> 🕐 Integral</label>
          </div>
        </div>
        <div class="campo">
          <label>Possui Transporte Próprio? <span>*</span></label>
          <div class="radio-group">
            <label class="radio-option"><input type="radio" name="transporte_proprio" value="Sim" onchange="toggleTransporte(true)" <%= form.transporte_proprio === 'Sim' ? 'checked' : '' %>> Sim</label>
            <label class="radio-option"><input type="radio" name="transporte_proprio" value="Não" onchange="toggleTransporte(false)" <%= form.transporte_proprio === 'Não' ? 'checked' : '' %>> Não</label>
          </div>
          <div id="campos-transporte">
            <label style="margin-top:8px">Se SIM, qual tipo?</label>
            <input name="tipo_transporte" placeholder="Ex: Carro, Moto, Bicicleta..." value="<%= form.tipo_transporte || '' %>">
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-titulo"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto do Diretivo</div>
      <div class="campo full">
        <label>Foto (JPG, PNG ou WebP — opcional)</label>
        <input type="file" name="foto" accept="image/*" style="padding:8px;background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px">
        <div style="font-size:12px;color:#6b7280;margin-top:4px">Envie uma foto de perfil para facilitar sua identificação.</div>
      </div>
    </div>
    <button type="submit" class="btn-submit"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Enviar Cadastro</button>
  </form>

  <div class="footer">
    <%= config.org_nome || 'Liga Acadêmica de Urologia' %> — Cadastro registrado em <%= new Date(new Date().toLocaleString('en-US',{timeZone:'America/Asuncion'})).toLocaleString('pt-BR') %>
  </div>
</div>

<script>
// ── Validação CPF ──
function validarCPF(cpf) {
  cpf = cpf.replace(/[^\d]/g,'');
  if (cpf.length !== 11 || /^(\d)+$/.test(cpf)) return false;
  let soma = 0;
  for (let i=0; i<9; i++) soma += parseInt(cpf[i])*(10-i);
  let r = (soma*10)%11; if(r===10||r===11) r=0;
  if(r !== parseInt(cpf[9])) return false;
  soma=0;
  for (let i=0; i<10; i++) soma += parseInt(cpf[i])*(11-i);
  r = (soma*10)%11; if(r===10||r===11) r=0;
  return r === parseInt(cpf[10]);
}

// ── Validação Email ──
function validarEmail(e) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }

// ── Máscara CPF ──
function mascaraCPF(v) {
  v=v.replace(/\D/g,'').substring(0,11);
  if(v.length>9) v=v.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/,'$1.$2.$3-$4');
  else if(v.length>6) v=v.replace(/(\d{3})(\d{3})(\d+)/,'$1.$2.$3');
  else if(v.length>3) v=v.replace(/(\d{3})(\d+)/,'$1.$2');
  return v;
}

// ── Validação formulário ──
function validarForm(e) {
  const erros = [];
  const nome = document.querySelector('[name=nome]').value.trim();
  const cpf = document.querySelector('[name=cpf]')?.value.trim();
  const email = document.querySelector('[name=email]').value.trim();
  const whatsapp = document.querySelector('[name=whatsapp]').value.trim();
  const rg = document.querySelector('[name=rg]')?.value.trim();
  const nascimento = document.querySelector('[name=data_nascimento]')?.value;

  if (nome.length < 5) erros.push('Nome completo muito curto (mínimo 5 caracteres).');
  if (!/^[a-zA-ZÀ-ÿ\s]+$/.test(nome)) erros.push('Nome deve conter apenas letras.');
  if (cpf && cpf.replace(/\D/g,'').length > 0 && !validarCPF(cpf)) erros.push('CPF inválido. Verifique o número digitado.');
  if (!validarEmail(email)) erros.push('E-mail inválido.');
  if (whatsapp.replace(/\D/g,'').length < 8) erros.push('WhatsApp/telefone muito curto.');
  if (rg && rg.length < 5) erros.push('RG/CI muito curto.');
  if (nascimento) {
    const dn = new Date(nascimento);
    const hoje = new Date();
    const idade = (hoje-dn)/(1000*60*60*24*365.25);
    if (idade < 14 || idade > 80) erros.push('Data de nascimento inválida.');
  }

  if (erros.length > 0) {
    e.preventDefault();
    let div = document.getElementById('erros-validacao');
    if (!div) { div = document.createElement('div'); div.id='erros-validacao'; div.className='alerta alerta-erro'; document.querySelector('form').prepend(div); }
    div.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> ' + erros.join('<br><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> ');
    div.scrollIntoView({behavior:'smooth',block:'center'});
  }
}

function toggleTransporte(sim) {
  document.getElementById('campos-transporte').style.display = sim ? 'block' : 'none';
}
window.addEventListener('load', function() {
  const sim = document.querySelector('input[name="transporte_proprio"][value="Sim"]');
  if (sim && sim.checked) toggleTransporte(true);
});
</script>
</body>
</html>
