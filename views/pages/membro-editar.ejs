<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Membro — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .phone-wrap { display:flex; gap:8px; align-items:flex-start; }
    .phone-pais { width:180px; flex-shrink:0; }
    .phone-numero { flex:1; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'membros' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Editar membro</h1>
      <a href="/membros" class="btn">← Voltar</a>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>
      <div class="config-secao">
        <form action="/membros/<%= membro.id %>/editar" method="POST" id="formMembro">
          <div class="form-grid">
            <div class="campo full">
              <label class="label">Nome completo *</label>
              <input name="nome" class="input" value="<%= membro.nome %>" required>
            </div>
            <div class="campo">
              <label class="label">CPF</label>
              <input name="cpf" class="input" value="<%= membro.cpf || '' %>" placeholder="000.000.000-00">
            </div>
            <div class="campo">
              <label class="label">Data de nascimento</label>
              <input name="data_nascimento" type="date" class="input" value="<%= membro.data_nascimento || '' %>">
            </div>
            <div class="campo">
              <label class="label">E-mail</label>
              <input name="email" type="email" class="input" value="<%= membro.email || '' %>">
            </div>

            <!-- CAMPO WHATSAPP INTERNACIONAL -->
            <div class="campo full">
              <label class="label">WhatsApp</label>
              <div class="phone-wrap">
                <select id="paisCodigo" class="input phone-pais" onchange="atualizarWhatsapp()">
                  <option value="55" data-flag="🇧🇷">🇧🇷 Brasil (+55)</option>
                  <option value="595" data-flag="🇵🇾">🇵🇾 Paraguai (+595)</option>
                  <option value="54" data-flag="🇦🇷">🇦🇷 Argentina (+54)</option>
                  <option value="598" data-flag="🇺🇾">🇺🇾 Uruguai (+598)</option>
                  <option value="591" data-flag="🇧🇴">🇧🇴 Bolívia (+591)</option>
                  <option value="56" data-flag="🇨🇱">🇨🇱 Chile (+56)</option>
                  <option value="57" data-flag="🇨🇴">🇨🇴 Colômbia (+57)</option>
                  <option value="51" data-flag="🇵🇪">🇵🇪 Peru (+51)</option>
                  <option value="58" data-flag="🇻🇪">🇻🇪 Venezuela (+58)</option>
                  <option value="1" data-flag="🇺🇸">🇺🇸 EUA/Canadá (+1)</option>
                  <option value="351" data-flag="🇵🇹">🇵🇹 Portugal (+351)</option>
                  <option value="34" data-flag="🇪🇸">🇪🇸 Espanha (+34)</option>
                  <option value="39" data-flag="🇮🇹">🇮🇹 Itália (+39)</option>
                  <option value="49" data-flag="🇩🇪">🇩🇪 Alemanha (+49)</option>
                  <option value="33" data-flag="🇫🇷">🇫🇷 França (+33)</option>
                  <option value="44" data-flag="🇬🇧">🇬🇧 Reino Unido (+44)</option>
                  <option value="81" data-flag="🇯🇵">🇯🇵 Japão (+81)</option>
                  <option value="outro" data-flag="🌍">🌍 Outro país</option>
                </select>
                <input id="numeroWhatsapp" class="input phone-numero"
                  placeholder="DDD + número"
                  oninput="atualizarWhatsapp()">
              </div>
              <input type="hidden" name="whatsapp" id="whatsappFinal">
              <div id="previewWhatsapp" style="font-size:11px;color:var(--texto2);margin-top:4px"></div>
            </div>

            <div class="campo">
              <label class="label">Mensalidade (R$)</label>
              <input name="mensalidade" type="number" step="0.01" class="input" value="<%= membro.mensalidade %>">
            </div>
            <div class="campo">
              <label class="label">Desconto pontualidade (%)</label>
              <input name="desconto_pontualidade" type="number" class="input" value="<%= membro.desconto_pontualidade %>">
            </div>
            <div class="campo">
              <label class="label">Dia de vencimento</label>
              <input name="dia_vencimento" type="number" min="1" max="28" class="input" value="<%= membro.dia_vencimento %>">
            </div>
            <div class="campo">
              <label class="label">Status</label>
              <select name="ativo" class="input">
                <option value="1" <%= membro.ativo == 1 ? 'selected' : '' %>>Ativo</option>
                <option value="0" <%= membro.ativo == 0 ? 'selected' : '' %>>Inativo</option>
              </select>
            </div>
            <div class="campo full">
              <label class="label">Observações</label>
              <textarea name="observacoes" class="input" rows="3"><%= membro.observacoes || '' %></textarea>
            </div>
          </div>
          <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px">
            <a href="/membros" class="btn">Cancelar</a>
            <button type="submit" class="btn btn-primario">Salvar alterações</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>
<script src="/js/app.js"></script>
<script>
// Carrega o numero atual do membro
const whatsappAtual = '<%= membro.whatsapp || "" %>'.replace(/\D/g,'');

function detectarPaisENumero(numero) {
  const codigos = ['595','351','598','591','55','56','57','51','58','54','44','49','33','39','34','81','1'];
  for (const cod of codigos) {
    if (numero.startsWith(cod)) {
      return { codigo: cod, numero: numero.slice(cod.length) };
    }
  }
  return { codigo: '55', numero: numero };
}

// Inicializa o campo com o valor atual
if (whatsappAtual) {
  const { codigo, numero } = detectarPaisENumero(whatsappAtual);
  const select = document.getElementById('paisCodigo');
  for (let i = 0; i < select.options.length; i++) {
    if (select.options[i].value === codigo) {
      select.selectedIndex = i;
      break;
    }
  }
  document.getElementById('numeroWhatsapp').value = numero;
  atualizarWhatsapp();
}

function atualizarWhatsapp() {
  const pais = document.getElementById('paisCodigo').value;
  const numero = document.getElementById('numeroWhatsapp').value.replace(/\D/g,'');
  const preview = document.getElementById('previewWhatsapp');
  const hidden = document.getElementById('whatsappFinal');

  if (pais === 'outro') {
    // Campo livre para digitar o numero completo com codigo do pais
    document.getElementById('numeroWhatsapp').placeholder = 'Código do país + número completo';
    hidden.value = numero;
    preview.textContent = numero ? 'Número completo: +' + numero : '';
  } else {
    document.getElementById('numeroWhatsapp').placeholder = 'DDD + número';
    const completo = pais + numero;
    hidden.value = completo;
    preview.textContent = numero ? 'Número completo: +' + completo : '';
  }
}

// Garante que o whatsapp seja enviado antes do submit
document.getElementById('formMembro').addEventListener('submit', function() {
  atualizarWhatsapp();
});
</script>
</body></html>
