<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — Gerenciar</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .tab-nav { display:flex; gap:4px; margin-bottom:20px; border-bottom:2px solid var(--borda); padding-bottom:0; flex-wrap:wrap; }
    .tab-btn { padding:9px 14px; border:none; background:none; cursor:pointer; font-weight:600; font-size:13px; color:var(--texto2); border-bottom:2px solid transparent; margin-bottom:-2px; white-space:nowrap; }
    .tab-btn.ativo { color:var(--cor-primaria); border-bottom-color:var(--cor-primaria); }
    .tab-content { display:none; }
    .tab-content.ativo { display:block; }
    .lote-card { background:var(--fundo); border:1px solid var(--borda); border-radius:8px; padding:12px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
    .badge { padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
    .campo-card { background:var(--fundo); border:1px solid var(--borda); border-radius:8px; padding:10px 12px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; }
    .patroc-card { background:var(--fundo); border:1px solid var(--borda); border-radius:8px; padding:10px 12px; margin-bottom:8px; display:flex; align-items:center; gap:12px; }
    .prog-card { border-left:3px solid var(--cor-primaria); padding:10px 14px; background:var(--fundo); border-radius:0 8px 8px 0; margin-bottom:8px; }
    .pales-card { background:var(--fundo); border:1px solid var(--borda); border-radius:8px; padding:12px; margin-bottom:8px; display:flex; gap:12px; align-items:center; }
    .pales-foto { width:50px; height:50px; border-radius:50%; object-fit:cover; background:var(--borda); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
    .cores-paleta { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:8px; }
    .cor-dot { width:28px; height:28px; border-radius:6px; cursor:pointer; border:3px solid transparent; transition:.2s; }
    .cor-dot:hover { transform:scale(1.1); }
    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
    @media(max-width:600px){.grid-2,.grid-3{grid-template-columns:1fr}}
    .stat-box { background:var(--card); border:1px solid var(--borda); border-radius:10px; padding:16px; text-align:center; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'eventos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo" style="font-size:16px">⚙️ <%= evento.nome %></h1>
      <div class="topbar-acoes">
        <a href="/eventos" class="btn">← Voltar</a>
        <a href="/inscricao/<%= evento.id %>" target="_blank" class="btn" style="background:#059669;color:white">🔗 Pág. Pública</a>
        <a href="/eventos/<%= evento.id %>/checkin" class="btn btn-primario">✅ Check-in</a>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- Stats -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-bottom:18px">
        <div class="stat-box"><div style="font-size:22px;font-weight:700;color:var(--cor-primaria)"><%= stats.total %></div><div style="font-size:11px;color:var(--texto2)">Inscritos</div></div>
        <div class="stat-box"><div style="font-size:22px;font-weight:700;color:#059669"><%= stats.confirmados %></div><div style="font-size:11px;color:var(--texto2)">Confirmados</div></div>
        <div class="stat-box"><div style="font-size:22px;font-weight:700;color:#6366f1"><%= stats.checkins %></div><div style="font-size:11px;color:var(--texto2)">Check-ins</div></div>
        <div class="stat-box"><div style="font-size:22px;font-weight:700;color:#f59e0b">R$ <%= Number(stats.receita||0).toFixed(2) %></div><div style="font-size:11px;color:var(--texto2)">Receita</div></div>
        <div class="stat-box"><div style="font-size:22px;font-weight:700;color:#dc2626"><%= evento.vagas_total - stats.total %></div><div style="font-size:11px;color:var(--texto2)">Vagas livres</div></div>
      </div>

      <div class="tab-nav">
        <button class="tab-btn ativo" onclick="showTab('info')">📋 Info</button>
        <button class="tab-btn" onclick="showTab('lotes')">🎫 Lotes</button>
        <button class="tab-btn" onclick="showTab('campos')">📝 Campos</button>
        <button class="tab-btn" onclick="showTab('inscritos')">👥 Inscritos</button>
        <button class="tab-btn" onclick="showTab('pagamentos')">💰 Pagamentos</button>
        <button class="tab-btn" onclick="showTab('programacao')">🗓️ Programação</button>
        <button class="tab-btn" onclick="showTab('palestrantes')">🎤 Palestrantes</button>
        <button class="tab-btn" onclick="showTab('patrocinadores')">🤝 Patrocinadores</button>
        <button class="tab-btn" onclick="showTab('certificados')">🏆 Certificados</button>
        <button class="tab-btn" onclick="showTab('avancado')">🔧 Avançado</button>
      </div>

      <!-- INFO -->
      <div class="tab-content ativo" id="tab-info">
        <div class="card">
          <div class="card-titulo">✏️ Editar Evento</div>
          <form action="/eventos/<%= evento.id %>/editar" method="POST" enctype="multipart/form-data">
            <div class="grid-2">
              <div class="campo" style="grid-column:1/-1"><label class="label">Nome do Evento</label><input name="nome" class="input" value="<%= evento.nome %>" required></div>
              <div class="campo" style="grid-column:1/-1">
                <label class="label">Descrição</label>
                <div id="editor-desc" style="height:200px;background:white;border-radius:8px"><%- evento.descricao||'' %></div>
                <input type="hidden" name="descricao" id="descricao-hidden">
              </div>
              <div class="campo"><label class="label">Data/Hora Início</label><input type="datetime-local" name="data_inicio" class="input" value="<%= evento.data_inicio?new Date(evento.data_inicio).toISOString().slice(0,16):'' %>"></div>
              <div class="campo"><label class="label">Data/Hora Fim</label><input type="datetime-local" name="data_fim" class="input" value="<%= evento.data_fim?new Date(evento.data_fim).toISOString().slice(0,16):'' %>"></div>
              <div class="campo"><label class="label">Local</label><input name="local" class="input" value="<%= evento.local||'' %>"></div>
              <div class="campo"><label class="label">Total de Vagas</label><input type="number" name="vagas_total" class="input" value="<%= evento.vagas_total %>"></div>
              <div class="campo" style="grid-column:1/-1"><label class="label">Endereço</label><input name="endereco" class="input" value="<%= evento.endereco||'' %>"></div>
              <div class="campo"><label class="label">Tipo</label>
                <select name="tipo_evento" class="input">
                  <option value="presencial" <%= evento.tipo_evento==='presencial'?'selected':'' %>>📍 Presencial</option>
                  <option value="online" <%= evento.tipo_evento==='online'?'selected':'' %>>💻 Online</option>
                  <option value="hibrido" <%= evento.tipo_evento==='hibrido'?'selected':'' %>>🔀 Híbrido</option>
                </select>
              </div>
              <div class="campo"><label class="label">Status</label>
                <select name="status" class="input">
                  <option value="rascunho" <%= evento.status==='rascunho'?'selected':'' %>>⚪ Rascunho</option>
                  <option value="ativo" <%= evento.status==='ativo'?'selected':'' %>>🟢 Ativo</option>
                  <option value="encerrado" <%= evento.status==='encerrado'?'selected':'' %>>🔴 Encerrado</option>
                  <option value="cancelado" <%= evento.status==='cancelado'?'selected':'' %>>⚫ Cancelado</option>
                </select>
              </div>
              <div class="campo"><label class="label">Inscrições Públicas</label>
                <select name="publico" class="input">
                  <option value="true" <%= evento.publico?'selected':'' %>>✅ Sim</option>
                  <option value="false" <%= !evento.publico?'selected':'' %>>❌ Não</option>
                </select>
              </div>
              <div class="campo">
                <label class="label">Cor Tema</label>
                <div class="cores-paleta">
                  <% ["#1a3d2b","#1a56db","#7c3aed","#dc2626","#ea580c","#ca8a04","#0891b2","#0f766e","#be185d","#374151"].forEach(cor=>{ %>
                  <div class="cor-dot" style="background:<%= cor %>;border-color:<%= (evento.cor_tema||'#1a3d2b')===cor?'white':'transparent' %>;box-shadow:<%= (evento.cor_tema||'#1a3d2b')===cor?'0 0 0 2px '+cor:'none' %>" onclick="setCor('<%= cor %>')"></div>
                  <% }) %>
                  <input type="color" onchange="setCor(this.value)" style="width:28px;height:28px;border:none;border-radius:6px;cursor:pointer;padding:0">
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                  <div id="cor-preview" style="width:32px;height:32px;border-radius:7px;background:<%= evento.cor_tema||'#1a3d2b' %>;border:1px solid var(--borda)"></div>
                  <input type="text" id="cor-input" name="cor_tema" class="input" value="<%= evento.cor_tema||'#1a3d2b' %>" style="max-width:110px" oninput="document.getElementById('cor-preview').style.background=this.value">
                </div>
              </div>
              <div class="campo">
                <label class="label">Banner <span style="font-size:11px;font-weight:400;color:var(--texto2)">(ideal: 1200×400px)</span></label>
                <% if(evento.banner_chave){%><img src="/eventos/<%= evento.id %>/banner" style="max-width:200px;border-radius:8px;margin-bottom:8px;display:block"><% } %>
                <input type="file" name="banner" class="input" accept="image/*">
              </div>
            </div>
            <div style="margin-top:14px"><button type="submit" class="btn btn-primario" onclick="document.getElementById('descricao-hidden').value=quill.root.innerHTML">💾 Salvar</button></div>
          </form>
        </div>
      </div>

      <!-- LOTES -->
      <div class="tab-content" id="tab-lotes">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">🎫 Lotes de Ingressos</div>
          <% if(lotes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum lote criado.</p><%}%>
          <% lotes.forEach(l => { %>
          <div class="lote-card">
            <div>
              <div style="font-weight:600"><%= l.nome %></div>
              <div style="font-size:12px;color:var(--texto2)">R$ <%= Number(l.preco).toFixed(2) %> • <%= l.vagas %> vagas • <%= l.inscritos||0 %> inscritos</div>
              <% if(l.data_inicio){%><div style="font-size:11px;color:var(--texto2)">📅 <%= new Date(l.data_inicio).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %> até <%= new Date(l.data_fim).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></div><%}%>
            </div>
            <div style="display:flex;gap:6px">
              <button onclick="editarLote(<%= l.id %>,'<%= l.nome %>',<%= l.preco %>,<%= l.vagas %>,'<%= l.data_inicio?new Date(l.data_inicio).toISOString().slice(0,16):'' %>','<%= l.data_fim?new Date(l.data_fim).toISOString().slice(0,16):'' %>')" class="btn" style="font-size:11px;padding:4px 8px;background:#0891b2;color:white">✏️</button>
              <form method="POST" action="/eventos/<%= evento.id %>/lotes/<%= l.id %>/deletar" onsubmit="return confirm('Excluir lote?')" style="display:inline">
                <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;color:var(--vermelho)">🗑</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <div class="card">
          <div class="card-titulo">+ Novo Lote</div>
          <form action="/eventos/<%= evento.id %>/lotes" method="POST">
            <div class="grid-3">
              <div class="campo"><label class="label">Nome</label><input name="nome" class="input" placeholder="Ex: Lote 1" required></div>
              <div class="campo"><label class="label">Preço (R$)</label><input type="number" step="0.01" name="preco" class="input" value="0" min="0"></div>
              <div class="campo"><label class="label">Vagas</label><input type="number" name="vagas" class="input" value="50" min="1"></div>
              <div class="campo"><label class="label">Início</label><input type="datetime-local" name="data_inicio" class="input"></div>
              <div class="campo"><label class="label">Fim</label><input type="datetime-local" name="data_fim" class="input"></div>
              <div class="campo" style="display:flex;align-items:flex-end"><button type="submit" class="btn btn-primario" style="width:100%">+ Adicionar</button></div>
            </div>
          </form>
        </div>
      </div>

      <!-- CAMPOS -->
      <div class="tab-content" id="tab-campos">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">📝 Campos do Formulário de Inscrição</div>
          <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Campos padrão sempre incluídos: Nome, Email, WhatsApp, Data de Nascimento, RG/CI, Catraca, Semestre e Turma. Adicione campos extras abaixo.</p>
          <% if(campos.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum campo extra adicionado.</p><%}%>
          <% campos.forEach(campo => { %>
          <div class="campo-card">
            <div>
              <span style="font-weight:600"><%= campo.label %></span>
              <span style="font-size:11px;color:var(--texto2);margin-left:8px;background:var(--borda);padding:2px 6px;border-radius:4px"><%= campo.tipo %></span>
              <% if(campo.obrigatorio){%><span style="font-size:11px;color:#dc2626;margin-left:4px">• obrigatório</span><%}%>
            </div>
            <form method="POST" action="/eventos/<%= evento.id %>/campos/<%= campo.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir campo?')">
              <button type="submit" class="btn" style="font-size:11px;padding:3px 8px;color:var(--vermelho)">🗑</button>
            </form>
          </div>
          <% }) %>
        </div>
        <div class="card">
          <div class="card-titulo">+ Adicionar Campo Extra</div>
          <form action="/eventos/<%= evento.id %>/campos" method="POST">
            <div class="grid-2">
              <div class="campo"><label class="label">Nome do Campo</label><input name="label" class="input" placeholder="Ex: Instituição, Nível, Turno..." required></div>
              <div class="campo"><label class="label">Tipo do Campo</label>
                <select name="tipo" class="input" onchange="mostrarOpcoes(this.value)">
                  <option value="text">📝 Texto simples</option>
                  <option value="textarea">📄 Caixa de texto</option>
                  <option value="email">📧 Email</option>
                  <option value="number">🔢 Número</option>
                  <option value="select">📋 Lista suspensa (Dropdown)</option>
                  <option value="radio">🔘 Múltipla escolha (Radio)</option>
                  <option value="checkbox">☑️ Caixas de seleção</option>
                  <option value="file">📎 Anexar arquivo/foto</option>
                  <option value="date">📅 Data</option>
                </select>
              </div>
              <div class="campo" id="div-opcoes" style="grid-column:1/-1;display:none">
                <label class="label">Opções (uma por linha)</label>
                <textarea name="opcoes" class="input" rows="4" placeholder="Opção 1&#10;Opção 2&#10;Opção 3"></textarea>
              </div>
              <div class="campo"><label class="label">Obrigatório?</label>
                <select name="obrigatorio" class="input">
                  <option value="false">Não</option>
                  <option value="true">Sim</option>
                </select>
              </div>
              <div class="campo" style="display:flex;align-items:flex-end">
                <button type="submit" class="btn btn-primario" style="width:100%">+ Adicionar Campo</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- INSCRITOS -->
      <div class="tab-content" id="tab-inscritos">
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
          <div style="display:flex;gap:8px">
            <a href="/eventos/<%= evento.id %>/inscricoes/exportar" class="btn">📥 Exportar</a>
            <button class="btn" onclick="abrirModal('modal-inscricao-manual')">+ Manual</button>
          </div>
          <input type="text" placeholder="Buscar..." class="input" style="width:200px" oninput="buscarInscrito(this.value)">
        </div>
        <div class="card">
          <table class="tabela" id="tabela-inscritos">
            <thead><tr><th>#</th><th>Nome</th><th>Email</th><th>Lote</th><th>Status</th><th>Check-in</th><th>Ações</th></tr></thead>
            <tbody>
              <% inscricoes.forEach(i => { %>
              <tr class="inscrito-row">
                <td><%= i.id %></td>
                <td><strong><%= i.nome %></strong></td>
                <td><%= i.email %></td>
                <td><%= i.lote_nome||'—' %></td>
                <td><span class="badge" style="background:<%= i.status==='confirmado'?'#dcfce7':i.status==='pendente'?'#fef3c7':'#fee2e2' %>;color:<%= i.status==='confirmado'?'#166534':i.status==='pendente'?'#92400e':'#991b1b' %>"><%= i.status %></span></td>
                <td><%= i.checkin_em?'✅ '+new Date(i.checkin_em).toLocaleTimeString('pt-BR'):'—' %></td>
                <td>
                  <div style="display:flex;gap:4px">
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/confirmar" style="display:inline"><button class="btn" style="font-size:10px;padding:3px 7px;background:#059669;color:white">✅</button></form>
                    <a href="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/certificado" class="btn" style="font-size:10px;padding:3px 7px;background:#6366f1;color:white">🏆</a>
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')"><button class="btn" style="font-size:10px;padding:3px 7px;color:var(--vermelho)">🗑</button></form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- PAGAMENTOS -->
      <div class="tab-content" id="tab-pagamentos">
        <div class="card">
          <div class="card-titulo">💰 Pagamentos</div>
          <table class="tabela">
            <thead><tr><th>Inscrito</th><th>Valor</th><th>Método</th><th>Status</th><th>Pago em</th><th>Ações</th></tr></thead>
            <tbody>
              <% pagamentos.forEach(pg => { %>
              <tr>
                <td><strong><%= pg.inscrito_nome %></strong></td>
                <td>R$ <%= Number(pg.valor).toFixed(2) %></td>
                <td><%= pg.metodo||'—' %></td>
                <td><span class="badge" style="background:<%= pg.status==='pago'?'#dcfce7':'#fef3c7' %>;color:<%= pg.status==='pago'?'#166534':'#92400e' %>"><%= pg.status %></span></td>
                <td><%= pg.pago_em?new Date(pg.pago_em).toLocaleDateString('pt-BR'):'—' %></td>
                <td><% if(pg.status!=='pago'){%><form method="POST" action="/eventos/<%= evento.id %>/pagamentos/<%= pg.id %>/confirmar" style="display:inline"><button class="btn" style="font-size:11px;padding:4px 8px;background:#059669;color:white">✅ Confirmar</button></form><%}%></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- PROGRAMAÇÃO -->
      <div class="tab-content" id="tab-programacao">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">🗓️ Programação do Evento</div>
          <% if(programacao.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum item na programação.</p><%}%>
          <% programacao.forEach(p => { %>
          <div class="prog-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start">
              <div>
                <div style="font-weight:700;font-size:14px"><%= p.titulo %></div>
                <div style="font-size:12px;color:var(--cor-primaria);font-weight:600">⏰ <%= p.horario %><% if(p.local){%> • 📍 <%= p.local %><%}%></div>
                <% if(p.descricao){%><div style="font-size:12px;color:var(--texto2);margin-top:4px"><%= p.descricao %></div><%}%>
              </div>
              <form method="POST" action="/eventos/<%= evento.id %>/programacao/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn" style="font-size:11px;padding:3px 8px;color:var(--vermelho)">🗑</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <div class="card">
          <div class="card-titulo">+ Adicionar Item</div>
          <form action="/eventos/<%= evento.id %>/programacao" method="POST">
            <div class="grid-2">
              <div class="campo"><label class="label">Horário (ex: 08:00 - 09:00)</label><input name="horario" class="input" placeholder="08:00 - 09:00" required></div>
              <div class="campo"><label class="label">Título</label><input name="titulo" class="input" placeholder="Abertura / Palestra / Workshop..." required></div>
              <div class="campo"><label class="label">Local (opcional)</label><input name="local" class="input" placeholder="Sala A / Auditório..."></div>
              <div class="campo"><label class="label">Descrição (opcional)</label><input name="descricao" class="input" placeholder="Breve descrição..."></div>
            </div>
            <button type="submit" class="btn btn-primario" style="margin-top:8px">+ Adicionar</button>
          </form>
        </div>
      </div>

      <!-- PALESTRANTES -->
      <div class="tab-content" id="tab-palestrantes">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">🎤 Palestrantes</div>
          <% if(palestrantes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum palestrante adicionado.</p><%}%>
          <% palestrantes.forEach(p => { %>
          <div class="pales-card">
            <% if(p.foto_chave){%><img src="/eventos/palestrantes/<%= p.id %>/foto" class="pales-foto"><% }else{ %><div class="pales-foto">🎤</div><%}%>
            <div style="flex:1">
              <div style="font-weight:700"><%= p.nome %></div>
              <% if(p.instituicao){%><div style="font-size:12px;color:var(--cor-primaria)"><%= p.instituicao %></div><%}%>
              <% if(p.bio){%><div style="font-size:12px;color:var(--texto2);margin-top:2px"><%= p.bio.substring(0,100) %><%= p.bio.length>100?'...':'' %></div><%}%>
            </div>
            <form method="POST" action="/eventos/<%= evento.id %>/palestrantes/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
              <button type="submit" class="btn" style="font-size:11px;padding:3px 8px;color:var(--vermelho)">🗑</button>
            </form>
          </div>
          <% }) %>
        </div>
        <div class="card">
          <div class="card-titulo">+ Adicionar Palestrante</div>
          <form action="/eventos/<%= evento.id %>/palestrantes" method="POST" enctype="multipart/form-data">
            <div class="grid-2">
              <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
              <div class="campo"><label class="label">Instituição</label><input name="instituicao" class="input"></div>
              <div class="campo" style="grid-column:1/-1"><label class="label">Bio</label><textarea name="bio" class="input" rows="3"></textarea></div>
              <div class="campo"><label class="label">Foto</label><input type="file" name="foto" class="input" accept="image/*"></div>
            </div>
            <button type="submit" class="btn btn-primario" style="margin-top:8px">+ Adicionar</button>
          </form>
        </div>
      </div>

      <!-- PATROCINADORES -->
      <div class="tab-content" id="tab-patrocinadores">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">🤝 Patrocinadores</div>
          <p style="font-size:13px;color:var(--texto2);margin-bottom:12px">Logos de patrocinadores aparecem na página pública do evento com link para o site.</p>
          <% if(patrocinadores.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum patrocinador adicionado.</p><%}%>
          <% patrocinadores.forEach(p => { %>
          <div class="patroc-card">
            <% if(p.logo_chave){%><img src="/eventos/patrocinadores/<%= p.id %>/logo" style="height:40px;object-fit:contain;border-radius:4px"><% }else{ %><div style="width:40px;height:40px;background:var(--borda);border-radius:4px;display:flex;align-items:center;justify-content:center">🤝</div><%}%>
            <div style="flex:1"><div style="font-weight:600"><%= p.nome %></div><div style="font-size:11px;color:var(--texto2)"><%= p.url||'' %></div></div>
            <form method="POST" action="/eventos/<%= evento.id %>/patrocinadores/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
              <button type="submit" class="btn" style="font-size:11px;padding:3px 8px;color:var(--vermelho)">🗑</button>
            </form>
          </div>
          <% }) %>
        </div>
        <div class="card">
          <div class="card-titulo">+ Adicionar Patrocinador</div>
          <form action="/eventos/<%= evento.id %>/patrocinadores" method="POST" enctype="multipart/form-data">
            <div class="grid-2">
              <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
              <div class="campo"><label class="label">Website/URL</label><input name="url" class="input" placeholder="https://..."></div>
              <div class="campo" style="grid-column:1/-1"><label class="label">Logo</label><input type="file" name="logo" class="input" accept="image/*"></div>
            </div>
            <button type="submit" class="btn btn-primario" style="margin-top:8px">+ Adicionar</button>
          </form>
        </div>
      </div>

      <!-- CERTIFICADOS -->
      <div class="tab-content" id="tab-certificados">
        <div class="card" style="margin-bottom:16px">
          <div class="card-titulo">🏆 Emitir Certificados</div>
          <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Emite certificados para todos os inscritos com check-in realizado.</p>
          <form method="POST" action="/eventos/<%= evento.id %>/certificados/emitir-todos" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
            <div class="campo"><label class="label">Carga Horária (h)</label><input type="number" name="carga_horaria" class="input" style="width:100px" value="4" min="1"></div>
            <div style="margin-top:18px"><button type="submit" class="btn btn-primario" onclick="return confirm('Emitir para todos com check-in?')">🏆 Emitir Todos</button></div>
          </form>
        </div>
        <div class="card">
          <div class="card-titulo">📋 Certificados Emitidos</div>
          <table class="tabela">
            <thead><tr><th>Inscrito</th><th>Emitido em</th><th>Ações</th></tr></thead>
            <tbody>
              <% certificados.forEach(cert => { %>
              <tr><td><%= cert.inscrito_nome %></td><td><%= new Date(cert.emitido_em).toLocaleDateString('pt-BR') %></td>
              <td><a href="/eventos/certificados/<%= cert.id %>/download" target="_blank" class="btn" style="font-size:11px;padding:4px 8px;background:#6366f1;color:white">📥 Baixar</a></td></tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- AVANÇADO -->
      <div class="tab-content" id="tab-avancado">
        <form action="/eventos/<%= evento.id %>/avancado" method="POST">
          <div class="card" style="margin-bottom:16px">
            <div class="card-titulo">📧 E-mails Personalizados</div>
            <div class="campo"><label class="label">Texto adicional — E-mail de inscrição realizada</label><textarea name="email_inscricao" class="input" rows="8" placeholder="Texto enviado após o participante se inscrever..."><%= evento.email_inscricao||'' %></textarea></div>
            <div class="campo"><label class="label">Texto adicional — E-mail de confirmação</label><textarea name="email_confirmacao" class="input" rows="8" placeholder="Texto enviado após confirmação do pagamento..."><%= evento.email_confirmacao||'' %></textarea></div>
            <div class="campo"><label class="label">Notificar novas inscrições para</label><input name="notif_email" class="input" value="<%= evento.notif_email||'lauroucpcde@lauroucpcde.com' %>"></div>
          </div>
          <div class="card" style="margin-bottom:16px">
            <div class="card-titulo">📱 Grupo WhatsApp do Evento</div>
            <div class="campo"><label class="label">Link do grupo WhatsApp</label><input name="wpp_grupo" class="input" value="<%= evento.wpp_grupo||'' %>" placeholder="https://chat.whatsapp.com/..."><span style="font-size:11px;color:var(--texto2)">Aparece na página pública e nos emails.</span></div>
          </div>
          <div class="card" style="margin-bottom:16px">
            <div class="card-titulo">⚙️ Configurações de Inscrição</div>
            <div class="grid-2">
              <div class="campo"><label class="label">Inscrições gratuitas</label>
                <select name="inscricao_gratuita_auto" class="input">
                  <option value="true" <%= evento.inscricao_gratuita_auto!==false?'selected':'' %>>✅ Confirmadas automaticamente</option>
                  <option value="false" <%= evento.inscricao_gratuita_auto===false?'selected':'' %>>✋ Confirmadas manualmente</option>
                </select>
              </div>
              <div class="campo"><label class="label">Inscrição única por email</label>
                <select name="inscricao_unica" class="input">
                  <option value="false" <%= !evento.inscricao_unica?'selected':'' %>>Não</option>
                  <option value="true" <%= evento.inscricao_unica?'selected':'' %>>Sim — apenas uma por email</option>
                </select>
              </div>
            </div>
          </div>
          <div class="card" style="margin-bottom:16px">
            <div class="card-titulo">📜 Termos e Condições / LGPD</div>
            <div class="campo"><label class="label">Texto dos Termos de Participação</label><textarea name="termos_texto" class="input" rows="10" placeholder="Termos e condições de participação..."><%= evento.termos_texto||'' %></textarea><span style="font-size:11px;color:var(--texto2)">Aparece na página pública para aceite obrigatório.</span></div>
          </div>
          <button type="submit" class="btn btn-primario">💾 Salvar Configurações</button>
        </form>
      </div>
    </div>
  </main>
</div>

<!-- Modal Editar Lote -->
<div class="modal-overlay" id="modal-editar-lote" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">✏️ Editar Lote</span><button class="icon-btn" onclick="fecharModal('modal-editar-lote')">✕</button></div>
    <form id="form-editar-lote" action="" method="POST">
      <div class="grid-3">
        <div class="campo"><label class="label">Nome</label><input id="el-nome" name="nome" class="input" required></div>
        <div class="campo"><label class="label">Preço</label><input id="el-preco" type="number" step="0.01" name="preco" class="input"></div>
        <div class="campo"><label class="label">Vagas</label><input id="el-vagas" type="number" name="vagas" class="input"></div>
        <div class="campo"><label class="label">Início</label><input id="el-inicio" type="datetime-local" name="data_inicio" class="input"></div>
        <div class="campo"><label class="label">Fim</label><input id="el-fim" type="datetime-local" name="data_fim" class="input"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-editar-lote')">Cancelar</button><button type="submit" class="btn btn-primario">💾 Salvar</button></div>
    </form>
  </div>
</div>

<!-- Modal Inscrição Manual -->
<div class="modal-overlay" id="modal-inscricao-manual" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">+ Inscrição Manual</span><button class="icon-btn" onclick="fecharModal('modal-inscricao-manual')">✕</button></div>
    <form action="/eventos/<%= evento.id %>/inscricoes/manual" method="POST">
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
        <div class="campo"><label class="label">Email *</label><input name="email" class="input" type="email" required></div>
        <div class="campo"><label class="label">WhatsApp</label><input name="whatsapp" class="input"></div>
        <div class="campo"><label class="label">Lote</label>
          <select name="lote_id" class="input"><% lotes.forEach(l=>{%><option value="<%= l.id %>"><%= l.nome %> — R$ <%= Number(l.preco).toFixed(2) %></option><%})%></select>
        </div>
        <div class="campo"><label class="label">Status</label>
          <select name="status" class="input"><option value="confirmado">✅ Confirmado</option><option value="pendente">⏳ Pendente</option></select>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-inscricao-manual')">Cancelar</button><button type="submit" class="btn btn-primario">+ Inscrever</button></div>
    </form>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="/js/app.js"></script>
<script>
const quill = new Quill('#editor-desc', {theme:'snow',modules:{toolbar:[[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'color':[]},{'background':[]}],[{'align':[]}],['link'],['clean']]}});

function showTab(id) {
  document.querySelectorAll('.tab-content').forEach(s=>s.classList.remove('ativo'));
  document.querySelectorAll('.tab-btn').forEach(t=>t.classList.remove('ativo'));
  document.getElementById('tab-'+id).classList.add('ativo');
  event.target.classList.add('ativo');
}
function buscarInscrito(q) {
  document.querySelectorAll('.inscrito-row').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});
}
function editarLote(id,nome,preco,vagas,inicio,fim) {
  document.getElementById('el-nome').value=nome;
  document.getElementById('el-preco').value=preco;
  document.getElementById('el-vagas').value=vagas;
  document.getElementById('el-inicio').value=inicio;
  document.getElementById('el-fim').value=fim;
  document.getElementById('form-editar-lote').action='/eventos/'+<%= evento.id %>+'/lotes/'+id+'/editar';
  abrirModal('modal-editar-lote');
}
function mostrarOpcoes(tipo) {
  document.getElementById('div-opcoes').style.display=['select','radio','checkbox'].includes(tipo)?'block':'none';
}
function setCor(cor) {
  document.getElementById('cor-input').value=cor;
  document.getElementById('cor-preview').style.background=cor;
}
</script>
</body>
</html>
