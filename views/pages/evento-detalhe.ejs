              <div class="grid-3">
                <div class="campo"><label class="label">Código</label><input name="codigo" class="input" placeholder="EX: DESCONTO20" required style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()"></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo" class="input"><option value="percentual">Percentual (%)</option><option value="fixo">Valor fixo (R$)</option></select>
                </div>
                <div class="campo"><label class="label">Valor</label><input type="number" name="valor" class="input" value="100" min="1" step="0.01"></div>
                <div class="campo"><label class="label">Usos máximos</label><input type="number" name="usos_max" class="input" value="1" min="1"></div>
                <div class="campo" style="display:flex;align-items:flex-end"><button type="submit" class="btn btn-primario" style="width:100%">Criar cupom</button></div>
