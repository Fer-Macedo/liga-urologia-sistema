            <div class="section-body">
              <div class="campo"><label class="label">Texto incluído no email de confirmação (após pagamento)</label><textarea name="email_inscricao" class="input" rows="6" placeholder="Este texto será incluído no email enviado ao participante..."><%= evento.email_inscricao||'' %></textarea></div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Grupo WhatsApp</div>
            <div class="section-body">
              <div class="campo"><label class="label">Link do grupo WhatsApp</label><input name="wpp_grupo" class="input" value="<%= evento.wpp_grupo||'' %>" placeholder="https://chat.whatsapp.com/..."></div>
              <div style="font-size:11px;color:var(--texto2);margin-top:4px">Aparece na página pública e no email de confirmação.</div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Configurações de inscrição</div>
            <div class="section-body">
              <div class="grid-2">
                <div class="campo"><label class="label">Inscrições gratuitas</label>
                  <select name="inscricao_gratuita_auto" class="input">
                    <option value="true" <%= evento.inscricao_gratuita_auto!==false?'selected':'' %>>Confirmadas automaticamente</option>
                    <option value="false" <%= evento.inscricao_gratuita_auto===false?'selected':'' %>>Confirmadas manualmente</option>
                  </select>
