<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="/js/app.js"></script>
<script>
let quilMala = null;
function initQuilMala() {
  if (quilMala) return;
  const el = document.getElementById('editor-mala');
  if (!el) return;
  quilMala = new Quill('#editor-mala', {
    theme: 'snow',
    modules: { toolbar: [[{'font':[]},{'size':['small',false,'large','huge']}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],[{'align':[]}],[{'list':'ordered'},{'list':'bullet'}],['link','image'],['clean']] }
  });
}
const quill = new Quill('#editor-desc', {
  theme: 'snow',
  modules: { toolbar: [[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'color':[]},{'background':[]}],[{'align':[]}],['link'],['clean']] }
});

function showTab(id, btn) {
  if (id === 'mala-direta') { initQuilMala(); carregarHistorico(); }
  document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('ativo'));
  document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('ativo'));
  document.getElementById('tab-'+id).classList.add('ativo');
  if(btn) btn.classList.add('ativo');
  const url = new URL(window.location);
  url.searchParams.set('tab', id);
  history.replaceState(null, '', url);
}

window.addEventListener('DOMContentLoaded', () => {
  initDrag();
  const tab = new URLSearchParams(window.location.search).get('tab');
  if (tab) {
    const btn = document.querySelector(`.tab-btn[onclick*="'${tab}'"]`);
    if (btn) showTab(tab, btn);
  }
});

function buscarInscrito(q) {
  document.querySelectorAll('.inscrito-row').forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}

function editarLote(id, nome, preco, vagas, inicio, fim) {
  document.getElementById('el-nome').value = nome;
  document.getElementById('el-preco').value = preco;
  document.getElementById('el-vagas').value = vagas;
  document.getElementById('el-inicio').value = inicio;
  document.getElementById('el-fim').value = fim;
  document.getElementById('form-editar-lote').action = '/eventos/<%= evento.id %>/lotes/'+id+'/editar';
  abrirModal('modal-editar-lote');
}

function editarInscrito(id, nome, email, wpp, cpf, inst, status) {
  document.getElementById('ei-nome').value = nome;
  document.getElementById('ei-email').value = email;
  document.getElementById('ei-wpp').value = wpp;
  document.getElementById('ei-cpf').value = cpf;
  document.getElementById('ei-inst').value = inst;
  document.getElementById('ei-status').value = status;
  document.getElementById('form-editar-inscrito').action = '/eventos/<%= evento.id %>/inscricoes/'+id+'/editar';
  abrirModal('modal-editar-inscrito');
}

let dragSrc=null;
function initDrag() {
  const lista = document.getElementById('lista-campos-ord');
  if (!lista) return;
  lista.querySelectorAll('.campo-ord-item').forEach(item => {
    item.setAttribute('draggable', true);
    item.addEventListener('dragstart', () => { dragSrc=item; item.style.opacity='.5'; });
    item.addEventListener('dragend', () => { item.style.opacity=''; lista.querySelectorAll('.campo-ord-item').forEach(i=>i.classList.remove('drag-over')); });
    item.addEventListener('dragover', e => { e.preventDefault(); item.classList.add('drag-over'); });
    item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
    item.addEventListener('drop', e => {
      e.preventDefault(); item.classList.remove('drag-over');
      if (dragSrc && dragSrc!==item) {
        const its=[...lista.querySelectorAll('.campo-ord-item')];
        if(its.indexOf(dragSrc)<its.indexOf(item)) item.after(dragSrc); else item.before(dragSrc);
        document.getElementById('btn-salvar-ordem').style.display='';
      }
    });
  });
}
function salvarOrdem() {
  const keys=[...document.querySelectorAll('.campo-ord-item')].map(i=>i.dataset.key);
  fetch('/eventos/<%= evento.id %>/campos/ordem',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({campos:JSON.stringify(keys)})})
    .then(r=>r.json()).then(d=>{ if(d.ok){document.getElementById('btn-salvar-ordem').style.display='none';alert('Ordem salva!');} });
}
const inscricoesMala=<%- JSON.stringify(inscricoes) %>;
function atualizarContador() {
  const dest=document.getElementById('sel-dest').value;
  let n=inscricoesMala.length;
  if(dest==='confirmados') n=inscricoesMala.filter(i=>i.status==='confirmado').length;
  else if(dest==='pendentes') n=inscricoesMala.filter(i=>i.status==='pendente').length;
  document.getElementById('txt-contador-dest').textContent=n+' inscritos';
}
function carregarHistorico() {
  fetch('/eventos/<%= evento.id %>/mala-direta/historico').then(r=>r.json()).then(d=>{
    const el=document.getElementById('historico-mala');
    if(!d.ok||!d.envios.length){el.innerHTML='<div style="padding:20px;text-align:center;color:var(--texto2)">Nenhum email enviado ainda.</div>';return;}
    el.innerHTML=d.envios.map(e=>{
      const dt=new Date(e.criado_em).toLocaleString('pt-BR');
      const tx=e.total_enviados>0?Math.round(e.total_enviados/(e.total_enviados+e.total_erros)*100):0;
      return '<div style="padding:14px 18px;border-bottom:1px solid var(--borda);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">'
        +'<div><div style="font-weight:600;font-size:13px">'+e.assunto+'</div>'
        +'<div style="font-size:11px;color:var(--texto2);margin-top:3px">'+dt+' · '+e.destinatarios+'</div></div>'
        +'<div style="display:flex;gap:10px;align-items:center">'
        +'<span style="color:#10b981;font-weight:600;font-size:12px">'+e.total_enviados+' enviados</span>'
        +(e.total_erros>0?'<span style="color:#ef4444;font-weight:600;font-size:12px">'+e.total_erros+' erros</span>':'')
        +'<span style="background:#eff6ff;color:#1e40af;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700">'+tx+'% entrega</span>'
        +'<button onclick="verLogs('+e.id+')" class="btn-xs">Detalhes</button></div></div>';
    }).join('');
  });
}
function copiarLinkCupom(codigo) {
  const appUrl = window.location.origin;
  const link = appUrl + '/inscricao/<%= evento.id %>?cupom=' + codigo;
  navigator.clipboard.writeText(link).then(() => {
    alert('Link copiado!\n\n' + link);
  }).catch(() => {
    prompt('Copie o link abaixo:', link);
  });
}
function verLogs(id){
  fetch('/eventos/<%= evento.id %>/mala-direta/'+id+'/logs').then(r=>r.json()).then(d=>{
    if(!d.ok)return;
    const w=window.open('','_blank','width=700,height=500');
    w.document.write('<html><head><title>Log</title><style>body{font-family:Arial;padding:20px}table{width:100%;border-collapse:collapse}th,td{padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:left}th{background:#f8fafc;font-size:12px}</style></head><body><h3>Detalhes do envio</h3><table><thead><tr><th>Nome</th><th>Email</th><th>Status</th></tr></thead><tbody>'
      +d.logs.map(l=>'<tr><td>'+l.nome+'</td><td>'+l.email+'</td><td style="color:'+(l.status==='enviado'?'#166534':'#991b1b')+'">'+l.status+'</td></tr>').join('')
      +'</tbody></table></body></html>');
    w.document.close();
  });
}
function mostrarOpcoes(tipo) {
  document.getElementById('div-opcoes').style.display = ['select','radio','checkbox'].includes(tipo) ? 'block' : 'none';
}

function setCor(cor) {
  document.getElementById('cor-input').value = cor;
  document.getElementById('cor-preview').style.background = cor;
}

function imprimirRelatorio() {
  const w = window.open('','_blank');
  w.document.write('<html><head><title>Relatório Financeiro</title><style>body{font-family:Arial;padding:20px}table{width:100%;border-collapse:collapse}th,td{padding:8px 12px;border:1px solid #e5e7eb;text-align:left}thead{background:#f8fafc}</style></head><body>'+document.getElementById('tab-financeiro').innerHTML+'</body></html>');
  w.document.close();
  w.print();
}

function enviarLinksLive() {
  const btn = event.target;
  btn.textContent = 'Enviando...';
  btn.disabled = true;
  fetch('/eventos/<%= evento.id %>/enviar-link-live', { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      document.getElementById('live-resultado').textContent = d.msg || (d.ok ? 'Links enviados!' : 'Erro: '+d.msg);
      btn.textContent = 'Enviar links de acesso';
      btn.disabled = false;
    })
    .catch(() => {
      document.getElementById('live-resultado').textContent = 'Erro de conexão.';
      btn.textContent = 'Enviar links de acesso';
      btn.disabled = false;
    });
}
</script>
</body>
</html>
