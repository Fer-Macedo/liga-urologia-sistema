            <form method="POST" action="/eventos/<%= evento.id %>/certificados/emitir-todos" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
              <div class="campo"><label class="label">Carga horária (h)</label><input type="number" name="carga_horaria" class="input" style="width:100px" value="<%= evento.carga_horaria||4 %>" min="1"></div>
