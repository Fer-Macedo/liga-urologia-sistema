                <div class="campo"><label class="label">Inscrição única por email</label>
                  <select name="inscricao_unica" class="input">
                    <option value="false" <%= !evento.inscricao_unica?'selected':'' %>>Não</option>
                    <option value="true" <%= evento.inscricao_unica?'selected':'' %>>Sim</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Termos e condições</div>
            <div class="section-body">
              <div class="campo"><textarea name="termos_texto" class="input" rows="6" placeholder="Termos e condições de participação..."><%= evento.termos_texto||'' %></textarea></div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Política de privacidade (LGPD)</div>
            <div class="section-body">
              <div class="campo"><textarea name="lgpd_texto" class="input" rows="8" placeholder="Informe como os dados dos participantes serão utilizados..."><%= evento.lgpd_texto||'' %></textarea></div>
            </div>
          </div>
          <button type="submit" class="btn btn-primario">Salvar configurações</button>
        </form>
      </div>

    </div>
  </main>
</div>

