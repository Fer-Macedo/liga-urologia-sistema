<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — Gerenciar</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .tab-nav {
      display: flex;
      gap: 2px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--borda);
      flex-wrap: wrap;
      overflow-x: auto;
    }
    .tab-btn {
      padding: 9px 16px;
      border: none;
      background: none;
      cursor: pointer;
      font-weight: 600;
      font-size: 12.5px;
      color: var(--texto2);
      border-bottom: 2.5px solid transparent;
      margin-bottom: -2px;
      white-space: nowrap;
      font-family: 'Outfit', sans-serif;
      transition: all .15s;
    }
    .tab-btn.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); }
    .tab-btn:hover { color: var(--texto); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    .stat-box {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 12px;
      padding: 14px 16px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .stat-box::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--cor-primaria);
      opacity: .5;
    }
    .stat-num {
      font-family: 'Outfit', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--cor-primaria);
      margin-bottom: 3px;
    }
    .stat-lab { font-size: 11px; color: var(--texto2); font-weight: 600; }

    .section-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 16px;
    }
    .section-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--borda);
      font-size: 14px;
      font-weight: 700;
      font-family: 'Outfit', sans-serif;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-body { padding: 18px; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    @media(max-width:600px){.grid-2,.grid-3{grid-template-columns:1fr}}

    .lote-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
      gap: 10px;
      flex-wrap: wrap;
    }
    .campo-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .prog-item {
      border-left: 3px solid var(--cor-primaria);
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 0 8px 8px 0;
      margin-bottom: 8px;
    }
    .pales-item {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .pales-foto {
      width: 48px; height: 48px;
      border-radius: 50%;
      object-fit: cover;
      background: var(--borda);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 20px;
    }
    .patroc-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .cupom-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .cupom-cod {
      font-family: monospace;
      font-size: 14px;
      font-weight: 700;
      color: var(--cor-primaria);
      background: var(--card);
      border: 1px dashed var(--borda);
      padding: 3px 10px;
      border-radius: 6px;
      letter-spacing: 2px;
    }

    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
    }
    .badge-confirmado { background: #dcfce7; color: #166534; }
    .badge-pendente   { background: #fef3c7; color: #92400e; }
    .badge-cancelado  { background: #fee2e2; color: #991b1b; }
    .badge-pago       { background: #dcfce7; color: #166534; }

    .btn-xs {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      border: 1px solid var(--borda);
      background: var(--fundo);
      color: var(--texto);
      cursor: pointer;
      text-decoration: none;
      transition: all .15s;
      font-family: inherit;
    }
    .btn-xs:hover { border-color: var(--cor-primaria); color: var(--cor-primaria); }
    .btn-xs.verde { background: #059669; color: white; border-color: transparent; }
    .btn-xs.azul  { background: #0891b2; color: white; border-color: transparent; }
    .btn-xs.roxo  { background: #6366f1; color: white; border-color: transparent; }
    .btn-xs.verm  { color: #dc2626; border-color: #fecaca; }
    .btn-xs.verm:hover { background: #fee2e2; }

    table.tabela { width: 100%; border-collapse: collapse; }
    table.tabela thead th {
      background: var(--fundo);
      padding: 10px 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--texto2);
      text-align: left;
      border-bottom: 1px solid var(--borda);
    }
    table.tabela tbody tr { border-bottom: 1px solid var(--borda); transition: background .15s; }
    table.tabela tbody tr:last-child { border-bottom: none; }
    table.tabela tbody tr:hover { background: var(--fundo); }
    table.tabela tbody td { padding: 10px 12px; font-size: 13px; color: var(--texto); vertical-align: middle; }

    .cores-paleta { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
    .cor-dot { width: 26px; height: 26px; border-radius: 6px; cursor: pointer; border: 3px solid transparent; transition: .2s; }
    .cor-dot:hover { transform: scale(1.1); }

    .campo-ord-item { display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--fundo);border-radius:8px;border:1px solid var(--borda);margin-bottom:6px;cursor:grab;transition:all .15s;gap:10px; }
    .campo-ord-item:active { cursor:grabbing;opacity:.8; }
    .campo-ord-item.drag-over { border-color:var(--cor-primaria);background:var(--card); }
    .drag-handle { color:var(--texto2);cursor:grab;flex-shrink:0; }
    .email-massa-box {
      background: var(--fundo);
      border: 2px solid var(--borda);
      border-radius: 12px;
      padding: 18px;
      margin-bottom: 16px;
    }

    .aviso-dim {
      background: #fffbeb;
      border: 1.5px solid #fcd34d;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 12px;
      color: #92400e;
      margin-bottom: 8px;
    }

    .live-box {
      background: linear-gradient(135deg, #1e1b4b, #312e81);
      border-radius: 12px;
      padding: 20px;
      color: white;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'eventos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo" style="font-size:15px"><%= evento.nome %></h1>
      <div class="topbar-acoes">
        <a href="/eventos" class="btn btn-sm">Voltar</a>
        <a href="/inscricao/<%= evento.id %>" target="_blank" class="btn btn-sm" style="background:#059669;color:white">Pág. Pública</a>
        <a href="/eventos/<%= evento.id %>/checkin" class="btn btn-sm btn-primario">Check-in</a>
        <a href="/eventos/<%= evento.id %>/presencas" class="btn btn-sm" style="background:#8b5cf6;color:white">Presenças</a>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-box"><div class="stat-num"><%= stats.total %></div><div class="stat-lab">Inscritos</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#059669"><%= stats.confirmados %></div><div class="stat-lab">Confirmados</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#6366f1"><%= stats.checkins %></div><div class="stat-lab">Check-ins</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#f59e0b">R$ <%= Number(stats.receita||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div><div class="stat-lab">Receita</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#dc2626"><%= evento.vagas_total - stats.total %></div><div class="stat-lab">Vagas livres</div></div>
      </div>

      <!-- TABS -->
      <div class="tab-nav">
        <button class="tab-btn ativo" onclick="showTab('info',this)">Informações</button>
        <button class="tab-btn" onclick="showTab('lotes',this)">Lotes</button>
        <button class="tab-btn" onclick="showTab('campos',this)">Campos</button>
        <button class="tab-btn" onclick="showTab('inscritos',this)">Inscritos</button>
        <button class="tab-btn" onclick="showTab('mala-direta',this)">Mala Direta</button>
        <button class="tab-btn" onclick="showTab('pagamentos',this)">Pagamentos</button>
        <button class="tab-btn" onclick="showTab('financeiro',this)">Financeiro</button>
        <button class="tab-btn" onclick="showTab('online',this)">Online / Live</button>
        <button class="tab-btn" onclick="showTab('programacao',this)">Programação</button>
        <button class="tab-btn" onclick="showTab('palestrantes',this)">Palestrantes</button>
        <button class="tab-btn" onclick="showTab('patrocinadores',this)">Patrocinadores</button>
        <button class="tab-btn" onclick="showTab('cupons',this)">Cupons</button>
        <button class="tab-btn" onclick="showTab('certificados',this)">Certificados</button>
        <button class="tab-btn" onclick="showTab('avancado',this)">Avançado</button>
      </div>

      <!-- INFO -->
      <div class="tab-content ativo" id="tab-info">
        <div class="section-card">
          <div class="section-header">Editar evento</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/editar" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo" style="grid-column:1/-1"><label class="label">Nome do evento</label><input name="nome" class="input" value="<%= evento.nome %>" required></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Descrição</label>
                  <div id="editor-desc" style="height:180px;background:white;border-radius:8px"><%- evento.descricao||'' %></div>
                  <input type="hidden" name="descricao" id="descricao-hidden">
                </div>
                <div class="campo"><label class="label">Data/hora início</label><input type="datetime-local" name="data_inicio" class="input" value="<%= evento.data_inicio?new Date(evento.data_inicio).toISOString().slice(0,16):'' %>"></div>
                <div class="campo"><label class="label">Data/hora fim</label><input type="datetime-local" name="data_fim" class="input" value="<%= evento.data_fim?new Date(evento.data_fim).toISOString().slice(0,16):'' %>"></div>
                <div class="campo"><label class="label">Local</label><input name="local" class="input" value="<%= evento.local||'' %>"></div>
                <div class="campo"><label class="label">Total de vagas</label><input type="number" name="vagas_total" class="input" value="<%= evento.vagas_total %>"></div>
                <div class="campo"><label class="label">Endereço</label><input name="endereco" class="input" value="<%= evento.endereco||'' %>"></div>
                <div class="campo"><label class="label">Carga horária (h)</label><input type="number" name="carga_horaria" class="input" value="<%= evento.carga_horaria||'' %>" placeholder="Ex: 4"></div>
                <div class="campo"><label class="label">Duração total (minutos)</label><input type="number" name="duracao_minutos" class="input" value="<%= evento.duracao_minutos||'' %>" placeholder="Ex: 240 = 4h"></div>
                <div class="campo"><label class="label">URL YouTube (transmissão online)</label><input name="youtube_url" class="input" value="<%= evento.youtube_url||'' %>" placeholder="https://youtu.be/..."></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo_evento" class="input">
                    <option value="presencial" <%= evento.tipo_evento==='presencial'?'selected':'' %>>Presencial</option>
                    <option value="online" <%= evento.tipo_evento==='online'?'selected':'' %>>Online</option>
                    <option value="hibrido" <%= evento.tipo_evento==='hibrido'?'selected':'' %>>Híbrido</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Status</label>
                  <select name="status" class="input">
                    <option value="rascunho" <%= evento.status==='rascunho'?'selected':'' %>>Rascunho</option>
                    <option value="ativo" <%= evento.status==='ativo'?'selected':'' %>>Ativo</option>
                    <option value="encerrado" <%= evento.status==='encerrado'?'selected':'' %>>Encerrado</option>
                    <option value="cancelado" <%= evento.status==='cancelado'?'selected':'' %>>Cancelado</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Inscrições públicas</label>
                  <select name="publico" class="input">
                    <option value="true" <%= evento.publico?'selected':'' %>>Sim</option>
                    <option value="false" <%= !evento.publico?'selected':'' %>>Não</option>
                  </select>
                </div>
                <div class="campo">
                  <label class="label">Cor tema</label>
                  <div class="cores-paleta">
                    <% ["#1a3d2b","#1a56db","#7c3aed","#dc2626","#ea580c","#ca8a04","#0891b2","#0f766e","#be185d","#374151"].forEach(cor=>{ %>
                    <div class="cor-dot" style="background:<%= cor %>" onclick="setCor('<%= cor %>')"></div>
                    <% }) %>
                    <input type="color" onchange="setCor(this.value)" style="width:26px;height:26px;border:none;border-radius:6px;cursor:pointer;padding:0">
                  </div>
                  <div style="display:flex;gap:8px;align-items:center">
                    <div id="cor-preview" style="width:30px;height:30px;border-radius:7px;background:<%= evento.cor_tema||'#1a3d2b' %>;border:1px solid var(--borda)"></div>
                    <input type="text" id="cor-input" name="cor_tema" class="input" value="<%= evento.cor_tema||'#1a3d2b' %>" style="max-width:110px" oninput="document.getElementById('cor-preview').style.background=this.value">
                  </div>
                </div>
                <div class="campo">
                  <label class="label">Banner <span style="font-size:11px;font-weight:400;color:var(--texto2)">(ideal: 1200×400px)</span></label>
                  <% if(evento.banner_chave){%><img src="/eventos/<%= evento.id %>/banner" style="max-width:200px;border-radius:8px;margin-bottom:8px;display:block"><% } %>
                  <input type="file" name="banner" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <div style="margin-top:14px"><button type="submit" class="btn btn-primario" onclick="document.getElementById('descricao-hidden').value=quill.root.innerHTML">Salvar alterações</button></div>
            </form>
          </div>
        </div>
      </div>

      <!-- LOTES -->
      <div class="tab-content" id="tab-lotes">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Lotes de ingressos</div>
          <div class="section-body">
            <% if(lotes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum lote criado.</p><%}%>
            <% lotes.forEach(l => { %>
            <div class="lote-item">
              <div>
                <div style="font-weight:600"><%= l.nome %></div>
                <div style="font-size:12px;color:var(--texto2)">R$ <%= Number(l.preco).toFixed(2) %> · <%= l.vagas %> vagas · <%= l.inscritos||0 %> inscritos</div>
                <% if(l.data_inicio){%><div style="font-size:11px;color:var(--texto2);margin-top:2px"><%= new Date(l.data_inicio).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %> até <%= new Date(l.data_fim).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></div><%}%>
              </div>
              <div style="display:flex;gap:6px">
                <button onclick="editarLote(<%= l.id %>,'<%= l.nome %>',<%= l.preco %>,<%= l.vagas %>,'<%= l.data_inicio?new Date(l.data_inicio).toISOString().slice(0,16):'' %>','<%= l.data_fim?new Date(l.data_fim).toISOString().slice(0,16):'' %>')" class="btn-xs azul">Editar</button>
                <form method="POST" action="/eventos/<%= evento.id %>/lotes/<%= l.id %>/deletar" onsubmit="return confirm('Excluir lote?')" style="display:inline">
                  <button type="submit" class="btn-xs verm">Excluir</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Novo lote</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/lotes" method="POST">
              <div class="grid-3">
                <div class="campo"><label class="label">Nome</label><input name="nome" class="input" placeholder="Ex: Lote 1" required></div>
                <div class="campo"><label class="label">Preço (R$)</label><input type="number" step="0.01" name="preco" class="input" value="0" min="0"></div>
                <div class="campo"><label class="label">Vagas</label><input type="number" name="vagas" class="input" value="50" min="1"></div>
                <div class="campo"><label class="label">Início</label><input type="datetime-local" name="data_inicio" class="input"></div>
                <div class="campo"><label class="label">Fim</label><input type="datetime-local" name="data_fim" class="input"></div>
                <div class="campo" style="display:flex;align-items:flex-end"><button type="submit" class="btn btn-primario" style="width:100%">Adicionar lote</button></div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- CAMPOS -->
      <div class="tab-content" id="tab-campos">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">
            Todos os campos
            <button type="button" onclick="salvarOrdem()" class="btn-xs verde" id="btn-salvar-ordem" style="display:none">Salvar ordem</button>
          </div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Arraste para reordenar. Campos padrão não podem ser excluídos.</p>
            <div id="lista-campos-ord">
              <% const camposPad=[{key:'nome',label:'Nome completo'},{key:'email',label:'Email'},{key:'whatsapp',label:'WhatsApp'},{key:'data_nascimento',label:'Data de nascimento'},{key:'rg',label:'RG / CI'},{key:'semestre',label:'Semestre'},{key:'turma',label:'Turma'},{key:'catraca',label:'Catraca (UCP)'},{key:'instituicao',label:'Instituição (externos)'}]; %>
              <% const todosCampos=[...camposPad.map(c=>({...c,padrao:true})),...campos.map(c=>({key:'extra_'+c.id,label:c.label,padrao:false,id:c.id,tipo:c.tipo,obrigatorio:c.obrigatorio}))]; %>
              <% todosCampos.forEach(c => { %>
              <div class="campo-ord-item" data-key="<%= c.key %>">
                <div style="display:flex;align-items:center;gap:10px;flex:1">
                  <div class="drag-handle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="5" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="15" cy="19" r="1.5"/></svg></div>
                  <span style="font-weight:600"><%= c.label %></span>
                  <% if(c.padrao){ %><span style="font-size:10px;background:#eff6ff;color:#1e40af;padding:2px 7px;border-radius:4px;font-weight:700">padrão</span>
                  <% }else{ %><span style="font-size:10px;background:var(--borda);color:var(--texto2);padding:2px 7px;border-radius:4px"><%= c.tipo %></span><% if(c.obrigatorio){%><span style="font-size:10px;color:#dc2626;margin-left:4px">obrig.</span><%}%><% } %>
                </div>
                <% if(!c.padrao){ %>
                <form method="POST" action="/eventos/<%= evento.id %>/campos/<%= c.id %>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')"><button type="submit" class="btn-xs verm">Excluir</button></form>
                <% }else{ %><span style="font-size:11px;color:#10b981;font-weight:600">fixo</span><% } %>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar campo extra</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/campos" method="POST">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome</label><input name="label" class="input" placeholder="Ex: Instituição..." required></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo" class="input" onchange="mostrarOpcoes(this.value)">
                    <option value="text">Texto simples</option>
                    <option value="textarea">Caixa de texto</option>
                    <option value="select">Lista suspensa</option>
                    <option value="radio">Múltipla escolha</option>
                    <option value="date">Data</option>
                  </select>
                </div>
                <div class="campo" id="div-opcoes" style="grid-column:1/-1;display:none">
                  <label class="label">Opções (uma por linha)</label>
                  <textarea name="opcoes" class="input" rows="3"></textarea>
                </div>
                <div class="campo"><label class="label">Obrigatório</label>
                  <select name="obrigatorio" class="input"><option value="false">Não</option><option value="true">Sim</option></select>
                </div>
                <div class="campo" style="display:flex;align-items:flex-end">
                  <button type="submit" class="btn btn-primario" style="width:100%">Adicionar</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
      <!-- MALA DIRETA -->
      <div class="tab-content" id="tab-mala-direta">
        <div class="section-card" style="margin-bottom:20px">
          <div class="section-header">Compor email</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/mala-direta" method="POST" id="form-mala">
              <input type="hidden" name="conteudo_html" id="mala-html">
              <div class="grid-2" style="margin-bottom:16px">
                <div class="campo"><label class="label">Assunto *</label><input name="assunto" class="input" required placeholder="Ex: Informações importantes..."></div>
                <div class="campo"><label class="label">Enviar para</label>
                  <select name="destinatarios" class="input" id="sel-dest" onchange="atualizarContador()">
                    <option value="todos">Todos os inscritos</option>
                    <option value="confirmados">Apenas confirmados</option>
                    <option value="pendentes">Apenas pendentes</option>
                  </select>
                </div>
              </div>
              <div class="campo" style="margin-bottom:16px">
                <label class="label">Conteúdo</label>
                <div style="font-size:11px;color:var(--texto2);margin-bottom:6px">Use <code style="background:var(--fundo);padding:2px 5px;border-radius:4px">{nome}</code> para o nome do participante.</div>
                <div id="editor-mala" style="height:300px;background:white;border-radius:8px"></div>
              </div>
              <div style="background:linear-gradient(135deg,#eff6ff,#f0fdf4);border:1px solid #bfdbfe;border-radius:10px;padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:16px">
                <div style="flex:1">
                  <div style="font-size:13px;font-weight:700;color:#1e40af;margin-bottom:4px">Layout do email</div>
                  <div style="font-size:12px;color:#3730a3;line-height:1.6">Cabeçalho colorido com logo da liga → "Olá, [Nome]!" → Seu conteúdo → Rodapé institucional.</div>
                </div>
                <div style="width:52px;height:52px;background:linear-gradient(135deg,var(--cor-primaria),#6366f1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
                <div style="font-size:13px;color:var(--texto2)">Enviando para: <strong id="txt-contador-dest"><%= inscricoes.length %> inscritos</strong></div>
                <button type="submit" class="btn btn-primario" onclick="document.getElementById('mala-html').value=quilMala.root.innerHTML;return confirm('Confirmar envio?')">Enviar emails</button>
              </div>
            </form>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Histórico de envios</div>
          <div id="historico-mala" style="padding:16px;text-align:center;color:var(--texto2);font-size:13px">Carregando...</div>
        </div>
      </div>
      <!-- INSCRITOS -->
      <div class="tab-content" id="tab-inscritos">
        <div class="email-massa-box">
          <div style="font-weight:700;font-size:14px;margin-bottom:12px;font-family:'Outfit',sans-serif">Email em massa para inscritos</div>
          <form action="/eventos/<%= evento.id %>/email-massa" method="POST">
            <div class="grid-2" style="margin-bottom:10px">
              <div class="campo"><label class="label">Assunto</label><input name="assunto" class="input" required placeholder="Ex: Atualização sobre o evento..."></div>
              <div class="campo"><label class="label">Filtro</label>
                <div style="display:flex;align-items:center;gap:8px;padding:8px 0">
                  <input type="checkbox" name="apenas_confirmados" id="ap-conf" style="width:16px;height:16px;accent-color:var(--cor-primaria)">
                  <label for="ap-conf" style="font-size:13px;cursor:pointer">Apenas confirmados</label>
                </div>
              </div>
              <div class="campo" style="grid-column:1/-1"><label class="label">Mensagem</label><textarea name="mensagem" class="input" rows="4" required></textarea></div>
            </div>
            <button type="submit" class="btn btn-primario" onclick="return confirm('Enviar email para todos os inscritos selecionados?')">Enviar email em massa</button>
          </form>
        </div>
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
          <div style="display:flex;gap:8px">
            <button class="btn btn-sm" onclick="abrirModal('modal-inscricao-manual')">+ Manual</button>
          </div>
          <input type="text" placeholder="Buscar..." class="input" style="width:220px;font-size:13px;padding:7px 12px" oninput="buscarInscrito(this.value)">
        </div>
        <div class="section-card">
          <table class="tabela" id="tabela-inscritos">
            <thead><tr><th>#</th><th>Nome</th><th>Email</th><th>Lote</th><th>Status</th><th>Check-in</th><th>Ações</th></tr></thead>
            <tbody>
              <% inscricoes.forEach(i => { %>
              <tr class="inscrito-row">
                <td style="color:var(--texto2)"><%= i.id %></td>
                <td style="font-weight:600"><%= i.nome %></td>
                <td style="font-size:12px;color:var(--texto2)"><%= i.email %></td>
                <td style="color:var(--texto2)"><%= i.lote_nome||'—' %></td>
                <td>
                  <span class="badge badge-<%= i.status %>"><%= i.status %></span>
                  <% if(i.isento){ %><span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:999px;font-size:10px;font-weight:700;margin-left:4px">ISENTO</span><% } %>
                </td>
                <td><%= i.checkin_em ? new Date(i.checkin_em).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) : '—' %></td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    <button onclick="editarInscrito(<%= i.id %>,'<%= i.nome.replace(/'/g,"\\'") %>','<%= i.email %>','<%= i.whatsapp||'' %>','<%= i.cpf||'' %>','<%= i.instituicao||'' %>','<%= i.status %>')" class="btn-xs azul">Editar</button>
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/confirmar" style="display:inline"><button class="btn-xs verde">Confirmar</button></form>
                    <a href="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/certificado" class="btn-xs roxo">Cert.</a>
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')"><button class="btn-xs verm">Excluir</button></form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- PAGAMENTOS -->
      <div class="tab-content" id="tab-pagamentos">
        <div class="section-card">
          <div class="section-header">Pagamentos</div>
          <table class="tabela">
            <thead><tr><th>Inscrito</th><th>Valor</th><th>Método</th><th>Status</th><th>Pago em</th><th>Ação</th></tr></thead>
            <tbody>
              <% pagamentos.forEach(pg => { %>
              <tr>
                <td style="font-weight:600"><%= pg.inscrito_nome %></td>
                <td>R$ <%= Number(pg.valor).toFixed(2) %></td>
                <td><span style="background:<%= pg.metodo==='pix'?'#dcfce7':'#eff6ff' %>;color:<%= pg.metodo==='pix'?'#166534':'#1e40af' %>;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700"><%= pg.metodo==='pix'?'PIX':pg.metodo==='cartao'?'Cartão':'—' %></span></td>
                <td><span class="badge badge-<%= pg.status %>"><%= pg.status %></span></td>
                <td style="color:var(--texto2)"><%= pg.pago_em?new Date(pg.pago_em).toLocaleDateString('pt-BR'):'—' %></td>
                <td><% if(pg.status!=='pago'){%><form method="POST" action="/eventos/<%= evento.id %>/pagamentos/<%= pg.id %>/confirmar" style="display:inline"><button class="btn-xs verde">Confirmar</button></form><%}%></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- FINANCEIRO -->
      <div class="tab-content" id="tab-financeiro">
        <%
          const pagsPagos = pagamentos.filter(p => p.status === 'pago');
          let bruto = 0, taxas = 0;
          pagsPagos.forEach(p => {
            const v = Number(p.valor) || 0;
            bruto += v;
            if (p.metodo === 'pix') taxas += v * 0.0099;
            else if (p.metodo === 'cartao') taxas += v * 0.0299 + 0.40;
          });
          const liquido = bruto - taxas;
          const taxaPct = bruto > 0 ? (taxas / bruto * 100) : 0;
        %>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px">
          <div class="stat-box" style="border-top:3px solid #10b981">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Receita Bruta</div>
            <div style="font-size:24px;font-weight:700;color:#10b981;font-family:'Outfit',sans-serif">R$ <%= bruto.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
            <div style="font-size:11px;color:var(--texto2);margin-top:4px"><%= pagsPagos.length %> pagamentos</div>
          </div>
          <div class="stat-box" style="border-top:3px solid #ef4444">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Taxas PagBank</div>
            <div style="font-size:24px;font-weight:700;color:#ef4444;font-family:'Outfit',sans-serif">R$ <%= taxas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
            <div style="font-size:11px;color:var(--texto2);margin-top:4px"><%= taxaPct.toFixed(1) %>% · PIX 0,99% · Cartão 2,99%+R$0,40</div>
          </div>
          <div class="stat-box" style="border-top:3px solid #1a56db">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Receita Líquida</div>
            <div style="font-size:24px;font-weight:700;color:#1a56db;font-family:'Outfit',sans-serif">R$ <%= liquido.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
            <div style="font-size:11px;color:var(--texto2);margin-top:4px">Valor efetivamente recebido</div>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Detalhamento por pagamento<button onclick="imprimirRelatorio()" class="btn-xs" style="font-size:11px">Imprimir</button></div>
          <table class="tabela">
            <thead><tr><th>Participante</th><th>Método</th><th>Bruto</th><th>Taxa</th><th>Líquido</th><th>Data</th></tr></thead>
            <tbody>
              <% pagsPagos.forEach(p => {
                const v = Number(p.valor)||0;
                let tx = 0;
                if(p.metodo==='pix') tx = v*0.0099;
                else if(p.metodo==='cartao') tx = v*0.0299+0.40;
                const liq = v - tx;
              %>
              <tr>
                <td style="font-weight:600"><%= p.inscrito_nome %></td>
                <td><span style="background:<%= p.metodo==='pix'?'#dcfce7':'#eff6ff' %>;color:<%= p.metodo==='pix'?'#166534':'#1e40af' %>;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700"><%= p.metodo==='pix'?'PIX':'Cartão' %></span></td>
                <td style="color:#10b981;font-weight:600">R$ <%= v.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#ef4444;font-size:12px">R$ <%= tx.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="font-weight:700;color:#1a56db">R$ <%= liq.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:var(--texto2);font-size:12px"><%= p.pago_em?new Date(p.pago_em).toLocaleDateString('pt-BR'):'—' %></td>
              </tr>
              <% }) %>
              <tr style="background:var(--fundo);font-weight:700">
                <td colspan="2">TOTAL</td>
                <td style="color:#10b981">R$ <%= bruto.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#ef4444">R$ <%= taxas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#1a56db">R$ <%= liquido.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ONLINE / LIVE -->
      <div class="tab-content" id="tab-online">
        <div class="live-box">
          <div style="font-size:16px;font-weight:700;margin-bottom:6px;font-family:'Outfit',sans-serif">Transmissão Online</div>
          <div style="font-size:13px;color:rgba(255,255,255,.7);margin-bottom:16px">
            Envie links únicos para cada inscrito confirmado. O sistema registra automaticamente o tempo de assistência de cada participante.
          </div>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <div style="font-size:13px;color:rgba(255,255,255,.8)">
              URL YouTube: <strong><%= evento.youtube_url || 'Não configurada — defina na aba Informações' %></strong>
            </div>
            <button onclick="enviarLinksLive()" class="btn btn-sm" style="background:white;color:#1e1b4b;font-weight:700;margin-left:auto">
              Enviar links de acesso
            </button>
            <a href="/eventos/<%= evento.id %>/presencas" class="btn btn-sm" style="background:rgba(255,255,255,.2);color:white">
              Ver presenças
            </a>
          </div>
          <div id="live-resultado" style="margin-top:12px;font-size:13px;color:rgba(255,255,255,.8)"></div>
        </div>
        <div class="section-card">
          <div class="section-header">Como funciona</div>
          <div class="section-body">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px">
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">1</div>
                <div style="font-weight:600;margin-bottom:4px">Configure o evento</div>
                <div style="font-size:12px;color:var(--texto2)">Adicione a URL do YouTube e a duração total do evento na aba Informações.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">2</div>
                <div style="font-weight:600;margin-bottom:4px">Envie os links</div>
                <div style="font-size:12px;color:var(--texto2)">Cada inscrito confirmado recebe um link único por WhatsApp e email.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">3</div>
                <div style="font-weight:600;margin-bottom:4px">Presença automática</div>
                <div style="font-size:12px;color:var(--texto2)">O sistema registra o tempo de assistência a cada 2 minutos. Se fechar a aba, para de contar.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">4</div>
                <div style="font-weight:600;margin-bottom:4px">Relatório final</div>
                <div style="font-size:12px;color:var(--texto2)">Veja quem assistiu 75% ou mais e emita os certificados automaticamente.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- PROGRAMAÇÃO -->
      <div class="tab-content" id="tab-programacao">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Programação do evento</div>
          <div class="section-body">
            <% if(programacao.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum item na programação.</p><%}%>
            <% programacao.forEach(p => { %>
            <div class="prog-item">
              <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                  <div style="font-weight:700;font-size:14px"><%= p.titulo %></div>
                  <div style="font-size:12px;color:var(--cor-primaria);font-weight:600;margin-top:2px"><%= p.horario %><% if(p.local){%> · <%= p.local %><%}%></div>
                  <% if(p.descricao){%><div style="font-size:12px;color:var(--texto2);margin-top:3px"><%= p.descricao %></div><%}%>
                </div>
                <form method="POST" action="/eventos/<%= evento.id %>/programacao/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                  <button type="submit" class="btn-xs verm">Excluir</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar item</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/programacao" method="POST">
              <div class="grid-2">
                <div class="campo"><label class="label">Horário</label><input name="horario" class="input" placeholder="08:00 - 09:00" required></div>
                <div class="campo"><label class="label">Título</label><input name="titulo" class="input" placeholder="Abertura / Palestra..." required></div>
                <div class="campo"><label class="label">Local (opcional)</label><input name="local" class="input" placeholder="Sala A / Auditório..."></div>
                <div class="campo"><label class="label">Descrição (opcional)</label><input name="descricao" class="input"></div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- PALESTRANTES -->
      <div class="tab-content" id="tab-palestrantes">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Palestrantes</div>
          <div class="section-body">
            <% if(palestrantes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum palestrante adicionado.</p><%}%>
            <% palestrantes.forEach(p => { %>
            <div class="pales-item">
              <% if(p.foto_chave){%><img src="/eventos/palestrantes/<%= p.id %>/foto" class="pales-foto"><% }else{ %><div class="pales-foto" style="background:var(--fundo);border:1px solid var(--borda)">?</div><%}%>
              <div style="flex:1">
                <div style="font-weight:700"><%= p.nome %></div>
                <% if(p.instituicao){%><div style="font-size:12px;color:var(--cor-primaria)"><%= p.instituicao %></div><%}%>
                <% if(p.bio){%><div style="font-size:12px;color:var(--texto2);margin-top:2px"><%= p.bio.substring(0,100) %><%= p.bio.length>100?'...':'' %></div><%}%>
              </div>
              <form method="POST" action="/eventos/<%= evento.id %>/palestrantes/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button>
              </form>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar palestrante</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/palestrantes" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
                <div class="campo"><label class="label">Instituição</label><input name="instituicao" class="input"></div>
                <div class="campo" style="grid-column:1/-1"><label class="label">Bio</label><textarea name="bio" class="input" rows="3"></textarea></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Foto (400×400px recomendado)</label>
                  <input type="file" name="foto" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- PATROCINADORES -->
      <div class="tab-content" id="tab-patrocinadores">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Patrocinadores</div>
          <div class="section-body">
            <% if(patrocinadores.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum patrocinador adicionado.</p><%}%>
            <% patrocinadores.forEach(p => { %>
            <div class="patroc-item">
              <% if(p.logo_chave){%><img src="/eventos/patrocinadores/<%= p.id %>/logo" style="height:50px;max-width:140px;object-fit:contain;border-radius:4px"><% }else{ %><div style="width:50px;height:50px;background:var(--borda);border-radius:4px"></div><%}%>
              <div style="flex:1"><div style="font-weight:600"><%= p.nome %></div><div style="font-size:11px;color:var(--texto2)"><%= p.url||'' %></div></div>
              <form method="POST" action="/eventos/<%= evento.id %>/patrocinadores/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button>
              </form>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar patrocinador</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/patrocinadores" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
                <div class="campo"><label class="label">Website</label><input name="url" class="input" placeholder="https://..."></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Logo (400×200px recomendado, PNG prefencial)</label>
                  <input type="file" name="logo" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- CUPONS -->
      <div class="tab-content" id="tab-cupons">
        <div class="section-card" style="margin-bottom:16px;border:1.5px solid #d1fae5">
          <div class="section-header" style="background:#f0fdf4">Cupons de isenção para ligantes e diretivos</div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Gera 1 cupom individual (100% desconto) por pessoa e envia via WhatsApp e/ou email.</p>
            <form action="/eventos/<%= evento.id %>/cupons/gerar-ligantes" method="POST">
              <div class="grid-2" style="margin-bottom:12px">
                <div class="campo"><label class="label">Prefixo do código</label><input name="prefixo" class="input" value="LAURO" maxlength="8" style="text-transform:uppercase"></div>
                <div class="campo"><label class="label">Enviar para</label>
                  <select name="destino" class="input">
                    <option value="ligantes">Ligantes em dia</option>
                    <option value="diretivos">Diretivos</option>
                    <option value="todos">Todos</option>
                  </select>
                </div>
              </div>
              <div style="display:flex;gap:20px;margin-bottom:14px;flex-wrap:wrap">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                  <input type="checkbox" name="enviar_wpp" style="width:16px;height:16px;accent-color:var(--cor-primaria)"> WhatsApp
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                  <input type="checkbox" name="enviar_email" style="width:16px;height:16px;accent-color:var(--cor-primaria)"> Email
                </label>
