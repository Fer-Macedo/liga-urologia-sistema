<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — Gerenciar</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <link rel="stylesheet" href="/css/tema-lauro.css">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .tab-nav {
      display: flex;
      gap: 2px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--borda);
      flex-wrap: wrap;
      overflow-x: auto;
    }
    .tab-btn {
      padding: 9px 16px;
      border: none;
      background: none;
      cursor: pointer;
      font-weight: 600;
      font-size: 12.5px;
      color: var(--texto2);
      border-bottom: 2.5px solid transparent;
      margin-bottom: -2px;
      white-space: nowrap;
      font-family: 'Outfit', sans-serif;
      transition: all .15s;
    }
    .tab-btn.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); }
    .tab-btn:hover { color: var(--texto); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    .stat-box {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 12px;
      padding: 14px 16px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .stat-box::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--cor-primaria);
      opacity: .5;
    }
    .stat-num {
      font-family: 'Outfit', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--cor-primaria);
      margin-bottom: 3px;
    }
    .stat-lab { font-size: 11px; color: var(--texto2); font-weight: 600; }

    .section-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 16px;
    }
    .section-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--borda);
      font-size: 14px;
      font-weight: 700;
      font-family: 'Outfit', sans-serif;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-body { padding: 18px; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    @media(max-width:600px){.grid-2,.grid-3{grid-template-columns:1fr}}

    .lote-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
      gap: 10px;
      flex-wrap: wrap;
    }
    .campo-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .prog-item {
      border-left: 3px solid var(--cor-primaria);
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 0 8px 8px 0;
      margin-bottom: 8px;
    }
    .pales-item {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .pales-foto {
      width: 48px; height: 48px;
      border-radius: 50%;
      object-fit: cover;
      background: var(--borda);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 20px;
    }
    .patroc-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
    }
    .cupom-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 14px;
      background: var(--fundo);
      border-radius: 8px;
      border: 1px solid var(--borda);
      margin-bottom: 8px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .cupom-cod {
      font-family: monospace;
      font-size: 14px;
      font-weight: 700;
      color: var(--cor-primaria);
      background: var(--card);
      border: 1px dashed var(--borda);
      padding: 3px 10px;
      border-radius: 6px;
      letter-spacing: 2px;
    }

    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
    }
    .badge-confirmado { background: #dcfce7; color: #166534; }
    .badge-pendente   { background: #fef3c7; color: #92400e; }
    .badge-cancelado  { background: #fee2e2; color: #991b1b; }
    .badge-pago       { background: #dcfce7; color: #166534; }

    .btn-xs {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      border: 1px solid var(--borda);
      background: var(--fundo);
      color: var(--texto);
      cursor: pointer;
      text-decoration: none;
      transition: all .15s;
      font-family: inherit;
    }
    .btn-xs { border-radius:0; transition:transform .12s ease, background .12s ease, border-color .12s ease, color .12s ease, box-shadow .12s ease; }
    .btn-xs svg { width:12px; height:12px; vertical-align:middle; margin-right:3px; }
    .btn-xs:hover { border-color:var(--cor-primaria); color:var(--cor-primaria); transform:translateY(-2px); box-shadow:0 3px 8px rgba(0,0,0,.12); }
    .btn-xs.verde { background:#059669; color:white; border-color:transparent; }
    .btn-xs.verde:hover { background:#047857; color:white; transform:translateY(-2px); box-shadow:0 4px 10px rgba(5,150,105,.35); }
    .btn-xs.azul  { background:#0891b2; color:white; border-color:transparent; }
    .btn-xs.azul:hover  { background:#0e7490; color:white; transform:translateY(-2px); box-shadow:0 4px 10px rgba(8,145,178,.35); }
    .btn-xs.roxo  { background:#6366f1; color:white; border-color:transparent; }
    .btn-xs.roxo:hover  { background:#4f46e5; color:white; transform:translateY(-2px); box-shadow:0 4px 10px rgba(99,102,241,.35); }
    .btn-xs.cyan  { background:#0d9488; color:white; border-color:transparent; }
    .btn-xs.cyan:hover  { background:#0f766e; color:white; transform:translateY(-2px); box-shadow:0 4px 10px rgba(13,148,136,.35); }
    .btn-xs.amarelo { background:#f59e0b; color:white; border-color:transparent; }
    .btn-xs.amarelo:hover { background:#d97706; color:white; transform:translateY(-2px); box-shadow:0 4px 10px rgba(245,158,11,.35); }
    .btn-xs.verm  { color:#dc2626; border-color:#fecaca; }
    .btn-xs.verm:hover  { background:#fee2e2; color:#dc2626; transform:translateY(-2px); box-shadow:0 3px 8px rgba(220,38,38,.15); }

    table.tabela { width: 100%; border-collapse: collapse; }
    table.tabela thead th {
      background: var(--fundo);
      padding: 10px 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--texto2);
      text-align: left;
      border-bottom: 1px solid var(--borda);
    }
    table.tabela tbody tr { border-bottom: 1px solid var(--borda); transition: background .15s; }
    table.tabela tbody tr:last-child { border-bottom: none; }
    table.tabela tbody tr:hover { background: var(--fundo); }
    table.tabela tbody td { padding: 10px 12px; font-size: 13px; color: var(--texto); vertical-align: middle; }

    .cores-paleta { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
    .cor-dot { width: 26px; height: 26px; border-radius: 6px; cursor: pointer; border: 3px solid transparent; transition: .2s; }
    .cor-dot:hover { transform: scale(1.1); }

    .campo-ord-item { display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--fundo);border-radius:8px;border:1px solid var(--borda);margin-bottom:6px;cursor:grab;transition:all .15s;gap:10px; }
    .campo-ord-item:active { cursor:grabbing;opacity:.8; }
    .campo-ord-item.drag-over { border-color:var(--cor-primaria);background:var(--card); }
    .drag-handle { color:var(--texto2);cursor:grab;flex-shrink:0; }
    .email-massa-box {
      background: var(--fundo);
      border: 2px solid var(--borda);
      border-radius: 12px;
      padding: 18px;
      margin-bottom: 16px;
    }

    .aviso-dim {
      background: #fffbeb;
      border: 1.5px solid #fcd34d;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 12px;
      color: #92400e;
      margin-bottom: 8px;
    }

    .live-box {
      background: linear-gradient(135deg, #103024, #0C231B);
      border-radius: 12px;
      padding: 20px;
      color: white;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'eventos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo" style="font-size:15px"><%= evento.nome %></h1>
      <div class="topbar-acoes">
        <a href="/eventos" class="btn btn-sm">Voltar</a>
        <a href="/eventos/<%= evento.id %>/relatorio-pdf" target="_blank" class="btn btn-sm" style="background:#374151;color:white">Relatorio PDF</a>
        <a href="/inscricao/<%= evento.id %>" target="_blank" class="btn btn-sm" style="background:#059669;color:white">Pág. Pública</a>
        <a href="/eventos/<%= evento.id %>/checkin" class="btn btn-sm btn-primario">Check-in</a>
        <a href="/eventos/<%= evento.id %>/presencas" class="btn btn-sm" style="background:#8b5cf6;color:white">Presenças</a>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-box"><div class="stat-num"><%= stats.total %></div><div class="stat-lab">Inscritos</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#059669"><%= stats.confirmados %></div><div class="stat-lab">Confirmados</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#6366f1"><%= stats.checkins %></div><div class="stat-lab">Check-ins</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#f59e0b">R$ <%= Number(stats.receita||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div><div class="stat-lab">Receita</div></div>
        <div class="stat-box"><div class="stat-num" style="color:#dc2626"><%= evento.vagas_total - stats.total %></div><div class="stat-lab">Vagas livres</div></div>
      </div>

      <!-- TABS -->
      <div class="tab-nav">
        <button class="tab-btn ativo" onclick="showTab('info',this)">Informações</button>
        <button class="tab-btn" onclick="showTab('lotes',this)">Lotes</button>
        <button class="tab-btn" onclick="showTab('campos',this)">Campos</button>
        <button class="tab-btn" onclick="showTab('inscritos',this)">Inscritos</button>
        <button class="tab-btn" onclick="showTab('mala-direta',this)">Mala Direta</button>
        <button class="tab-btn" onclick="showTab('pagamentos',this)">Pagamentos</button>
        <button class="tab-btn" onclick="showTab('financeiro',this)">Financeiro</button>
        <button class="tab-btn" onclick="showTab('online',this)">Online / Live</button>
        <button class="tab-btn" onclick="showTab('programacao',this)">Programação</button>
        <button class="tab-btn" onclick="showTab('palestrantes',this)">Palestrantes</button>
        <button class="tab-btn" onclick="showTab('patrocinadores',this)">Patrocinadores</button>
        <button class="tab-btn" onclick="showTab('cupons',this)">Cupons</button>
        <button class="tab-btn" onclick="showTab('certificados',this)">Certificados</button>
        <button class="tab-btn" onclick="showTab('avancado',this)">Avançado</button>
      </div>

      <!-- INFO -->
      <div class="tab-content ativo" id="tab-info">
        <div class="section-card">
          <div class="section-header">Editar evento</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/editar" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo" style="grid-column:1/-1"><label class="label">Nome do evento</label><input name="nome" class="input" value="<%= evento.nome %>" required></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Descrição</label>
                  <div id="editor-desc" style="height:180px;background:white;border-radius:8px"><%- evento.descricao||'' %></div>
                  <input type="hidden" name="descricao" id="descricao-hidden">
                </div>
                <div class="campo"><label class="label">Data/hora início</label><input type="datetime-local" name="data_inicio" class="input" value="<%= evento.data_inicio? new Date(new Date(evento.data_inicio).getTime() - new Date(evento.data_inicio).getTimezoneOffset()*60000).toISOString().slice(0,16):'' %>"></div>
              <div class="campo"><label class="label">Data/hora fim</label><input type="datetime-local" name="data_fim" class="input" value="<%= evento.data_fim? new Date(new Date(evento.data_fim).getTime() - new Date(evento.data_fim).getTimezoneOffset()*60000).toISOString().slice(0,16):'' %>"></div>
                <div class="campo"><label class="label">Local</label><input name="local" class="input" value="<%= evento.local||'' %>"></div>
                <div class="campo"><label class="label">Total de vagas</label><input type="number" name="vagas_total" class="input" value="<%= evento.vagas_total %>"></div>
                <div class="campo"><label class="label">Endereço</label><input name="endereco" class="input" value="<%= evento.endereco||'' %>"></div>
                <div class="campo"><label class="label">Carga horária (h)</label><input type="number" name="carga_horaria" class="input" value="<%= evento.carga_horaria||'' %>" placeholder="Ex: 4"></div>
                <div class="campo"><label class="label">Duração total (minutos)</label><input type="number" name="duracao_minutos" class="input" value="<%= evento.duracao_minutos||'' %>" placeholder="Ex: 240 = 4h"></div>
                <div class="campo"><label class="label">URL YouTube (transmissão online)</label><input name="youtube_url" class="input" value="<%= evento.youtube_url||'' %>" placeholder="https://youtu.be/..."></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo_evento" class="input">
                    <option value="presencial" <%= evento.tipo_evento==='presencial'?'selected':'' %>>Presencial</option>
                    <option value="online" <%= evento.tipo_evento==='online'?'selected':'' %>>Online</option>
                    <option value="hibrido" <%= evento.tipo_evento==='hibrido'?'selected':'' %>>Híbrido</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Status</label>
                  <select name="status" class="input">
                    <option value="rascunho" <%= evento.status==='rascunho'?'selected':'' %>>Rascunho</option>
                    <option value="ativo" <%= evento.status==='ativo'?'selected':'' %>>Ativo</option>
                    <option value="encerrado" <%= evento.status==='encerrado'?'selected':'' %>>Encerrado</option>
                    <option value="cancelado" <%= evento.status==='cancelado'?'selected':'' %>>Cancelado</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Inscrições públicas</label>
                  <select name="publico" class="input">
                    <option value="true" <%= evento.publico?'selected':'' %>>Sim</option>
                    <option value="false" <%= !evento.publico?'selected':'' %>>Não</option>
                  </select>
                </div>
                <div class="campo">
                  <label class="label">Cor tema</label>
                  <div class="cores-paleta">
                    <% ["#1a3d2b","#1a56db","#7c3aed","#dc2626","#ea580c","#ca8a04","#0891b2","#0f766e","#be185d","#374151"].forEach(cor=>{ %>
                    <div class="cor-dot" style="background:<%= cor %>" onclick="setCor('<%= cor %>')"></div>
                    <% }) %>
                    <input type="color" onchange="setCor(this.value)" style="width:26px;height:26px;border:none;border-radius:6px;cursor:pointer;padding:0">
                  </div>
                  <div style="display:flex;gap:8px;align-items:center">
                    <div id="cor-preview" style="width:30px;height:30px;border-radius:7px;background:<%= evento.cor_tema||'#1a3d2b' %>;border:1px solid var(--borda)"></div>
                    <input type="text" id="cor-input" name="cor_tema" class="input" value="<%= evento.cor_tema||'#1a3d2b' %>" style="max-width:110px" oninput="document.getElementById('cor-preview').style.background=this.value">
                  </div>
                </div>
                <div class="campo">
                  <label class="label">Banner <span style="font-size:11px;font-weight:400;color:var(--texto2)">(ideal: 1200×400px)</span></label>
                  <% if(evento.banner_chave){%><img src="/eventos/<%= evento.id %>/banner" style="max-width:200px;border-radius:8px;margin-bottom:8px;display:block"><% } %>
                  <input type="file" name="banner" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <div style="margin-top:14px"><button type="submit" class="btn btn-primario" onclick="document.getElementById('descricao-hidden').value=quill.root.innerHTML">Salvar alterações</button></div>
            </form>
          </div>
        </div>
      </div>

      <!-- LOTES -->
      <div class="tab-content" id="tab-lotes">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Lotes de ingressos</div>
          <div class="section-body">
            <% if(lotes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum lote criado.</p><%}%>
            <% lotes.forEach(l => { %>
            <div class="lote-item">
              <div>
                <div style="font-weight:600"><%= l.nome %></div>
                <div style="font-size:12px;color:var(--texto2)">R$ <%= Number(l.preco).toFixed(2) %> · <%= l.vagas %> vagas · <%= l.inscritos||0 %> inscritos</div>
                <% if(l.data_inicio){%><div style="font-size:11px;color:var(--texto2);margin-top:2px"><%= new Date(l.data_inicio).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %> até <%= new Date(l.data_fim).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %></div><%}%>
              </div>
              <div style="display:flex;gap:6px">
        <button onclick="editarLote(<%= l.id %>,'<%= l.nome %>',<%= l.preco %>,<%= l.vagas %>,'<%= l.data_inicio? new Date(new Date(l.data_inicio).getTime() - new Date(l.data_inicio).getTimezoneOffset()*60000).toISOString().slice(0,16):'' %>','<%= l.data_fim? new Date(new Date(l.data_fim).getTime() - new Date(l.data_fim).getTimezoneOffset()*60000).toISOString().slice(0,16):'' %>')" class="btn-xs azul">Editar</button>
                <form method="POST" action="/eventos/<%= evento.id %>/lotes/<%= l.id %>/deletar" onsubmit="return confirm('Excluir lote?')" style="display:inline">
                  <button type="submit" class="btn-xs verm">Excluir</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Novo lote</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/lotes" method="POST">
              <div class="grid-3">
                <div class="campo"><label class="label">Nome</label><input name="nome" class="input" placeholder="Ex: Lote 1" required></div>
                <div class="campo"><label class="label">Preço (R$)</label><input type="number" step="0.01" name="preco" class="input" value="0" min="0"></div>
                <div class="campo"><label class="label">Vagas</label><input type="number" name="vagas" class="input" value="50" min="1"></div>
                <div class="campo"><label class="label">Início</label><input type="datetime-local" name="data_inicio" class="input"></div>
                <div class="campo"><label class="label">Fim</label><input type="datetime-local" name="data_fim" class="input"></div>
                <div class="campo" style="display:flex;align-items:flex-end"><button type="submit" class="btn btn-primario" style="width:100%">Adicionar lote</button></div>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- CAMPOS -->
      <div class="tab-content" id="tab-campos">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">
            Todos os campos
            <button type="button" onclick="salvarOrdem()" class="btn-xs verde" id="btn-salvar-ordem" style="display:none">Salvar ordem</button>
          </div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Arraste para reordenar. Campos padrão não podem ser excluídos.</p>
            <div id="lista-campos-ord">
              <% const camposPad=[{key:'nome',label:'Nome completo'},{key:'email',label:'Email'},{key:'whatsapp',label:'WhatsApp'},{key:'data_nascimento',label:'Data de nascimento'},{key:'rg',label:'RG / CI'},{key:'semestre',label:'Semestre'},{key:'turma',label:'Turma'},{key:'catraca',label:'Catraca (UCP)'},{key:'instituicao',label:'Instituição (externos)'}]; %>
              <% const todosCampos=[...camposPad.map(c=>({...c,padrao:true})),...campos.map(c=>({key:'extra_'+c.id,label:c.label,padrao:false,id:c.id,tipo:c.tipo,obrigatorio:c.obrigatorio}))]; %>
              <% todosCampos.forEach(c => { %>
              <div class="campo-ord-item" data-key="<%= c.key %>">
                <div style="display:flex;align-items:center;gap:10px;flex:1">
                  <div class="drag-handle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="5" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="15" cy="19" r="1.5"/></svg></div>
                  <span style="font-weight:600"><%= c.label %></span>
                  <% if(c.padrao){ %><span style="font-size:10px;background:#eff6ff;color:#1e40af;padding:2px 7px;border-radius:4px;font-weight:700">padrão</span>
                  <% }else{ %><span style="font-size:10px;background:var(--borda);color:var(--texto2);padding:2px 7px;border-radius:4px"><%= c.tipo %></span><% if(c.obrigatorio){%><span style="font-size:10px;color:#dc2626;margin-left:4px">obrig.</span><%}%><% } %>
                </div>
                <% if(!c.padrao){ %>
                <form method="POST" action="/eventos/<%= evento.id %>/campos/<%= c.id %>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')"><button type="submit" class="btn-xs verm">Excluir</button></form>
                <% }else{ %><span style="font-size:11px;color:#10b981;font-weight:600">fixo</span><% } %>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar campo extra</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/campos" method="POST">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome</label><input name="label" class="input" placeholder="Ex: Instituição..." required></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo" class="input" onchange="mostrarOpcoes(this.value)">
                    <option value="text">Texto simples</option>
                    <option value="textarea">Caixa de texto</option>
                    <option value="select">Lista suspensa</option>
                    <option value="radio">Múltipla escolha</option>
                    <option value="date">Data</option>
                  </select>
                </div>
                <div class="campo" id="div-opcoes" style="grid-column:1/-1;display:none">
                  <label class="label">Opções (uma por linha)</label>
                  <textarea name="opcoes" class="input" rows="3"></textarea>
                </div>
                <div class="campo"><label class="label">Obrigatório</label>
                  <select name="obrigatorio" class="input"><option value="false">Não</option><option value="true">Sim</option></select>
                </div>
                <div class="campo" style="display:flex;align-items:flex-end">
                  <button type="submit" class="btn btn-primario" style="width:100%">Adicionar</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
      <!-- MALA DIRETA -->
      <div class="tab-content" id="tab-mala-direta">
        <div class="section-card" style="margin-bottom:20px">
          <div class="section-header">Compor email</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/mala-direta" method="POST" id="form-mala">
              <input type="hidden" name="conteudo_html" id="mala-html">
              <div class="grid-2" style="margin-bottom:16px">
                <div class="campo"><label class="label">Assunto *</label><input name="assunto" class="input" required placeholder="Ex: Informações importantes..."></div>
                <div class="campo"><label class="label">Enviar para</label>
                  <select name="destinatarios" class="input" id="sel-dest" onchange="atualizarContador()">
                    <option value="todos">Todos os inscritos</option>
                    <option value="confirmados">Apenas confirmados</option>
                    <option value="pendentes">Apenas pendentes</option>
                  </select>
                </div>
              </div>
              <div class="campo" style="margin-bottom:16px">
                <label class="label">Conteúdo</label>
                <div style="font-size:11px;color:var(--texto2);margin-bottom:6px">Use <code style="background:var(--fundo);padding:2px 5px;border-radius:4px">{nome}</code> para o nome do participante.</div>
                <div id="editor-mala" style="height:300px;background:white;border-radius:8px"></div>
              </div>
              <div style="background:linear-gradient(135deg,#eff6ff,#f0fdf4);border:1px solid #bfdbfe;border-radius:10px;padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:16px">
                <div style="flex:1">
                  <div style="font-size:13px;font-weight:700;color:#1e40af;margin-bottom:4px">Layout do email</div>
                  <div style="font-size:12px;color:#3730a3;line-height:1.6">Cabeçalho colorido com logo da liga → "Olá, [Nome]!" → Seu conteúdo → Rodapé institucional.</div>
                </div>
                <div style="width:52px;height:52px;background:linear-gradient(135deg,var(--cor-primaria),#6366f1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
                <div style="font-size:13px;color:var(--texto2)">Enviando para: <strong id="txt-contador-dest"><%= inscricoes.length %> inscritos</strong></div>
                <button type="submit" class="btn btn-primario" onclick="document.getElementById('mala-html').value=quilMala.root.innerHTML;return confirm('Confirmar envio?')">Enviar emails</button>
              </div>
            </form>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Histórico de envios</div>
          <div id="historico-mala" style="padding:16px;text-align:center;color:var(--texto2);font-size:13px">Carregando...</div>
        </div>
      </div>
      <!-- INSCRITOS -->
     <div class="tab-content" id="tab-inscritos">
        <div class="email-massa-box">
          <div style="font-weight:700;font-size:14px;margin-bottom:12px;font-family:'Outfit',sans-serif">Email em massa para inscritos</div>
          <form action="/eventos/<%= evento.id %>/email-massa" method="POST">
            <div class="grid-2" style="margin-bottom:10px">
              <div class="campo"><label class="label">Assunto</label><input name="assunto" class="input" required placeholder="Ex: Atualização sobre o evento..."></div>
              <div class="campo"><label class="label">Filtro</label>
                <div style="display:flex;align-items:center;gap:8px;padding:8px 0">
                  <input type="checkbox" name="apenas_confirmados" id="ap-conf" style="width:16px;height:16px;accent-color:var(--cor-primaria)">
                  <label for="ap-conf" style="font-size:13px;cursor:pointer">Apenas confirmados</label>
                </div>
              </div>
              <div class="campo" style="grid-column:1/-1"><label class="label">Mensagem</label>
                <div id="quill-massa-evento" style="background:#fff;min-height:180px"></div>
                <textarea name="mensagem" id="massa-mensagem-hidden" hidden></textarea>
              </div>
            </div>
            <button type="submit" class="btn btn-primario" onclick="return confirm('Enviar email para todos os inscritos selecionados?')">Enviar email em massa</button>
          </form>
        </div>

        <!-- FILTROS + PAGINAÇÃO -->
        <div style="background:var(--card);border:1px solid var(--borda);border-radius:8px;padding:16px;margin-bottom:14px">
          <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end">
            <div style="flex:1;min-width:180px">
              <label class="label">Buscar</label>
              <input type="text" id="ins-busca" class="input" style="width:100%;font-size:13px" placeholder="Nome ou email..." oninput="filtrarInscritos()">
            </div>
            <div style="min-width:130px">
              <label class="label">Status</label>
              <select id="ins-status" class="input" style="width:100%;font-size:13px" onchange="filtrarInscritos()">
                <option value="">Todos</option><option value="confirmado">Confirmado</option><option value="pendente">Pendente</option><option value="cancelado">Cancelado</option>
              </select>
            </div>
            <div style="min-width:120px">
              <label class="label">Tipo</label>
              <select id="ins-tipo" class="input" style="width:100%;font-size:13px" onchange="filtrarInscritos()">
                <option value="">Todos</option><option value="isento">Isentos</option><option value="pagante">Pagantes</option>
              </select>
            </div>
            <div style="min-width:140px">
              <label class="label">Lote</label>
              <select id="ins-lote" class="input" style="width:100%;font-size:13px" onchange="filtrarInscritos()">
                <option value="">Todos</option>
                <% lotes.forEach(l => { %><option value="<%= l.id %>"><%= l.nome %></option><% }) %>
              </select>
            </div>
            <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
              <button class="btn btn-sm" onclick="abrirModal('modal-inscricao-manual')" style="white-space:nowrap">+ Manual</button>
              <button class="btn btn-sm" onclick="limparFiltrosInscritos()" style="white-space:nowrap">Limpar</button>
              <button class="btn btn-sm" onclick="imprimirInscritos()" style="white-space:nowrap;background:var(--cor-primaria);color:#fff;border-color:transparent">Imprimir filtrados</button>
            </div>
          </div>
          <div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
            <div style="font-size:12px;color:var(--texto2)">Exibindo <span id="ins-count-filt" style="font-weight:700;color:var(--cor-primaria)">0</span> de <span id="ins-count-tot" style="font-weight:700"><%= inscricoes.length %></span> inscritos</div>
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-size:12px;color:var(--texto2)">Por página:</span>
              <select id="ins-por-pagina" class="input" style="font-size:12px;padding:4px 8px;width:74px" onchange="filtrarInscritos()">
                <option value="25">25</option><option value="50">50</option><option value="100">100</option><option value="9999">Todos</option>
              </select>
            </div>
          </div>
        </div>

        <div class="section-card">
          <table class="tabela" id="tabela-inscritos">
            <thead><tr><th>#</th><th>Nome</th><th>Email</th><th>Lote</th><th>Status</th><th>Check-in</th><th>Ações</th></tr></thead>
            <tbody>
              <% inscricoes.forEach(i => { %>
              <tr class="inscrito-row"
                data-nome="<%= (i.nome||'').toLowerCase() %>"
                data-email="<%= (i.email||'').toLowerCase() %>"
                data-status="<%= i.status %>"
                data-isento="<%= i.isento ? 'isento' : 'pagante' %>"
                data-lote="<%= i.lote_id||'' %>">
                <td style="color:var(--texto2)"><%= i.id %></td>
                <td style="font-weight:600"><%= i.nome %></td>
                <td style="font-size:12px;color:var(--texto2)"><%= i.email %></td>
                <td style="color:var(--texto2)"><%= i.lote_nome||'—' %></td>
                <td>
                  <span class="badge badge-<%= i.status %>"><%= i.status %></span>
                  <% if(i.isento){ %><span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:999px;font-size:10px;font-weight:700;margin-left:4px">ISENTO</span><% } %>
                </td>
                <td><%= i.checkin_em ? new Date(i.checkin_em).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) : '—' %></td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap">
                    <button onclick="editarInscrito(<%= i.id %>)" class="btn-xs azul">Editar</button>
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/confirmar" style="display:inline"><button class="btn-xs verde">Confirmar</button></form>
                    <a href="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/certificado" class="btn-xs roxo">Cert.</a>
                    <a href="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/cracha" target="_blank" class="btn-xs cyan">Cracha</a>
                    <form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')"><button class="btn-xs verm">Excluir</button></form><form method="POST" action="/eventos/<%= evento.id %>/inscricoes/<%= i.id %>/reenviar-email" style="display:inline" onsubmit="return confirm('Reenviar e-mail de confirmação para <%= i.email %>?')"><button class="btn-xs amarelo" title="Reenviar e-mail de confirmação"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Email</button></form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <div id="ins-paginacao" style="display:flex;align-items:center;justify-content:center;gap:6px;padding:16px 0;flex-wrap:wrap"></div>
        </div>
      </div>

      <!-- LISTA ESPERA -->
      <div id="lista-espera-section" style="margin-top:20px" class="section-card">
        <div class="section-header" style="display:flex;justify-content:space-between;align-items:center">
          <span>Lista de espera</span>
          <button onclick="carregarEspera()" class="btn-xs azul">Atualizar</button>
        </div>
        <div id="espera-conteudo" style="padding:16px;text-align:center;color:var(--texto2);font-size:13px">Clique em Atualizar para ver a lista.</div>
      </div>

      <!-- PAGAMENTOS -->
      <div class="tab-content" id="tab-pagamentos">
        <!-- FILTROS PAGAMENTOS -->
        <div style="background:var(--card);border:1px solid var(--borda);border-radius:8px;padding:16px;margin-bottom:14px">
          <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end">
            <div style="flex:1;min-width:160px">
              <label class="label">Buscar</label>
              <input type="text" id="pg-busca" class="input" style="width:100%;font-size:13px" placeholder="Nome do inscrito..." oninput="filtrarPagamentos()">
            </div>
            <div style="min-width:120px">
              <label class="label">Status</label>
              <select id="pg-status" class="input" style="width:100%;font-size:13px" onchange="filtrarPagamentos()">
                <option value="">Todos</option><option value="pago">Pago</option><option value="pendente">Pendente</option><option value="cancelado">Cancelado</option>
              </select>
            </div>
            <div style="min-width:120px">
              <label class="label">Método</label>
              <select id="pg-metodo" class="input" style="width:100%;font-size:13px" onchange="filtrarPagamentos()">
                <option value="">Todos</option><option value="pix">PIX</option><option value="cartao">Cartão</option>
              </select>
            </div>
            <div style="min-width:130px">
              <label class="label">Pago de</label>
              <input type="date" id="pg-data-de" class="input" style="width:100%;font-size:13px" onchange="filtrarPagamentos()">
            </div>
            <div style="min-width:130px">
              <label class="label">Pago até</label>
              <input type="date" id="pg-data-ate" class="input" style="width:100%;font-size:13px" onchange="filtrarPagamentos()">
            </div>
            <div style="display:flex;gap:8px;align-items:flex-end">
              <button class="btn btn-sm" onclick="limparFiltrosPagamentos()" style="white-space:nowrap">Limpar</button>
            </div>
          </div>
          <div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
            <div style="font-size:12px;color:var(--texto2)">Exibindo <span id="pg-count-filt" style="font-weight:700;color:var(--cor-primaria)">0</span> de <span id="pg-count-tot" style="font-weight:700"><%= pagamentos.length %></span> pagamentos</div>
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-size:12px;color:var(--texto2)">Por página:</span>
              <select id="pg-por-pagina" class="input" style="font-size:12px;padding:4px 8px;width:74px" onchange="filtrarPagamentos()">
                <option value="25">25</option><option value="50">50</option><option value="100">100</option><option value="9999">Todos</option>
              </select>
            </div>
          </div>
        </div>

        <div class="section-card">
          <div class="section-header">Pagamentos</div>
          <table class="tabela" id="tabela-pagamentos">
            <thead><tr><th>Inscrito</th><th>Valor</th><th>Método</th><th>Status</th><th>Pago em</th><th>Ação</th></tr></thead>
            <tbody>
              <% pagamentos.forEach(pg => { %>
              <tr class="pagamento-row"
                data-nome="<%= (pg.inscrito_nome||'').toLowerCase() %>"
                data-status="<%= pg.status %>"
                data-metodo="<%= pg.metodo||'' %>"
                data-data="<%= pg.pago_em ? new Date(new Date(pg.pago_em).getTime() - new Date(pg.pago_em).getTimezoneOffset()*60000).toISOString().slice(0,10) : '' %>">
                <td style="font-weight:600"><%= pg.inscrito_nome %></td>
                <td>R$ <%= Number(pg.valor).toFixed(2) %></td>
                <td><span style="background:<%= pg.metodo==='pix'?'#dcfce7':'#eff6ff' %>;color:<%= pg.metodo==='pix'?'#166534':'#1e40af' %>;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700"><%= pg.metodo==='pix'?'PIX':pg.metodo==='cartao'?'Cartão':'—' %></span></td>
                <td><span class="badge badge-<%= pg.status %>"><%= pg.status %></span></td>
                <td style="color:var(--texto2)"><%= pg.pago_em?new Date(pg.pago_em).toLocaleDateString('pt-BR'):'—' %></td>
                <td><% if(pg.status!=='pago'){%><form method="POST" action="/eventos/<%= evento.id %>/pagamentos/<%= pg.id %>/confirmar" style="display:inline"><button class="btn-xs verde">Confirmar</button></form><%}%></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <div id="pg-paginacao" style="display:flex;align-items:center;justify-content:center;gap:6px;padding:16px 0;flex-wrap:wrap"></div>
        </div>
      </div>
      <!-- FINANCEIRO -->
      <div class="tab-content" id="tab-financeiro">
        <%
          const pagsPagos = pagamentos.filter(p => p.status === 'pago');
          let bruto = 0, taxas = 0;
          pagsPagos.forEach(p => {
            const v = Number(p.valor) || 0;
            bruto += v;
           if (p.metodo === 'pix') taxas += v * 0.018;
            else if (p.metodo === 'cartao') taxas += v * 0.04;
          });
          const liquido = bruto - taxas;
          const taxaPct = bruto > 0 ? (taxas / bruto * 100) : 0;
        %>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px">
          <div class="stat-box" style="border-top:3px solid #10b981">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Receita Bruta</div>
            <div style="font-size:24px;font-weight:700;color:#10b981;font-family:'Outfit',sans-serif">R$ <%= bruto.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
            <div style="font-size:11px;color:var(--texto2);margin-top:4px"><%= pagsPagos.length %> pagamentos</div>
          </div>
          <div class="stat-box" style="border-top:3px solid #ef4444">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Taxas PagBank</div>
            <div style="font-size:24px;font-weight:700;color:#ef4444;font-family:'Outfit',sans-serif">R$ <%= taxas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
         <div style="font-size:11px;color:var(--texto2);margin-top:4px"><%= taxaPct.toFixed(1) %>% · PIX 1,8% · Cartão 4,0%</div>
          </div>
          <div class="stat-box" style="border-top:3px solid #1a56db">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--texto2);margin-bottom:6px">Receita Líquida</div>
            <div style="font-size:24px;font-weight:700;color:#1a56db;font-family:'Outfit',sans-serif">R$ <%= liquido.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
            <div style="font-size:11px;color:var(--texto2);margin-top:4px">Valor efetivamente recebido</div>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Detalhamento por pagamento<button onclick="imprimirRelatorio()" class="btn-xs" style="font-size:11px">Imprimir</button></div>
          <table class="tabela">
            <thead><tr><th>Participante</th><th>Método</th><th>Bruto</th><th>Taxa</th><th>Líquido</th><th>Data</th></tr></thead>
            <tbody>
              <% pagsPagos.forEach(p => {
                const v = Number(p.valor)||0;
                let tx = 0;
                if(p.metodo==='pix') tx = v*0.018;
                else if(p.metodo==='cartao') tx = v*0.04;
                const liq = v - tx;
              %>
              <tr>
                <td style="font-weight:600"><%= p.inscrito_nome %></td>
                <td><span style="background:<%= p.metodo==='pix'?'#dcfce7':'#eff6ff' %>;color:<%= p.metodo==='pix'?'#166534':'#1e40af' %>;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700"><%= p.metodo==='pix'?'PIX':'Cartão' %></span></td>
                <td style="color:#10b981;font-weight:600">R$ <%= v.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#ef4444;font-size:12px">R$ <%= tx.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="font-weight:700;color:#1a56db">R$ <%= liq.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:var(--texto2);font-size:12px"><%= p.pago_em?new Date(p.pago_em).toLocaleDateString('pt-BR'):'—' %></td>
              </tr>
              <% }) %>
              <tr style="background:var(--fundo);font-weight:700">
                <td colspan="2">TOTAL</td>
                <td style="color:#10b981">R$ <%= bruto.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#ef4444">R$ <%= taxas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td style="color:#1a56db">R$ <%= liquido.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ONLINE / LIVE -->
      <div class="tab-content" id="tab-online">
        <div class="live-box">
          <div style="font-size:16px;font-weight:700;margin-bottom:6px;font-family:'Outfit',sans-serif">Transmissão Online</div>
          <div style="font-size:13px;color:rgba(255,255,255,.7);margin-bottom:16px">
            Envie links únicos para cada inscrito confirmado. O sistema registra automaticamente o tempo de assistência de cada participante.
          </div>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <div style="font-size:13px;color:rgba(255,255,255,.8)">
              URL YouTube: <strong><%= evento.youtube_url || 'Não configurada — defina na aba Informações' %></strong>
            </div>
            <button onclick="enviarLinksLive()" class="btn btn-sm" style="background:#2FA873;color:#0C231B;font-weight:700;margin-left:auto;border-color:transparent">
              Enviar links de acesso
            </button>
            <a href="/eventos/<%= evento.id %>/presencas" class="btn btn-sm" style="background:rgba(255,255,255,.2);color:white">
              Ver presenças
            </a>
          </div>
          <div id="live-resultado" style="margin-top:12px;font-size:13px;color:rgba(255,255,255,.8)"></div>
        </div>
        <div class="section-card">
          <div class="section-header">Como funciona</div>
          <div class="section-body">
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px">
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">1</div>
                <div style="font-weight:600;margin-bottom:4px">Configure o evento</div>
                <div style="font-size:12px;color:var(--texto2)">Adicione a URL do YouTube e a duração total do evento na aba Informações.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">2</div>
                <div style="font-weight:600;margin-bottom:4px">Envie os links</div>
                <div style="font-size:12px;color:var(--texto2)">Cada inscrito confirmado recebe um link único por WhatsApp e email.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">3</div>
                <div style="font-weight:600;margin-bottom:4px">Presença automática</div>
                <div style="font-size:12px;color:var(--texto2)">O sistema registra o tempo de assistência a cada 2 minutos. Se fechar a aba, para de contar.</div>
              </div>
              <div style="background:var(--fundo);border-radius:10px;padding:16px;border:1px solid var(--borda)">
                <div style="font-size:20px;font-weight:700;color:var(--cor-primaria);font-family:'Outfit',sans-serif;margin-bottom:6px">4</div>
                <div style="font-weight:600;margin-bottom:4px">Relatório final</div>
                <div style="font-size:12px;color:var(--texto2)">Veja quem assistiu 75% ou mais e emita os certificados automaticamente.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- PROGRAMAÇÃO -->
      <div class="tab-content" id="tab-programacao">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Programação do evento</div>
          <div class="section-body">
            <% if(programacao.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum item na programação.</p><%}%>
            <% programacao.forEach(p => { %>
            <div class="prog-item">
              <div style="display:flex;justify-content:space-between;align-items:flex-start">
                <div>
                  <div style="font-weight:700;font-size:14px"><%= p.titulo %></div>
                  <div style="font-size:12px;color:var(--cor-primaria);font-weight:600;margin-top:2px"><%= p.horario %><% if(p.local){%> · <%= p.local %><%}%></div>
                  <% if(p.descricao){%><div style="font-size:12px;color:var(--texto2);margin-top:3px"><%= p.descricao %></div><%}%>
                </div>
                <form method="POST" action="/eventos/<%= evento.id %>/programacao/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                  <button type="submit" class="btn-xs verm">Excluir</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar item</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/programacao" method="POST">
              <div class="grid-2">
                <div class="campo"><label class="label">Horário</label><input name="horario" class="input" placeholder="08:00 - 09:00" required></div>
                <div class="campo"><label class="label">Título</label><input name="titulo" class="input" placeholder="Abertura / Palestra..." required></div>
                <div class="campo"><label class="label">Local (opcional)</label><input name="local" class="input" placeholder="Sala A / Auditório..."></div>
                <div class="campo"><label class="label">Descrição (opcional)</label><input name="descricao" class="input"></div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px" onclick="if(window._qBioAdd){document.getElementById(&quot;bio-add-hidden&quot;).value=_qBioAdd.root.innerHTML;}">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- PALESTRANTES -->
      <div class="tab-content" id="tab-palestrantes">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Palestrantes</div>
          <div class="section-body">
            <% if(palestrantes.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum palestrante adicionado.</p><%}%>
            <% palestrantes.forEach(p => { %>
            <div class="pales-item">
              <% if(p.foto_chave){%><img src="/eventos/palestrantes/<%= p.id %>/foto" class="pales-foto"><% }else{ %><div class="pales-foto" style="background:var(--fundo);border:1px solid var(--borda)">?</div><%}%>
              <div style="flex:1">
                <div style="font-weight:700"><%= p.nome %></div>
                <% if(p.instituicao){%><div style="font-size:12px;color:var(--cor-primaria)"><%= p.instituicao %></div><%}%>
                <% if(p.bio){ const _bioTxt = p.bio.replace(/<[^>]*>/g,' ').replace(/&nbsp;/g,' ').replace(/\s+/g,' ').trim(); %><div style="font-size:12px;color:var(--texto2);margin-top:2px"><%= _bioTxt.substring(0,120) %><%= _bioTxt.length>120?'...':'' %></div><%}%>
              </div>
              <button type="button" onclick="editarPalestrante(<%= p.id %>)" class="btn-xs azul">Editar</button>
              <form method="POST" action="/eventos/<%= evento.id %>/palestrantes/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button>
              </form>
            </div>
            <% }) %>
          </div>
        </div>
        <script id="pales-data" type="application/json"><%- JSON.stringify(palestrantes.map(function(p){return {id:p.id,nome:p.nome,instituicao:p.instituicao||'',bio:p.bio||''};})) %></script>
          <div class="section-card">
          <div class="section-header">Adicionar palestrante</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/palestrantes" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
                <div class="campo"><label class="label">Instituição</label><input name="instituicao" class="input"></div>
                <div class="campo" style="grid-column:1/-1"><label class="label">Bio</label><div id="quill-bio-add" style="background:#fff;min-height:120px"></div><textarea name="bio" id="bio-add-hidden" hidden></textarea></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Foto (400×400px recomendado)</label>
                  <input type="file" name="foto" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- PATROCINADORES -->
      <div class="tab-content" id="tab-patrocinadores">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Patrocinadores</div>
          <div class="section-body">
            <% if(patrocinadores.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum patrocinador adicionado.</p><%}%>
            <% patrocinadores.forEach(p => { %>
            <div class="patroc-item">
              <% if(p.logo_chave){%><img src="/eventos/patrocinadores/<%= p.id %>/logo" style="height:50px;max-width:140px;object-fit:contain;border-radius:4px"><% }else{ %><div style="width:50px;height:50px;background:var(--borda);border-radius:4px"></div><%}%>
              <div style="flex:1"><div style="font-weight:600"><%= p.nome %></div><div style="font-size:11px;color:var(--texto2)"><%= p.url||'' %></div></div>
              <form method="POST" action="/eventos/<%= evento.id %>/patrocinadores/<%= p.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button>
              </form>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Adicionar patrocinador</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/patrocinadores" method="POST" enctype="multipart/form-data">
              <div class="grid-2">
                <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
                <div class="campo"><label class="label">Website</label><input name="url" class="input" placeholder="https://..."></div>
                <div class="campo" style="grid-column:1/-1">
                  <label class="label">Logo (400×200px recomendado, PNG prefencial)</label>
                  <input type="file" name="logo" class="input" accept="image/*" style="padding:8px">
                </div>
              </div>
              <button type="submit" class="btn btn-primario" style="margin-top:8px">Adicionar</button>
            </form>
          </div>
        </div>
      </div>

      <!-- CUPONS -->
      <div class="tab-content" id="tab-cupons">
        <div class="section-card" style="margin-bottom:16px;border:1.5px solid #d1fae5">
          <div class="section-header" style="background:#f0fdf4">Cupons de isenção para ligantes e diretivos</div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Gera 1 cupom individual (100% desconto) por pessoa e envia via WhatsApp e/ou email.</p>
            <form action="/eventos/<%= evento.id %>/cupons/gerar-ligantes" method="POST">
              <div class="grid-2" style="margin-bottom:12px">
                <div class="campo"><label class="label">Prefixo do código</label><input name="prefixo" class="input" value="LAURO" maxlength="8" style="text-transform:uppercase"></div>
                <div class="campo"><label class="label">Enviar para</label>
                  <select name="destino" class="input">
                    <option value="ligantes">Ligantes em dia</option>
                    <option value="diretivos">Diretivos</option>
                    <option value="todos">Todos</option>
                  </select>
                </div>
              </div>
              <div style="display:flex;gap:20px;margin-bottom:14px;flex-wrap:wrap">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                  <input type="checkbox" name="enviar_wpp" style="width:16px;height:16px;accent-color:var(--cor-primaria)"> WhatsApp
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                  <input type="checkbox" name="enviar_email" style="width:16px;height:16px;accent-color:var(--cor-primaria)"> Email
                </label>
              </div>
              <button type="submit" class="btn btn-primario" onclick="return confirm('Gerar e enviar cupons?')">Gerar e enviar cupons</button>
            </form>
          </div>
        </div>
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Criar cupom manual</div>
          <div class="section-body">
            <form action="/eventos/<%= evento.id %>/cupons" method="POST">
              <div class="grid-3">
                <div class="campo"><label class="label">Código</label><input name="codigo" class="input" placeholder="EX: DESCONTO20" required style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()"></div>
                <div class="campo"><label class="label">Tipo</label>
                  <select name="tipo" class="input"><option value="percentual">Percentual (%)</option><option value="fixo">Valor fixo (R$)</option></select>
                </div>
                <div class="campo"><label class="label">Valor</label><input type="number" name="valor" class="input" value="100" min="1" step="0.01"></div>
                <div class="campo"><label class="label">Usos máximos</label><input type="number" name="usos_max" class="input" value="1" min="1"></div>
                <div class="campo" style="display:flex;align-items:flex-end"><button type="submit" class="btn btn-primario" style="width:100%">Criar cupom</button></div>
              </div>
            </form>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">Cupons criados (<%= cupons.length %>)</div>
            <div style="padding:14px 18px 0;display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap"><div style="flex:1;min-width:150px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Buscar</label><input type="text" id="cup-busca" class="input" style="width:100%;font-size:13px;padding:7px 12px" placeholder="Codigo ou nome..." oninput="filtrarCupons()"></div><div style="min-width:120px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Situacao</label><select id="cup-situacao" class="input" style="width:100%;font-size:13px;padding:7px 12px" onchange="filtrarCupons()"><option value="">Todos</option><option value="usado">Usados</option><option value="naousado">Nao usados</option></select></div><div style="min-width:120px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Criado de</label><input type="date" id="cup-cr-de" class="input" style="width:100%;font-size:13px;padding:7px 12px" onchange="filtrarCupons()"></div><div style="min-width:120px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Criado ate</label><input type="date" id="cup-cr-ate" class="input" style="width:100%;font-size:13px;padding:7px 12px" onchange="filtrarCupons()"></div><div style="min-width:120px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Usado de</label><input type="date" id="cup-us-de" class="input" style="width:100%;font-size:13px;padding:7px 12px" onchange="filtrarCupons()"></div><div style="min-width:120px"><label style="font-size:11px;font-weight:600;color:var(--texto2);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:4px">Usado ate</label><input type="date" id="cup-us-ate" class="input" style="width:100%;font-size:13px;padding:7px 12px" onchange="filtrarCupons()"></div><button type="button" class="btn btn-sm" onclick="limparCup()" style="white-space:nowrap">Limpar</button><div style="font-size:12px;color:var(--texto2);padding-bottom:8px;width:100%">Exibindo <span id="cup-count" style="font-weight:700;color:var(--cor-primaria)">0</span> de <%= cupons.length %></div></div>
          <div class="section-body">
            <% if(cupons.length===0){%><p style="color:var(--texto2);font-size:13px">Nenhum cupom criado ainda.</p><%}%>
            <% cupons.forEach(c => { %>
            <div class="cupom-item cup-row" data-busca="<%= (c.codigo + ' ' + (c.usado_nome||'') + ' ' + (c.dono_nome||'')).toLowerCase() %>" data-usado="<%= c.usado_nome ? 'usado' : 'naousado' %>" data-criado="<%= c.cupom_criado_em ? new Date(new Date(c.cupom_criado_em).getTime() - new Date(c.cupom_criado_em).getTimezoneOffset()*60000).toISOString().slice(0,10) : '' %>" data-uso="<%= c.usado_em ? new Date(new Date(c.usado_em).getTime() - new Date(c.usado_em).getTimezoneOffset()*60000).toISOString().slice(0,10) : '' %>">
              <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                <span class="cupom-cod"><%= c.codigo %></span>
                <div>
                  <div style="font-size:12px;font-weight:600"><%= c.tipo==='percentual' ? c.valor+'% desconto' : 'R$ '+Number(c.valor).toFixed(2)+' desconto' %></div>
                  <div style="font-size:11px;color:var(--texto2)">Usos: <%= c.usos_atual||0 %>/<%= c.usos_max %> <span style="margin-left:6px;background:<%= c.ativo?'#dcfce7':'#fee2e2' %>;color:<%= c.ativo?'#166534':'#991b1b' %>;padding:2px 6px;border-radius:4px;font-weight:700"><%= c.ativo?'ATIVO':'INATIVO' %></span></div>
                    <% if(c.dono_nome){ %><div style="font-size:11px;color:var(--texto2);margin-top:3px">De: <strong><%= c.dono_nome %></strong></div><% } %><% if(c.usado_nome){ %><div style="font-size:11px;color:var(--cor-primaria);margin-top:3px">Usado por: <strong><%= c.usado_nome %></strong><% if(c.usado_em){ %> em <%= new Date(new Date(c.usado_em).getTime() - new Date(c.usado_em).getTimezoneOffset()*60000).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %><% } %></div><% } %>
                </div>
              </div>
              <div style="display:flex;gap:6px;align-items:center">
                <button onclick="copiarLinkCupom('<%= c.codigo %>')" class="btn-xs azul" title="Copiar link com cupom aplicado">Link</button>
                  <% if(c.ligante_id || c.diretivo_id){ %>
                  <form method="POST" action="/eventos/<%= evento.id %>/cupons/<%= c.id %>/reenviar" style="display:inline" onsubmit="return confirm('Reenviar este cupom por WhatsApp e email?')">
                    <button type="submit" class="btn-xs verde" title="Reenviar cupom por WhatsApp e email">Reenviar</button>
                  </form>
                  <% } %>
                <form method="POST" action="/eventos/<%= evento.id %>/cupons/<%= c.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir cupom?')">
                  <button type="submit" class="btn-xs verm">Excluir</button>
                </form>
              </div>
            </div>
            <% }) %>
            <div id="cup-paginacao" style="display:flex;align-items:center;justify-content:center;gap:6px;padding:16px 0;flex-wrap:wrap"></div>
          </div>
        </div>
      </div>

      <!-- CERTIFICADOS -->
      <div class="tab-content" id="tab-certificados">
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Imagem de fundo</div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Fundo personalizado para este evento. Se não definir, usa o timbrado global.</p>
            <form action="/eventos/<%= evento.id %>/cert-bg" method="POST" enctype="multipart/form-data" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
              <% if(evento.cert_bg_chave){ %>
              <div><img src="/eventos/<%= evento.id %>/cert-bg" style="max-width:180px;border-radius:8px;border:1px solid var(--borda);display:block;margin-bottom:4px"><span style="font-size:11px;color:#10b981;font-weight:600">Fundo ativo</span></div>
              <% } %>
              <div class="campo" style="flex:1"><label class="label">Upload (A4: 2480x3508px)</label><input type="file" name="cert_bg" class="input" accept="image/*" style="padding:8px"></div>
              <button type="submit" class="btn btn-primario">Salvar</button>
            </form>
            <% if(evento.cert_bg_chave){ %>
            <form method="POST" action="/eventos/<%= evento.id %>/cert-bg/remover" style="margin-top:8px">
              <button type="submit" class="btn-xs verm" onclick="return confirm('Remover?')">Remover fundo personalizado</button>
            </form>
            <% } %>
          </div>
        </div>
        <div class="section-card" style="margin-bottom:16px">
          <div class="section-header">Emitir certificados</div>
          <div class="section-body">
            <p style="font-size:13px;color:var(--texto2);margin-bottom:14px">Emite para inscritos com check-in e envia por email e WhatsApp automaticamente.</p>
            <form method="POST" action="/eventos/<%= evento.id %>/certificados/emitir-todos" style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
              <div class="campo"><label class="label">Carga horaria (h)</label><input type="number" name="carga_horaria" class="input" style="width:100px" value="<%= evento.carga_horaria||4 %>" min="1"></div>
              <button type="submit" class="btn btn-primario" onclick="return confirm('Emitir para todos com check-in?')">Emitir todos</button>
            </form>
          </div>
        </div>
        <div class="section-card">
          <div class="section-header">
            Certificados emitidos (<%= certificados.length %>)
            <a href="/certificado/validar/demo" target="_blank" class="btn-xs azul" onclick="event.preventDefault();window.open('/certificado/validar/teste','_blank')">Ver página de validação</a>
          </div>
          <table class="tabela">
            <thead><tr><th>Participante</th><th>Emitido em</th><th style="text-align:center">Email</th><th style="text-align:center">WhatsApp</th><th>Acoes</th></tr></thead>
            <tbody>
              <% certificados.forEach(cert => { %>
              <tr>
                <td style="font-weight:600"><%= cert.inscrito_nome %></td>
                <td style="color:var(--texto2)"><%= new Date(cert.emitido_em).toLocaleDateString('pt-BR') %></td>
                <td style="text-align:center"><%= cert.enviado_email ? '✅' : '—' %></td>
                <td style="text-align:center"><%= cert.enviado_wpp ? '✅' : '—' %></td>
                <td><div style="display:flex;gap:6px">
                  <a href="/eventos/<%= evento.id %>/inscricoes/<%= cert.inscricao_id %>/certificado" target="_blank" class="btn-xs roxo">Ver</a>
                  <% if(cert.codigo_validacao){ %>
                  <button onclick="copiarLink('/certificado/validar/<%= cert.codigo_validacao %>')" class="btn-xs azul">Link</button>
                  <% } %>
                </div></td>
              </tr>
              <% }) %>
              <% if(certificados.length===0){ %>
              <tr><td colspan="5" style="text-align:center;padding:30px;color:var(--texto2)">Nenhum certificado emitido ainda.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- AVANÇADO -->
      <div class="tab-content" id="tab-avancado">
        <form action="/eventos/<%= evento.id %>/avancado" method="POST">
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Email de confirmação personalizado</div>
            <div class="section-body">
              <div class="campo"><label class="label">Texto incluído no email de confirmação (após pagamento)</label><div id="editor-email" style="background:#fff;min-height:140px"><%- evento.email_inscricao||'' %></div><textarea name="email_inscricao" id="email-hidden" hidden><%= evento.email_inscricao||'' %></textarea></div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Grupo WhatsApp</div>
            <div class="section-body">
              <div class="campo"><label class="label">Link do grupo WhatsApp</label><input name="wpp_grupo" class="input" value="<%= evento.wpp_grupo||'' %>" placeholder="https://chat.whatsapp.com/..."></div>
              <div style="font-size:11px;color:var(--texto2);margin-top:4px">Aparece na página pública e no email de confirmação.</div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Configurações de inscrição</div>
            <div class="section-body">
              <div class="grid-2">
                <div class="campo"><label class="label">Inscrições gratuitas</label>
                  <select name="inscricao_gratuita_auto" class="input">
                    <option value="true" <%= evento.inscricao_gratuita_auto!==false?'selected':'' %>>Confirmadas automaticamente</option>
                    <option value="false" <%= evento.inscricao_gratuita_auto===false?'selected':'' %>>Confirmadas manualmente</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Inscrição única por email</label>
                  <select name="inscricao_unica" class="input">
                    <option value="false" <%= !evento.inscricao_unica?'selected':'' %>>Não</option>
                    <option value="true" <%= evento.inscricao_unica?'selected':'' %>>Sim</option>
                  </select>
                </div>
              </div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Termos e condições</div>
            <div class="section-body">
              <div class="campo"><div id="editor-termos" style="background:#fff;min-height:160px"><%- evento.termos_texto||'' %></div><textarea name="termos_texto" id="termos-hidden" hidden><%= evento.termos_texto||'' %></textarea></div>
            </div>
          </div>
          <div class="section-card" style="margin-bottom:16px">
            <div class="section-header">Política de privacidade (LGPD)</div>
            <div class="section-body">
              <div class="campo"><div id="editor-lgpd" style="background:#fff;min-height:200px"><%- evento.lgpd_texto||'' %></div><textarea name="lgpd_texto" id="lgpd-hidden" hidden><%= evento.lgpd_texto||'' %></textarea></div>
            </div>
          </div>
          <button type="submit" class="btn btn-primario" onclick="if(window._qEmail){document.getElementById('email-hidden').value=_qEmail.root.innerHTML;}if(window._qTermos){document.getElementById('termos-hidden').value=_qTermos.root.innerHTML;}if(window._qLgpd){document.getElementById('lgpd-hidden').value=_qLgpd.root.innerHTML;}">Salvar configurações</button>
        </form>
      </div>

    </div>
  </main>
</div>

<!-- MODAL EDITAR LOTE -->
<div class="modal-overlay" id="modal-editar-lote" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">Editar lote</span><button class="icon-btn" onclick="fecharModal('modal-editar-lote')">✕</button></div>
    <form id="form-editar-lote" action="" method="POST">
      <div class="grid-3">
        <div class="campo"><label class="label">Nome</label><input id="el-nome" name="nome" class="input" required></div>
        <div class="campo"><label class="label">Preço</label><input id="el-preco" type="number" step="0.01" name="preco" class="input"></div>
        <div class="campo"><label class="label">Vagas</label><input id="el-vagas" type="number" name="vagas" class="input"></div>
        <div class="campo"><label class="label">Início</label><input id="el-inicio" type="datetime-local" name="data_inicio" class="input"></div>
        <div class="campo"><label class="label">Fim</label><input id="el-fim" type="datetime-local" name="data_fim" class="input"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-editar-lote')">Cancelar</button><button type="submit" class="btn btn-primario">Salvar</button></div>
    </form>
  </div>
</div>

<!-- MODAL INSCRIÇÃO MANUAL -->
<div class="modal-overlay" id="modal-inscricao-manual" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">Inscrição manual</span><button class="icon-btn" onclick="fecharModal('modal-inscricao-manual')">✕</button></div>
    <form action="/eventos/<%= evento.id %>/inscricoes/manual" method="POST">
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="campo"><label class="label">Nome *</label><input name="nome" class="input" required></div>
        <div class="campo"><label class="label">Email *</label><input name="email" class="input" type="email" required></div>
        <div class="campo"><label class="label">WhatsApp</label><input name="whatsapp" class="input"></div>
        <div class="campo"><label class="label">Lote</label>
          <select name="lote_id" class="input"><% lotes.forEach(l=>{%><option value="<%= l.id %>"><%= l.nome %> — R$ <%= Number(l.preco).toFixed(2) %></option><%})%></select>
        </div>
        <div class="campo"><label class="label">Status</label>
          <select name="status" class="input"><option value="confirmado">Confirmado</option><option value="pendente">Pendente</option></select>
        </div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-inscricao-manual')">Cancelar</button><button type="submit" class="btn btn-primario">Inscrever</button></div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="modal-editar-palestrante" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">Editar palestrante</span><button class="icon-btn" onclick="fecharModal('modal-editar-palestrante')">&#10005;</button></div>
    <form id="form-editar-palestrante" method="POST" enctype="multipart/form-data" onsubmit="document.getElementById('ep-bio-hidden').value=_qBioEditar.root.innerHTML;">
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="campo"><label class="label">Nome *</label><input name="nome" id="ep-nome" class="input" required></div>
        <div class="campo"><label class="label">Institui&ccedil;&atilde;o</label><input name="instituicao" id="ep-inst" class="input"></div>
        <div class="campo"><label class="label">Bio</label><div id="quill-bio-editar" style="background:#fff;min-height:120px"></div><textarea name="bio" id="ep-bio-hidden" hidden></textarea></div>
        <div class="campo"><label class="label">Trocar foto <span style="font-size:11px;font-weight:400;color:var(--texto2)">(opcional &middot; 400&times;400px recomendado)</span></label><input type="file" name="foto" class="input" accept="image/*" style="padding:8px"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-editar-palestrante')">Cancelar</button><button type="submit" class="btn btn-primario">Salvar</button></div>
    </form>
  </div>
</div>

<!-- MODAL EDITAR INSCRITO -->
<div class="modal-overlay" id="modal-editar-inscrito" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">Editar inscrito</span><button class="icon-btn" onclick="fecharModal('modal-editar-inscrito')">✕</button></div>
    <form id="form-editar-inscrito" action="" method="POST">
      <div style="display:flex;flex-direction:column;gap:12px">
        <div class="campo"><label class="label">Nome *</label><input id="ei-nome" name="nome" class="input" required></div>
        <div class="campo"><label class="label">Email *</label><input id="ei-email" name="email" class="input" type="email" required></div>
        <div class="campo"><label class="label">WhatsApp</label><input id="ei-wpp" name="whatsapp" class="input"></div>
        <div class="campo"><label class="label">CPF</label><input id="ei-cpf" name="cpf" class="input"></div>
        <div class="campo"><label class="label">Instituição</label><input id="ei-inst" name="instituicao" class="input"></div>
        <div class="campo"><label class="label">Status</label>
          <select id="ei-status" name="status" class="input">
            <option value="pendente">Pendente</option>
            <option value="confirmado">Confirmado</option>
            <option value="cancelado">Cancelado</option>
          </select>
        </div>
        <div class="campo"><label class="label">RG / CI</label><input id="ei-rg" name="rg" class="input"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="campo"><label class="label">Semestre</label><input id="ei-semestre" name="semestre" class="input"></div>
          <div class="campo"><label class="label">Turma</label><input id="ei-turma" name="turma" class="input"></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="campo"><label class="label">Catraca (UCP)</label><input id="ei-catraca" name="catraca" class="input"></div>
          <div class="campo"><label class="label">Tipo</label>
            <select id="ei-tipo" name="tipo_participante" class="input">
              <option value="externo">Externo</option>
              <option value="interno">Interno (UCP)</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="campo"><label class="label">Lote</label>
            <select id="ei-lote" name="lote_id" class="input">
              <option value="">—</option>
              <% lotes.forEach(function(l){ %><option value="<%= l.id %>"><%= l.nome %></option><% }) %>
            </select>
          </div>
          <div class="campo"><label class="label">Isento de pagamento</label>
            <select id="ei-isento" name="isento" class="input">
              <option value="false">Não</option>
              <option value="true">Sim</option>
            </select>
          </div>
        </div>
        <div class="campo"><label class="label">Cupom usado</label><input id="ei-cupom" name="cupom_codigo" class="input"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-editar-inscrito')">Cancelar</button><button type="submit" class="btn btn-primario">Salvar</button></div>
    </form>
  </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script src="/js/app.js"></script>
<script>
let quilMala = null;
function initQuilMala() {
  if (quilMala) return;
  const el = document.getElementById('editor-mala');
  if (!el) return;
  quilMala = new Quill('#editor-mala', {
    theme: 'snow',
    modules: { toolbar: [[{'font':[]},{'size':['small',false,'large','huge']}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],[{'align':[]}],[{'list':'ordered'},{'list':'bullet'}],['link','image'],['clean']] }
  });
}
var _qMassaEv = new Quill('#quill-massa-evento', {
  theme: 'snow',
  placeholder: 'Escreva a mensagem do email...',
  modules: { toolbar: [[{'font':[]},{'size':['small',false,'large','huge']}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],[{'align':[]}],[{'list':'ordered'},{'list':'bullet'}],['link','image'],['clean']] }
});
var _qBioAdd = document.getElementById('quill-bio-add') ? new Quill('#quill-bio-add', { theme:'snow', placeholder:'Biografia do palestrante...', modules:{ toolbar:[[{'font':[]},{'size':['small',false,'large','huge']}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],[{'align':[]}],[{'list':'ordered'},{'list':'bullet'}],['link','image'],['clean']] } }) : null;
var _qBioEditar = document.getElementById('quill-bio-editar') ? new Quill('#quill-bio-editar', { theme:'snow', modules:{ toolbar:[[{'font':[]},{'size':['small',false,'large','huge']}],['bold','italic','underline','strike'],[{'color':[]},{'background':[]}],[{'align':[]}],[{'list':'ordered'},{'list':'bullet'}],['link','image'],['clean']] } }) : null;
var _PALES = (function(){ try { var el=document.getElementById('pales-data'); return el?JSON.parse(el.textContent):[]; } catch(e){ return []; } })();
function editarPalestrante(id){
  var p = _PALES.find(function(x){return x.id===id;});
  if(!p) return;
  document.getElementById('ep-nome').value = p.nome||'';
  document.getElementById('ep-inst').value = p.instituicao||'';
  if(_qBioEditar){ _qBioEditar.root.innerHTML = p.bio||''; }
  document.getElementById('form-editar-palestrante').action = '/eventos/<%= evento.id %>/palestrantes/'+id+'/editar';
  abrirModal('modal-editar-palestrante');
}
var _qTermos = document.getElementById('editor-termos') ? new Quill('#editor-termos', { theme:'snow', modules:{ toolbar:[[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'list':'ordered'},{'list':'bullet'}],[{'align':[]}],['link','clean']] } }) : null;
  var _qLgpd = document.getElementById('editor-lgpd') ? new Quill('#editor-lgpd', { theme:'snow', modules:{ toolbar:[[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'list':'ordered'},{'list':'bullet'}],[{'align':[]}],['link','clean']] } }) : null;
  var _qEmail = document.getElementById('editor-email') ? new Quill('#editor-email', { theme:'snow', modules:{ toolbar:[[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'list':'ordered'},{'list':'bullet'}],[{'align':[]}],['link','clean']] } }) : null;
  const quill = new Quill('#editor-desc', {
  theme: 'snow',
  modules: { toolbar: [[{'header':[1,2,3,false]}],['bold','italic','underline'],[{'color':[]},{'background':[]}],[{'align':[]}],['link'],['clean']] }
});

function filtrarCupons(){
  var b=(document.getElementById('cup-busca')?document.getElementById('cup-busca').value:'').toLowerCase();
  var sit=document.getElementById('cup-situacao')?document.getElementById('cup-situacao').value:'';
  var crDe=document.getElementById('cup-cr-de')?document.getElementById('cup-cr-de').value:'';
  var crAte=document.getElementById('cup-cr-ate')?document.getElementById('cup-cr-ate').value:'';
  var usDe=document.getElementById('cup-us-de')?document.getElementById('cup-us-de').value:'';
  var usAte=document.getElementById('cup-us-ate')?document.getElementById('cup-us-ate').value:'';
  _cupFilt=Array.prototype.slice.call(document.querySelectorAll('.cup-row')).filter(function(rr){
    if(b && (rr.dataset.busca||'').indexOf(b)<0) return false;
    if(sit && rr.dataset.usado!==sit) return false;
    var dc=rr.dataset.criado||'';
    if(crDe && (!dc||dc<crDe)) return false;
    if(crAte && (!dc||dc>crAte)) return false;
    var du=rr.dataset.uso||'';
    if(usDe && (!du||du<usDe)) return false;
    if(usAte && (!du||du>usAte)) return false;
    return true;
  });
  _cupPag=1; renderCup();
}
var _cupPag=1,_cupFilt=[];
function renderCup(){
  var pp=25, total=_cupFilt.length, totalP=Math.ceil(total/pp)||1;
  if(_cupPag>totalP)_cupPag=totalP;
  var ini=(_cupPag-1)*pp, fim=ini+pp;
  document.querySelectorAll('.cup-row').forEach(function(rr){rr.style.display='none';});
  _cupFilt.forEach(function(rr,i){rr.style.display=(i>=ini&&i<fim)?'':'none';});
  var cc=document.getElementById('cup-count'); if(cc)cc.textContent=total;
  var pi=document.getElementById('cup-paginacao'); if(!pi)return;
  var bs='display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--borda);background:var(--card);color:var(--texto2);font-size:12px;font-weight:600;cursor:pointer;';
  var ba='display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--cor-primaria);background:var(--cor-primaria);color:#fff;font-size:12px;font-weight:700;cursor:pointer;';
  var h='<button type=\"button\" onclick=\"cupPag(-1)\" style=\"'+bs+'\" '+(_cupPag<=1?'disabled':'')+'>&#8592;</button>';
  var start=Math.max(1,_cupPag-2),end=Math.min(totalP,start+4); if(end-start<4)start=Math.max(1,end-4);
  if(start>1){h+='<button type=\"button\" onclick=\"cupNum(1)\" style=\"'+bs+'\">1</button>'; if(start>2)h+='<span style=\"padding:0 4px;color:var(--texto2)\">...</span>';}
  for(var p=start;p<=end;p++)h+='<button type=\"button\" onclick=\"cupNum('+p+')\" style=\"'+(_cupPag===p?ba:bs)+'\">'+p+'</button>';
  if(end<totalP){if(end<totalP-1)h+='<span style=\"padding:0 4px;color:var(--texto2)\">...</span>';h+='<button type=\"button\" onclick=\"cupNum('+totalP+')\" style=\"'+bs+'\">'+totalP+'</button>';}
  h+='<button type=\"button\" onclick=\"cupPag(1)\" style=\"'+bs+'\" '+(_cupPag>=totalP?'disabled':'')+'>&#8594;</button>';
  pi.innerHTML=h;
}
function cupNum(n){var tp=Math.ceil(_cupFilt.length/25)||1;_cupPag=Math.max(1,Math.min(tp,n));renderCup();}
function cupPag(d){cupNum(_cupPag+d);}
function limparCup(){['cup-busca','cup-situacao','cup-cr-de','cup-cr-ate','cup-us-de','cup-us-ate'].forEach(function(id){var e=document.getElementById(id); if(e)e.value='';});filtrarCupons();}
function showTab(id, btn) {
  if (id === 'mala-direta') { initQuilMala(); carregarHistorico(); }
  document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('ativo'));
  document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('ativo'));
  document.getElementById('tab-'+id).classList.add('ativo');
  if(btn) btn.classList.add('ativo');
  const url = new URL(window.location);
  url.searchParams.set('tab', id);
  history.replaceState(null, '', url);
}

window.addEventListener('DOMContentLoaded', () => {
  initDrag();
  const tab = new URLSearchParams(window.location.search).get('tab');
  if (tab) {
    const btn = document.querySelector(`.tab-btn[onclick*="'${tab}'"]`);
    if (btn) showTab(tab, btn);
  }
});

function buscarInscrito(q) {
  document.querySelectorAll('.inscrito-row').forEach(r => {
    r.style.display = r.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}

function editarLote(id, nome, preco, vagas, inicio, fim) {
  document.getElementById('el-nome').value = nome;
  document.getElementById('el-preco').value = preco;
  document.getElementById('el-vagas').value = vagas;
  document.getElementById('el-inicio').value = inicio;
  document.getElementById('el-fim').value = fim;
  document.getElementById('form-editar-lote').action = '/eventos/<%= evento.id %>/lotes/'+id+'/editar';
  abrirModal('modal-editar-lote');
}

function editarInscrito(id) {
  var i = (inscricoesMala||[]).find(function(x){ return x.id===id; });
  if(!i) return;
  function setv(elId, val){ var e=document.getElementById(elId); if(e) e.value = (val==null?'':val); }
  setv('ei-nome', i.nome);
  setv('ei-email', i.email);
  setv('ei-wpp', i.whatsapp);
  setv('ei-cpf', i.cpf);
  setv('ei-inst', i.instituicao);
  setv('ei-status', i.status);
  setv('ei-rg', i.rg);
  setv('ei-semestre', i.semestre);
  setv('ei-turma', i.turma);
  setv('ei-catraca', i.catraca);
  setv('ei-tipo', i.tipo_participante || 'externo');
  setv('ei-lote', i.lote_id);
  setv('ei-cupom', i.cupom_codigo);
  setv('ei-isento', i.isento ? 'true' : 'false');
  document.getElementById('form-editar-inscrito').action = '/eventos/<%= evento.id %>/inscricoes/'+id+'/editar';
  abrirModal('modal-editar-inscrito');
}

let dragSrc=null;
function initDrag() {
  const lista = document.getElementById('lista-campos-ord');
  if (!lista) return;
  lista.querySelectorAll('.campo-ord-item').forEach(item => {
    item.setAttribute('draggable', true);
    item.addEventListener('dragstart', () => { dragSrc=item; item.style.opacity='.5'; });
    item.addEventListener('dragend', () => { item.style.opacity=''; lista.querySelectorAll('.campo-ord-item').forEach(i=>i.classList.remove('drag-over')); });
    item.addEventListener('dragover', e => { e.preventDefault(); item.classList.add('drag-over'); });
    item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
    item.addEventListener('drop', e => {
      e.preventDefault(); item.classList.remove('drag-over');
      if (dragSrc && dragSrc!==item) {
        const its=[...lista.querySelectorAll('.campo-ord-item')];
        if(its.indexOf(dragSrc)<its.indexOf(item)) item.after(dragSrc); else item.before(dragSrc);
        document.getElementById('btn-salvar-ordem').style.display='';
      }
    });
  });
}
function salvarOrdem() {
  const keys=[...document.querySelectorAll('.campo-ord-item')].map(i=>i.dataset.key);
  fetch('/eventos/<%= evento.id %>/campos/ordem',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({campos:JSON.stringify(keys)})})
    .then(r=>r.json()).then(d=>{ if(d.ok){document.getElementById('btn-salvar-ordem').style.display='none';alert('Ordem salva!');} });
}
const inscricoesMala=<%- JSON.stringify(inscricoes) %>;
function atualizarContador() {
  const dest=document.getElementById('sel-dest').value;
  let n=inscricoesMala.length;
  if(dest==='confirmados') n=inscricoesMala.filter(i=>i.status==='confirmado').length;
  else if(dest==='pendentes') n=inscricoesMala.filter(i=>i.status==='pendente').length;
  document.getElementById('txt-contador-dest').textContent=n+' inscritos';
}
function carregarHistorico() {
  fetch('/eventos/<%= evento.id %>/mala-direta/historico').then(r=>r.json()).then(d=>{
    const el=document.getElementById('historico-mala');
    if(!d.ok||!d.envios.length){el.innerHTML='<div style="padding:20px;text-align:center;color:var(--texto2)">Nenhum email enviado ainda.</div>';return;}
    el.innerHTML=d.envios.map(e=>{
      const dt=new Date(e.criado_em).toLocaleString('pt-BR');
      const tx=e.total_enviados>0?Math.round(e.total_enviados/(e.total_enviados+e.total_erros)*100):0;
      return '<div style="padding:14px 18px;border-bottom:1px solid var(--borda);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">'
        +'<div><div style="font-weight:600;font-size:13px">'+e.assunto+'</div>'
        +'<div style="font-size:11px;color:var(--texto2);margin-top:3px">'+dt+' · '+e.destinatarios+'</div></div>'
        +'<div style="display:flex;gap:10px;align-items:center">'
        +'<span style="color:#10b981;font-weight:600;font-size:12px">'+e.total_enviados+' enviados</span>'
        +(e.total_erros>0?'<span style="color:#ef4444;font-weight:600;font-size:12px">'+e.total_erros+' erros</span>':'')
        +'<span style="background:#eff6ff;color:#1e40af;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700">'+tx+'% entrega</span>'
        +'<button onclick="verLogs('+e.id+')" class="btn-xs">Detalhes</button></div></div>';
    }).join('');
  });
}
function copiarLink(path) {
  const link = window.location.origin + path;
  navigator.clipboard.writeText(link).then(() => alert('Link copiado!\n\n'+link)).catch(() => prompt('Copie:', link));
}
function copiarLinkCupom(codigo) {
  const appUrl = window.location.origin;
  const link = appUrl + '/inscricao/<%= evento.id %>?cupom=' + codigo;
  navigator.clipboard.writeText(link).then(() => {
    alert('Link copiado!\n\n' + link);
  }).catch(() => {
    prompt('Copie o link abaixo:', link);
  });
}
function carregarEspera() {
  fetch('/eventos/<%= evento.id %>/lista-espera')
    .then(r=>r.json()).then(d=>{
      const el = document.getElementById('espera-conteudo');
      if (!d.ok || !d.espera.length) { el.innerHTML='<div style="padding:20px;text-align:center;color:var(--texto2)">Nenhuma pessoa na lista de espera.</div>'; return; }
      el.innerHTML = '<table class="tabela" style="width:100%"><thead><tr><th>#</th><th>Nome</th><th>WhatsApp</th><th>Email</th><th>Cadastrado em</th><th>Notificado</th></tr></thead><tbody>'
        + d.espera.map((e,i) => '<tr>'
          +'<td style="color:var(--texto2)">'+(i+1)+'</td>'
          +'<td style="font-weight:600">'+e.nome+'</td>'
          +'<td style="color:var(--texto2)">'+(e.whatsapp||'—')+'</td>'
          +'<td style="color:var(--texto2)">'+(e.email||'—')+'</td>'
          +'<td style="color:var(--texto2)">'+new Date(e.criado_em).toLocaleDateString('pt-BR')+'</td>'
          +'<td>'+(e.notificado?'<span style="color:#10b981;font-weight:600">Notificado</span>':'<span style="color:var(--texto2)">Aguardando</span>')+'</td>'
          +'</tr>').join('')
        + '</tbody></table>';
    });
}
function verLogs(id){
  fetch('/eventos/<%= evento.id %>/mala-direta/'+id+'/logs').then(r=>r.json()).then(d=>{
    if(!d.ok)return;
    const w=window.open('','_blank','width=700,height=500');
    w.document.write('<html><head><title>Log</title><style>body{font-family:Arial;padding:20px}table{width:100%;border-collapse:collapse}th,td{padding:8px 12px;border-bottom:1px solid #e5e7eb;text-align:left}th{background:#f8fafc;font-size:12px}</style></head><body><h3>Detalhes do envio</h3><table><thead><tr><th>Nome</th><th>Email</th><th>Status</th></tr></thead><tbody>'
      +d.logs.map(l=>'<tr><td>'+l.nome+'</td><td>'+l.email+'</td><td style="color:'+(l.status==='enviado'?'#166534':'#991b1b')+'">'+l.status+'</td></tr>').join('')
      +'</tbody></table></body></html>');
    w.document.close();
  });
}
function mostrarOpcoes(tipo) {
  document.getElementById('div-opcoes').style.display = ['select','radio','checkbox'].includes(tipo) ? 'block' : 'none';
}

function setCor(cor) {
  document.getElementById('cor-input').value = cor;
  document.getElementById('cor-preview').style.background = cor;
}

function imprimirRelatorio() {
  const w = window.open('','_blank');
  w.document.write('<html><head><title>Relatório Financeiro</title><style>body{font-family:Arial;padding:20px}table{width:100%;border-collapse:collapse}th,td{padding:8px 12px;border:1px solid #e5e7eb;text-align:left}thead{background:#f8fafc}</style></head><body>'+document.getElementById('tab-financeiro').innerHTML+'</body></html>');
  w.document.close();
  w.print();
}

function enviarLinksLive() {
  const btn = event.target;
  btn.textContent = 'Enviando...';
  btn.disabled = true;
  fetch('/eventos/<%= evento.id %>/enviar-link-live', { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      document.getElementById('live-resultado').textContent = d.msg || (d.ok ? 'Links enviados!' : 'Erro: '+d.msg);
      btn.textContent = 'Enviar links de acesso';
      btn.disabled = false;
    })
    .catch(() => {
      document.getElementById('live-resultado').textContent = 'Erro de conexão.';
      btn.textContent = 'Enviar links de acesso';
      btn.disabled = false;
    });
}
</script>
<script>
// ===== Filtros + paginação + impressão da aba Inscritos =====
var _insPagina = 1;
var _insFiltradas = [];
function filtrarInscritos() {
  var busca = (document.getElementById('ins-busca')?.value || '').toLowerCase();
  var status = document.getElementById('ins-status')?.value || '';
  var tipo = document.getElementById('ins-tipo')?.value || '';
  var lote = document.getElementById('ins-lote')?.value || '';
  var rows = Array.prototype.slice.call(document.querySelectorAll('.inscrito-row'));
  _insFiltradas = rows.filter(function(r){
    var n = r.dataset.nome||'', e = r.dataset.email||'';
    if (busca && n.indexOf(busca)<0 && e.indexOf(busca)<0) return false;
    if (status && r.dataset.status !== status) return false;
    if (tipo && r.dataset.isento !== tipo) return false;
    if (lote && String(r.dataset.lote||'') !== lote) return false;
    return true;
  });
  _insPagina = 1;
  renderInscritos();
}
function renderInscritos() {
  var pp = parseInt(document.getElementById('ins-por-pagina')?.value) || 25;
  var total = _insFiltradas.length;
  var totalP = Math.ceil(total / pp) || 1;
  if (_insPagina > totalP) _insPagina = totalP;
  var ini = (_insPagina - 1) * pp, fim = ini + pp;
  document.querySelectorAll('.inscrito-row').forEach(function(r){ r.style.display='none'; });
  _insFiltradas.forEach(function(r,i){ r.style.display = (i>=ini && i<fim) ? '' : 'none'; });
  var cf = document.getElementById('ins-count-filt'); if (cf) cf.textContent = total;
  var pi = document.getElementById('ins-paginacao');
  if (!pi) return;
  var bs = 'display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--borda);background:var(--card);color:var(--texto2);font-size:12px;font-weight:600;cursor:pointer;';
  var ba = 'display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--cor-primaria);background:var(--cor-primaria);color:#fff;font-size:12px;font-weight:700;cursor:pointer;';
  var h = '<button onclick="insPag(-1)" style="'+bs+'" '+(_insPagina<=1?'disabled':'')+'>&#8592;</button>';
  var start = Math.max(1, _insPagina-2), end = Math.min(totalP, start+4);
  if (end-start<4) start = Math.max(1, end-4);
  if (start>1) { h += '<button onclick="insNum(1)" style="'+bs+'">1</button>'; if (start>2) h += '<span style="padding:0 4px;color:var(--texto2)">...</span>'; }
  for (var p=start; p<=end; p++) h += '<button onclick="insNum('+p+')" style="'+(_insPagina===p?ba:bs)+'">'+p+'</button>';
  if (end<totalP) { if (end<totalP-1) h += '<span style="padding:0 4px;color:var(--texto2)">...</span>'; h += '<button onclick="insNum('+totalP+')" style="'+bs+'">'+totalP+'</button>'; }
  h += '<button onclick="insPag(1)" style="'+bs+'" '+(_insPagina>=totalP?'disabled':'')+'>&#8594;</button>';
  pi.innerHTML = h;
}
function insNum(n){ var pp=parseInt(document.getElementById('ins-por-pagina')?.value)||25; var tp=Math.ceil(_insFiltradas.length/pp)||1; _insPagina=Math.max(1,Math.min(tp,n)); renderInscritos(); document.getElementById('tabela-inscritos')?.scrollIntoView({behavior:'smooth',block:'start'}); }
function insPag(d){ insNum(_insPagina + d); }
function limparFiltrosInscritos(){ ['ins-busca','ins-status','ins-tipo','ins-lote'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; }); filtrarInscritos(); }
function imprimirInscritos(){
  var p = new URLSearchParams();
  var b=document.getElementById('ins-busca')?.value||''; if(b)p.set('busca',b);
  var s=document.getElementById('ins-status')?.value||''; if(s)p.set('status',s);
  var t=document.getElementById('ins-tipo')?.value||''; if(t)p.set('tipo',t);
  var l=document.getElementById('ins-lote')?.value||''; if(l)p.set('lote',l);
  window.open('/eventos/<%= evento.id %>/inscritos-pdf?'+p.toString(),'_blank');
}
document.addEventListener('DOMContentLoaded', function(){ if(document.getElementById('tabela-inscritos')) filtrarInscritos(); });
</script>
<script>
// ===== Filtros + paginação da aba Pagamentos =====
var _pgPagina = 1;
var _pgFiltradas = [];
function filtrarPagamentos() {
  var busca = (document.getElementById('pg-busca')?.value || '').toLowerCase();
  var status = document.getElementById('pg-status')?.value || '';
  var metodo = document.getElementById('pg-metodo')?.value || '';
  var de = document.getElementById('pg-data-de')?.value || '';
  var ate = document.getElementById('pg-data-ate')?.value || '';
  var rows = Array.prototype.slice.call(document.querySelectorAll('.pagamento-row'));
  _pgFiltradas = rows.filter(function(r){
    var n = r.dataset.nome||'';
    if (busca && n.indexOf(busca)<0) return false;
    if (status && r.dataset.status !== status) return false;
    if (metodo && r.dataset.metodo !== metodo) return false;
    var d = r.dataset.data || '';
    if (de && (!d || d < de)) return false;
    if (ate && (!d || d > ate)) return false;
    return true;
  });
  _pgPagina = 1;
  renderPagamentos();
}
function renderPagamentos() {
  var pp = parseInt(document.getElementById('pg-por-pagina')?.value) || 25;
  var total = _pgFiltradas.length;
  var totalP = Math.ceil(total / pp) || 1;
  if (_pgPagina > totalP) _pgPagina = totalP;
  var ini = (_pgPagina - 1) * pp, fim = ini + pp;
  document.querySelectorAll('.pagamento-row').forEach(function(r){ r.style.display='none'; });
  _pgFiltradas.forEach(function(r,i){ r.style.display = (i>=ini && i<fim) ? '' : 'none'; });
  var cf = document.getElementById('pg-count-filt'); if (cf) cf.textContent = total;
  var pi = document.getElementById('pg-paginacao');
  if (!pi) return;
  var bs = 'display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--borda);background:var(--card);color:var(--texto2);font-size:12px;font-weight:600;cursor:pointer;';
  var ba = 'display:inline-flex;align-items:center;justify-content:center;min-width:32px;height:32px;padding:0 8px;border-radius:3px;border:1px solid var(--cor-primaria);background:var(--cor-primaria);color:#fff;font-size:12px;font-weight:700;cursor:pointer;';
  var h = '<button onclick="pgPag(-1)" style="'+bs+'" '+(_pgPagina<=1?'disabled':'')+'>&#8592;</button>';
  var start = Math.max(1, _pgPagina-2), end = Math.min(totalP, start+4);
  if (end-start<4) start = Math.max(1, end-4);
  if (start>1) { h += '<button onclick="pgNum(1)" style="'+bs+'">1</button>'; if (start>2) h += '<span style="padding:0 4px;color:var(--texto2)">...</span>'; }
  for (var p=start; p<=end; p++) h += '<button onclick="pgNum('+p+')" style="'+(_pgPagina===p?ba:bs)+'">'+p+'</button>';
  if (end<totalP) { if (end<totalP-1) h += '<span style="padding:0 4px;color:var(--texto2)">...</span>'; h += '<button onclick="pgNum('+totalP+')" style="'+bs+'">'+totalP+'</button>'; }
  h += '<button onclick="pgPag(1)" style="'+bs+'" '+(_pgPagina>=totalP?'disabled':'')+'>&#8594;</button>';
  pi.innerHTML = h;
}
function pgNum(n){ var pp=parseInt(document.getElementById('pg-por-pagina')?.value)||25; var tp=Math.ceil(_pgFiltradas.length/pp)||1; _pgPagina=Math.max(1,Math.min(tp,n)); renderPagamentos(); document.getElementById('tabela-pagamentos')?.scrollIntoView({behavior:'smooth',block:'start'}); }
function pgPag(d){ pgNum(_pgPagina + d); }
function limparFiltrosPagamentos(){ ['pg-busca','pg-status','pg-metodo','pg-data-de','pg-data-ate'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; }); filtrarPagamentos(); }
document.addEventListener('DOMContentLoaded', function(){ if(document.getElementById('tabela-pagamentos')) filtrarPagamentos(); });
</script>
</body>
</html>
