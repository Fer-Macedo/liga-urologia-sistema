<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Processo Seletivo — LAURO</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%= config.org_cor||'#2b6803' %>;--rad:2px;}
    .ps-tabs{display:flex;gap:4px;margin-bottom:20px;background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:5px;flex-wrap:wrap;}
    .ps-tab{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:var(--rad);border:none;background:transparent;cursor:pointer;font-weight:600;font-size:12px;transition:all .15s;color:var(--texto2);font-family:inherit;white-space:nowrap;}
    .ps-tab:hover{background:var(--fundo);}
    .ps-tab.ativo{background:var(--cor-primaria);color:white;}
    .ps-tab svg{width:13px;height:13px;}
    .ps-sec{display:none;}.ps-sec.ativo{display:block;}
    .q-card{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:14px;margin-bottom:8px;transition:border-color .15s;}
    .q-card:hover{border-color:var(--cor-primaria);}
    .q-tema{display:inline-block;padding:2px 8px;border-radius:var(--rad);font-size:10px;font-weight:700;background:#dbefd3;color:#166534;margin-bottom:6px;}
    .q-enunciado{font-size:13px;font-weight:600;margin-bottom:8px;line-height:1.4;}
    .q-opcoes{display:grid;grid-template-columns:1fr 1fr;gap:4px;font-size:12px;}
    .q-op{padding:4px 8px;border-radius:var(--rad);background:var(--fundo);border:1px solid var(--borda);}
    .q-op.correta{background:#dcfce7;border-color:#16a34a;font-weight:700;}
    .badge-dif{padding:2px 7px;border-radius:var(--rad);font-size:10px;font-weight:700;}
    .dif-facil{background:#dcfce7;color:#166534;}
    .dif-medio{background:#fef3c7;color:#92400e;}
    .dif-dificil{background:#fee2e2;color:#dc2626;}
    .btn-xs{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:var(--rad);font-size:11px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);cursor:pointer;text-decoration:none;transition:all .15s;font-family:inherit;}
    .btn-xs:hover{border-color:var(--cor-primaria);color:var(--cor-primaria);}
    .btn-xs.verde{background:#059669;color:white;border-color:transparent;}
    .btn-xs.verm{color:#dc2626;border-color:#fecaca;}
    .btn-xs.azul{background:#1d4ed8;color:white;border-color:transparent;}
    .btn-xs.amarelo{background:#f59e0b;color:white;border-color:transparent;}
    .btn-xs.roxo{background:#7c3aed;color:white;border-color:transparent;}
    .processo-card{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:18px;margin-bottom:12px;transition:border-color .15s;}
    .processo-card:hover{border-color:var(--cor-primaria);}
    .status-badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:var(--rad);font-size:11px;font-weight:700;}
    .st-aberto{background:#dcfce7;color:#166534;}
    .st-correcao{background:#fef3c7;color:#92400e;}
    .st-entrevista{background:#dbeafe;color:#1e40af;}
    .st-encerrado{background:#f1f5f9;color:#6b7280;}
    .stat-mini{background:var(--fundo);border:1px solid var(--borda);border-radius:var(--rad);padding:10px 14px;text-align:center;flex:1;min-width:80px;}
    .stat-mini-num{font-size:20px;font-weight:800;color:var(--cor-primaria);}
    .stat-mini-lab{font-size:10px;color:var(--texto2);font-weight:600;}
    .gabarito-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;}
    .gabarito-item{display:flex;align-items:center;gap:8px;background:var(--fundo);border:1px solid var(--borda);border-radius:var(--rad);padding:6px 10px;}
    .gabarito-num{font-size:12px;font-weight:700;width:24px;flex-shrink:0;}
    .gabarito-ops{display:flex;gap:4px;}
    .gab-op{width:28px;height:28px;border-radius:50%;border:2px solid var(--borda);background:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;color:var(--texto2);}
    .gab-op.sel{background:var(--cor-primaria);border-color:var(--cor-primaria);color:white;}
    .cand-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--borda);}
    .cand-row:last-child{border-bottom:none;}
    .rank-num{width:28px;height:28px;border-radius:50%;background:var(--cor-primaria);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;}
    .rank-num.ouro{background:#f59e0b;}
    .rank-num.prata{background:#6b7280;}
    .rank-num.bronze{background:#92400e;}
    .progress-bar{flex:1;height:8px;background:var(--fundo);border-radius:4px;overflow:hidden;border:1px solid var(--borda);}
    .progress-fill{height:100%;border-radius:4px;transition:width .4s;}
    .entrev-pergunta{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:14px;margin-bottom:10px;}
    .nota-slider{display:flex;gap:4px;flex-wrap:wrap;margin-top:8px;}
    .nota-btn{width:32px;height:32px;border-radius:var(--rad);border:1.5px solid var(--borda);background:var(--fundo);font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;}
    .nota-btn.sel{background:var(--cor-primaria);border-color:var(--cor-primaria);color:white;}
    .nota-btn:hover{border-color:var(--cor-primaria);}
    .q-select-card{background:var(--card);border:2px solid var(--borda);border-radius:var(--rad);padding:12px;margin-bottom:6px;cursor:pointer;transition:all .15s;}
    .q-select-card.selecionada{border-color:var(--cor-primaria);background:#f0f7eb;}
    .q-select-card:hover{border-color:var(--cor-primaria);}
    .tema-chip{display:inline-block;padding:2px 8px;border-radius:var(--rad);font-size:10px;font-weight:700;margin-right:4px;}
    .filter-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
    .filter-bar select,.filter-bar input{font-size:12px;padding:5px 8px;height:auto;}
    @media(max-width:768px){.q-opcoes{grid-template-columns:1fr;}.gabarito-grid{grid-template-columns:repeat(2,1fr);}}
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'processo-seletivo' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Processo Seletivo</h1>
      <div class="topbar-acoes">
        <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-novo-processo')">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Novo Processo</button>
      </div>
    </div>
    <div class="content">
      <%if(msg&&msg.length>0){%><div class="alerta alerta-ok"><%=msg[0]%></div><%}%>
      <%if(erro&&erro.length>0){%><div class="alerta alerta-erro"><%=erro[0]%></div><%}%>

      <div class="ps-tabs">
        <button class="ps-tab ativo" onclick="psTab('processos',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Processos</button>
        <button class="ps-tab" onclick="psTab('questoes',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Banco de Questões</button>
        <button class="ps-tab" onclick="psTab('provas',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Provas & Gabaritos</button>
        <button class="ps-tab" onclick="psTab('candidatos',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Candidatos</button>
        <button class="ps-tab" onclick="psTab('correcao',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Correção</button>
        <button class="ps-tab" onclick="psTab('entrevistas',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Entrevistas</button>
        <button class="ps-tab" onclick="psTab('resultados',this)">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Resultados</button>
      </div>

      <!-- PROCESSOS -->
      <div class="ps-sec ativo" id="sec-processos">
        <%if(processos.length===0){%>
        <div style="text-align:center;padding:48px;color:var(--texto2)">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 12px;opacity:.3"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <div style="font-weight:600;margin-bottom:4px">Nenhum processo seletivo criado</div>
          <div style="font-size:12px">Clique em "+ Novo Processo" para começar</div>
        </div>
        <%}%>
        <%processos.forEach(p=>{%>
        <div class="processo-card">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap">
            <div style="flex:1">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap">
                <span style="font-size:16px;font-weight:700"><%=p.nome%></span>
                <span class="status-badge st-<%=p.status%>"><%=p.status%></span>
                <%if(p.semestre){%><span style="font-size:11px;color:var(--texto2);font-weight:600"><%=p.semestre%></span><%}%>
              </div>
              <div style="display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:var(--texto2)">
                <%if(p.data_prova){%><span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> <%=new Date(p.data_prova).toLocaleDateString('pt-BR')%></span><%}%>
                <%if(p.local_prova){%><span> <%=p.local_prova%></span><%}%>
                <span> <%=p.vagas%> vagas</span>
                <span><svg width="14" height="14" viewBox="0 0 24 24" fill="#dcfce7" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><circle cx="12" cy="12" r="10" fill="#dcfce7" stroke="#16a34a"/><polyline points="8 12 11 15 16 9" stroke="#16a34a" fill="none"/></svg> Mín. <%=p.nota_minima%>%</span>
              </div>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap">
              <button class="btn-xs" onclick="selecionarProcesso(<%=p.id%>,this.dataset.nome)" data-nome="<%=p.nome%>">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>Selecionar</button>
              <a href="/processo-seletivo/<%=p.id%>/prova/gerar" class="btn-xs amarelo">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>Montar Prova</button>
              <a href="/processo-seletivo/<%=p.id%>/pdf-prova" target="_blank" class="btn-xs roxo">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>PDF Prova</a>
              <a href="/processo-seletivo/<%=p.id%>/pdf-gabarito" target="_blank" class="btn-xs azul">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>PDF Gabarito</a>
              <form method="POST" action="/processo-seletivo/<%=p.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button></form>
            </div>
          </div>
        </div>
        <%});%>
      </div>

      <!-- BANCO DE QUESTÕES -->
      <div class="ps-sec" id="sec-questoes">
        <div class="filter-bar">
          <select id="filtro-tema" class="input" onchange="filtrarQuestoes()">
            <option value="">Todos os temas</option>
            <%temas.forEach(t=>{%><option><%=t%></option><%});%>
          </select>
          <select id="filtro-dif" class="input" onchange="filtrarQuestoes()">
            <option value="">Qualquer dificuldade</option>
            <option>facil</option><option>medio</option><option>dificil</option>
          </select>
          <input type="text" id="filtro-busca" class="input" placeholder="Buscar questão..." oninput="filtrarQuestoes()" style="flex:1;min-width:180px">
          <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-nova-questao')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nova Questão</button>
        </div>
        <div style="font-size:12px;color:var(--texto2);margin-bottom:10px" id="q-count"><%=questoes.length%> questão(ões) no banco</div>
        <div id="lista-questoes">
        <%questoes.forEach(q=>{%>
        <div class="q-card q-item" data-tema="<%=q.tema%>" data-dif="<%=q.dificuldade%>" data-txt="<%=(q.enunciado||'').toLowerCase()%>">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px">
            <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
              <span class="q-tema"><%=q.tema%></span>
              <span class="badge-dif dif-<%=q.dificuldade%>"><%=q.dificuldade%></span>
              <span style="font-size:10px;color:var(--texto2)">#<%=q.id%></span>
            </div>
            <div style="display:flex;gap:4px;flex-shrink:0">
              <button class="btn-xs" onclick="editarQuestao(<%=q.id%>)">Editar</button>
              <form method="POST" action="/processo-seletivo/questao/<%=q.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir questão?')">
                <button type="submit" class="btn-xs verm"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></form>
            </div>
          </div>
          <div class="q-enunciado"><%=q.enunciado%></div>
          <div class="q-opcoes">
            <div class="q-op <%=q.resposta_correta==='A'?'correta':''%>">A) <%=q.opcao_a%></div>
            <div class="q-op <%=q.resposta_correta==='B'?'correta':''%>">B) <%=q.opcao_b%></div>
            <div class="q-op <%=q.resposta_correta==='C'?'correta':''%>">C) <%=q.opcao_c%></div>
            <div class="q-op <%=q.resposta_correta==='D'?'correta':''%>">D) <%=q.opcao_d%></div>
          </div>
        </div>
        <%});%>
        </div>
      </div>

      <!-- PROVAS & GABARITOS -->
      <div class="ps-sec" id="sec-provas">
        <div style="background:#eff6ff;border-radius:var(--rad);padding:12px 16px;margin-bottom:16px;font-size:13px;color:#1e40af">
          <strong>Como usar:</strong> 1) Selecione um processo na aba <em>Processos</em> → 2) Clique em "Montar Prova" → 3) Selecione as questões por tema → 4) Gere o PDF da prova e do cartão de resposta.
        </div>
        <%if(provas.length===0){%>
        <div style="text-align:center;padding:40px;color:var(--texto2);font-size:13px">Nenhuma prova gerada ainda. Use "Montar Prova" no processo seletivo.</div>
        <%}%>
        <%provas.forEach(pv=>{%>
        <div class="q-card">
          <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
            <div>
              <span style="font-weight:700">Fila <%=pv.fila%></span>
              <span style="font-size:12px;color:var(--texto2);margin-left:8px"><%=pv.processo_nome%></span>
              <span style="font-size:11px;color:var(--texto2);margin-left:8px"><%=JSON.parse(pv.questoes_json||'[]').length%> questões</span>
            </div>
            <div style="display:flex;gap:6px">
              <a href="/processo-seletivo/prova/<%=pv.id%>/pdf" target="_blank" class="btn-xs roxo">PDF Prova</a>
              <a href="/processo-seletivo/prova/<%=pv.id%>/gabarito" target="_blank" class="btn-xs azul">PDF Gabarito</a>
            </div>
          </div>
        </div>
        <%});%>
      </div>

      <!-- CANDIDATOS -->
      <div class="ps-sec" id="sec-candidatos">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px">
          <select id="filtro-proc-cand" class="input" style="font-size:12px;padding:5px 8px;height:auto" onchange="filtrarCandidatos(this.value)">
            <option value="">Todos os processos</option>
            <%processos.forEach(p=>{%><option value="<%=p.id%>"><%=p.nome%></option><%});%>
          </select>
          <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-novo-candidato')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Inscr. Candidato</button>
        </div>
        <%if(candidatos.length===0){%>
        <div style="text-align:center;padding:40px;color:var(--texto2);font-size:13px">Nenhum candidato inscrito</div>
        <%}%>
        <div class="table-card">
          <table class="tabela">
            <thead><tr>
              <th>Nº</th><th>Candidato</th><th>Fila</th><th>Contato</th><th>Status</th><th>Nota Prova</th><th>Ações</th>
            </tr></thead>
            <tbody>
            <%candidatos.forEach(c=>{%>
            <tr class="cand-item" data-proc="<%=c.processo_id%>">
              <td style="font-weight:700;color:var(--cor-primaria)"><%=c.numero_lista||'—'%></td>
              <td>
                <div style="font-weight:600;font-size:13px"><%=c.nome%></div>
                <div style="font-size:11px;color:var(--texto2)"><%=c.curso||''%><%=c.semestre_atual?' • '+c.semestre_atual+'º sem':'  '%></div>
              </td>
              <td><span style="font-weight:700;font-size:14px;color:var(--cor-primaria)"><%=c.fila_prova||'—'%></span></td>
              <td style="font-size:12px">
                <%if(c.email){%><div><%=c.email%></div><%}%>
                <%if(c.telefone){%><div style="color:var(--texto2)"><%=c.telefone%></div><%}%>
              </td>
              <td><span class="status-badge st-<%=c.status==='aprovado'?'aberto':c.status==='entrevista'?'entrevista':c.status==='reprovado'?'encerrado':'correcao'%>"><%=c.status%></span></td>
              <td>
                <%if(c.percentual!=null){%>
                <div style="font-weight:700;font-size:14px;color:<%=c.aprovado_prova?'#166534':'#dc2626'%>"><%=parseFloat(c.percentual).toFixed(1)%>%</div>
                <div style="font-size:10px;color:var(--texto2)"><%=c.total_acertos%>/<%=c.total_questoes%> acertos</div>
                <%}else{%><span style="color:var(--texto2);font-size:12px">Não corrigido</span><%}%>
              </td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  <button class="btn-xs verde" onclick="abrirCorrecao(<%=c.id%>,this.dataset.nome,<%=c.processo_id%>,'<%=c.fila_prova||'A'%>')" data-nome="<%=c.nome%>">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Corrigir</button>
                  <button class="btn-xs azul" onclick="abrirEntrevista(<%=c.id%>,this.dataset.nome,<%=c.processo_id%>)" data-nome="<%=c.nome%>">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Entrevista</button>
                  <form method="POST" action="/processo-seletivo/candidato/<%=c.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Remover?')">
                    <button type="submit" class="btn-xs verm"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></form>
                </div>
              </td>
            </tr>
            <%});%>
            </tbody>
          </table>
        </div>
      </div>

      <!-- CORREÇÃO -->
      <div class="ps-sec" id="sec-correcao">
        <div style="background:#f0f7eb;border-radius:var(--rad);padding:12px 16px;margin-bottom:16px;font-size:13px;color:#166534">
          <strong>Correção Digital</strong> — Selecione o candidato e lance as respostas. O sistema calcula a nota automaticamente comparando com o gabarito da fila.
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px">
          <select id="sel-proc-corr" class="input" style="font-size:12px" onchange="carregarCandidatosCorrecao(this.value)">
            <option value="">Selecione o processo...</option>
            <%processos.forEach(p=>{%><option value="<%=p.id%>"><%=p.nome%></option><%});%>
          </select>
          <select id="sel-cand-corr" class="input" style="font-size:12px" onchange="carregarGabaritoCorrecao()">
            <option value="">Selecione o candidato...</option>
          </select>
        </div>
        <div id="painel-correcao" style="display:none">
          <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;flex-wrap:wrap">
            <div style="font-size:14px;font-weight:700" id="corr-nome-label">—</div>
            <div style="font-size:12px;color:var(--texto2)">Fila: <strong id="corr-fila-label">—</strong></div>
            <div id="corr-score-live" style="font-size:18px;font-weight:800;color:var(--cor-primaria)">0%</div>
            <div id="corr-acertos-live" style="font-size:12px;color:var(--texto2)">0/0 acertos</div>
          </div>
          <div id="gabarito-correcao" class="gabarito-grid"></div>
          <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn btn-primario" onclick="salvarCorrecao()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Salvar Correção</button>
            <div>
              <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px">Foto do Cartão (opcional)</label>
