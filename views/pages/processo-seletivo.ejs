      </div>

      <!-- ENTREVISTAS -->
      <div class="ps-sec" id="sec-entrevistas">
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;align-items:center">
          <select id="sel-proc-entrev" class="input" style="font-size:12px" onchange="carregarCandidatosEntrevista(this.value)">
            <option value="">Selecione o processo...</option>
            <%processos.forEach(p=>{%><option value="<%=p.id%>"><%=p.nome%></option><%});%>
          </select>
          <select id="sel-cand-entrev" class="input" style="font-size:12px" onchange="carregarFichaEntrevista()">
            <option value="">Selecione o candidato...</option>
          </select>
          <button class="btn btn-sm" onclick="abrirModal('modal-config-perguntas')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Config. Perguntas</button>
        </div>
        <div id="painel-entrevista" style="display:none">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
