            <%processos.forEach(p=>{%><option value="<%=p.id%>"><%=p.nome%></option><%});%>
          </select>
          <button class="btn btn-sm" id="btn-export-csv" onclick="exportarCSV()" style="display:none">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportar CSV</button>
        </div>
        <div id="painel-resultados">
          <div style="text-align:center;padding:40px;color:var(--texto2);font-size:13px">Selecione um processo para ver os resultados</div>
