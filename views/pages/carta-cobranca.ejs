<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cartas de Cobrança — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .badge { padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700; }
    .badge-pendente { background:#fef3c7;color:#92400e; }
    .badge-enviado { background:#dbeafe;color:#1e40af; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'cobrancas' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">📄 Cartas de Cobrança</h1>
      <div class="topbar-acoes">
        <a href="/cobrancas" class="btn">← Cobranças</a>
        <button class="btn btn-primario" onclick="abrirModal('modal-nova')">+ Nova Carta</button>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <div class="card">
        <table class="tabela">
          <thead>
            <tr>
              <th>#</th>
              <th>Membro/Ligante</th>
              <th>Email</th>
              <th>Mês Ref.</th>
              <th>Vencimento</th>
              <th>Status</th>
              <th>Enviado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (cartas.length === 0) { %>
            <tr><td colspan="8" style="text-align:center;color:var(--texto2);padding:40px">Nenhuma carta cadastrada</td></tr>
            <% } %>
            <% cartas.forEach(d => { %>
            <tr>
              <td><%= d.id %></td>
              <td><strong><%= d.pessoa_nome || '—' %></strong></td>
              <td><%= d.pessoa_email || '—' %></td>
              <td><%= d.mes_referencia || '—' %></td>
              <td><%= d.vencimento ? new Date(d.vencimento).toLocaleDateString('pt-BR') : '—' %></td>
              <td>
                <% if (d.status === 'enviado') { %>
                  <span class="badge badge-enviado">📧 Enviado</span>
                <% } else { %>
                  <span class="badge badge-pendente">⏳ Pendente</span>
                <% } %>
              </td>
              <td><%= d.enviado_em ? new Date(d.enviado_em).toLocaleString('pt-BR') : '—' %></td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  <a href="/carta-cobranca/<%= d.id %>/visualizar" target="_blank" class="btn" style="font-size:11px;padding:4px 8px" title="Visualizar">👁</a>
                  <a href="/carta-cobranca/<%= d.id %>/imprimir" target="_blank" class="btn" style="font-size:11px;padding:4px 8px;background:#6366f1;color:white" title="Imprimir">🖨️</a>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/enviar" style="display:inline">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;background:#059669;color:white">📧 Enviar</button>
                  </form>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/reenviar" style="display:inline">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;background:#f59e0b;color:white">🔄 Reenviar</button>
                  </form>
                  <% if (usuario.perfil === 'admin' || usuario.perfil === 'presidencia' || usuario.perfil === 'financeiro') { %>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;color:var(--vermelho)">🗑</button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Modal Nova Carta -->
<div class="modal-overlay" id="modal-nova" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">📄 Nova Carta de Cobrança</span>
      <button class="icon-btn" onclick="fecharModal('modal-nova')">✕</button>
    </div>
    <form action="/carta-cobranca" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Tipo de destinatário</label>
          <select id="tipo-dest" class="input" onchange="trocarTipo(this.value)">
            <option value="membro">Membro</option>
            <option value="ligante">Ligante</option>
          </select>
        </div>
        <div class="campo" id="campo-membro">
          <label class="label">Membro *</label>
          <select name="membro_id" class="input" id="sel-membro">
            <option value="">Selecione...</option>
            <% membros.forEach(m => { %>
            <option value="<%= m.id %>"><%= m.nome %> — <%= m.email %></option>
            <% }) %>
          </select>
        </div>
        <div class="campo" id="campo-ligante" style="display:none">
          <label class="label">Ligante *</label>
          <select name="ligante_id" class="input" id="sel-ligante">
            <option value="">Selecione...</option>
            <% ligantes.forEach(l => { %>
            <option value="<%= l.id %>"><%= l.nome %> — <%= l.email %></option>
            <% }) %>
          </select>
        </div>
        <div class="campo">
          <label class="label">Mês de referência (ex: mayo 2026)</label>
          <input type="text" name="mes_referencia" class="input" placeholder="mayo 2026" required>
        </div>
        <div class="campo">
          <label class="label">Data de vencimento</label>
          <input type="date" name="vencimento" class="input">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-nova')">Cancelar</button>
        <button type="submit" class="btn btn-primario">📄 Criar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
function trocarTipo(tipo) {
  document.getElementById('campo-membro').style.display = tipo === 'membro' ? '' : 'none';
  document.getElementById('campo-ligante').style.display = tipo === 'ligante' ? '' : 'none';
}
</script>
</body>
</html>
