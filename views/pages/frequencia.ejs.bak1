<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Frequência Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .freq-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 20px;
      margin-bottom: 16px;
    }

    .freq-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--borda);
    }
    .freq-tab {
      padding: 10px 20px;
      border: none;
      background: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--texto2);
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      font-family: Outfit, sans-serif;
      transition: all .15s;
    }
    .freq-tab.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); font-weight: 600; }
    .freq-tab:hover { color: var(--texto); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }

    /* STATS */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }
    .stat-mini {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 18px 20px;
      position: relative;
      overflow: hidden;
    }
    .stat-mini::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .stat-mini.verde::before { background: linear-gradient(90deg,#10b981,#34d399); }
    .stat-mini.amr::before   { background: linear-gradient(90deg,#f59e0b,#fbbf24); }
    .stat-mini.verm::before  { background: linear-gradient(90deg,#ef4444,#f87171); }
    .stat-mini .num { font-family:'Outfit',sans-serif;font-size:28px;font-weight:700;margin-bottom:4px; }
    .stat-mini.verde .num { color:#10b981; }
    .stat-mini.amr   .num { color:#f59e0b; }
    .stat-mini.verm  .num { color:#ef4444; }
    .stat-mini .lab { font-size:11.5px;color:var(--texto2);font-weight:600;text-transform:uppercase;letter-spacing:.06em; }

    /* BARRA FREQUÊNCIA */
    .presenca-row {
      display: flex;
      align-items: center;
      padding: 12px 14px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      gap: 12px;
      margin-bottom: 8px;
    }
    .barra-wrap { background:#e5e7eb;border-radius:20px;height:7px;flex:1;max-width:160px; }
    .barra { height:7px;border-radius:20px; }
    .barra.apto   { background:#10b981; }
    .barra.risco  { background:#f59e0b; }
    .barra.inapto { background:#ef4444; }

    /* ATIVIDADE CARD */
    .atividade-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 14px;
    }
    .atividade-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px;
      border-bottom: 1px solid var(--borda);
      flex-wrap: wrap;
      gap: 10px;
      cursor: pointer;
      user-select: none;
    }
    .atividade-header:hover { background: var(--fundo); }
    .atividade-body {
      padding: 16px 18px;
    }

    /* CHECKBOXES DE PRESENÇA */
    .presenca-lista {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 8px;
      margin-bottom: 14px;
    }
    .presenca-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1.5px solid var(--borda);
      cursor: pointer;
      transition: all .15s ease;
    }
    .presenca-item:hover { border-color: var(--cor-primaria); }
    .presenca-item input[type=checkbox] {
      width: 18px; height: 18px;
      accent-color: var(--cor-primaria);
      flex-shrink: 0;
      cursor: pointer;
    }
    .presenca-item.presente {
      border-color: #10b981;
      background: #f0fdf4;
    }
    .presenca-item.presente .presenca-nome { color: #166534; }

    .presenca-nome { font-size: 13px; font-weight: 500; }

    .badge-tipo {
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 600;
      color: white;
      white-space: nowrap;
    }

    .btn-excluir-membro {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 8px;
      background: transparent;
      color: #dc2626;
      border: 1px solid #fecaca;
      font-size: 11.5px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s ease;
      font-family: inherit;
    }
    .btn-excluir-membro:hover {
      background: #fee2e2;
    }

    .turma-btn {
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 12.5px;
      font-weight: 600;
      border: 1.5px solid var(--borda);
      background: var(--fundo);
      color: var(--texto2);
      cursor: pointer;
      text-decoration: none;
      transition: all .15s;
    }
    .turma-btn.ativo {
      background: linear-gradient(135deg,#1a56db,#1e3a8a);
      color: white;
      border-color: transparent;
    }
    .turma-btn:hover:not(.ativo) { border-color: var(--cor-primaria); color: var(--cor-primaria); }

    .selecionar-row {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'frequencia' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Frequência Ligantes</h1>
      <div class="topbar-acoes">
        <button class="btn btn-sm" onclick="abrirModal('modal-turma')">+ Nova turma</button>
        <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-atividade')">+ Nova atividade</button>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

      <!-- SELETOR DE TURMA -->
      <div class="freq-card" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--texto2)">Turma</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;flex:1">
          <% turmas.slice().sort((a,b) => a.nome.localeCompare(b.nome)).forEach(t => { %>
            <a href="/frequencia?turma=<%= t.id %>" class="turma-btn <%= turmaAtual && turmaAtual.id == t.id ? 'ativo' : '' %>">
              <%= t.nome %>
              <% if (t.data_inicio) { %>
                <span style="font-size:10px;opacity:.7;margin-left:4px">
                  <%= new Date(t.data_inicio+'T12:00:00').toLocaleDateString('pt-BR',{month:'short',year:'numeric'}) %>
                </span>
              <% } %>
            </a>
          <% }) %>
          <% if (turmas.length === 0) { %>
            <span style="color:var(--texto2);font-size:13px">Nenhuma turma. Crie uma para começar.</span>
          <% } %>
        </div>
        <% if (turmaAtual) { %>
          <a href="/frequencia/relatorio/<%= turmaAtual.id %>" class="btn btn-sm" target="_blank">Relatório</a>
          <form method="POST" action="/frequencia/turma/<%= turmaAtual.id %>/sincronizar" style="display:inline">
            <button type="submit" class="btn btn-sm" onclick="return confirm('Sincronizar todos os ligantes ativos com esta turma?')" title="Adiciona automaticamente todos ligantes ativos que ainda não estão na turma">🔄 Sincronizar Ligantes</button>
            <button type="button" onclick="verificarIntegridade(<%=turmaAtual.id%>)" class="btn btn-sm" style="background:#f59e0b;color:white;border:none"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Verificar Integridade</button>
          </form>
          <button class="btn btn-sm" onclick="abrirModalEnvio(<%= turmaAtual.id %>)">Enviar frequências</button>
        <% } %>
      </div>

      <% if (turmaAtual) { %>

      <!-- TABS -->
      <div class="freq-tabs">
        <button class="freq-tab ativo" onclick="mostrarTab('tab-resumo',this)">Resumo</button>
        <button class="freq-tab" onclick="mostrarTab('tab-atividades',this)">Atividades (<%= atividades.length %>)</button>
        <button class="freq-tab" onclick="mostrarTab('tab-ligantes',this)">Ligantes (<%= membrosFrequencia.length %>)</button>
      </div>

      <!-- TAB RESUMO -->
      <div id="tab-resumo" class="tab-content ativo">
        <div class="stats-row">
          <div class="stat-mini verde">
            <div class="num"><%= resumo.aptos %></div>
            <div class="lab">Aptos (≥75%)</div>
          </div>
          <div class="stat-mini amr">
            <div class="num"><%= resumo.risco %></div>
            <div class="lab">Em risco (50–74%)</div>
          </div>
          <div class="stat-mini verm">
            <div class="num"><%= resumo.inaptos %></div>
            <div class="lab">Não aptos (&lt;50%)</div>
          </div>
        </div>

        <div class="freq-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <div style="font-size:15px;font-weight:700;font-family:'Outfit',sans-serif">Frequência por Ligante</div>
            <span style="font-size:12px;color:var(--texto2)">Mínimo 75% para certificado</span>
          </div>
          <% if (membrosFrequencia.length === 0) { %>
            <div style="text-align:center;padding:30px;color:var(--texto2)">Nenhum ligante na turma ainda</div>
          <% } %>
          <% membrosFrequencia.forEach(m => {
            const pct = m.total_atividades > 0 ? Math.round((m.presencas / m.total_atividades) * 100) : 0;
            const faltas = m.total_atividades - m.presencas;
            const cor = pct >= 75 ? 'apto' : pct >= 50 ? 'risco' : 'inapto';
            const corTexto = pct >= 75 ? '#10b981' : pct >= 50 ? '#f59e0b' : '#ef4444';
            const badgeBg = pct >= 75 ? '#dcfce7' : pct >= 50 ? '#fef3c7' : '#fee2e2';
            const badgeCor = pct >= 75 ? '#166534' : pct >= 50 ? '#92400e' : '#991b1b';
          %>
          <div class="presenca-row">
            <div class="avatar" style="width:34px;height:34px;font-size:11px;flex-shrink:0"><%= m.nome.substring(0,2).toUpperCase() %></div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13.5px;font-weight:600;margin-bottom:5px"><%= m.nome %></div>
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <div class="barra-wrap"><div class="barra <%= cor %>" style="width:<%= pct %>%"></div></div>
                <span style="font-size:12px;color:var(--texto2)"><%= m.presencas %> pres. / <%= faltas %> faltas / <%= m.total_atividades %> total</span>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
              <span style="font-size:14px;font-weight:700;color:<%= corTexto %>"><%= pct %>%</span>
              <span style="background:<%= badgeBg %>;color:<%= badgeCor %>;border-radius:999px;font-size:11px;font-weight:700;padding:3px 10px">
                <%= pct >= 75 ? 'Apto' : pct >= 50 ? 'Em risco' : 'Não apto' %>
              </span>
              <form action="/frequencia/turma/<%= turmaAtual.id %>/remover-membro" method="POST"
                onsubmit="return confirm('Excluir o registro de <%= m.nome.replace(/'/g,"\\'") %> desta turma?')"
                style="display:inline;margin:0">
                <input type="hidden" name="membro_id" value="<%= m.membro_id %>">
                <button type="submit" class="btn-excluir-membro">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
                  Excluir
                </button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- TAB ATIVIDADES -->
      <div id="tab-atividades" class="tab-content">
        <% if (atividades.length === 0) { %>
          <div style="text-align:center;padding:60px;color:var(--texto2)">Nenhuma atividade cadastrada</div>
        <% } %>

        <% const coresTipo = {
          'Aula Presencial': '#1a56db',
          'Aula On-line': '#7c3aed',
          'Extensão': '#059669',
          'Reunião': '#d97706',
          'Bienvenidas': '#db2777',
          'Expoligas': '#dc2626',
          'Outras': '#6b7280'
        }; %>

        <% atividades.forEach(a => { %>
        <div class="atividade-card">
          <div class="atividade-header" onclick="toggleAtividade(<%= a.id %>)">
            <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
              <span class="badge-tipo" style="background:<%= coresTipo[a.tipo]||'#6b7280' %>"><%= a.tipo %></span>
              <div>
                <div style="font-size:14px;font-weight:700"><%= a.descricao %></div>
                <div style="font-size:12px;color:var(--texto2);margin-top:2px">
                  <%= new Date(a.data_atividade+'T12:00:00').toLocaleDateString('pt-BR',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %>
                </div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;flex-shrink:0">
              <span style="font-size:13px;font-weight:600;color:var(--texto2)">
                <span style="color:#10b981"><%= a.presentes %></span> / <%= a.total_membros %> presentes
              </span>
              <form action="/frequencia/atividade/<%= a.id %>/deletar" method="POST"
                onsubmit="return confirm('Excluir esta atividade?')" style="display:inline;margin:0"
                onclick="event.stopPropagation()">
                <button class="btn-excluir-membro" type="submit">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
              </form>
              <svg id="chevron-<%= a.id %>" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .2s;color:var(--texto2)"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

          <div class="atividade-body" id="body-<%= a.id %>" style="display:none">
            <form action="/frequencia/atividade/<%= a.id %>/presenca" method="POST">

              <!-- CONTROLES RÁPIDOS -->
              <div class="selecionar-row">
                <span style="font-size:12px;font-weight:600;color:var(--texto2)">Marcar presença:</span>
                <button type="button" class="btn btn-sm"
                  onclick="marcarTodos(<%= a.id %>, true)"
                  style="font-size:12px;background:#f0fdf4;color:#166534;border:1px solid #bbf7d0">
                  Todos presentes
                </button>
                <button type="button" class="btn btn-sm"
                  onclick="marcarTodos(<%= a.id %>, false)"
                  style="font-size:12px;background:var(--fundo);color:var(--texto2);border:1px solid var(--borda)">
                  Desmarcar todos
                </button>
              </div>

              <!-- LISTA DE CHECKBOXES -->
              <div class="presenca-lista" id="lista-<%= a.id %>">
                <% a.membros.forEach(m => { %>
                <label class="presenca-item <%= m.presente ? 'presente' : '' %>" id="item-<%= a.id %>-<%= m.membro_id %>">
                  <input type="checkbox" name="presentes" value="<%= m.membro_id %>"
                    <%= m.presente ? 'checked' : '' %>
                    onchange="togglePresente(this, <%= a.id %>, <%= m.membro_id %>)">
                  <span class="presenca-nome"><%= m.nome %></span>
                </label>
                <% }) %>
              </div>

              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                <span id="contagem-<%= a.id %>" style="font-size:13px;color:var(--texto2)">
                  <%= a.membros.filter(m=>m.presente).length %> de <%= a.membros.length %> presentes
                </span>
                <button type="submit" class="btn btn-primario btn-sm">Salvar presenças</button>
              </div>
            </form>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- TAB LIGANTES -->
      <div id="tab-ligantes" class="tab-content">
        <div class="freq-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
            <div>
              <div style="font-size:15px;font-weight:700;font-family:'Outfit',sans-serif">Ligantes da turma</div>
              <div style="font-size:12px;color:var(--texto2);margin-top:2px">Turma <%= turmaAtual.nome %></div>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-sm" onclick="abrirModal('modal-add-todos')"
                style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;font-size:12px">
                + Adicionar todos os ligantes
              </button>
              <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-add-membro')">+ Adicionar ligante</button>
            </div>
          </div>

          <% if (membrosFrequencia.length === 0) { %>
            <div style="text-align:center;padding:30px;color:var(--texto2)">Nenhum ligante na turma</div>
          <% } %>

          <% membrosFrequencia.forEach(m => {
            const pct = m.total_atividades > 0 ? Math.round((m.presencas / m.total_atividades) * 100) : 0;
            const faltas = m.total_atividades - m.presencas;
            const badgeBg = pct >= 75 ? '#dcfce7' : pct >= 50 ? '#fef3c7' : '#fee2e2';
            const badgeCor = pct >= 75 ? '#166534' : pct >= 50 ? '#92400e' : '#991b1b';
          %>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--borda);gap:10px;flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
              <div class="avatar" style="width:34px;height:34px;font-size:11px;flex-shrink:0"><%= m.nome.substring(0,2).toUpperCase() %></div>
              <div>
                <div style="font-size:13.5px;font-weight:600"><%= m.nome %></div>
                <div style="font-size:11.5px;color:var(--texto2);margin-top:2px"><%= m.presencas %> presenças · <%= faltas %> faltas</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">
              <span style="background:<%= badgeBg %>;color:<%= badgeCor %>;border-radius:999px;font-size:11px;font-weight:700;padding:3px 10px"><%= pct %>%</span>
              <form action="/frequencia/turma/<%= turmaAtual.id %>/remover-membro" method="POST"
                onsubmit="return confirm('Remover <%= m.nome.replace(/'/g,"\\'") %> desta turma?')"
                style="display:inline;margin:0">
                <input type="hidden" name="membro_id" value="<%= m.membro_id %>">
                <button type="submit" class="btn-excluir-membro">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
                  Excluir
                </button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <% } else if (turmas.length > 0) { %>
        <div style="text-align:center;padding:60px;color:var(--texto2)">Selecione uma turma acima para ver a frequência</div>
      <% } %>
    </div>
  </main>
</div>

<!-- MODAL NOVA TURMA -->
<div class="modal-overlay" id="modal-turma" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Nova Turma</span>
      <button class="icon-btn" onclick="fecharModal('modal-turma')">✕</button>
    </div>
    <form action="/frequencia/turma" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Nome da turma *</label>
          <input name="nome" class="input" required placeholder="Ex: 2025.2, 2026.1">
        </div>
        <div class="campo">
          <label class="label">Data de início *</label>
          <input name="data_inicio" type="date" class="input" required>
        </div>
        <div class="campo">
          <label class="label">Data de término (opcional)</label>
          <input name="data_fim" type="date" class="input">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-turma')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Criar turma</button>
      </div>
    </form>
  </div>
</div>

<!-- MODAL NOVA ATIVIDADE -->
<div class="modal-overlay" id="modal-atividade" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Nova Atividade</span>
      <button class="icon-btn" onclick="fecharModal('modal-atividade')">✕</button>
    </div>
    <form action="/frequencia/atividade" method="POST">
      <input type="hidden" name="turma_id" value="<%= turmaAtual ? turmaAtual.id : '' %>">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Turmas * <span style="font-size:11px;color:var(--texto2)">(selecione uma ou mais)</span></label>
          <div style="display:flex;flex-direction:column;gap:8px;background:var(--fundo);border:1.5px solid var(--borda);border-radius:10px;padding:12px">
            <% turmas.forEach(t => { %>
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px;font-weight:500">
              <input type="checkbox" name="turmas_ids" value="<%= t.id %>"
                <%= turmaAtual && turmaAtual.id == t.id ? 'checked' : '' %>
                style="width:16px;height:16px;accent-color:var(--cor-primaria);cursor:pointer">
              <%= t.nome %>
            </label>
            <% }) %>
          </div>
        </div>
        <div class="campo">
          <label class="label">Tipo de atividade *</label>
          <select name="tipo" class="input" required>
            <option value="Aula Presencial">Aula Presencial</option>
            <option value="Aula On-line">Aula On-line</option>
            <option value="Extensão">Extensão</option>
            <option value="Reunião">Reunião</option>
            <option value="Bienvenidas">Bienvenidas</option>
            <option value="Expoligas">Expoligas</option>
            <option value="Outras">Outras</option>
          </select>
        </div>
        <div class="campo">
          <label class="label">Descrição *</label>
          <input name="descricao" class="input" required placeholder="Ex: Urgências Urológicas, HPB...">
        </div>
        <div class="campo">
          <label class="label">Data da atividade *</label>
          <input name="data_atividade" type="date" class="input" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-atividade')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Criar atividade</button>
      </div>
    </form>
  </div>
</div>

<!-- MODAL ADICIONAR LIGANTE INDIVIDUAL -->
<div class="modal-overlay" id="modal-add-membro" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Adicionar Ligante</span>
      <button class="icon-btn" onclick="fecharModal('modal-add-membro')">✕</button>
    </div>
    <form action="/frequencia/turma/<%= turmaAtual ? turmaAtual.id : 0 %>/adicionar-membro" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Ligante *</label>
          <select name="membro_id" class="input" required>
            <option value="">Selecione...</option>
            <% todosMembros.forEach(m => { %>
              <% const jaNaTurma = membrosFrequencia.some(mf => mf.membro_id == m.id); %>
              <% if (!jaNaTurma) { %>
                <option value="<%= m.id %>"><%= m.nome %></option>
              <% } %>
            <% }) %>
          </select>
          <small style="font-size:11px;color:var(--texto2);margin-top:4px;display:block">
            Apenas ligantes não vinculados à turma aparecem aqui.
          </small>
        </div>
        <input type="hidden" name="data_entrada" value="<%= new Date().toISOString().split('T')[0] %>">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-add-membro')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Adicionar</button>
      </div>
    </form>
  </div>
</div>

<!-- MODAL ADICIONAR TODOS OS LIGANTES -->
<div class="modal-overlay" id="modal-add-todos" style="display:none">
  <div class="modal" style="max-width:560px">
    <div class="modal-header">
      <span class="modal-titulo">Adicionar ligantes à turma</span>
      <button class="icon-btn" onclick="fecharModal('modal-add-todos')">✕</button>
    </div>
    <p style="font-size:13px;color:var(--texto2);margin-bottom:16px">
      Selecione os ligantes que farão parte da turma <strong><%= turmaAtual ? turmaAtual.nome : '' %></strong>.
      Ligantes já vinculados não aparecem aqui.
    </p>

    <% const naoNaTurma = todosMembros.filter(m => !membrosFrequencia.some(mf => mf.membro_id == m.id)); %>

    <% if (naoNaTurma.length === 0) { %>
      <div style="text-align:center;padding:20px;color:var(--texto2);font-size:13px">
        Todos os ligantes já estão nesta turma.
      </div>
    <% } else { %>
      <div style="display:flex;gap:8px;margin-bottom:12px">
        <button type="button" class="btn btn-sm" onclick="selecionarTodosLigantes(true)"
          style="font-size:12px;background:#f0fdf4;color:#166534;border:1px solid #bbf7d0">
          Selecionar todos
        </button>
        <button type="button" class="btn btn-sm" onclick="selecionarTodosLigantes(false)"
          style="font-size:12px;background:var(--fundo);color:var(--texto2);border:1px solid var(--borda)">
          Desmarcar todos
        </button>
      </div>

      <div style="max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;margin-bottom:16px" id="lista-add-todos">
        <% naoNaTurma.forEach(m => { %>
        <label style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--fundo);border-radius:10px;border:1px solid var(--borda);cursor:pointer">
          <input type="checkbox" class="check-add-todos" value="<%= m.id %>" checked
            style="width:18px;height:18px;accent-color:var(--cor-primaria)">
          <span style="font-size:13px;font-weight:500"><%= m.nome %></span>
        </label>
        <% }) %>
      </div>

      <div style="text-align:right">
        <button type="button" class="btn btn-primario" onclick="adicionarTodosSelecionados()">
          Adicionar selecionados
        </button>
      </div>
    <% } %>
  </div>
</div>

<!-- MODAL ENVIAR FREQUÊNCIA -->
<div class="modal-overlay" id="modal-envio" style="display:none">
  <div class="modal" style="max-width:500px">
    <div class="modal-header">
      <span class="modal-titulo">Enviar Frequência</span>
      <button class="icon-btn" onclick="fecharModal('modal-envio')">✕</button>
    </div>
    <p style="font-size:13px;color:var(--texto2);margin:0 0 12px">Selecione quem receberá o relatório por WhatsApp e e-mail:</p>
    <div style="display:flex;gap:8px;margin-bottom:12px">
      <button class="btn btn-sm" onclick="selecionarTodos(true)"
        style="font-size:12px;background:#f0fdf4;color:#166534;border:1px solid #bbf7d0">Selecionar todos</button>
      <button class="btn btn-sm" onclick="selecionarTodos(false)"
        style="font-size:12px;background:var(--fundo);color:var(--texto2);border:1px solid var(--borda)">Desmarcar todos</button>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;max-height:300px;overflow-y:auto">
      <% membrosFrequencia.forEach(m => {
        const pctE = m.total_atividades > 0 ? Math.round((m.presencas / m.total_atividades) * 100) : 0;
      %>
      <label style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--fundo);border-radius:8px;border:1px solid var(--borda);cursor:pointer">
        <input type="checkbox" class="check-envio" value="<%= m.membro_id %>" checked
          style="width:18px;height:18px;accent-color:var(--cor-primaria)">
        <div>
          <div style="font-size:13px;font-weight:600"><%= m.nome %></div>
          <div style="font-size:11px;color:var(--texto2)"><%= m.presencas %> pres. · <%= m.total_atividades - m.presencas %> faltas · <%= pctE %>%</div>
        </div>
      </label>
      <% }) %>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn" onclick="fecharModal('modal-envio')">Cancelar</button>
      <button type="button" class="btn btn-primario" onclick="confirmarEnvio()">Enviar selecionados</button>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const turmaAtualId = <%= turmaAtual ? turmaAtual.id : 'null' %>;

function mostrarTab(tabId, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('ativo'));
  document.querySelectorAll('.freq-tab').forEach(t => t.classList.remove('ativo'));
  document.getElementById(tabId).classList.add('ativo');
  btn.classList.add('ativo');
}

function toggleAtividade(id) {
  const body = document.getElementById('body-' + id);
  const chevron = document.getElementById('chevron-' + id);
  const aberto = body.style.display !== 'none';
  body.style.display = aberto ? 'none' : 'block';
  chevron.style.transform = aberto ? '' : 'rotate(180deg)';
}

function marcarTodos(atividadeId, marcar) {
  const lista = document.getElementById('lista-' + atividadeId);
  lista.querySelectorAll('input[type=checkbox]').forEach(cb => {
    cb.checked = marcar;
    const item = document.getElementById('item-' + atividadeId + '-' + cb.value);
    if (item) item.classList.toggle('presente', marcar);
  });
  atualizarContagem(atividadeId);
}

function togglePresente(cb, atividadeId, membroId) {
  const item = document.getElementById('item-' + atividadeId + '-' + membroId);
  if (item) item.classList.toggle('presente', cb.checked);
  atualizarContagem(atividadeId);
}

function atualizarContagem(atividadeId) {
  const lista = document.getElementById('lista-' + atividadeId);
  const total = lista.querySelectorAll('input[type=checkbox]').length;
  const marcados = lista.querySelectorAll('input[type=checkbox]:checked').length;
  const span = document.getElementById('contagem-' + atividadeId);
  if (span) span.textContent = marcados + ' de ' + total + ' presentes';
}

// Adicionar todos os ligantes em massa
function selecionarTodosLigantes(val) {
  document.querySelectorAll('.check-add-todos').forEach(c => c.checked = val);
}

function adicionarTodosSelecionados() {
  const selecionados = Array.from(document.querySelectorAll('.check-add-todos:checked')).map(c => c.value);
  if (selecionados.length === 0) { alert('Selecione pelo menos um ligante.'); return; }

  const dataEntrada = new Date().toISOString().split('T')[0];
  let count = 0;

  const promessas = selecionados.map(id => {
    const form = new FormData();
    form.append('membro_id', id);
    form.append('data_entrada', dataEntrada);
    return fetch('/frequencia/turma/' + turmaAtualId + '/adicionar-membro', {
      method: 'POST', body: form, redirect: 'manual'
    }).then(() => count++);
  });

  Promise.all(promessas).then(() => {
    alert(count + ' ligante(s) adicionado(s) com sucesso!');
    location.reload();
  }).catch(() => {
    alert('Erro ao adicionar. Tente novamente.');
  });
}

// Envio de frequência
let turmaIdEnvio = null;
function abrirModalEnvio(id) { turmaIdEnvio = id; abrirModal('modal-envio'); }
function selecionarTodos(val) { document.querySelectorAll('.check-envio').forEach(c => c.checked = val); }
function confirmarEnvio() {
  const selecionados = Array.from(document.querySelectorAll('.check-envio:checked')).map(c => c.value);
  if (selecionados.length === 0) { alert('Selecione pelo menos um ligante!'); return; }
  fecharModal('modal-envio');
  const formData = new FormData();
  selecionados.forEach(id => formData.append('membros_ids', id));
  fetch('/frequencia/turma/' + turmaIdEnvio + '/enviar', { method: 'POST', body: formData })
    .then(r => r.json())
    .then(d => alert(d.msg || 'Enviado!'))
    .catch(() => alert('Erro ao enviar'));
}

async function verificarIntegridade(turmaId) {
  if (!turmaId) { alert('Selecione uma turma primeiro'); return; }
  const btn = event.target;
  btn.textContent = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg> Verificando...';
  btn.disabled = true;
  try {
    const resp = await fetch('/frequencia/integridade/' + turmaId);
    const data = await resp.json();
    let msg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Verificação de Integridade — Turma\n\n';
    if (data.totalProblemas === 0) {
      msg += '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Nenhum problema encontrado! Sistema íntegro.';
    } else {
      msg += data.totalProblemas + ' problema(s) encontrado(s):\n\n';
      data.problemas.forEach(p => {
        const icon = p.severidade === 'erro' ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
        msg += icon + ' ' + p.descricao + '\n';
      });
    }
    alert(msg);
  } catch(e) {
    alert('Erro ao verificar integridade: ' + e.message);
  }
  btn.textContent = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Verificar Integridade';
  btn.disabled = false;
}
</script>
</body>
</html>
