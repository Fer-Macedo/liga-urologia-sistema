<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cartas de Cobranca</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .stats-row { display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px; }
    .stat-box { background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:16px 18px;display:flex;align-items:center;gap:14px;position:relative;overflow:hidden; }
    .stat-box::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--cor-stat,var(--cor-primaria)); }
    .stat-icon { width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
    .stat-num { font-family:'Outfit',sans-serif;font-size:22px;font-weight:700;line-height:1;margin-bottom:2px; }
    .stat-lab { font-size:12px;color:var(--texto2);font-weight:600; }
    .table-card { background:var(--card);border:1px solid var(--borda);border-radius:14px;overflow:hidden; }
    .table-header { padding:14px 18px;border-bottom:1px solid var(--borda);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap; }
    .table-titulo { font-size:14px;font-weight:700;font-family:'Outfit',sans-serif; }
    table.tabela { width:100%;border-collapse:collapse; }
    table.tabela thead th { background:var(--fundo);padding:10px 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--texto2);text-align:left;border-bottom:1px solid var(--borda); }
    table.tabela tbody tr { border-bottom:1px solid var(--borda);transition:background .15s; }
    table.tabela tbody tr:last-child { border-bottom:none; }
    table.tabela tbody tr:hover { background:var(--fundo); }
    table.tabela tbody td { padding:12px 14px;font-size:13px;color:var(--texto);vertical-align:middle; }
    .pessoa-info { display:flex;align-items:center;gap:10px; }
    .avatar-sm { width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--cor-primaria),var(--cor-primaria)99);color:white;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
    .pessoa-nome { font-weight:600;font-size:13px; }
    .pessoa-email { font-size:11px;color:var(--texto2);margin-top:1px; }
    .badge-status { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700; }
    .badge-enviado { background:#dbeafe;color:#1e40af; }
    .badge-pendente { background:#fef3c7;color:#92400e; }
    .btn-xs { display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:7px;font-size:11px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);cursor:pointer;text-decoration:none;transition:all .15s;font-family:inherit;white-space:nowrap; }
    .btn-xs:hover { border-color:var(--cor-primaria);color:var(--cor-primaria); }
    .btn-xs.roxo { background:#6366f1;color:white;border-color:transparent; }
    .btn-xs.verde { background:#059669;color:white;border-color:transparent; }
    .btn-xs.amarelo { background:#f59e0b;color:white;border-color:transparent; }
    .btn-xs.verm { color:#dc2626;border-color:#fecaca; }
    .btn-xs.verm:hover { background:#fee2e2; }
    .search-bar { display:flex;align-items:center;gap:8px;background:var(--fundo);border:1px solid var(--borda);border-radius:8px;padding:0 12px;height:34px; }
    .search-bar input { border:none;background:transparent;font-size:13px;color:var(--texto);outline:none;width:160px;font-family:inherit; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'cobrancas' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Cartas de Cobranca</h1>
      <div class="topbar-acoes">
        <a href="/cobrancas" class="btn btn-sm">Voltar</a>
        <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-nova')">+ Nova Carta</button>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>
      <% const total=cartas.length; const enviadas=cartas.filter(c=>c.status==='enviado').length; const pendentes=total-enviadas; %>
      <div class="stats-row">
        <div class="stat-box" style="--cor-stat:var(--cor-primaria)">
          <div class="stat-icon" style="background:#eff6ff"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a56db" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
          <div><div class="stat-num" style="color:var(--cor-primaria)"><%= total %></div><div class="stat-lab">Total de cartas</div></div>
        </div>
        <div class="stat-box" style="--cor-stat:#1d4ed8">
          <div class="stat-icon" style="background:#dbeafe"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <div><div class="stat-num" style="color:#1d4ed8"><%= enviadas %></div><div class="stat-lab">Enviadas</div></div>
        </div>
        <div class="stat-box" style="--cor-stat:#f59e0b">
          <div class="stat-icon" style="background:#fffbeb"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><div class="stat-num" style="color:#f59e0b"><%= pendentes %></div><div class="stat-lab">Pendentes</div></div>
        </div>
      </div>
      <div class="table-card">
        <div class="table-header">
          <span class="table-titulo">Todas as cartas (<%= total %>)</span>
          <div class="search-bar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--texto2)"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
            <input type="text" placeholder="Buscar pessoa..." oninput="filtrar(this.value)">
          </div>
        </div>
        <table class="tabela">
          <thead><tr><th>Destinatario</th><th>Mes Ref.</th><th>Vencimento</th><th>Status</th><th>Enviado em</th><th>Acoes</th></tr></thead>
          <tbody>
            <% if (!cartas.length) { %>
            <tr><td colspan="6" style="text-align:center;padding:48px;color:var(--texto2)">
              <div style="font-size:32px;margin-bottom:12px">📄</div>
              <div style="font-weight:600;margin-bottom:4px">Nenhuma carta criada</div>
              <div style="font-size:12px">Clique em Nova Carta para comecar</div>
            </td></tr>
            <% } %>
            <% cartas.forEach(d => { %>
            <tr class="carta-row">
              <td>
                <div class="pessoa-info">
                  <div class="avatar-sm"><%= (d.pessoa_nome||'?').substring(0,2).toUpperCase() %></div>
                  <div>
                    <div class="pessoa-nome"><%= d.pessoa_nome || '—' %></div>
                    <div class="pessoa-email"><%= d.pessoa_email || '—' %></div>
                  </div>
                </div>
              </td>
              <td style="color:var(--texto2)"><%= d.mes_referencia || '—' %></td>
              <td style="color:var(--texto2);white-space:nowrap"><%= d.vencimento ? new Date(d.vencimento).toLocaleDateString('pt-BR') : '—' %></td>
              <td>
                <% if (d.status === 'enviado') { %>
                <span class="badge-status badge-enviado">Enviada</span>
                <% } else { %>
                <span class="badge-status badge-pendente">Pendente</span>
                <% } %>
              </td>
              <td style="color:var(--texto2);font-size:12px"><%= d.enviado_em ? new Date(d.enviado_em).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'}) : '—' %></td>
              <td>
                <div style="display:flex;gap:5px;flex-wrap:wrap">
                  <a href="/carta-cobranca/<%= d.id %>/visualizar" target="_blank" class="btn-xs">Ver</a>
                  <a href="/carta-cobranca/<%= d.id %>/imprimir" target="_blank" class="btn-xs roxo">Imprimir</a>
                  <% if (d.status !== 'enviado') { %>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/enviar" style="display:inline;margin:0"><button type="submit" class="btn-xs verde">Enviar</button></form>
                  <% } else { %>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/reenviar" style="display:inline;margin:0"><button type="submit" class="btn-xs amarelo">Reenviar</button></form>
                  <% } %>
                  <% if (usuario.perfil === 'admin' || usuario.perfil === 'presidencia' || usuario.perfil === 'financeiro') { %>
                  <form method="POST" action="/carta-cobranca/<%= d.id %>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')"><button type="submit" class="btn-xs verm">Excluir</button></form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<div class="modal-overlay" id="modal-nova" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Nova Carta de Cobranca</span>
      <button class="icon-btn" onclick="fecharModal('modal-nova')">✕</button>
    </div>
    <form action="/carta-cobranca" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Tipo de destinatario</label>
          <select id="tipo-dest" class="input" onchange="trocarTipo(this.value)"><option value="membro">Membro</option><option value="ligante">Ligante</option></select>
        </div>
        <div class="campo" id="campo-membro">
          <label class="label">Membro *</label>
          <select name="membro_id" class="input"><option value="">Selecione...</option><% membros.forEach(m => { %><option value="<%= m.id %>"><%= m.nome %></option><% }) %></select>
        </div>
        <div class="campo" id="campo-ligante" style="display:none">
          <label class="label">Ligante *</label>
          <select name="ligante_id" class="input"><option value="">Selecione...</option><% ligantes.forEach(l => { %><option value="<%= l.id %>"><%= l.nome %></option><% }) %></select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="campo"><label class="label">Mes de referencia</label><input type="text" name="mes_referencia" class="input" placeholder="Maio 2026" required></div>
          <div class="campo"><label class="label">Data de vencimento</label><input type="date" name="vencimento" class="input"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-nova')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Criar carta</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/app.js"></script>
<script>
function trocarTipo(t){document.getElementById('campo-membro').style.display=t==='membro'?'':'none';document.getElementById('campo-ligante').style.display=t==='ligante'?'':'none';}
function filtrar(q){document.querySelectorAll('.carta-row').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});}
</script>
</body>
</html>
