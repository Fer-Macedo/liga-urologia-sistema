<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marketing</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%= config.org_cor||'#1a56db' %>;}
    .mkt-tabs{display:flex;gap:6px;margin-bottom:20px;flex-wrap:wrap;background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:6px;}
    .mkt-tab{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;border:none;background:transparent;cursor:pointer;font-weight:600;font-size:13px;transition:all .2s;color:var(--texto2);font-family:inherit;}
    .mkt-tab:hover{background:var(--fundo);color:var(--texto);}
    .mkt-tab.ativo{background:var(--cor-primaria);color:white;}
    .mkt-section{display:none;}
    .mkt-section.ativo{display:block;}
    .stats-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px;}
    .stat-box{background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:16px;position:relative;overflow:hidden;}
    .stat-box::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--cor-stat,var(--cor-primaria));}
    .stat-num{font-size:24px;font-weight:700;line-height:1;margin-bottom:4px;color:var(--cor-stat,var(--cor-primaria));}
    .stat-lab{font-size:12px;color:var(--texto2);font-weight:600;}
    .post-card{background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:16px;margin-bottom:10px;transition:box-shadow .15s;}
    .post-card:hover{box-shadow:0 2px 12px rgba(0,0,0,.06);}
    .rede-badge{padding:3px 8px;border-radius:999px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;gap:4px;}
    .rede-instagram{background:#e1306c;color:white;}
    .rede-facebook{background:#1877f2;color:white;}
    .rede-whatsapp{background:#25d366;color:white;}
    .badge-status{display:inline-flex;align-items:center;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
    .status-rascunho{background:#f3f4f6;color:#6b7280;}
    .status-agendado{background:#dbeafe;color:#1e40af;}
    .status-publicado{background:#dcfce7;color:#166534;}
    .status-erro{background:#fee2e2;color:#991b1b;}
    .calendario-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
    .cal-header{text-align:center;font-weight:700;font-size:11px;padding:6px;color:var(--texto2);text-transform:uppercase;}
    .cal-dia{min-height:72px;background:var(--card);border:1px solid var(--borda);border-radius:8px;padding:6px;transition:.15s;}
    .cal-dia.hoje{border-color:var(--cor-primaria);background:#eff6ff;}
    .cal-dia.outro-mes{opacity:.35;}
    .cal-num{font-size:12px;font-weight:700;margin-bottom:3px;}
    .cal-post{background:var(--cor-primaria);color:white;border-radius:4px;padding:2px 5px;font-size:10px;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;}
    .midia-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;}
    .midia-card{border:1px solid var(--borda);border-radius:10px;overflow:hidden;position:relative;cursor:pointer;transition:.15s;}
    .midia-card:hover{border-color:var(--cor-primaria);transform:translateY(-2px);}
    .midia-card img{width:100%;height:120px;object-fit:cover;display:block;}
    .midia-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);opacity:0;transition:.2s;display:flex;align-items:center;justify-content:center;gap:8px;}
    .midia-card:hover .midia-overlay{opacity:1;}
    .midia-card-info{padding:6px 8px;font-size:11px;font-weight:600;}
    .integ-card{background:var(--card);border:1px solid var(--borda);border-radius:14px;padding:20px;}
    .integ-logo{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .badge-conectado{background:#dcfce7;color:#166534;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
    .badge-desconectado{background:#fee2e2;color:#991b1b;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
    .whatsapp-preview{background:#e5ddd5;border-radius:12px;padding:16px;min-height:200px;}
    .wpp-bubble{background:white;border-radius:12px;padding:10px 14px;margin-bottom:8px;box-shadow:0 1px 2px rgba(0,0,0,.1);font-size:13px;max-width:85%;}
    .wpp-bubble.saida{background:#d9fdd3;margin-left:auto;}
    .engaj-bar{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .engaj-label{width:90px;font-size:12px;color:var(--texto2);font-weight:600;}
    .engaj-fill{flex:1;background:var(--fundo);border-radius:4px;height:8px;overflow:hidden;border:1px solid var(--borda);}
    .engaj-valor{width:36px;font-size:12px;font-weight:700;text-align:right;}
    .btn-xs{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:7px;font-size:11px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);cursor:pointer;text-decoration:none;transition:all .15s;font-family:inherit;white-space:nowrap;}
    .btn-xs:hover{border-color:var(--cor-primaria);color:var(--cor-primaria);}
    .btn-xs.verde{background:#059669;color:white;border-color:transparent;}
    .btn-xs.roxo{background:#7c3aed;color:white;border-color:transparent;}
    .btn-xs.verm{color:#dc2626;border-color:#fecaca;}
    .btn-xs.azul{background:#1d4ed8;color:white;border-color:transparent;}
    .ia-loading{display:none;align-items:center;gap:8px;font-size:13px;color:var(--texto2);padding:8px;}
    .ia-loading.ativo{display:flex;}
    .dots span{animation:dots 1.2s infinite;opacity:0;}
    .dots span:nth-child(2){animation-delay:.2s;}
    .dots span:nth-child(3){animation-delay:.4s;}
    @keyframes dots{0%,80%,100%{opacity:0}40%{opacity:1}}
    .template-btn{display:block;width:100%;text-align:left;padding:10px 14px;border:1px solid var(--borda);border-radius:8px;background:var(--fundo);cursor:pointer;font-size:12px;margin-bottom:6px;transition:.15s;font-family:inherit;}
    .template-btn:hover{border-color:var(--cor-primaria);background:#eff6ff;color:var(--cor-primaria);}
    .search-bar{display:flex;align-items:center;gap:8px;background:var(--fundo);border:1px solid var(--borda);border-radius:8px;padding:0 12px;height:36px;}
    .search-bar input{border:none;background:transparent;font-size:13px;color:var(--texto);outline:none;width:180px;font-family:inherit;}
    .filter-pills{display:flex;gap:6px;flex-wrap:wrap;}
    .pill{padding:5px 14px;border-radius:999px;border:1.5px solid var(--borda);background:var(--card);font-size:12px;font-weight:600;cursor:pointer;transition:.15s;color:var(--texto2);}
    .pill.ativo{background:var(--cor-primaria);color:white;border-color:var(--cor-primaria);}
    .score-wrap{background:var(--fundo);border:1px solid var(--borda);border-radius:10px;padding:12px 14px;margin-top:8px;}
    .score-bar-wrap{height:8px;border-radius:4px;background:#e5e7eb;overflow:hidden;margin:6px 0;}
    .score-bar-fill{height:100%;border-radius:4px;transition:width .4s;}
    .score-label{font-size:11px;font-weight:700;display:flex;justify-content:space-between;}
    .hashtag-grid{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;}
    .hashtag-chip{padding:3px 10px;border-radius:999px;background:#eff6ff;color:var(--cor-primaria);font-size:11px;font-weight:600;cursor:pointer;border:1.5px solid #bfdbfe;transition:.15s;}
    .hashtag-chip:hover{background:var(--cor-primaria);color:white;border-color:var(--cor-primaria);}
    .hashtag-chip.selecionado{background:var(--cor-primaria);color:white;border-color:var(--cor-primaria);}
    .horario-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-top:8px;}
    .horario-dia{text-align:center;font-size:10px;}
    .horario-dia-nome{font-weight:700;color:var(--texto2);margin-bottom:4px;}
    .horario-slot{padding:3px 2px;border-radius:4px;font-size:9px;font-weight:600;text-align:center;margin-bottom:2px;}
    .slot-bom{background:#dcfce7;color:#166534;}
    .slot-otimo{background:#059669;color:white;}
    .slot-fraco{background:#f3f4f6;color:#9ca3af;}
    .aprovacao-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
    .aprovacao-pendente{background:#fef3c7;color:#92400e;}
    .aprovacao-aprovado{background:#dcfce7;color:#166534;}
    .aprovacao-rejeitado{background:#fee2e2;color:#991b1b;}
    .historico-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--borda);}
    .historico-item:last-child{border-bottom:none;}
    .preview-social{border:1px solid var(--borda);border-radius:12px;overflow:hidden;background:white;}
    .preview-social-header{padding:10px 12px;display:flex;align-items:center;gap:8px;border-bottom:1px solid #f0f0f0;}
    .preview-social-img{width:36px;height:36px;border-radius:50%;background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);}
    .preview-social-body{padding:10px 12px;font-size:13px;line-height:1.5;}
    .preview-social-footer{padding:6px 12px;font-size:11px;color:#9ca3af;border-top:1px solid #f0f0f0;display:flex;gap:12px;}
    .campanha-step{display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--borda);border-radius:8px;margin-bottom:8px;}
    .campanha-step-num{width:28px;height:28px;border-radius:50%;background:var(--cor-primaria);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;}
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'marketing' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Marketing</h1>
      <div class="topbar-acoes">
        <button class="btn btn-sm" onclick="abrirModal('modal-wpp-massa')">WhatsApp em Massa</button>
        <button class="btn btn-sm btn-primario" onclick="abrirModal('modal-novo-post')">+ Novo Post</button>
      </div>
    </div>
    <div class="content">
      <%if(msg&&msg.length>0){%><div class="alerta alerta-ok"><%=msg[0]%></div><%}%>
      <%if(erro&&erro.length>0){%><div class="alerta alerta-erro"><%=erro[0]%></div><%}%>
      <div class="mkt-tabs">
        <button class="mkt-tab ativo" onclick="showTab('dashboard',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard</button>
        <button class="mkt-tab" onclick="showTab('posts',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Posts</button>
        <button class="mkt-tab" onclick="showTab('calendario',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Calendario</button>
        <button class="mkt-tab" onclick="showTab('midias',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Midias</button>
        <button class="mkt-tab" onclick="showTab('whatsapp',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          WhatsApp</button>
        <button class="mkt-tab" onclick="showTab('integracao',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/></svg>
          Integracoes</button>
        <button class="mkt-tab" onclick="showTab('aprovacao',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Aprovacoes</button>
        <button class="mkt-tab" onclick="showTab('campanha',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Campanhas</button>
        <button class="mkt-tab" onclick="showTab('templates',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          Templates</button>
        <button class="mkt-tab" onclick="showTab('historico',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Historico</button>
        <button class="mkt-tab" onclick="showTab('analytics',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Analytics</button>
      </div>
      <div id="mkt-content">
      <div class="mkt-section ativo" id="tab-dashboard">
        <%const total=posts.length;const agend=posts.filter(p=>p.status==='agendado').length;
        const pub=posts.filter(p=>p.status==='publicado').length;
        const rasc=posts.filter(p=>p.status==='rascunho').length;%>
        <div class="stats-row">
          <div class="stat-box" style="--cor-stat:var(--cor-primaria)">
            <div class="stat-num"><%=total%></div><div class="stat-lab">Total de Posts</div>
          </div>
          <div class="stat-box" style="--cor-stat:#f59e0b">
            <div class="stat-num"><%=agend%></div><div class="stat-lab">Agendados</div>
          </div>
          <div class="stat-box" style="--cor-stat:#10b981">
            <div class="stat-num"><%=pub%></div><div class="stat-lab">Publicados</div>
          </div>
          <div class="stat-box" style="--cor-stat:#6b7280">
            <div class="stat-num"><%=rasc%></div><div class="stat-lab">Rascunhos</div>
          </div>
          <div class="stat-box" style="--cor-stat:#0891b2">
            <div class="stat-num"><%=midias.length%></div><div class="stat-lab">Midias</div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Proximos Posts Agendados</div>
            <%const prox=posts.filter(p=>p.status==='agendado').slice(0,5);%>
            <%if(prox.length===0){%>
            <p style="color:var(--texto2);font-size:13px">Nenhum post agendado</p>
            <%}%>
            <%prox.forEach(p=>{%>
            <div class="post-card" style="padding:10px;margin-bottom:8px">
              <div style="font-weight:600;font-size:13px"><%=p.titulo%></div>
              <div style="font-size:11px;color:var(--texto2);margin-top:3px">
                <%=p.agendado_para?new Date(p.agendado_para).toLocaleString('pt-BR'):'&#8212;'%>
              </div>
              <div style="margin-top:6px;display:flex;gap:4px">
                <%(p.redes||[]).forEach(r=>{%>
                <span class="rede-badge rede-<%=r%>"><%=r%></span>
                <%});%>
              </div>
            </div>
            <%});%>
          </div>
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Distribuicao por Rede</div>
            <div class="engaj-bar">
              <div class="engaj-label">Instagram</div>
              <div class="engaj-fill"><div style="height:100%;background:#e1306c;width:<%=igPct%>%"></div></div>
              <div class="engaj-valor" style="color:#e1306c"><%=posts.filter(p=>(p.redes||[]).includes('instagram')).length%></div>
            </div>
            <div class="engaj-bar">
              <div class="engaj-label">Facebook</div>
              <div class="engaj-fill"><div style="height:100%;background:#1877f2;width:<%=fbPct%>%"></div></div>
              <div class="engaj-valor" style="color:#1877f2"><%=posts.filter(p=>(p.redes||[]).includes('facebook')).length%></div>
            </div>
            <div class="engaj-bar">
              <div class="engaj-label">WhatsApp</div>
              <div class="engaj-fill"><div style="height:100%;background:#25d366;width:<%=waPct%>%"></div></div>
              <div class="engaj-valor" style="color:#25d366"><%=posts.filter(p=>(p.redes||[]).includes('whatsapp')).length%></div>
            </div>
          </div>
        </div>
        <div class="card" style="margin-top:16px">
          <div class="card-titulo" style="margin-bottom:14px">Melhores Horarios para Postar</div>
          <div style="font-size:12px;color:var(--texto2);margin-bottom:10px">Baseado em dados do setor de saude e educacao no Brasil</div>
          <div class="horario-grid">
            <div class="horario-dia"><div class="horario-dia-nome">Dom</div><div class="horario-slot slot-fraco">8h</div><div class="horario-slot slot-fraco">12h</div><div class="horario-slot slot-bom">18h</div><div class="horario-slot slot-fraco">21h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Seg</div><div class="horario-slot slot-bom">8h</div><div class="horario-slot slot-otimo">12h</div><div class="horario-slot slot-bom">18h</div><div class="horario-slot slot-bom">20h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Ter</div><div class="horario-slot slot-bom">8h</div><div class="horario-slot slot-otimo">12h</div><div class="horario-slot slot-otimo">18h</div><div class="horario-slot slot-bom">20h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Qua</div><div class="horario-slot slot-otimo">8h</div><div class="horario-slot slot-otimo">12h</div><div class="horario-slot slot-otimo">18h</div><div class="horario-slot slot-bom">20h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Qui</div><div class="horario-slot slot-bom">8h</div><div class="horario-slot slot-otimo">12h</div><div class="horario-slot slot-bom">18h</div><div class="horario-slot slot-bom">20h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Sex</div><div class="horario-slot slot-bom">8h</div><div class="horario-slot slot-bom">12h</div><div class="horario-slot slot-fraco">18h</div><div class="horario-slot slot-fraco">20h</div></div>
            <div class="horario-dia"><div class="horario-dia-nome">Sab</div><div class="horario-slot slot-fraco">10h</div><div class="horario-slot slot-bom">12h</div><div class="horario-slot slot-bom">16h</div><div class="horario-slot slot-fraco">20h</div></div>
          </div>

        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:16px">
          <div class="filter-pills">
            <span class="pill ativo" onclick="filtrarPosts('todos',this)">Todos (<%=total%>)</span>
            <span class="pill" onclick="filtrarPosts('rascunho',this)">Rascunhos</span>
            <span class="pill" onclick="filtrarPosts('agendado',this)">Agendados</span>
            <span class="pill" onclick="filtrarPosts('publicado',this)">Publicados</span>
          </div>
          <div class="search-bar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--texto2)"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
            <input type="text" placeholder="Buscar post..." oninput="buscarPost(this.value)">
          </div>
        </div>
        <%if(posts.length===0){%>
        <div style="text-align:center;padding:48px;color:var(--texto2)">
          <div style="font-size:32px;margin-bottom:12px">&#128221;</div>
          <div style="font-weight:600">Nenhum post criado ainda</div>
        </div><%}%>
        <%posts.forEach(p=>{%>
        <div class="post-card post-item" data-status="<%=p.status%>" data-titulo="<%=(p.titulo||'').toLowerCase()%>">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
            <div style="display:flex;align-items:center;gap:12px;flex:1">
              <%if(p.imagem_chave){%>
              <img src="/marketing/midia/<%=p.id%>/img" style="width:52px;height:52px;border-radius:8px;object-fit:cover;flex-shrink:0">
              <%}else{%>
              <div style="width:52px;height:52px;border-radius:8px;background:var(--fundo);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--borda)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--texto2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div><%}%>
              <div style="flex:1;min-width:0">
                <div style="font-weight:700;font-size:14px;margin-bottom:3px"><%=p.titulo||'(Sem titulo)'%></div>
                <div style="font-size:12px;color:var(--texto2)"><%=(p.conteudo||'').substring(0,100)%><%=(p.conteudo||'').length>100?'...':''%></div>
              </div>
            </div>
            <span class="badge-status status-<%=p.status%>"><%=p.status%></span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;flex-wrap:wrap;gap:8px">
            <div style="display:flex;gap:4px;flex-wrap:wrap">
              <%(p.redes||[]).forEach(r=>{%>
              <span class="rede-badge rede-<%=r%>"><%=r%></span>
              <%});%>
              <%if(p.agendado_para){%>
              <span style="font-size:11px;color:var(--texto2);margin-left:6px">
                <%=new Date(p.agendado_para).toLocaleString('pt-BR')%>
              </span><%}%>
            </div>
            <div style="display:flex;gap:5px">
              <button onclick="editarPost(<%=p.id%>)" class="btn-xs">Editar</button>
              <%if(p.status==='rascunho'||p.status==='agendado'){%>
              <form method="POST" action="/marketing/<%=p.id%>/publicar" style="display:inline;margin:0">
                <button type="submit" class="btn-xs verde">Publicar</button></form>
              <%}%>
              <form method="POST" action="/marketing/<%=p.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button></form>
            </div>
          </div>
        </div>
        <%});%>
      </div>
      <div class="mkt-section" id="tab-posts">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:16px">
          <div class="filter-pills">
            <span class="pill ativo" onclick="filtrarPosts('todos',this)">Todos (<%=posts.length%>)</span>
            <span class="pill" onclick="filtrarPosts('rascunho',this)">Rascunhos</span>
            <span class="pill" onclick="filtrarPosts('agendado',this)">Agendados</span>
            <span class="pill" onclick="filtrarPosts('publicado',this)">Publicados</span>
          </div>
          <div class="search-bar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--texto2)"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
            <input type="text" placeholder="Buscar post..." oninput="buscarPost(this.value)">
          </div>
        </div>
        <%if(posts.length===0){%>
        <div style="text-align:center;padding:48px;color:var(--texto2)">
          <div style="font-size:32px;margin-bottom:12px">&#128221;</div>
          <div style="font-weight:600">Nenhum post criado ainda</div>
        </div><%}%>
        <%posts.forEach(p=>{%>
        <div class="post-card post-item" data-status="<%=p.status%>" data-titulo="<%=(p.titulo||'').toLowerCase()%>">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
            <div style="display:flex;align-items:center;gap:12px;flex:1">
              <%if(p.imagem_chave){%>
              <img src="/marketing/midia/<%=p.id%>/img" style="width:52px;height:52px;border-radius:8px;object-fit:cover;flex-shrink:0">
              <%}else{%>
              <div style="width:52px;height:52px;border-radius:8px;background:var(--fundo);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid var(--borda)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--texto2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              </div><%}%>
              <div style="flex:1;min-width:0">
                <div style="font-weight:700;font-size:14px;margin-bottom:3px"><%=p.titulo||'(Sem titulo)'%></div>
                <div style="font-size:12px;color:var(--texto2)"><%=(p.conteudo||'').substring(0,100)%><%=(p.conteudo||'').length>100?'...':''%></div>
              </div>
            </div>
            <span class="badge-status status-<%=p.status%>"><%=p.status%></span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;flex-wrap:wrap;gap:8px">
            <div style="display:flex;gap:4px;flex-wrap:wrap">
              <%(p.redes||[]).forEach(r=>{%><span class="rede-badge rede-<%=r%>"><%=r%></span><%});%>
              <%if(p.agendado_para){%><span style="font-size:11px;color:var(--texto2);margin-left:6px"><%=new Date(p.agendado_para).toLocaleString('pt-BR')%></span><%}%>
            </div>
            <div style="display:flex;gap:5px">
              <button onclick="editarPost(<%=p.id%>)" class="btn-xs">Editar</button>
              <%if(p.status==='rascunho'||p.status==='agendado'){%>
              <form method="POST" action="/marketing/<%=p.id%>/publicar" style="display:inline;margin:0"><button type="submit" class="btn-xs verde">Publicar</button></form>
              <%}%>
              <form method="POST" action="/marketing/<%=p.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button></form>
            </div>
          </div>
        </div>
        <%});%>
      </div>
      <div class="mkt-section" id="tab-calendario">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
          <button class="btn btn-sm" onclick="mudarMes(-1)">&#8592; Anterior</button>
          <h3 id="cal-titulo" style="font-size:16px;font-weight:700;font-family:'Outfit',sans-serif"></h3>
          <button class="btn btn-sm" onclick="mudarMes(1)">Proximo &#8594;</button>
        </div>
        <div class="calendario-grid">
          <div class="cal-header">Dom</div><div class="cal-header">Seg</div><div class="cal-header">Ter</div>
          <div class="cal-header">Qua</div><div class="cal-header">Qui</div><div class="cal-header">Sex</div><div class="cal-header">Sab</div>
        </div>
        <div class="calendario-grid" id="cal-grid" style="margin-top:4px"></div>
      </div>
      <div class="mkt-section" id="tab-midias">
        <div style="margin-bottom:16px">
          <form action="/marketing/midias/upload" method="POST" enctype="multipart/form-data" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <input type="file" name="midia" class="input" accept="image/*,video/*" style="flex:1;min-width:200px">
            <input type="text" name="nome" class="input" placeholder="Nome da midia" style="flex:1;min-width:150px">
            <button type="submit" class="btn btn-primario btn-sm">Upload</button>
          </form>
        </div>
        <%if(midias.length===0){%><div style="text-align:center;padding:48px;color:var(--texto2)"><div style="font-size:32px;margin-bottom:8px">&#128444;</div><div style="font-weight:600">Nenhuma midia enviada</div></div><%}%>
        <div class="midia-grid">
          <%midias.forEach(m=>{%>
          <div class="midia-card">
            <img src="/marketing/midias/<%=m.id%>/img" alt="<%=m.nome%>" onerror="this.src='/img/placeholder.png'">
            <div class="midia-overlay">
              <button onclick="usarMidia('<%=m.id%>','<%=m.nome%>')" class="btn-xs" style="background:white;color:#111">Usar</button>
              <form method="POST" action="/marketing/midias/<%=m.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm" style="background:#dc2626;color:white;border-color:transparent">Excluir</button></form>
            </div>
            <div class="midia-card-info"><%=m.nome%></div>
          </div>
          <%});%>
        </div>
      </div>
      <div class="mkt-section" id="tab-whatsapp">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Envio em Massa</div>
            <form action="/marketing/whatsapp-massa" method="POST">
              <div style="display:flex;flex-direction:column;gap:12px">
                <div class="campo"><label class="label">Destinatarios</label>
                  <select name="destinatarios" class="input">
                    <option value="todos">Todos (Ligantes + Diretivos)</option>
                    <option value="ligantes">Somente Ligantes</option>
                    <option value="diretivos">Somente Diretivos</option>
                  </select>
                </div>
                <div class="campo"><label class="label">Mensagem</label>
                  <textarea name="mensagem" class="input" rows="5" placeholder="Digite a mensagem..." oninput="previewWpp(this.value)"></textarea>
                </div>
                <button type="submit" class="btn btn-primario" onclick="return confirm('Enviar para todos?')">Enviar Agora</button>
              </div>
            </form>
          </div>
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Preview</div>
            <div class="whatsapp-preview">
              <div class="wpp-bubble">Ola! Como vai?</div>
              <div class="wpp-bubble saida" id="wpp-preview-text">Sua mensagem aparecera aqui...</div>
            </div>
          </div>
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Templates Rapidos</div>
            <button class="template-btn" onclick="usarTemplate(this)">Convite para evento da Liga — prezado ligante, convidamos voce para participar do nosso proximo evento...</button>
            <button class="template-btn" onclick="usarTemplate(this)">Lembrete de mensalidade — informamos que sua mensalidade esta em aberto. Realize o pagamento para continuar ativo...</button>
            <button class="template-btn" onclick="usarTemplate(this)">Aviso de reuniao — comunicamos que havera reuniao da diretoria na proxima semana. Sua presenca e importante...</button>
            <button class="template-btn" onclick="usarTemplate(this)">Boas-vindas ao novo ligante — seja bem-vindo a Liga! Estamos felizes em ter voce conosco...</button>
          </div>
        </div>
      </div>
      <div class="mkt-section" id="tab-integracao">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
          <div class="integ-card">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
              <div class="integ-logo" style="background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4" fill="none" stroke="white" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="white"/></svg>
              </div>
              <div><div style="font-weight:700">Instagram</div><div style="font-size:12px;color:var(--texto2)">Meta Graph API</div></div>
              <%if(mktConfig.instagram_token){%><span class="badge-conectado" style="margin-left:auto">Conectado</span><%}else{%><span class="badge-desconectado" style="margin-left:auto">Desconectado</span><%}%>
            </div>
            <form action="/marketing/config/instagram" method="POST">
              <div class="campo"><label class="label">Access Token</label><input name="instagram_token" class="input" type="password" placeholder="Token da API Meta" value="<%=mktConfig.instagram_token||''%>"></div>
              <div class="campo"><label class="label">Instagram Business ID</label><input name="instagram_id" class="input" placeholder="ID da conta business" value="<%=mktConfig.instagram_id||''%>"></div>
              <button type="submit" class="btn btn-primario" style="width:100%;margin-top:8px">Salvar</button>
            </form>
          </div>
          <div class="integ-card">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
              <div class="integ-logo" style="background:#1877f2">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </div>
              <div><div style="font-weight:700">Facebook</div><div style="font-size:12px;color:var(--texto2)">Meta Graph API</div></div>
              <%if(mktConfig.facebook_token){%><span class="badge-conectado" style="margin-left:auto">Conectado</span><%}else{%><span class="badge-desconectado" style="margin-left:auto">Desconectado</span><%}%>
            </div>
            <form action="/marketing/config/facebook" method="POST">
              <div class="campo"><label class="label">Page Access Token</label><input name="facebook_token" class="input" type="password" placeholder="Token da pagina" value="<%=mktConfig.facebook_token||''%>"></div>
              <div class="campo"><label class="label">Facebook Page ID</label><input name="facebook_id" class="input" placeholder="ID da pagina" value="<%=mktConfig.facebook_id||''%>"></div>
              <button type="submit" class="btn btn-primario" style="width:100%;margin-top:8px">Salvar</button>
            </form>
          </div>
          <div class="integ-card">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
              <div class="integ-logo" style="background:#25d366">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </div>
              <div><div style="font-weight:700">WhatsApp</div><div style="font-size:12px;color:var(--texto2)">W-API</div></div>
              <span class="badge-conectado" style="margin-left:auto">Conectado</span>
            </div>
            <p style="font-size:13px;color:var(--texto2)">Integracao W-API ja configurada. Pronta para envio em massa.</p>
          </div>
        </div>
      </div>
    </div>
      <div class="mkt-section" id="tab-aprovacao">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Posts Aguardando Aprovacao</div>
            <%const pendAprov=posts.filter(p=>p.status==='rascunho');%>
            <%if(pendAprov.length===0){%>
            <div style="text-align:center;padding:32px;color:var(--texto2)">Nenhum pendente</div>
            <%}%>
            <%pendAprov.forEach(p=>{%>
            <div class="post-card" style="padding:12px;margin-bottom:8px">
              <div style="font-weight:600;font-size:13px;margin-bottom:4px"><%=p.titulo||'(Sem titulo)'%></div>
              <div style="font-size:11px;color:var(--texto2);margin-bottom:8px"><%=(p.conteudo||'').substring(0,80)%>...</div>
              <div style="display:flex;gap:6px">
                <form method="POST" action="/marketing/<%=p.id%>/publicar" style="display:inline;margin:0">
                  <button type="submit" class="btn-xs verde">Aprovar</button></form>
                <form method="POST" action="/marketing/<%=p.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Reprovar?')">
                  <button type="submit" class="btn-xs verm">Reprovar</button></form>
              </div>
            </div>
            <%});%>
          </div>
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Melhores Horarios</div>
            <p style="font-size:12px;color:var(--texto2);margin-bottom:10px">Setor saude/educacao no Brasil</p>
            <div class="horario-grid">
              <%[['Dom',0],['Seg',1],['Ter',1],['Qua',1],['Qui',1],['Sex',1],['Sab',0]].forEach(([d,util])=>{%>
              <div class="horario-dia"><div class="horario-dia-nome"><%=d%></div>
                <div class="horario-slot <%=util?'alto':'baixo'%>">8h</div>
                <div class="horario-slot <%=util?'alto':'medio'%>">12h</div>
                <div class="horario-slot <%=util?'alto':'medio'%>">18h</div>
                <div class="horario-slot medio">21h</div>
              </div><%});%>
            </div>
            <div style="display:flex;gap:8px;margin-top:10px;font-size:11px">
              <span style="background:#dcfce7;color:#166534;padding:2px 8px;border-radius:4px;font-weight:600">Alto</span>
              <span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:4px;font-weight:600">Medio</span>
              <span style="background:#f3f4f6;color:#9ca3af;padding:2px 8px;border-radius:4px;font-weight:600">Baixo</span>
            </div>
          </div>
        </div>
      </div>
      <div class="mkt-section" id="tab-historico">
        <div class="card">
          <div class="card-titulo" style="margin-bottom:14px">Historico de Publicacoes</div>
          <%const pubList=posts.filter(p=>p.status==='publicado');%>
          <%if(pubList.length===0){%>
          <div style="text-align:center;padding:40px;color:var(--texto2)">Nenhuma publicacao ainda</div>
          <%}%>
          <%pubList.forEach(p=>{%>
          <div class="log-item">
            <div class="log-dot" style="background:#10b981"></div>
            <div style="flex:1">
              <div style="font-weight:600;font-size:13px"><%=p.titulo%></div>
              <div style="font-size:11px;color:var(--texto2)"><%=new Date(p.criado_em).toLocaleString('pt-BR')%></div>
            </div>
            <div style="display:flex;gap:4px"><%=(p.redes||[]).map(r=>'<span class="rede-badge rede-'+r+'">'+r+'</span>').join(' ')%></div>
          </div><%});%>
        </div>
      </div>
      <div class="mkt-section" id="tab-analytics">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
          <div class="card"><div class="card-titulo" style="margin-bottom:14px">Por Rede</div>
            <div style="display:flex;flex-direction:column;gap:10px">
              <div style="display:flex;justify-content:space-between;padding:10px;background:#fce7f3;border-radius:8px">
                <span style="font-weight:600;color:#9d174d">Instagram</span>
                <span style="font-weight:700;font-size:18px;color:#9d174d"><%=posts.filter(p=>(p.redes||[]).includes('instagram')).length%></span>
              </div>
              <div style="display:flex;justify-content:space-between;padding:10px;background:#dbeafe;border-radius:8px">
                <span style="font-weight:600;color:#1e40af">Facebook</span>
                <span style="font-weight:700;font-size:18px;color:#1e40af"><%=posts.filter(p=>(p.redes||[]).includes('facebook')).length%></span>
              </div>
              <div style="display:flex;justify-content:space-between;padding:10px;background:#dcfce7;border-radius:8px">
                <span style="font-weight:600;color:#166534">WhatsApp</span>
                <span style="font-weight:700;font-size:18px;color:#166534"><%=posts.filter(p=>(p.redes||[]).includes('whatsapp')).length%></span>
              </div>
            </div>
          </div>
          <div class="card"><div class="card-titulo" style="margin-bottom:14px">Resumo do Mes</div>
            <%const mesAtual=new Date().getMonth();const anoAtual=new Date().getFullYear();
            const postsMes=posts.filter(p=>{const d=new Date(p.criado_em);return d.getMonth()===mesAtual&&d.getFullYear()===anoAtual;});%>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
              <div style="background:var(--fundo);border-radius:8px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:700;color:var(--cor-primaria)"><%=postsMes.length%></div><div style="font-size:11px;color:var(--texto2)">Posts este mes</div></div>
              <div style="background:var(--fundo);border-radius:8px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:700;color:#10b981"><%=postsMes.filter(p=>p.status==='publicado').length%></div><div style="font-size:11px;color:var(--texto2)">Publicados</div></div>
              <div style="background:var(--fundo);border-radius:8px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:700;color:#f59e0b"><%=postsMes.filter(p=>p.status==='agendado').length%></div><div style="font-size:11px;color:var(--texto2)">Agendados</div></div>
              <div style="background:var(--fundo);border-radius:8px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:700;color:#0891b2"><%=midias.length%></div><div style="font-size:11px;color:var(--texto2)">Midias</div></div>
            </div>
          </div>
        </div>
        <div class="card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
            <div class="card-titulo">Relatorio Mensal</div>
            <button class="btn btn-sm btn-primario" onclick="gerarRelatorio()">Baixar CSV</button>
          </div>
          <p style="font-size:13px;color:var(--texto2)">Exporta todos os posts com status, redes e datas.</p>
        </div>
      </div>
    </div>
      <div class="mkt-section" id="tab-campanha">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:100%">
          <div class="card">
            <div class="card-titulo" style="margin-bottom:4px">Campanha Multicanal</div>
            <p style="font-size:12px;color:var(--texto2);margin-bottom:14px">Dispare para todas as redes com um unico clique</p>
            <form action="/marketing/posts" method="POST" enctype="multipart/form-data">
              <div style="display:flex;flex-direction:column;gap:12px">
                <div class="campo"><label class="label">Titulo *</label>
                  <input name="titulo" class="input" required placeholder="Ex: Semana Urologica 2026">
                </div>
                <div class="campo"><label class="label">Legenda *</label>
                  <textarea name="conteudo" class="input" rows="4" placeholder="Mensagem para todas as redes..."></textarea>
                </div>
                <div class="campo"><label class="label">Imagem</label>
                  <input type="file" name="imagem" class="input" accept="image/*">
                </div>
                <div class="campo"><label class="label">Canais</label>
                  <div style="display:flex;gap:14px;flex-wrap:wrap">
                    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
                      <input type="checkbox" name="redes" value="instagram" checked> Instagram
                    </label>
                    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
                      <input type="checkbox" name="redes" value="facebook" checked> Facebook
                    </label>
                    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
                      <input type="checkbox" name="redes" value="whatsapp" checked> WhatsApp
                    </label>
                  </div>
                </div>
                <button type="submit" name="acao" value="agendar" class="btn btn-primario"
                  onclick="return confirm('Disparar campanha para todas as redes?')">Disparar Campanha</button>
              </div>
            </form>
          </div>
          <div class="card">
            <div class="card-titulo" style="margin-bottom:14px">Como funciona</div>
            <div style="display:flex;flex-direction:column;gap:14px">
              <div style="display:flex;gap:12px;align-items:flex-start">
                <div style="width:28px;height:28px;border-radius:50%;background:var(--cor-primaria);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">1</div>
                <div><div style="font-weight:600;font-size:13px">Crie o conteudo</div>
                <div style="font-size:12px;color:var(--texto2)">Escreva a legenda e adicione imagem</div></div>
              </div>
              <div style="display:flex;gap:12px;align-items:flex-start">
                <div style="width:28px;height:28px;border-radius:50%;background:var(--cor-primaria);color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">2</div>
                <div><div style="font-weight:600;font-size:13px">Selecione os canais</div>
                <div style="font-size:12px;color:var(--texto2)">Instagram, Facebook e/ou WhatsApp</div></div>
              </div>
              <div style="display:flex;gap:12px;align-items:flex-start">
                <div style="width:28px;height:28px;border-radius:50%;background:#10b981;color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">3</div>
                <div><div style="font-weight:600;font-size:13px">Disparo automatico</div>
                <div style="font-size:12px;color:var(--texto2)">Sistema publica em todos os canais</div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="mkt-section" id="tab-templates">
        <div style="margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
          <div style="font-size:14px;font-weight:700">Templates Prontos</div>
          <span style="font-size:12px;color:var(--texto2)">Clique para usar como base no novo post</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
          <div class="post-card" style="cursor:pointer" onclick="usarTemplate2('Semana Urologica','Prezados ligantes, convidamos voce para a nossa Semana Urologica 2026! Um evento repleto de palestras, workshops e discussoes de casos clinicos. Sua presenca e fundamental! Data: a confirmar. #urologia #medicinaacademica #ligaurologia')">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <div style="width:36px;height:36px;border-radius:8px;background:#eff6ff;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
              <div><div style="font-weight:700;font-size:13px">Semana Urologica</div><div style="font-size:11px;color:var(--texto2)">Evento cientifico</div></div>
            </div>
            <p style="font-size:12px;color:var(--texto2);line-height:1.5">Convite para evento academico da liga com palestras e workshops.</p>
            <div style="margin-top:8px"><span class="rede-badge rede-instagram">instagram</span> <span class="rede-badge rede-facebook">facebook</span></div>
          </div>
          <div class="post-card" style="cursor:pointer" onclick="usarTemplate2('Boas-vindas Ligante','Sejam bem-vindos aos novos integrantes da Liga Academica de Urologia! Estamos muito felizes em ter voces conosco. Juntos vamos crescer, aprender e fazer historia na urologia academica. #ligaurologia #bemvindo #medicinaacademica')">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <div style="width:36px;height:36px;border-radius:8px;background:#f0fdf4;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
              <div><div style="font-weight:700;font-size:13px">Boas-vindas</div><div style="font-size:11px;color:var(--texto2)">Novos membros</div></div>
            </div>
            <p style="font-size:12px;color:var(--texto2);line-height:1.5">Mensagem de boas-vindas para novos integrantes da liga.</p>
            <div style="margin-top:8px"><span class="rede-badge rede-whatsapp">whatsapp</span> <span class="rede-badge rede-instagram">instagram</span></div>
          </div>
          <div class="post-card" style="cursor:pointer" onclick="usarTemplate2('Congresso de Urologia','A Liga Academica de Urologia estara presente no Congresso Brasileiro de Urologia! Venha nos encontrar e trocar experiencias. Um orgulho representar nossa liga neste grande evento. #CBU #urologia #congresso')">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <div style="width:36px;height:36px;border-radius:8px;background:#fdf4ff;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div><div style="font-weight:700;font-size:13px">Congresso</div><div style="font-size:11px;color:var(--texto2)">Representacao em evento</div></div>
            </div>
            <p style="font-size:12px;color:var(--texto2);line-height:1.5">Post sobre participacao em congresso nacional de urologia.</p>
            <div style="margin-top:8px"><span class="rede-badge rede-instagram">instagram</span> <span class="rede-badge rede-facebook">facebook</span></div>
          </div>
          <div class="post-card" style="cursor:pointer" onclick="usarTemplate2('Lembrete Mensalidade','Prezado ligante, lembramos que sua mensalidade esta em aberto. Para continuar ativo e aproveitando todos os beneficios da liga, realize o pagamento ate o fim do mes. Qualquer duvida, entre em contato conosco.')">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <div style="width:36px;height:36px;border-radius:8px;background:#fffbeb;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
              <div><div style="font-weight:700;font-size:13px">Lembrete</div><div style="font-size:11px;color:var(--texto2)">Cobranca mensalidade</div></div>
            </div>
            <p style="font-size:12px;color:var(--texto2);line-height:1.5">Mensagem de lembrete de mensalidade via WhatsApp.</p>
            <div style="margin-top:8px"><span class="rede-badge rede-whatsapp">whatsapp</span></div>
          </div>
          <div class="post-card" style="cursor:pointer" onclick="usarTemplate2('Divulgacao Pesquisa','Nossa liga esta desenvolvendo uma pesquisa cientifica na area de urologia! Seu apoio e fundamental para o avanco da medicina academica. Acompanhe nossas redes para novidades. #pesquisa #urologia #ciencia')">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <div style="width:36px;height:36px;border-radius:8px;background:#fff1f2;display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e11d48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
              <div><div style="font-weight:700;font-size:13px">Pesquisa</div><div style="font-size:11px;color:var(--texto2)">Divulgacao cientifica</div></div>
            </div>
            <p style="font-size:12px;color:var(--texto2);line-height:1.5">Post de divulgacao de pesquisa cientifica da liga.</p>
            <div style="margin-top:8px"><span class="rede-badge rede-instagram">instagram</span> <span class="rede-badge rede-facebook">facebook</span></div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </main>
</div>
<div class="modal-overlay" id="modal-novo-post" style="display:none">
  <div class="modal" style="max-width:600px">
    <div class="modal-header"><span class="modal-titulo">Novo Post</span><button class="icon-btn" onclick="fecharModal('modal-novo-post')">&#x2715;</button></div>
    <form action="/marketing/posts" method="POST" enctype="multipart/form-data">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo"><label class="label">Titulo</label><input name="titulo" class="input" placeholder="Titulo do post" required></div>
        <div class="campo">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
            <label class="label" style="margin:0">Conteudo / Legenda</label>
            <button type="button" class="btn-xs roxo" onclick="gerarComIA()">Gerar com IA</button>
          </div>
          <div class="ia-loading" id="ia-loading"><div class="dots"><span>.</span><span>.</span><span>.</span></div> IA gerando legenda...</div>
          <textarea name="conteudo" id="post-conteudo" class="input" rows="4" placeholder="Escreva a legenda do post..."></textarea>
        </div>
        <div class="campo"><label class="label">Imagem</label><input type="file" name="imagem" class="input" accept="image/*"></div>
        <div class="campo"><label class="label">Redes Sociais</label>
          <div style="display:flex;gap:16px;flex-wrap:wrap">
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px"><input type="checkbox" name="redes" value="instagram"> Instagram</label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px"><input type="checkbox" name="redes" value="facebook"> Facebook</label>
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px"><input type="checkbox" name="redes" value="whatsapp"> WhatsApp</label>
          </div>
        </div>
        <div class="campo"><label class="label">Agendar para (opcional)</label><input type="datetime-local" name="agendado_para" class="input" onchange="calcularMelhorHorario(this.value)"></div>
        <div class="campo">
          <label class="label">Hashtags (clique para adicionar)</label>
          <div class="ia-loading" id="hashtag-loading"><div class="dots"><span>.</span><span>.</span><span>.</span></div> Buscando hashtags...</div>
          <div class="hashtag-grid" id="hashtag-grid"></div>
          <input type="hidden" name="hashtags" id="hashtags-selecionadas">
          <button type="button" class="btn-xs roxo" style="margin-top:8px" onclick="gerarHashtags()">Sugerir hashtags com IA</button>
        </div>
        <div class="score-wrap" id="score-wrap">
          <div class="score-label"><span style="font-weight:700">Score do Post</span><span id="score-valor" style="color:var(--cor-primaria)">0/100</span></div>
          <div class="score-bar-wrap"><div class="score-bar-fill" id="score-bar" style="width:0%;background:#ef4444"></div></div>
          <div id="score-dicas" style="font-size:11px;color:var(--texto2);margin-top:6px"></div>
        </div>
      </div>
      <div class="campo">
        <label class="label">Preview</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <div style="font-size:11px;font-weight:700;color:#e1306c;margin-bottom:6px">Instagram</div>
            <div id="prev-ig" style="background:#fafafa;border:1px solid #dbdbdb;border-radius:10px;overflow:hidden;max-width:220px">
              <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-bottom:1px solid #efefef">
                <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366)"></div>
                <span style="font-size:12px;font-weight:700">liga_urologia</span>
              </div>
              <div id="prev-ig-img" style="width:100%;height:120px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px">Sem imagem</div>
              <div style="padding:8px 10px">
                <div style="font-size:11px;line-height:1.4" id="prev-ig-txt">Legenda aparece aqui...</div>
              </div>
            </div>
          </div>
          <div>
            <div style="font-size:11px;font-weight:700;color:#25d366;margin-bottom:6px">WhatsApp</div>
            <div style="background:#e5ddd5;border-radius:10px;padding:10px;min-height:120px">
              <div class="wpp-bubble saida" id="prev-wpp-txt" style="font-size:11px">Mensagem aparece aqui...</div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-novo-post')">Cancelar</button>
        <button type="submit" name="acao" value="rascunho" class="btn">Rascunho</button>
        <button type="submit" name="acao" value="agendar" class="btn btn-primario">Agendar</button>
      </div>
    </form>
  </div>
</div>
<div class="modal-overlay" id="modal-wpp-massa" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">WhatsApp em Massa</span><button class="icon-btn" onclick="fecharModal('modal-wpp-massa')">&#x2715;</button></div>
    <form action="/marketing/whatsapp-massa" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo"><label class="label">Destinatarios</label>
          <select name="destinatarios" class="input">
            <option value="todos">Todos (Ligantes + Diretivos)</option>
            <option value="ligantes">Somente Ligantes</option>
            <option value="diretivos">Somente Diretivos</option>
          </select>
        </div>
        <div class="campo"><label class="label">Mensagem</label>
          <textarea name="mensagem" class="input" rows="5" placeholder="Digite a mensagem..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-wpp-massa')">Cancelar</button>
        <button type="submit" class="btn btn-primario" onclick="return confirm('Enviar para todos?')">Enviar</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/app.js"></script>
<script>
const postsData=<%- JSON.stringify(posts) %>;
let calMes=new Date().getMonth(),calAno=new Date().getFullYear();
function showTab(id,btn){document.querySelectorAll('.mkt-section').forEach(s=>s.classList.remove('ativo'));document.querySelectorAll('.mkt-tab').forEach(t=>t.classList.remove('ativo'));const sec=document.getElementById('tab-'+id);if(sec)sec.classList.add('ativo');if(btn)btn.classList.add('ativo');else{const b=document.querySelector('[onclick*="showTab(\''+id+'\'"]');if(b)b.classList.add('ativo');}}
function filtrarPosts(status,el){document.querySelectorAll('.post-item').forEach(p=>{p.style.display=status==='todos'||p.dataset.status===status?'':' none';});document.querySelectorAll('.pill').forEach(p=>p.classList.remove('ativo'));el.classList.add('ativo');}
function buscarPost(q){document.querySelectorAll('.post-item').forEach(p=>{p.style.display=p.dataset.titulo.includes(q.toLowerCase())?'':' none';});}
function previewWpp(txt){document.getElementById('wpp-preview-text').textContent=txt||'Sua mensagem aqui...';}
function editarPost(id){window.location='/marketing/'+id+'/editar';}
function usarMidia(id,nome){alert('Midia "'+nome+'" selecionada!');}
function usarTemplate(btn){const ta=document.querySelector('[name="mensagem"]');if(ta){ta.value=btn.textContent.trim();previewWpp(ta.value);}}
function renderCal(){
  const meses=['Janeiro','Fevereiro','Marco','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  document.getElementById('cal-titulo').textContent=meses[calMes]+' '+calAno;
  const grid=document.getElementById('cal-grid');grid.innerHTML='';
  const primeiro=new Date(calAno,calMes,1).getDay();
  const dias=new Date(calAno,calMes+1,0).getDate();
  const hoje=new Date();
  for(let i=0;i<primeiro;i++){const d=document.createElement('div');d.className='cal-dia outro-mes';grid.appendChild(d);}
  for(let d=1;d<=dias;d++){
    const div=document.createElement('div');
    div.className='cal-dia'+(d===hoje.getDate()&&calMes===hoje.getMonth()&&calAno===hoje.getFullYear()?" hoje":"");
    div.innerHTML='<div class="cal-num">'+d+'</div>';
    const ds=calAno+'-'+(String(calMes+1).padStart(2,'0'))+'-'+(String(d).padStart(2,'0'));
    postsData.filter(p=>p.agendado_para&&p.agendado_para.startsWith(ds)).forEach(p=>{
      const s=document.createElement('div');s.className='cal-post';s.textContent=p.titulo||'Post';div.appendChild(s);
    });grid.appendChild(div);
  }
}
function mudarMes(d){calMes+=d;if(calMes<0){calMes=11;calAno--;}if(calMes>11){calMes=0;calAno++;}renderCal();}
renderCal();
const hashtagsSel=new Set();
function calcScore(){
  const titulo=document.querySelector('[name="titulo"]')?.value||'';
  const conteudo=document.getElementById('post-conteudo')?.value||'';
  const imagem=document.querySelector('[name="imagem"]')?.files?.length>0;
  const redes=document.querySelectorAll('[name="redes"]:checked').length;
  const agendado=document.querySelector('[name="agendado_para"]')?.value;
  let score=0;const itens=[];
  if(titulo.length>5){score+=20;itens.push({ok:true,txt:'Titulo preenchido'});}else{itens.push({ok:false,txt:'Adicione um titulo'});}
  if(conteudo.length>30){score+=20;itens.push({ok:true,txt:'Legenda boa'});}else{itens.push({ok:false,txt:'Escreva uma legenda'});}
  if(conteudo.length>=100&&conteudo.length<=2200){score+=15;itens.push({ok:true,txt:'Tamanho ideal'});}else if(conteudo.length>0){itens.push({ok:false,txt:'Tamanho nao ideal'});}
  if(imagem){score+=20;itens.push({ok:true,txt:'Tem imagem'});}else{itens.push({ok:false,txt:'Adicione uma imagem'});}
  if(redes>0){score+=15;itens.push({ok:true,txt:redes+' rede(s)'});}else{itens.push({ok:false,txt:'Selecione redes'});}
  if(hashtagsSel.size>0){score+=10;itens.push({ok:true,txt:hashtagsSel.size+' hashtag(s)'});}else{itens.push({ok:false,txt:'Adicione hashtags'});}
  const cor=score>=70?'#10b981':score>=40?'#f59e0b':'#ef4444';
  document.getElementById('score-num').textContent=score;
  document.getElementById('score-num').style.color=cor;
  document.getElementById('score-fill').style.width=score+'%';
  document.getElementById('score-fill').style.background=cor;
  document.getElementById('score-itens').innerHTML=itens.map(i=>'<span class="score-item '+(i.ok?'ok':'no')+'">'+( i.ok?'✓ ':'✗ ')+i.txt+'</span>').join('');
}
document.addEventListener('input',e=>{if(e.target.closest('#modal-novo-post'))calcScore();});
document.addEventListener('change',e=>{if(e.target.closest('#modal-novo-post'))calcScore();});
async function gerarHashtags(){
  const titulo=document.querySelector('[name="titulo"]')?.value||'';
  const grid=document.getElementById('hashtag-grid');
  grid.innerHTML='<span style="font-size:12px;color:var(--texto2)">Gerando...</span>';
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:300,
        messages:[{role:"user",content:"Liste 15 hashtags para post sobre: "+titulo+" de liga academica de urologia. Retorne APENAS hashtags separadas por espaco."}]})
    });
    const data=await r.json();
    const tags=data.content[0].text.trim().split(/\s+/).filter(t=>t.startsWith('#')).slice(0,15);
    grid.innerHTML=tags.map(t=>'<span class="hashtag-chip" onclick="toggleHashtag(this,\''+t+'\')">'+t+'</span>').join('');
  }catch(e){grid.innerHTML='<span style="color:#dc2626;font-size:12px">Erro ao gerar</span>';}
}
function toggleHashtag(el,tag){
  el.classList.toggle('selecionado');
  if(el.classList.contains('selecionado'))hashtagsSel.add(tag);else hashtagsSel.delete(tag);
  document.getElementById('hashtags-selecionadas').value=[...hashtagsSel].join(' ');
  calcScore();
}
function usarTemplate2(titulo,conteudo){
  abrirModal('modal-novo-post');
  setTimeout(()=>{
    const t=document.querySelector('#modal-novo-post [name="titulo"]');
    const c=document.getElementById('post-conteudo');
    if(t)t.value=titulo;
    if(c){c.value=conteudo;atualizarPreview();calcScore();}
  },100);
}
function atualizarPreview(){
  const txt=document.getElementById('post-conteudo')?.value||'';
  const ig=document.getElementById('prev-ig-txt');
  const wpp=document.getElementById('prev-wpp-txt');
  if(ig)ig.textContent=txt.substring(0,150)+(txt.length>150?'...':'');
  if(wpp)wpp.textContent=txt.substring(0,200)+(txt.length>200?'...':'');
}
document.addEventListener('input',e=>{
  if(e.target.id==='post-conteudo')atualizarPreview();
});
function gerarRelatorio(){
  const linhas=[['Titulo','Status','Redes','Data']];
  postsData.forEach(p=>linhas.push([
    p.titulo||'(Sem titulo)',
    p.status,
    (p.redes||[]).join('/'),
    new Date(p.criado_em).toLocaleDateString('pt-BR')
  ]));
  const csv=linhas.map(l=>l.map(v=>'"'+(v||'').replace(/"/g,'""')+'"').join(',')).join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='relatorio-marketing.csv';
  a.click();
}
async function gerarComIA(){
  const titulo=document.querySelector('[name="titulo"]').value;
  const loading=document.getElementById('ia-loading');
  loading.classList.add('ativo');
  try{
    const r=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:500,messages:[{role:"user",content:"Crie uma legenda profissional para post de marketing de uma liga academica de urologia sobre: "+titulo+". Maximo 150 palavras, tom profissional e engajador."}]})});
    const data=await r.json();
    document.getElementById('post-conteudo').value=data.content[0].text;
  }catch(e){alert('Erro ao gerar com IA. Tente novamente.');}
  loading.classList.remove('ativo');
}
</script>
</body>
</html>