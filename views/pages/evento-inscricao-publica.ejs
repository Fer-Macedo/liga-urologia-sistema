    <div style="display:flex;align-items:center;gap:14px">
      <span style="font-size:10px;font-weight:700;color:var(--ink4);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">Encerra em</span>
      <div style="display:flex;align-items:center;gap:8px">
        <div style="text-align:center"><span id="cd-d" style="font-size:20px;font-weight:800;color:var(--ink);line-height:1;display:block;font-variant-numeric:tabular-nums">--</span><span style="font-size:9px;color:var(--ink4);font-weight:600;text-transform:uppercase;letter-spacing:.4px">dias</span></div>
        <span style="font-size:16px;font-weight:300;color:var(--bdr2);line-height:1.2">:</span>
        <div style="text-align:center"><span id="cd-h" style="font-size:20px;font-weight:800;color:var(--ink);line-height:1;display:block;font-variant-numeric:tabular-nums">--</span><span style="font-size:9px;color:var(--ink4);font-weight:600;text-transform:uppercase;letter-spacing:.4px">horas</span></div>
        <span style="font-size:16px;font-weight:300;color:var(--bdr2);line-height:1.2">:</span>
        <div style="text-align:center"><span id="cd-m" style="font-size:20px;font-weight:800;color:var(--ink);line-height:1;display:block;font-variant-numeric:tabular-nums">--</span><span style="font-size:9px;color:var(--ink4);font-weight:600;text-transform:uppercase;letter-spacing:.4px">min</span></div>
        <span style="font-size:16px;font-weight:300;color:var(--bdr2);line-height:1.2">:</span>
        <div style="text-align:center"><span id="cd-s" style="font-size:20px;font-weight:800;color:var(--ink);line-height:1;display:block;font-variant-numeric:tabular-nums">--</span><span style="font-size:9px;color:var(--ink4);font-weight:600;text-transform:uppercase;letter-spacing:.4px">seg</span></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span style="font-size:11px;color:var(--ink3);font-weight:500">Vagas preenchidas</span>
      <div style="width:90px;height:5px;background:var(--sur3);border-radius:3px;overflow:hidden"><div style="height:100%;border-radius:3px;background:linear-gradient(90deg,#22c55e,#16a34a);width:73%"></div></div>
      <span style="font-size:11px;font-weight:700;color:#16a34a">73%</span>
    </div>
  </div>
</div>
<% } %>

<div class="wrap">
  <div class="grid">
    <div>
      <% if(evento.descricao){ %>
      <div class="card">
        <div class="card-hd">
          <div class="card-hd-l">
            <div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/></svg></div>
            <h2>Sobre o Evento</h2>
          </div>
        </div>
        <div class="card-bd" style="font-size:14px;line-height:1.85;color:var(--ink2);text-align:justify"><%- evento.descricao %></div>
      </div>
      <% } %>

      <% if(lotes.length>0){ %>
      <div class="card" id="inscricao">
        <div class="card-hd">
          <div class="card-hd-l">
            <div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M20 12c0-1.1.9-2 2-2V6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v4c1.1 0 2 .9 2 2s-.9 2-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2z"/></svg></div>
            <div><h2>Ingressos</h2><p>Selecione o ingresso desejado</p></div>
          </div>
        </div>
        <div class="card-bd">
          <% lotes.forEach((l,i)=>{ %>
          <div class="lote <%= i===0?'sel':'' %>" id="lote-<%= l.id %>" onclick="selLote(<%= l.id %>,this)">
            <div class="lote-top">
              <div style="flex:1">
                <% if(i===0){ %><span class="lote-badge lote-badge-pop">Mais Popular</span><% } %>
                <% if(l.vagas_restantes&&l.vagas_restantes<=10){ %>
                <span class="lote-badge lote-badge-hot">
                  <svg style="width:10px;height:10px;fill:#c2410c" viewBox="0 0 24 24"><path d="M13.5.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5.67z"/></svg>
                  Últimas vagas
                </span>
                <% } %>
                <div class="lote-nome"><%= l.nome %></div>
                <% if(l.data_fim){ %><div class="lote-info">Disponível até <%= new Date(l.data_fim).toLocaleDateString('pt-BR') %></div><% } %>
              </div>
              <div style="display:flex;align-items:flex-start;gap:10px">
                <% if(parseFloat(l.preco)===0){ %>
                  <span class="badge-free">Gratuito</span>
                <% } else { %>
                <div class="lote-preco-wrap">
                  <div class="lote-preco">R$ <%= Number(l.preco).toFixed(2) %></div>
                  <div class="lote-preco-sub">por participante</div>
                </div>
                <% } %>
                <div class="lote-radio"></div>
              </div>
            </div>
            <!-- SELETOR DE QUANTIDADE -->
            <div class="lote-qty" id="qty-row-<%= l.id %>" style="display:none" onclick="event.stopPropagation()">
              <span class="lote-qty-label">Quantidade de ingressos</span>
              <div class="qty-ctrl">
                <button class="qty-btn" onclick="mudaQty(<%= l.id %>,-1)" id="qty-minus-<%= l.id %>" disabled>−</button>
                <input class="qty-num" id="qty-<%= l.id %>" value="1" readonly>
                <button class="qty-btn" onclick="mudaQty(<%= l.id %>,1)" id="qty-plus-<%= l.id %>">+</button>
              </div>
            </div>
          </div>
          <% }) %>
          <div class="cupom-sec">
            <div class="cupom-lbl">Cupom de desconto</div>
            <div class="cupom-row">
              <input id="cupom-in" class="cupom-in" placeholder="CÓDIGO DO CUPOM" oninput="this.value=this.value.toUpperCase()">
              <button type="button" class="cupom-btn" onclick="aplicarCupom()">Aplicar</button>
            </div>
            <div id="cupom-msg" style="display:none"></div>
          </div>
          <button class="btn-prox" onclick="abrirForm()">Garantir minha vaga →</button>
          <div style="display:flex;align-items:center;gap:7px;background:var(--sur3);border-radius:8px;padding:9px 12px;margin-top:8px">
            <svg style="width:13px;height:13px;fill:var(--ink4);flex-shrink:0" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
            <span style="font-size:11px;color:var(--ink3)">Pagamento 100% seguro via PIX ou Cartão · PagBank</span>
          </div>
        </div>
      </div>
      <% } %>

      <div class="form-sec" id="form-sec">
        <div class="card">
          <div class="card-hd">
            <div class="card-hd-l">
              <div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></div>
              <div><h2>Dados do Participante</h2><p>Todos os campos são obrigatórios</p></div>
            </div>
          </div>
          <div class="card-bd">
            <form action="/inscricao/<%= evento.id %>" method="POST" id="form-ins">
              <input type="hidden" name="lote_id" id="lote-sel" value="<%= lotes[0]?.id %>">
              <input type="hidden" name="quantidade" id="campo-qty" value="1">
              <input type="hidden" name="cupom" id="campo-cupom" value="">
              <input type="hidden" name="tipo_participante" id="campo-tipo" value="ucp">
              <div style="margin-bottom:20px">
                <div class="sec-title">Tipo de participante</div>
                <div class="tipo-participante">
                  <div class="tipo-opt sel" id="opt-ucp" onclick="selectTipo('ucp')">
                    <div class="tipo-ic"><svg viewBox="0 0 24 24"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg></div>
                    <div class="tipo-lbl">Aluno UCP</div>
                    <div class="tipo-sub">Universidad Central del Paraguay</div>
                  </div>
                  <div class="tipo-opt" id="opt-externo" onclick="selectTipo('externo')">
                    <div class="tipo-ic"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg></div>
                    <div class="tipo-lbl">Externo</div>
                    <div class="tipo-sub">Outra instituição</div>
                  </div>
                </div>
              </div>
              <div class="sec-title">Informações pessoais</div>
              <div class="grid2" style="margin-bottom:14px">
                <div class="campo" style="grid-column:1/-1"><label>Nome Completo <span class="req">*</span></label><input name="nome" class="inp" required placeholder="Seu nome completo"></div>
                <div class="campo"><label>E-mail <span class="req">*</span></label><input name="email" class="inp" type="email" required placeholder="email@exemplo.com"></div>
                <div class="campo"><label>WhatsApp <span class="req">*</span></label>
                  <div class="inp-group">
                    <select name="whatsapp_pais" class="inp" style="max-width:86px;flex-shrink:0"><option value="+595">🇵🇾 +595</option><option value="+55">🇧🇷 +55</option><option value="+54">🇦🇷 +54</option><option value="+598">🇺🇾 +598</option><option value="+1">🇺🇸 +1</option></select>
                    <input name="whatsapp" class="inp" placeholder="99 999 9999" required>
                  </div>
                </div>
                <div class="campo"><label>Data de Nascimento <span class="req">*</span></label><input type="date" name="data_nascimento" class="inp" required></div>
                <div class="campo"><label>RG / CI <span class="req">*</span></label><input name="rg" class="inp" required placeholder="Número do documento"></div>
                <div class="campo" id="campo-catraca"><label>Catraca UCP <span class="req">*</span></label><input name="catraca" id="inp-catraca" class="inp" required placeholder="Número da catraca"></div>
                <div class="campo" id="campo-instituicao" style="display:none"><label>Instituição <span class="req">*</span></label><input name="instituicao" id="inp-instituicao" class="inp" placeholder="Nome da sua universidade"></div>
                <div class="campo"><label>Semestre <span class="req">*</span></label>
                  <select name="semestre" class="inp" required><option value="">Selecione...</option><% for(let s=1;s<=10;s++){ %><option value="<%= s %>º"><%= s %>º Semestre</option><% } %></select>
                </div>
                <div class="campo"><label>Turma <span class="req">*</span></label>
                  <select name="turma" class="inp" required><option value="">Selecione...</option><% 'ABCDEFGHIJKLMNOP'.split('').forEach(t=>{ %><option value="<%= t %>">Turma <%= t %></option><% }) %></select>
                </div>
              </div>
              <% if(campos&&campos.length>0){ %>
              <div class="sec-title" style="margin-top:8px">Informações adicionais</div>
              <div class="grid2" style="margin-bottom:14px">
                <% campos.forEach(campo=>{ %>
                <div class="campo" style="<%= campo.tipo==='textarea'?'grid-column:1/-1':'' %>">
                  <label><%= campo.label %><% if(campo.obrigatorio){ %><span class="req"> *</span><% } %></label>
                  <% if(campo.tipo==='select'){ %><select name="campo_<%= campo.id %>" class="inp" <%= campo.obrigatorio?'required':'' %>><option value="">Selecione...</option><% (campo.opcoes||'').split('\n').filter(o=>o.trim()).forEach(op=>{ %><option value="<%= op.trim() %>"><%= op.trim() %></option><% }) %></select>
                  <% } else if(campo.tipo==='textarea'){ %><textarea name="campo_<%= campo.id %>" class="inp" rows="3" <%= campo.obrigatorio?'required':'' %>></textarea>
                  <% } else { %><input type="<%= campo.tipo==='email'?'email':campo.tipo==='number'?'number':campo.tipo==='date'?'date':'text' %>" name="campo_<%= campo.id %>" class="inp" <%= campo.obrigatorio?'required':'' %>><% } %>
                </div>
                <% }) %>
              </div>
              <% } %>
              <div class="termos-box">
                <% if(evento.termos_texto){ %><div class="termo-check"><input type="checkbox" name="aceite_termos" required><span>Li e concordo com os <span class="termo-link" onclick="abrirModal('modal-termos')">Termos de Participação</span> <span class="req">*</span></span></div><% } %>
                <div class="termo-check"><input type="checkbox" name="aceite_lgpd" required><span>Li e aceito a <span class="termo-link" onclick="abrirModal('modal-lgpd')">Política de Privacidade</span> <span class="req">*</span></span></div>
              </div>
              <button type="submit" class="btn-sub">Confirmar Inscrição</button>
              <div class="secure-note"><svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>Seus dados estão protegidos com segurança</div>
            </form>
          </div>
        </div>
      </div>

      <% if(programacao&&programacao.length>0){ %>
      <div class="card">
        <div class="card-hd"><div class="card-hd-l"><div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM5 8V6h14v2H5z"/></svg></div><h2>Programação</h2></div></div>
        <div class="card-bd">
          <% programacao.forEach((p,i)=>{ %>
          <div class="prog-item" id="prog-item-<%= i %>" onclick="togProg(<%= i %>)">
            <div class="prog-item-hd">
              <div style="flex:1"><div class="prog-hora"><%= p.horario %><% if(p.local){ %> · <%= p.local %><% } %></div><div class="prog-titulo"><%= p.titulo %></div></div>
              <% if(p.descricao){ %><span class="prog-chevron">▼</span><% } %>
            </div>
            <% if(p.descricao){ %><div class="prog-desc" id="prog-desc-<%= i %>"><div class="prog-desc-inner"><%= p.descricao %></div></div><% } %>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if(palestrantes&&palestrantes.length>0){ %>
      <div class="card">
        <div class="card-hd"><div class="card-hd-l"><div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg></div><div><h2>Palestrantes</h2><p>Clique para ver a biografia completa</p></div></div></div>
        <div class="card-bd">
          <div class="pales-grid">
            <% palestrantes.forEach((p,i)=>{ %>
            <div class="pales-card" id="pales-<%= i %>" onclick="togPales(<%= i %>)">
              <% if(p.foto_chave){ %>
              <div class="pales-foto-wrap"><img src="/eventos/palestrantes/<%= p.id %>/foto" class="pales-foto" alt="<%= p.nome %>"><div class="pales-foto-ring"></div></div>
              <% } else { %><div class="pales-ph"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></div><% } %>
              <div class="pales-nome"><%= p.nome %></div>
              <% if(p.instituicao){ %><div class="pales-inst"><%= p.instituicao %></div><% } %>
              <% if(p.bio){ %><div class="pales-bio-wrap" id="pbio-<%= i %>"><div class="pales-bio"><%= p.bio %></div></div><% } %>
            </div>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

      <div class="card" id="contato">
        <div class="card-hd"><div class="card-hd-l"><div class="card-hd-ic"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div><h2>Contato</h2></div></div>
        <div class="card-bd">
          <div class="contact-grid">
            <a href="mailto:lauroucpcde@lauroucpcde.com" class="contact-btn"><div class="contact-ic" style="background:#fee2e2"><svg style="fill:#dc2626" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div><div><div class="contact-lbl">E-mail</div><div class="contact-val" style="font-size:12px">lauroucpcde@lauroucpcde.com</div></div></a>
            <a href="https://wa.me/595994225753" target="_blank" class="contact-btn"><div class="contact-ic" style="background:#dcfce7"><svg style="fill:#16a34a" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div><div><div class="contact-lbl">WhatsApp</div><div class="contact-val">+595 994 225 753</div></div></a>
          </div>
          <div style="margin-top:10px">
            <div class="contact-btn" onclick="togForm()" style="width:100%">
              <div class="contact-ic" style="background:var(--sur3)"><svg style="fill:var(--ink3)" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg></div>
              <div style="flex:1"><div class="contact-lbl">Mensagem</div><div class="contact-val">Enviar mensagem para a equipe</div></div>
              <span id="form-arrow" style="color:var(--ink4);font-size:11px;transition:transform .25s">▼</span>
            </div>
            <div class="c-form" id="c-form">
              <form action="/contato-evento/<%= evento.id %>" method="POST" style="margin-top:12px">
                <input name="nome" class="c-inp" placeholder="Seu nome" required>
                <input name="email" type="email" class="c-inp" placeholder="Seu e-mail" required>
                <textarea name="mensagem" class="c-inp" rows="3" placeholder="Sua mensagem..." style="resize:vertical" required></textarea>
                <button type="submit" class="c-send">Enviar mensagem</button>
              </form>
            </div>
          </div>
        </div>
      </div>
