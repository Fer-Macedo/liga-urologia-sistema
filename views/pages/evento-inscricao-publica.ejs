      <% if(evento.local&&evento.tipo_evento!=='online'){%><div class="t-chip">📍 <%= evento.local %></div><%}%>
    </div>
  </div>
</div>

<!-- GRUPO WPP -->
<% if(evento.wpp_grupo){%>
<div class="wpp-banner">
  <div class="wpp-in">
