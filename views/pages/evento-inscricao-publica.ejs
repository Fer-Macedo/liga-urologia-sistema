<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — LAURO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --primary:<%= evento.cor_tema||'#1a3d2b' %>;
      --primary-rgb:<%= (evento.cor_tema||'#1a3d2b').replace('#','') %>;
      --white:#fff;
      --gray-50:#f9fafb;
      --gray-100:#f3f4f6;
      --gray-200:#e5e7eb;
      --gray-400:#9ca3af;
      --gray-600:#4b5563;
      --gray-800:#1f2937;
      --gray-900:#111827;
    }
    body{font-family:'Inter',sans-serif;background:var(--gray-50);color:var(--gray-900)}

    /* NAV */
    nav{background:var(--white);border-bottom:1px solid var(--gray-200);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:1100px;margin:0 auto;padding:0 24px;height:58px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .nav-logo-img{height:34px;width:auto}
    .nav-logo-text{font-weight:800;font-size:17px;color:var(--primary)}
    .nav-links{display:flex;gap:20px;align-items:center}
    .nav-link{font-size:13px;font-weight:500;color:var(--gray-600);text-decoration:none}
    .nav-link:hover{color:var(--primary)}
    .nav-cta{background:var(--primary);color:white;padding:7px 18px;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none}

    /* BANNER */
    .banner-wrap{width:100%;max-height:420px;overflow:hidden;background:var(--gray-900)}
    .banner-img{width:100%;max-height:420px;object-fit:cover;display:block}
    .banner-placeholder{width:100%;height:280px;background:linear-gradient(135deg,var(--primary),#000);display:flex;align-items:center;justify-content:center;color:white;font-size:48px}

    /* TITULO ABAIXO DO BANNER */
    .titulo-wrap{background:var(--white);border-bottom:1px solid var(--gray-200);padding:28px 0 20px}
    .titulo-inner{max-width:1100px;margin:0 auto;padding:0 24px}
    .tipo-chip{display:inline-flex;align-items:center;gap:6px;background:var(--gray-100);border-radius:20px;padding:4px 12px;font-size:12px;font-weight:600;color:var(--gray-600);margin-bottom:10px}
    .titulo-inner h1{font-size:clamp(20px,3.5vw,32px);font-weight:800;color:var(--gray-900);line-height:1.2;text-align:justify}
    .titulo-meta{display:flex;flex-wrap:wrap;gap:16px;margin-top:14px}
    .titulo-chip{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--gray-600);font-weight:500}

    /* LAYOUT */
    .page-wrap{max-width:1100px;margin:0 auto;padding:28px 24px 80px}
    .main-grid{display:grid;grid-template-columns:1fr 340px;gap:24px;align-items:start}
    @media(max-width:860px){.main-grid{grid-template-columns:1fr}.sidebar{order:-1}}

    /* CARDS */
    .card{background:var(--white);border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.08),0 2px 12px rgba(0,0,0,.05);overflow:hidden;margin-bottom:18px}
    .card-hd{padding:18px 22px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;gap:10px}
    .card-hd h2{font-size:15px;font-weight:700;color:var(--gray-900)}
    .card-hd p{font-size:12px;color:var(--gray-400);margin-top:1px}
    .card-bd{padding:20px 22px}

    /* LOTES */
    .lote{border:2px solid var(--gray-200);border-radius:12px;padding:16px 18px;margin-bottom:10px;cursor:pointer;transition:all .2s;position:relative;background:var(--white)}
    .lote:hover{border-color:var(--primary);box-shadow:0 0 0 3px color-mix(in srgb,var(--primary) 15%,transparent)}
    .lote.ativo{border-color:var(--primary);background:color-mix(in srgb,var(--primary) 6%,white)}
    .lote-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
    .lote-left{flex:1}
    .lote-nome{font-weight:700;font-size:15px;color:var(--gray-900)}
    .lote-info{font-size:12px;color:var(--gray-400);margin-top:3px}
    .lote-preco{font-size:22px;font-weight:900;color:var(--primary);white-space:nowrap}
    .badge-free{background:#dcfce7;color:#166534;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;display:inline-block}
    .lote-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--gray-300);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:.2s}
    .lote.ativo .lote-check{background:var(--primary);border-color:var(--primary);color:white}

    /* QUANTIDADE */
    .qty-wrap{display:flex;align-items:center;gap:10px;margin-top:12px;padding-top:12px;border-top:1px solid var(--gray-100)}
    .qty-btn{width:32px;height:32px;border-radius:8px;border:1.5px solid var(--gray-200);background:var(--white);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--gray-700);transition:.2s}
    .qty-btn:hover{border-color:var(--primary);color:var(--primary)}
    .qty-num{font-size:16px;font-weight:700;min-width:24px;text-align:center}
    .qty-label{font-size:12px;color:var(--gray-400);margin-left:4px}

    /* CUPOM */
    .cupom-wrap{display:flex;gap:8px;margin-top:14px}
    .cupom-input{flex:1;padding:9px 12px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:13px;font-family:'Inter',sans-serif}
    .cupom-input:focus{outline:none;border-color:var(--primary)}
    .cupom-btn{padding:9px 16px;background:var(--gray-100);border:1.5px solid var(--gray-200);border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;color:var(--gray-700)}
    .cupom-btn:hover{background:var(--primary);color:white;border-color:var(--primary)}
    .cupom-ok{background:#dcfce7;color:#166534;border-color:#86efac}
    .cupom-erro{background:#fee2e2;color:#991b1b;border-color:#fca5a5}

    /* PARTICIPANTES */
    .participante-bloco{border:1.5px solid var(--gray-200);border-radius:10px;padding:16px;margin-bottom:12px;position:relative}
    .participante-titulo{font-size:13px;font-weight:700;color:var(--gray-700);margin-bottom:12px;display:flex;align-items:center;gap:8px}
    .participante-num{width:22px;height:22px;background:var(--primary);color:white;border-radius:50%;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center}

    /* CAMPOS FORM */
    .campo{margin-bottom:14px}
    .campo label{display:block;font-size:12px;font-weight:600;color:var(--gray-700);margin-bottom:5px}
    .req{color:#ef4444}
    .input{width:100%;padding:10px 13px;border:1.5px solid var(--gray-200);border-radius:9px;font-size:13px;font-family:'Inter',sans-serif;transition:.2s}
    .input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px color-mix(in srgb,var(--primary) 12%,transparent)}
    .input-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    @media(max-width:500px){.input-grid{grid-template-columns:1fr}}

    /* FORM ANIMADO */
    .form-section{overflow:hidden;transition:max-height .4s ease,opacity .4s ease;max-height:0;opacity:0}
    .form-section.visivel{max-height:2000px;opacity:1}

    /* SUBMIT */
    .btn-submit{width:100%;padding:15px;background:var(--primary);color:white;border:none;border-radius:11px;font-size:15px;font-weight:700;cursor:pointer;transition:.2s;font-family:'Inter',sans-serif;margin-top:10px}
    .btn-submit:hover{opacity:.92;transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.2)}
    .secure{text-align:center;font-size:12px;color:var(--gray-400);margin-top:8px}

    /* SIDEBAR */
    .sidebar-card{background:var(--white);border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.08),0 2px 12px rgba(0,0,0,.05);padding:20px;margin-bottom:16px}
    .sidebar-title{font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--gray-100)}
    .info-item{display:flex;gap:10px;align-items:flex-start;margin-bottom:12px}
    .info-icon{width:34px;height:34px;border-radius:9px;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
    .info-label{font-size:10px;color:var(--gray-400);font-weight:600;text-transform:uppercase;letter-spacing:.4px}
    .info-val{font-weight:600;font-size:13px;color:var(--gray-900);margin-top:1px}
    .info-sub{font-size:11px;color:var(--gray-600);margin-top:1px}
    .org-box{background:var(--gray-50);border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;margin-top:14px}
    .org-logo{width:38px;height:38px;border-radius:9px;overflow:hidden;background:var(--primary);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .org-logo img{width:100%;height:100%;object-fit:contain}

    /* RESUMO SIDEBAR */
    .resumo-box{background:color-mix(in srgb,var(--primary) 8%,white);border:1.5px solid var(--primary);border-radius:10px;padding:14px}
    .resumo-nome{font-weight:700;font-size:13px;color:var(--primary)}
    .resumo-preco{font-size:24px;font-weight:900;color:var(--primary)}
    .resumo-qty{font-size:12px;color:var(--gray-600);margin-top:2px}
    .btn-inscrever-side{display:flex;align-items:center;justify-content:center;margin-top:12px;padding:12px;background:var(--primary);color:white;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px}

    /* CONTATO */
    .contato-link{display:flex;align-items:center;gap:10px;padding:11px 13px;border-radius:9px;border:1.5px solid var(--gray-200);text-decoration:none;color:var(--gray-800);font-size:13px;font-weight:500;margin-bottom:8px;transition:.2s}
    .contato-link:hover{border-color:var(--primary);background:color-mix(in srgb,var(--primary) 5%,white)}
    .c-icon{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
    .form-contato-input{width:100%;padding:9px 12px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;margin-bottom:8px}
    .form-contato-input:focus{outline:none;border-color:var(--primary)}
    .btn-contato{width:100%;padding:10px;background:var(--primary);color:white;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif}

    /* SUCESSO */
    .sucesso-wrap{min-height:70vh;display:flex;align-items:center;justify-content:center;padding:40px 20px}
    .sucesso-box{background:var(--white);border-radius:20px;box-shadow:0 4px 40px rgba(0,0,0,.12);padding:44px 32px;text-align:center;max-width:480px;width:100%}
    .sucesso-icon{width:72px;height:72px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 20px;animation:pop .4s ease}
    @keyframes pop{0%{transform:scale(0)}80%{transform:scale(1.1)}100%{transform:scale(1)}}
    .codigo-box{background:var(--gray-900);color:#10b981;font-family:monospace;font-size:15px;padding:12px 20px;border-radius:9px;margin:18px auto;display:inline-block;letter-spacing:2px}

    /* WHATSAPP FLOAT */
    .wpp-float{position:fixed;bottom:24px;right:24px;z-index:999;width:56px;height:56px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.4);text-decoration:none;transition:.2s}
    .wpp-float:hover{transform:scale(1.1);box-shadow:0 6px 28px rgba(37,211,102,.5)}
    .wpp-float svg{width:30px;height:30px;fill:white}

    /* FOOTER */
    footer{background:var(--gray-900);color:rgba(255,255,255,.5);text-align:center;padding:22px;font-size:12px;margin-top:40px}
    footer strong{color:white}
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <% if (config && config.org_logo) { %>
      <img src="<%= config.org_logo %>" class="nav-logo-img" alt="LAURO">
      <% } else { %>
      <div style="width:34px;height:34px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:15px">L</div>
      <% } %>
      <span class="nav-logo-text">LAURO</span>
    </a>
    <div class="nav-links">
      <a href="https://www.instagram.com/lauroucp.cde/" target="_blank" class="nav-link">Instagram</a>
      <a href="#contato" class="nav-link">Contato</a>
      <a href="#inscricao" class="nav-cta">Inscrever-se</a>
    </div>
  </div>
</nav>

<% if (sucesso) { %>
<div class="sucesso-wrap">
  <div class="sucesso-box">
    <div class="sucesso-icon">✓</div>
    <h2 style="font-size:22px;font-weight:800;margin-bottom:8px">Inscrição Realizada!</h2>
    <p style="color:var(--gray-600);font-size:14px;line-height:1.6">Sua inscrição foi confirmada. Verifique seu email.</p>
    <div class="codigo-box"><%= codigoInscricao %></div>
    <p style="font-size:12px;color:var(--gray-400);margin-top:4px">Apresente este código no check-in</p>
    <a href="https://www.instagram.com/lauroucp.cde/" target="_blank" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;padding:12px 22px;background:var(--primary);color:white;border-radius:10px;text-decoration:none;font-weight:600;font-size:14px">Seguir no Instagram →</a>
  </div>
</div>
<% } else { %>

<!-- BANNER -->
<div class="banner-wrap">
  <% if (evento.banner_chave) { %>
  <img src="/eventos/<%= evento.id %>/banner" class="banner-img" alt="Banner">
  <% } else { %>
  <div class="banner-placeholder">📅</div>
  <% } %>
</div>

<!-- TÍTULO ABAIXO DO BANNER -->
<div class="titulo-wrap">
  <div class="titulo-inner">
    <div class="tipo-chip">
      <% if(evento.tipo_evento==='online'){%>💻 Online<%}else if(evento.tipo_evento==='hibrido'){%>🔀 Híbrido<%}else{%>📍 Presencial<%}%>
    </div>
    <h1><%= evento.nome %></h1>
    <div class="titulo-meta">
      <% if (evento.data_inicio) { %>
      <div class="titulo-chip">📅 <strong><%= new Date(evento.data_inicio).toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) %></strong></div>
      <% } %>
      <% if (evento.local && evento.tipo_evento !== 'online') { %>
      <div class="titulo-chip">📍 <span><%= evento.local %></span></div>
      <% } %>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="page-wrap">
  <div class="main-grid">

    <!-- COLUNA ESQUERDA -->
    <div>

      <!-- Sobre -->
      <% if (evento.descricao) { %>
      <div class="card">
        <div class="card-hd"><h2>Sobre o Evento</h2></div>
        <div class="card-bd" style="font-size:14px;line-height:1.8;color:var(--gray-700);text-align:justify"><%- evento.descricao %></div>
      </div>
      <% } %>

      <!-- Ingressos -->
      <% if (lotes.length > 0) { %>
      <div class="card" id="inscricao">
        <div class="card-hd"><div><h2>🎫 Ingressos</h2><p>Selecione e escolha a quantidade</p></div></div>
        <div class="card-bd">
          <% lotes.forEach((l, i) => { %>
          <div class="lote <%= i===0?'ativo':'' %>" id="lote-<%= l.id %>" onclick="selecionarLote(<%= l.id %>, this)">
            <div class="lote-top">
              <div class="lote-left">
                <div class="lote-nome"><%= l.nome %></div>
                <% if (l.data_fim) { %><div class="lote-info">Até <%= new Date(l.data_fim).toLocaleDateString('pt-BR') %></div><% } %>
              </div>
              <div style="display:flex;align-items:center;gap:10px">
                <div>
                  <% if (parseFloat(l.preco) === 0) { %>
                  <span class="badge-free">GRATUITO</span>
                  <% } else { %>
                  <div class="lote-preco">R$ <%= Number(l.preco).toFixed(2) %></div>
                  <% } %>
                </div>
                <div class="lote-check"><%= i===0?'✓':'' %></div>
              </div>
            </div>
            <% if (i===0) { %>
            <div class="qty-wrap" id="qty-wrap-<%= l.id %>">
              <button type="button" class="qty-btn" onclick="event.stopPropagation();alterarQty(-1)">−</button>
              <span class="qty-num" id="qty-num">1</span>
              <button type="button" class="qty-btn" onclick="event.stopPropagation();alterarQty(1)">+</button>
              <span class="qty-label">ingresso(s)</span>
            </div>
            <% } %>
          </div>
          <% }) %>

          <!-- Cupom -->
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--gray-100)">
            <div style="font-size:13px;font-weight:600;color:var(--gray-700);margin-bottom:8px">🏷️ Cupom de Desconto</div>
            <div class="cupom-wrap">
              <input type="text" id="cupom-input" class="cupom-input" placeholder="Digite seu cupom..." oninput="this.value=this.value.toUpperCase()">
              <button type="button" class="cupom-btn" onclick="aplicarCupom()">Aplicar</button>
            </div>
            <div id="cupom-msg" style="font-size:12px;margin-top:6px;display:none"></div>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Formulário animado -->
      <div class="form-section" id="form-section">
        <div class="card">
          <div class="card-hd"><div><h2>📝 Dados dos Participantes</h2><p>Preencha os dados de cada participante</p></div></div>
          <div class="card-bd">
            <form action="/inscricao/<%= evento.id %>" method="POST" id="form-inscricao">
              <input type="hidden" name="lote_id" id="lote_selecionado" value="<%= lotes[0]?.id %>">
              <input type="hidden" name="quantidade" id="campo-qty" value="1">
              <input type="hidden" name="cupom" id="campo-cupom" value="">

              <div id="participantes-wrap">
                <!-- Participante 1 -->
                <div class="participante-bloco" id="part-1">
                  <div class="participante-titulo"><div class="participante-num">1</div> Participante 1</div>
                  <div class="input-grid">
                    <div class="campo" style="grid-column:1/-1">
                      <label>Nome Completo <span class="req">*</span></label>
                      <input name="nome" class="input" required placeholder="Nome completo">
                    </div>
                    <div class="campo">
                      <label>Email <span class="req">*</span></label>
                      <input name="email" class="input" type="email" required placeholder="email@exemplo.com">
                    </div>
                    <div class="campo">
                      <label>WhatsApp</label>
                      <input name="whatsapp" class="input" placeholder="+595 99 999 9999">
                    </div>
                    <div class="campo">
                      <label>CPF</label>
                      <input name="cpf" class="input" placeholder="000.000.000-00">
                    </div>
                    <div class="campo">
                      <label>Instituição</label>
                      <input name="instituicao" class="input" placeholder="Universidade / Empresa">
                    </div>
                  </div>
                  <% if (campos && campos.length > 0) { %>
                  <% campos.forEach(campo => { %>
                  <div class="campo">
                    <label><%= campo.label %><% if(campo.obrigatorio){%><span class="req"> *</span><%}%></label>
                    <% if (campo.tipo === 'select') { %>
                    <select name="campo_<%= campo.id %>" class="input" <%= campo.obrigatorio?'required':'' %>>
                      <option value="">Selecione...</option>
                      <% (campo.opcoes||'').split('\n').filter(o=>o.trim()).forEach(op=>{ %><option value="<%= op.trim() %>"><%= op.trim() %></option><% }) %>
                    </select>
                    <% } else if (campo.tipo === 'textarea') { %>
                    <textarea name="campo_<%= campo.id %>" class="input" rows="3" <%= campo.obrigatorio?'required':'' %>></textarea>
                    <% } else { %>
                    <input type="<%= campo.tipo==='email'?'email':campo.tipo==='number'?'number':'text' %>" name="campo_<%= campo.id %>" class="input" <%= campo.obrigatorio?'required':'' %>>
                    <% } %>
                  </div>
                  <% }) %>
                  <% } %>
                </div>
              </div>

              <button type="submit" class="btn-submit" id="btn-submit">Confirmar Inscrição →</button>
              <div class="secure">🔒 Seus dados estão protegidos</div>
            </form>
          </div>
        </div>
      </div>

      <!-- Contato -->
      <div class="card" id="contato">
        <div class="card-hd"><div><h2>💬 Contato</h2><p>Fale com nossa equipe</p></div></div>
        <div class="card-bd">
          <a href="mailto:lauroucpcde@lauroucpcde.com" class="contato-link">
            <div class="c-icon" style="background:#fee2e2">✉️</div>
            <div><div style="font-size:10px;color:var(--gray-400);font-weight:600">EMAIL</div>lauroucpcde@lauroucpcde.com</div>
          </a>
          <a href="https://wa.me/595994225753" target="_blank" class="contato-link">
            <div class="c-icon" style="background:#dcfce7">📱</div>
            <div><div style="font-size:10px;color:var(--gray-400);font-weight:600">WHATSAPP</div>+595 994 225 753</div>
          </a>
          <a href="https://www.instagram.com/lauroucp.cde/" target="_blank" class="contato-link">
            <div class="c-icon" style="background:#fce7f3">📸</div>
            <div><div style="font-size:10px;color:var(--gray-400);font-weight:600">INSTAGRAM</div>@lauroucp.cde</div>
          </a>
          <div style="border-top:1px solid var(--gray-100);padding-top:16px;margin-top:8px">
            <p style="font-size:13px;font-weight:600;margin-bottom:10px">Enviar mensagem</p>
            <form action="/contato-evento/<%= evento.id %>" method="POST">
              <input name="nome" class="form-contato-input" placeholder="Seu nome" required>
              <input name="email" type="email" class="form-contato-input" placeholder="Seu email" required>
              <textarea name="mensagem" class="form-contato-input" rows="3" placeholder="Sua mensagem..." style="resize:vertical" required></textarea>
              <button type="submit" class="btn-contato">Enviar →</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-card">
        <div class="sidebar-title">Informações</div>
        <% if (evento.data_inicio) { %>
        <div class="info-item">
          <div class="info-icon">📅</div>
          <div><div class="info-label">Data</div><div class="info-val"><%= new Date(evento.data_inicio).toLocaleDateString('pt-BR',{day:'2-digit',month:'long',year:'numeric'}) %></div><div class="info-sub"><%= new Date(evento.data_inicio).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %> h</div></div>
        </div>
        <% } %>
        <% if (evento.data_fim) { %>
        <div class="info-item">
          <div class="info-icon">🏁</div>
          <div><div class="info-label">Término</div><div class="info-val"><%= new Date(evento.data_fim).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %> h</div></div>
        </div>
        <% } %>
        <div class="info-item">
          <div class="info-icon"><%= evento.tipo_evento==='online'?'💻':evento.tipo_evento==='hibrido'?'🔀':'📍' %></div>
          <div><div class="info-label">Modalidade</div><div class="info-val"><%= evento.tipo_evento==='online'?'Online':evento.tipo_evento==='hibrido'?'Híbrido':'Presencial' %></div></div>
        </div>
        <% if (evento.local && evento.tipo_evento !== 'online') { %>
        <div class="info-item">
          <div class="info-icon">📍</div>
          <div><div class="info-label">Local</div><div class="info-val"><%= evento.local %></div><% if(evento.endereco){%><div class="info-sub"><%= evento.endereco %></div><%}%></div>
        </div>
        <% } %>
        <div class="org-box">
          <div class="org-logo">
            <% if (config && config.org_logo) { %><img src="<%= config.org_logo %>" alt="LAURO"><% } else { %><span style="color:white;font-weight:800;font-size:15px">L</span><% } %>
          </div>
          <div><div style="font-weight:700;font-size:13px">LAURO</div><div style="font-size:11px;color:var(--gray-600)">Liga Académica de Urología</div></div>
        </div>
      </div>

      <!-- Resumo Ingresso -->
      <% if (lotes.length > 0) { %>
      <div class="sidebar-card">
        <div class="sidebar-title">Ingresso Selecionado</div>
        <div class="resumo-box">
          <div class="resumo-nome" id="resumo-nome"><%= lotes[0]?.nome %></div>
          <div class="resumo-preco" id="resumo-preco"><%= parseFloat(lotes[0]?.preco||0)===0?'Gratuito':'R$ '+Number(lotes[0]?.preco||0).toFixed(2) %></div>
          <div class="resumo-qty" id="resumo-qty">1 ingresso</div>
        </div>
        <a href="#form-section" class="btn-inscrever-side" onclick="mostrarForm()">Preencher Dados →</a>
      </div>
      <% } %>

      <!-- Instagram -->
      <div class="sidebar-card">
        <a href="https://www.instagram.com/lauroucp.cde/" target="_blank" style="display:flex;align-items:center;gap:12px;padding:12px;background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);border-radius:10px;text-decoration:none;color:white">
          <div style="font-size:24px">📸</div>
          <div><div style="font-weight:700;font-size:13px">@lauroucp.cde</div><div style="font-size:11px;opacity:.85">Siga no Instagram</div></div>
        </a>
      </div>
    </div>
  </div>
</div>
<% } %>

