<script>
const lotesData=<%- JSON.stringify(lotes) %>;
let loteId=<%= lotes[0]?.id||'null' %>,precoBase=<%= parseFloat(lotes[0]?.preco||0) %>,desconto=0,quantidade=1;

function selLote(id,el){
  // forçar string para comparação consistente
  id = String(id);
  document.querySelectorAll('.lote').forEach(e=>e.classList.remove('sel'));
  el.classList.add('sel');
  document.getElementById('lote-sel').value=id;
  loteId=id;
  quantidade=1;
  document.getElementById('campo-qty').value=1;
  // mostrar seletor de qtd apenas no lote selecionado
  lotesData.forEach(function(l){
    var lid=String(l.id);
    var row=document.getElementById('qty-row-'+lid);
    if(row) row.style.display=(lid===id)?'flex':'none';
    var inp=document.getElementById('qty-'+lid);
    if(inp) inp.value=1;
    var minus=document.getElementById('qty-minus-'+lid);
    if(minus) minus.disabled=true;
    var plus=document.getElementById('qty-plus-'+lid);
    if(plus) plus.disabled=false;
  });
  const l=lotesData.find(x=>String(x.id)===id);
  precoBase=l?parseFloat(l.preco):0;
  updRes(l);
}

// Inicializar mostrando o qty-row do primeiro lote
window.addEventListener('DOMContentLoaded',function(){
  if(lotesData.length>0){
    var first=lotesData[0];
    var firstId=String(first.id);
    var row=document.getElementById('qty-row-'+firstId);
    if(row) row.style.display='flex';
    updRes(first);
  }
});

function mudaQty(id,delta){
  id=String(id);
  var inp=document.getElementById('qty-'+id);
  if(!inp)return;
  var val=parseInt(inp.value)||1;
  val=Math.max(1,Math.min(10,val+delta));
  inp.value=val;
  quantidade=val;
  document.getElementById('campo-qty').value=val;
  document.getElementById('qty-minus-'+id).disabled=val<=1;
  document.getElementById('qty-plus-'+id).disabled=val>=10;
  const l=lotesData.find(x=>String(x.id)===id);
  updRes(l);
}

function updRes(l){
  const rn=document.getElementById('res-nome'),rp=document.getElementById('res-preco'),rq=document.getElementById('res-qty');
  if(!rn)return;
  const unitario=precoBase*(1-desconto);
  const total=unitario*quantidade;
  rn.textContent=l?l.nome:'';
  rp.textContent=total===0?'Gratuito':'R$ '+total.toFixed(2).replace('.',',');
  if(rq) rq.textContent=quantidade>1?quantidade+'x R$ '+unitario.toFixed(2).replace('.',','):'';
}
<% if(evento.data_inicio){ %>
(function(){
  var target=new Date('<%= evento.data_inicio %>');
  function tick(){
    var now=new Date(),diff=Math.max(0,target-now);
    var d=Math.floor(diff/86400000),h=Math.floor((diff%86400000)/3600000);
    var m=Math.floor((diff%3600000)/60000),s=Math.floor((diff%60000)/1000);
    var cd=document.getElementById('cd-d'),ch=document.getElementById('cd-h'),cm=document.getElementById('cd-m'),cs=document.getElementById('cd-s');
    if(cd){cd.textContent=String(d).padStart(2,'0');ch.textContent=String(h).padStart(2,'0');cm.textContent=String(m).padStart(2,'0');cs.textContent=String(s).padStart(2,'0');}
  }
  tick();setInterval(tick,1000);
})();
<% } %>

function selectTipo(tipo){
  document.getElementById('campo-tipo').value=tipo;
  document.getElementById('opt-ucp').classList.toggle('sel',tipo==='ucp');
  document.getElementById('opt-externo').classList.toggle('sel',tipo==='externo');
  const cc=document.getElementById('campo-catraca'),ci=document.getElementById('campo-instituicao');
  const ic=document.getElementById('inp-catraca'),ii=document.getElementById('inp-instituicao');
  if(tipo==='ucp'){cc.style.display='block';ci.style.display='none';ic.required=true;ii.required=false;ii.value='';}
  else{cc.style.display='none';ci.style.display='block';ic.required=false;ic.value='';ii.required=true;}
}
function abrirForm(){
  const fs=document.getElementById('form-sec');
  fs.classList.add('open');
  setTimeout(()=>fs.scrollIntoView({behavior:'smooth',block:'start'}),100);
}
function aplicarCupom(){
  const cod=document.getElementById('cupom-in').value.trim();
  const msg=document.getElementById('cupom-msg');
  if(!cod){msg.style.display='none';return;}
  fetch('/eventos/<%= evento.id %>/cupom?cod='+encodeURIComponent(cod))
    .then(r=>r.json()).then(d=>{
      msg.style.display='block';
      if(d.ok){desconto=d.desconto||0;msg.className='cupom-ok';msg.textContent='Cupom aplicado — '+Math.round(desconto*100)+'% de desconto';document.getElementById('campo-cupom').value=cod;updRes(lotesData.find(x=>x.id==loteId));}
      else{msg.className='cupom-err';msg.textContent=d.msg||'Cupom inválido ou expirado';}
    }).catch(()=>{document.getElementById('cupom-msg').className='cupom-err';document.getElementById('cupom-msg').textContent='Erro ao verificar o cupom';document.getElementById('cupom-msg').style.display='block';});
}
function togProg(i){
  const item=document.getElementById('prog-item-'+i),desc=document.getElementById('prog-desc-'+i);
  if(!desc)return;
  const open=desc.classList.toggle('open');
  item.classList.toggle('open',open);
}
function togPales(i){
  const card=document.getElementById('pales-'+i),bio=document.getElementById('pbio-'+i);
  if(!bio)return;
  const open=bio.classList.toggle('open');
  card.classList.toggle('open',open);
}
function togForm(){
  const f=document.getElementById('c-form'),a=document.getElementById('form-arrow');
  const open=f.classList.toggle('open');
  if(a)a.style.transform=open?'rotate(180deg)':'';
}
function abrirModal(id){document.getElementById(id)?.classList.add('open');}
function fecharModal(id){document.getElementById(id)?.classList.remove('open');}
const l0=lotesData.find(x=>x.id==loteId);updRes(l0);
</script>
</body>
</html>
