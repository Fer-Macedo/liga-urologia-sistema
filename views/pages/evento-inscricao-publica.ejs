  <strong>LAURO</strong> — Liga Académica de Urología · Universidad Central del Paraguay<br>
  <span style="margin-top:4px;display:block">lauroucpcde@lauroucpcde.com · +595 994 225 753</span>
</footer>

<script>
const lotesData = <%- JSON.stringify(lotes) %>;
let qtyAtual = 1;
let loteSelecionadoId = <%= lotes[0]?.id || 'null' %>;
let precoBase = <%= parseFloat(lotes[0]?.preco||0) %>;
let desconto = 0;

function selecionarLote(id, el) {
  document.querySelectorAll('.lote').forEach(e=>{
    e.classList.remove('ativo');
    const chk=e.querySelector('.lote-check');
    if(chk)chk.textContent='';
    const qw=e.querySelector('.qty-wrap');
    if(qw)qw.remove();
  });
  el.classList.add('ativo');
  const chk=el.querySelector('.lote-check');
  if(chk)chk.textContent='✓';
  document.getElementById('lote_selecionado').value=id;
  loteSelecionadoId=id;
  const l=lotesData.find(x=>x.id==id);
  precoBase=l?parseFloat(l.preco):0;
  // Adiciona qty
  if(!el.querySelector('.qty-wrap')){
    const qw=document.createElement('div');
    qw.className='qty-wrap';
    qw.id='qty-wrap-'+id;
    qw.innerHTML='<button type="button" class="qty-btn" onclick="event.stopPropagation();alterarQty(-1)">−</button><span class="qty-num" id="qty-num">'+qtyAtual+'</span><button type="button" class="qty-btn" onclick="event.stopPropagation();alterarQty(1)">+</button><span class="qty-label">ingresso(s)</span>';
    el.appendChild(qw);
  }
  atualizarResumo(l);
}

function alterarQty(delta) {
  qtyAtual = Math.max(1, Math.min(10, qtyAtual + delta));
  const el=document.getElementById('qty-num');
  if(el)el.textContent=qtyAtual;
  document.getElementById('campo-qty').value=qtyAtual;
  const l=lotesData.find(x=>x.id==loteSelecionadoId);
  atualizarResumo(l);
  atualizarParticipantes();
}

function atualizarResumo(l) {
  const nome=l?l.nome:'';
  const preco=precoBase*(1-desconto)*qtyAtual;
  document.getElementById('resumo-nome').textContent=nome;
  document.getElementById('resumo-preco').textContent=preco===0?'Gratuito':'R$ '+preco.toFixed(2);
  document.getElementById('resumo-qty').textContent=qtyAtual+' ingresso'+(qtyAtual>1?'s':'');
}

function atualizarParticipantes() {
  const wrap=document.getElementById('participantes-wrap');
  const atual=wrap.querySelectorAll('.participante-bloco').length;
  if(qtyAtual>atual){
    for(let i=atual+1;i<=qtyAtual;i++){
      const div=document.createElement('div');
      div.className='participante-bloco';
      div.id='part-'+i;
      div.innerHTML='<div class="participante-titulo"><div class="participante-num">'+i+'</div> Participante '+i+'</div><div class="input-grid"><div class="campo" style="grid-column:1/-1"><label>Nome Completo <span class="req">*</span></label><input name="nome_'+i+'" class="input" required placeholder="Nome completo"></div><div class="campo"><label>Email <span class="req">*</span></label><input name="email_'+i+'" class="input" type="email" required placeholder="email@exemplo.com"></div><div class="campo"><label>WhatsApp</label><input name="whatsapp_'+i+'" class="input" placeholder="+595 99 999 9999"></div></div>';
      wrap.appendChild(div);
    }
  } else {
    for(let i=atual;i>qtyAtual;i--){
      const el=document.getElementById('part-'+i);
      if(el)el.remove();
    }
  }
}

function mostrarForm() {
  const fs=document.getElementById('form-section');
  fs.classList.add('visivel');
  setTimeout(()=>fs.scrollIntoView({behavior:'smooth',block:'start'}),100);
}

function aplicarCupom() {
  const cod=document.getElementById('cupom-input').value.trim();
  const msg=document.getElementById('cupom-msg');
  if(!cod){msg.style.display='none';return;}
  // Simulação - integrar com backend
  fetch('/eventos/<%= evento.id %>/cupom?cod='+encodeURIComponent(cod))
    .then(r=>r.json())
    .then(d=>{
      msg.style.display='block';
      if(d.ok){
        desconto=d.desconto||0;
        msg.textContent='✅ Cupom aplicado! '+Math.round(desconto*100)+'% de desconto';
        msg.className='cupom-ok';
        document.getElementById('campo-cupom').value=cod;
        const l=lotesData.find(x=>x.id==loteSelecionadoId);
        atualizarResumo(l);
      } else {
        msg.textContent='❌ Cupom inválido ou expirado';
        msg.className='cupom-erro';
      }
    }).catch(()=>{msg.textContent='❌ Erro ao verificar cupom';msg.style.display='block';msg.className='cupom-erro';});
}

// Mostra form ao clicar em inscrever
document.querySelector('a[href="#form-section"]')?.addEventListener('click', mostrarForm);
</script>
</body>
</html>
