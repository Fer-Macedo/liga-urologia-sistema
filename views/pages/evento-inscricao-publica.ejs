<div class="wrap">
  <div class="grid">
    <!-- COLUNA ESQUERDA -->
    <div>

      <!-- SOBRE -->
      <% if(evento.descricao){%>
      <div class="card">
        <div class="card-hd"><h2>Sobre o Evento</h2></div>
        <div class="card-bd" style="font-size:14px;line-height:1.8;color:var(--g700);text-align:justify"><%- evento.descricao %></div>
      </div>
      <%}%>

      <!-- INGRESSOS -->
      <% if(lotes.length>0){%>
      <div class="card" id="inscricao">
        <div class="card-hd"><div><h2>🎫 Ingressos</h2><p style="font-size:12px;color:var(--g400)">Selecione o ingresso desejado</p></div></div>
        <div class="card-bd">
          <% lotes.forEach((l,i)=>{%>
          <div class="lote <%= i===0?'sel':'' %>" id="lote-<%= l.id %>" onclick="selLote(<%= l.id %>,this)">
            <div class="lote-top">
              <div style="flex:1">
                <div class="lote-nome"><%= l.nome %></div>
                <% if(l.data_fim){%><div class="lote-info">Até <%= new Date(l.data_fim).toLocaleDateString('pt-BR') %></div><%}%>
              </div>
              <div style="display:flex;align-items:center;gap:12px">
                <% if(parseFloat(l.preco)===0){%><span class="badge-free">GRATUITO</span><%}else{%><div class="lote-preco">R$ <%= Number(l.preco).toFixed(2) %></div><%}%>
                <div class="lote-radio"></div>
              </div>
            </div>
          </div>
          <%})%>

          <!-- CUPOM -->
          <div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--g100)">
            <div style="font-size:13px;font-weight:600;color:var(--g700);margin-bottom:8px">🏷️ Cupom de Desconto</div>
            <div class="cupom-row">
              <input id="cupom-in" class="cupom-in" placeholder="Código do cupom..." oninput="this.value=this.value.toUpperCase()">
              <button type="button" class="cupom-btn" onclick="aplicarCupom()">Aplicar</button>
            </div>
            <div id="cupom-msg" style="display:none"></div>
          </div>

          <button class="btn-prox" onclick="abrirForm()">Prosseguir com a Inscrição →</button>
        </div>
      </div>
      <%}%>

      <!-- FORMULÁRIO ANIMADO -->
      <div class="form-sec" id="form-sec">
        <div class="card">
          <div class="card-hd"><div><h2>📝 Dados do Participante</h2><p style="font-size:12px;color:var(--g400)">Preencha todos os dados obrigatórios</p></div></div>
          <div class="card-bd">
            <form action="/inscricao/<%= evento.id %>" method="POST" id="form-ins">
              <input type="hidden" name="lote_id" id="lote-sel" value="<%= lotes[0]?.id %>">
              <input type="hidden" name="cupom" id="campo-cupom" value="">
              <input type="hidden" name="tipo_participante" id="campo-tipo" value="ucp">

              <!-- TIPO DE PARTICIPANTE -->
              <div style="margin-bottom:16px">
                <div style="font-size:13px;font-weight:600;color:var(--g700);margin-bottom:10px">Você é:</div>
                <div class="tipo-participante">
                  <div class="tipo-opt sel" id="opt-ucp" onclick="selectTipo('ucp')">
                    <div class="tipo-icon">🎓</div>
                    <div class="tipo-label">Aluno UCP</div>
                    <div class="tipo-sub">Universidad Central del Paraguay</div>
                  </div>
                  <div class="tipo-opt" id="opt-externo" onclick="selectTipo('externo')">
                    <div class="tipo-icon">🌐</div>
                    <div class="tipo-label">Externo</div>
                    <div class="tipo-sub">Outra instituição</div>
                  </div>
                </div>
              </div>

              <div class="part-bloco">
                <div class="grid2">
                  <div class="campo" style="grid-column:1/-1">
                    <label>Nome Completo <span class="req">*</span></label>
                    <input name="nome" class="inp" required placeholder="Seu nome completo">
                  </div>
                  <div class="campo">
                    <label>Email <span class="req">*</span></label>
                    <input name="email" class="inp" type="email" required placeholder="email@exemplo.com">
                  </div>
                  <div class="campo">
                    <label>WhatsApp <span class="req">*</span></label>
                    <div style="display:flex;gap:6px">
                      <select name="whatsapp_pais" class="inp" style="max-width:88px">
                        <option value="+595">🇵🇾 +595</option>
                        <option value="+55">🇧🇷 +55</option>
                        <option value="+54">🇦🇷 +54</option>
                        <option value="+598">🇺🇾 +598</option>
                        <option value="+1">🇺🇸 +1</option>
                      </select>
                      <input name="whatsapp" class="inp" placeholder="99 999 9999" required style="flex:1">
                    </div>
                  </div>
                  <div class="campo">
                    <label>Data de Nascimento <span class="req">*</span></label>
                    <input type="date" name="data_nascimento" class="inp" required>
                  </div>
                  <div class="campo">
                    <label>RG / CI <span class="req">*</span></label>
                    <input name="rg" class="inp" required placeholder="Número do documento">
                  </div>

                  <!-- CATRACA — só para alunos UCP -->
                  <div class="campo" id="campo-catraca">
                    <label>Catraca UCP <span class="req">*</span></label>
                    <input name="catraca" id="inp-catraca" class="inp" required placeholder="Número da catraca">
                  </div>

                  <!-- INSTITUIÇÃO — só para externos -->
                  <div class="campo" id="campo-instituicao" style="display:none">
                    <label>Instituição <span class="req">*</span></label>
                    <input name="instituicao" id="inp-instituicao" class="inp" placeholder="Nome da sua universidade/instituição">
                  </div>

                  <div class="campo">
                    <label>Semestre <span class="req">*</span></label>
                    <select name="semestre" class="inp" required>
                      <option value="">Selecione...</option>
                      <% for(let s=1;s<=10;s++){%><option value="<%= s %>º"><%= s %>º Semestre</option><%}%>
                    </select>
                  </div>
                  <div class="campo">
                    <label>Turma <span class="req">*</span></label>
                    <select name="turma" class="inp" required>
                      <option value="">Selecione...</option>
                      <% 'ABCDEFGHIJKLMNOP'.split('').forEach(t=>{%><option value="<%= t %>">Turma <%= t %></option><%})%>
                    </select>
                  </div>
                </div>

                <!-- CAMPOS EXTRAS -->
                <% if(campos&&campos.length>0){campos.forEach(campo=>{%>
                <div class="campo">
                  <label><%= campo.label %><% if(campo.obrigatorio){%><span class="req"> *</span><%}%></label>
                  <% if(campo.tipo==='select'){%>
                  <select name="campo_<%= campo.id %>" class="inp" <%= campo.obrigatorio?'required':'' %>><option value="">Selecione...</option><% (campo.opcoes||'').split('\n').filter(o=>o.trim()).forEach(op=>{%><option value="<%= op.trim() %>"><%= op.trim() %></option><%})%></select>
                  <%}else if(campo.tipo==='textarea'){%><textarea name="campo_<%= campo.id %>" class="inp" rows="3" <%= campo.obrigatorio?'required':'' %>></textarea>
                  <%}else{%><input type="<%= campo.tipo==='email'?'email':campo.tipo==='number'?'number':campo.tipo==='date'?'date':'text' %>" name="campo_<%= campo.id %>" class="inp" <%= campo.obrigatorio?'required':'' %>><%}%>
                </div>
                <%})}%>
              </div>

              <!-- TERMOS -->
              <div style="background:var(--g50);border:1.5px solid var(--g200);border-radius:10px;padding:14px;margin-top:14px">
                <% if(evento.termos_texto){%>
                <div class="termo-check">
                  <input type="checkbox" name="aceite_termos" required>
                  <span>Li e concordo com os <span class="termo-link" onclick="abrirModal('modal-termos')">Termos de Compra e Participação</span> <span class="req">*</span></span>
                </div>
                <%}%>
                <div class="termo-check">
                  <input type="checkbox" name="aceite_lgpd" required>
                  <span>Li e aceito a <span class="termo-link" onclick="abrirModal('modal-lgpd')">Política de Privacidade e LGPD</span> <span class="req">*</span></span>
                </div>
              </div>

              <button type="submit" class="btn-sub">Confirmar Inscrição →</button>
              <div class="secure">🔒 Seus dados estão protegidos</div>
            </form>
          </div>
        </div>
      </div>

      <!-- PROGRAMAÇÃO -->
      <% if(programacao&&programacao.length>0){%>
      <div class="card">
        <div class="card-hd"><h2>🗓️ Programação</h2></div>
        <div class="card-bd">
          <% programacao.forEach((p,i)=>{%>
          <div class="prog-acc">
            <div class="prog-hd" onclick="togProg(this,<%= i %>)">
              <div class="prog-info">
                <div class="prog-titulo"><%= p.titulo %></div>
                <div class="prog-hora">⏰ <%= p.horario %><% if(p.local){%> · 📍 <%= p.local %><%}%></div>
              </div>
              <% if(p.descricao){%><span class="prog-arrow">▼</span><%}%>
            </div>
            <% if(p.descricao){%>
            <div class="prog-body" id="prog-<%= i %>"><div class="prog-desc"><%= p.descricao %></div></div>
            <%}%>
          </div>
          <%})%>
        </div>
      </div>
      <%}%>

      <!-- PALESTRANTES -->
      <% if(palestrantes&&palestrantes.length>0){%>
      <div class="card">
        <div class="card-hd"><h2>🎤 Palestrantes</h2></div>
        <div class="card-bd">
          <div class="pales-grid">
            <% palestrantes.forEach((p,i)=>{%>
            <div class="pales-card" id="pales-<%= i %>" onclick="togPales(<%= i %>)">
              <% if(p.foto_chave){%>
              <img src="/eventos/palestrantes/<%= p.id %>/foto" class="pales-foto" alt="<%= p.nome %>">
              <%}else{%>
              <div class="pales-ph">🎤</div>
              <%}%>
              <div class="pales-nome"><%= p.nome %></div>
              <% if(p.instituicao){%><div class="pales-inst"><%= p.instituicao %></div><%}%>
              <% if(p.bio){%>
              <div class="pales-bio-wrap" id="pbio-<%= i %>"><div class="pales-bio"><%= p.bio %></div></div>
              <%}%>
            </div>
            <%})%>
          </div>
        </div>
      </div>
      <%}%>

      <!-- CONTATO -->
      <div class="card" id="contato">
        <div class="card-hd"><h2>💬 Contato</h2></div>
        <div class="card-bd">
          <div class="contato-btns">
            <a href="mailto:lauroucpcde@lauroucpcde.com" class="c-btn">
              <div class="c-icon" style="background:#fee2e2">✉️</div>
              <div><div style="font-size:10px;color:var(--g400);font-weight:600;text-transform:uppercase">Email</div>lauroucpcde@lauroucpcde.com</div>
            </a>
            <a href="https://wa.me/595994225753" target="_blank" class="c-btn">
              <div class="c-icon" style="background:#dcfce7"><svg style="width:18px;height:18px;fill:#25d366" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div>
              <div><div style="font-size:10px;color:var(--g400);font-weight:600;text-transform:uppercase">WhatsApp</div>+595 994 225 753</div>
            </a>
            <div class="c-btn" onclick="togForm()">
              <div class="c-icon" style="background:#eff6ff">✉️</div>
              <div><div style="font-size:10px;color:var(--g400);font-weight:600;text-transform:uppercase">Mensagem</div>Enviar mensagem para nossa equipe</div>
              <span id="form-arrow" style="margin-left:auto;font-size:12px;color:var(--g400);transition:.3s">▼</span>
            </div>
          </div>
          <div class="c-form" id="c-form">
            <form action="/contato-evento/<%= evento.id %>" method="POST">
              <input name="nome" class="c-inp" placeholder="Seu nome" required>
              <input name="email" type="email" class="c-inp" placeholder="Seu email" required>
              <textarea name="mensagem" class="c-inp" rows="3" placeholder="Sua mensagem..." style="resize:vertical" required></textarea>
              <button type="submit" class="c-send">Enviar →</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">

      <!-- RESUMO INGRESSO -->
      <% if(lotes.length>0){%>
      <div class="resumo-card">
        <div class="resumo-label">Ingresso Selecionado</div>
        <div class="resumo-nome" id="res-nome"><%= lotes[0]?.nome %></div>
        <div class="resumo-preco" id="res-preco"><%= parseFloat(lotes[0]?.preco||0)===0?'Gratuito':'R$ '+Number(lotes[0]?.preco||0).toFixed(2) %></div>
        <button class="resumo-btn" onclick="abrirForm()">Garantir Minha Vaga →</button>
      </div>
      <%}%>

      <!-- INFO -->
      <div class="s-card">
        <div class="s-title">Informações</div>

        <% if(evento.data_inicio){%>
        <div class="info-it">
          <div class="i-icon">📅</div>
          <div>
            <div class="i-lbl">Data</div>
            <div class="i-val"><%= new Date(evento.data_inicio).toLocaleDateString('pt-BR',{day:'2-digit',month:'long',year:'numeric'}) %></div>
          </div>
        </div>
        <%}%>

        <% if(evento.data_inicio){%>
        <div class="info-it">
          <div class="i-icon">⏰</div>
          <div>
            <div class="i-lbl">Início</div>
            <div class="i-val"><%= new Date(evento.data_inicio).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}) %> h</div>
          </div>
        </div>
        <%}%>

        <div class="info-it">
          <div class="i-icon"><%= evento.tipo_evento==='online'?'💻':evento.tipo_evento==='hibrido'?'🔀':'📍' %></div>
          <div>
            <div class="i-lbl">Modalidade</div>
            <div class="i-val"><%= evento.tipo_evento==='online'?'Online':evento.tipo_evento==='hibrido'?'Híbrido':'Presencial' %></div>
          </div>
        </div>

        <% if(evento.local&&evento.tipo_evento!=='online'){%>
        <div class="info-it">
          <div class="i-icon">📍</div>
          <div>
            <div class="i-lbl">Local</div>
            <div class="i-val"><%= evento.local %></div>
            <% if(evento.endereco){%><div class="i-sub"><%= evento.endereco %></div><%}%>
          </div>
        </div>
        <%}%>

        <% if(evento.carga_horaria){%>
        <div class="info-it">
          <div class="i-icon">🏆</div>
          <div>
            <div class="i-lbl">Certificado</div>
            <div class="i-val"><%= evento.carga_horaria %> horas</div>
          </div>
        </div>
        <%}%>

        <div class="org-box">
          <div class="org-logo"><% if(config&&config.org_logo){%><img src="<%= config.org_logo %>" alt="LAURO"><%}else{%><span style="color:white;font-weight:800;font-size:14px">L</span><%}%></div>
          <div><div style="font-weight:700;font-size:13px">LAURO</div><div style="font-size:11px;color:var(--g600)">Liga Académica de Urología</div></div>
