        <div id="res-qty" style="font-size:11px;color:rgba(255,255,255,.5);margin-top:3px;position:relative;z-index:1"></div>
        <div class="resumo-preco" id="res-preco"><%= parseFloat(lotes[0]?.preco||0)===0?'Gratuito':'R$ '+Number(lotes[0]?.preco||0).toFixed(2).replace('.',',') %></div>
