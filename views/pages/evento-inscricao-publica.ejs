<script>
const lotesData = <%- JSON.stringify(lotes) %>;
let loteId = <%= lotes[0]?.id||'null' %>;
let precoBase = <%= parseFloat(lotes[0]?.preco||0) %>;
let desconto = 0;
let tipoParticipante = 'ucp';

// TIPO PARTICIPANTE
function selectTipo(tipo) {
  tipoParticipante = tipo;
  document.getElementById('campo-tipo').value = tipo;
  document.getElementById('opt-ucp').classList.toggle('sel', tipo === 'ucp');
  document.getElementById('opt-externo').classList.toggle('sel', tipo === 'externo');

  const camCatraca = document.getElementById('campo-catraca');
  const camInstit  = document.getElementById('campo-instituicao');
  const inpCatraca = document.getElementById('inp-catraca');
  const inpInstit  = document.getElementById('inp-instituicao');

  if (tipo === 'ucp') {
    camCatraca.style.display = 'block';
    camInstit.style.display  = 'none';
    inpCatraca.required = true;
    inpInstit.required  = false;
    inpInstit.value = '';
  } else {
    camCatraca.style.display = 'none';
    camInstit.style.display  = 'block';
    inpCatraca.required = false;
    inpInstit.required  = true;
    inpCatraca.value = '';
  }
}

// SELECIONAR LOTE
function selLote(id, el) {
  document.querySelectorAll('.lote').forEach(e => e.classList.remove('sel'));
  el.classList.add('sel');
  document.getElementById('lote-sel').value = id;
  loteId = id;
  const l = lotesData.find(x => x.id == id);
  precoBase = l ? parseFloat(l.preco) : 0;
  updRes(l);
}

function updRes(l) {
  if (!document.getElementById('res-nome')) return;
  const p = precoBase * (1 - desconto);
  document.getElementById('res-nome').textContent = l ? l.nome : '';
  document.getElementById('res-preco').textContent = p === 0 ? 'Gratuito' : 'R$ ' + p.toFixed(2);
}

// ABRIR FORM
function abrirForm() {
  const fs = document.getElementById('form-sec');
  fs.classList.add('open');
  setTimeout(() => fs.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
}

// CUPOM
function aplicarCupom() {
  const cod = document.getElementById('cupom-in').value.trim();
  const msg = document.getElementById('cupom-msg');
  if (!cod) { msg.style.display = 'none'; return; }
  fetch('/eventos/<%= evento.id %>/cupom?cod=' + encodeURIComponent(cod))
    .then(r => r.json()).then(d => {
      msg.style.display = 'block';
      if (d.ok) {
        desconto = d.desconto || 0;
        msg.className = 'cupom-ok';
        msg.textContent = '✅ Cupom aplicado! ' + Math.round(desconto * 100) + '% de desconto';
        document.getElementById('campo-cupom').value = cod;
        const l = lotesData.find(x => x.id == loteId);
        updRes(l);
      } else {
        msg.className = 'cupom-err';
        msg.textContent = '❌ ' + (d.msg || 'Cupom inválido ou expirado');
      }
    }).catch(() => {
      document.getElementById('cupom-msg').className = 'cupom-err';
      document.getElementById('cupom-msg').textContent = '❌ Erro ao verificar';
      document.getElementById('cupom-msg').style.display = 'block';
    });
}

// PROGRAMAÇÃO
function togProg(el, i) {
  const body = document.getElementById('prog-' + i);
  if (!body) return;
  const open = body.classList.toggle('open');
  el.classList.toggle('open', open);
}

// PALESTRANTES
function togPales(i) {
  const card = document.getElementById('pales-' + i);
  const bio  = document.getElementById('pbio-' + i);
  if (!bio) return;
  const open = bio.classList.toggle('open');
  card.classList.toggle('open', open);
}

// CONTATO FORM
function togForm() {
  const f = document.getElementById('c-form');
  const a = document.getElementById('form-arrow');
  const open = f.classList.toggle('open');
  if (a) a.style.transform = open ? 'rotate(180deg)' : '';
}

// MODAIS
function abrirModal(id) { document.getElementById(id)?.classList.add('open'); }
function fecharModal(id) { document.getElementById(id)?.classList.remove('open'); }

// Init
const l0 = lotesData.find(x => x.id == loteId);
updRes(l0);
</script>
</body>
</html>
