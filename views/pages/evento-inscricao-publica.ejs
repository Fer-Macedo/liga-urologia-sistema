<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — LAURO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Inter:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --p: <%= evento.cor_tema||'#1d4ed8' %>;
      --p-light: color-mix(in srgb,<%= evento.cor_tema||'#1d4ed8' %> 8%,white);
      --p-mid: color-mix(in srgb,<%= evento.cor_tema||'#1d4ed8' %> 18%,white);
      --ink: #111827; --ink2: #374151; --ink3: #6b7280; --ink4: #9ca3af;
      --sur: #ffffff; --sur2: #f5f5f0; --sur3: #f3f4f6;
      --bdr: #e5e7eb; --bdr2: #d1d5db;
      --sh: 0 1px 3px rgba(0,0,0,.06),0 4px 12px rgba(0,0,0,.05);
      --sh-sm: 0 1px 2px rgba(0,0,0,.05);
      --sh-lg: 0 10px 40px rgba(0,0,0,.12),0 2px 8px rgba(0,0,0,.06);
      --r: 12px; --r-sm: 8px; --r-lg: 16px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{font-family:'Inter',sans-serif;background:var(--sur2);color:var(--ink);line-height:1.6;-webkit-font-smoothing:antialiased}

    /* NAV */
    nav{background:rgba(255,255,255,.93);backdrop-filter:blur(20px);border-bottom:1px solid var(--bdr);position:sticky;top:0;z-index:200}
    .nav-in{max-width:1160px;margin:0 auto;padding:0 28px;height:62px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .nav-logo-mark{width:34px;height:34px;border-radius:9px;background:var(--p);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .nav-logo-mark svg{width:18px;height:18px;fill:white}
    .nav-logo-txt{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:22px;color:var(--p);letter-spacing:.5px;font-style:italic}
    .nav-links{display:flex;gap:6px;align-items:center}
    .nav-a{font-size:13px;font-weight:500;color:var(--ink2);text-decoration:none;padding:6px 12px;border-radius:7px;transition:background .18s,color .18s}
    .nav-a:hover{background:var(--sur3);color:var(--ink)}
    .nav-cta{background:var(--p);color:white;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;transition:opacity .18s,transform .18s}
    .nav-cta:hover{opacity:.88;transform:translateY(-1px)}

    /* BANNER */
    .banner-wrap{width:100%;position:relative;background:var(--ink);overflow:hidden;max-height:480px}
    .banner-img{width:100%;max-height:480px;object-fit:cover;display:block;opacity:.88}
    .banner-ph{height:320px;background:linear-gradient(135deg,var(--p) 0%,color-mix(in srgb,var(--p) 60%,#000) 100%);display:flex;align-items:center;justify-content:center}
    .banner-ph-icon{width:80px;height:80px;border-radius:20px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center}
    .banner-ph-icon svg{width:40px;height:40px;fill:rgba(255,255,255,.6)}
    .banner-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.55) 0%,transparent 50%)}
    .banner-badge{position:absolute;top:22px;left:28px;background:rgba(255,255,255,.15);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.25);color:white;font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;letter-spacing:.6px;text-transform:uppercase}

    /* TÍTULO */
    .title-wrap{background:var(--sur);border-bottom:1px solid var(--bdr);padding:28px 0 24px}
    .title-in{max-width:1160px;margin:0 auto;padding:0 28px}
    .event-tag{display:inline-flex;align-items:center;gap:6px;background:var(--p-light);color:var(--p);border:1px solid color-mix(in srgb,var(--p) 20%,transparent);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:12px}
    .event-tag svg{width:12px;height:12px;fill:currentColor}
    .title-in h1{font-family:'Cormorant Garamond',serif;font-size:clamp(22px,4vw,38px);font-weight:700;color:var(--ink);line-height:1.2;letter-spacing:-.5px;margin-bottom:14px}
    .title-meta{display:flex;flex-wrap:wrap;gap:20px}
    .t-chip{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ink2);font-weight:500}
    .t-chip-icon{width:28px;height:28px;border-radius:7px;background:var(--sur3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .t-chip-icon svg{width:14px;height:14px;fill:var(--ink3)}

    /* WPP BANNER */
    .wpp-banner{background:linear-gradient(90deg,#0a7a6e 0%,#25d366 100%);padding:13px 0}
    .wpp-in{max-width:1160px;margin:0 auto;padding:0 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
    .wpp-txt{color:white;font-size:13px;font-weight:500;display:flex;align-items:center;gap:9px}
    .wpp-txt svg{width:18px;height:18px;fill:white;flex-shrink:0}
    .wpp-join{background:white;color:#0a7a6e;padding:7px 18px;border-radius:7px;font-weight:700;font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px;transition:transform .18s,box-shadow .18s;white-space:nowrap}
    .wpp-join:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.15)}
    .wpp-join svg{width:14px;height:14px;fill:#0a7a6e}

    /* LAYOUT */
    .wrap{max-width:1160px;margin:0 auto;padding:32px 28px 80px}
    .grid{display:grid;grid-template-columns:1fr 380px;gap:28px;align-items:start}
    @media(max-width:920px){.grid{grid-template-columns:1fr}.sidebar{order:-1}}
    @media(max-width:600px){.wrap{padding:20px 16px 60px}.nav-in{padding:0 16px}}

    /* CARD */
    .card{background:var(--sur);border-radius:var(--r-lg);box-shadow:var(--sh);border:1px solid var(--bdr);overflow:hidden;margin-bottom:20px}
    .card-hd{padding:20px 26px 16px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
    .card-hd-l{display:flex;align-items:center;gap:10px}
    .card-hd-ic{width:32px;height:32px;border-radius:8px;background:var(--p-light);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .card-hd-ic svg{width:15px;height:15px;fill:var(--p)}
    .card-hd h2{font-size:14px;font-weight:700;color:var(--ink);letter-spacing:-.1px}
    .card-hd p{font-size:11px;color:var(--ink3);margin-top:1px}
    .card-bd{padding:22px 26px}

    /* LOTES — estilo premium com barra lateral */
    .lote{border:1.5px solid var(--bdr);border-radius:var(--r);padding:16px 18px;margin-bottom:10px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
    .lote::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--bdr);transition:background .2s;border-radius:4px 0 0 4px}
    .lote:hover{border-color:var(--p);box-shadow:0 0 0 3px var(--p-light)}
    .lote:hover::before{background:var(--p)}
    .lote.sel{border-color:var(--p);background:var(--p-light);box-shadow:0 0 0 3px color-mix(in srgb,var(--p) 10%,transparent)}
    .lote.sel::before{background:var(--p)}
    .lote-top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
    .lote-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;margin-bottom:5px}
    .lote-badge-pop{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
    .lote-badge-hot{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;display:inline-flex;align-items:center;gap:5px}
    .lote-nome{font-weight:700;font-size:14px;color:var(--ink)}
    .lote-info{font-size:11px;color:var(--ink4);margin-top:3px}
    .lote-preco-wrap{text-align:right;flex-shrink:0}
    .lote-preco{font-family:'Inter',sans-serif;font-size:22px;font-weight:800;color:var(--p);white-space:nowrap;line-height:1;letter-spacing:-.5px}
    .lote-preco-sub{font-size:10px;color:var(--ink4);margin-top:3px}
    .badge-free{background:#dcfce7;color:#15803d;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700}
    .lote-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--bdr2);flex-shrink:0;transition:all .2s;display:flex;align-items:center;justify-content:center;margin-top:3px}
    .lote.sel .lote-radio{border-color:var(--p);background:var(--p)}
    .lote.sel .lote-radio::after{content:'';width:6px;height:6px;border-radius:50%;background:white}

    /* QUANTIDADE INGRESSO */
    .lote-qty{display:flex;align-items:center;gap:10px;margin-top:12px;padding-top:12px;border-top:1px solid var(--bdr)}
    .lote-qty-label{font-size:12px;color:var(--ink3);font-weight:500;flex:1}
    .qty-ctrl{display:flex;align-items:center;gap:0;border:2px solid var(--p);border-radius:9px;overflow:hidden;background:var(--sur)}
    .qty-btn{width:36px;height:36px;border:none;background:var(--p);cursor:pointer;font-size:20px;font-weight:400;color:white;display:flex;align-items:center;justify-content:center;transition:opacity .15s;user-select:none;font-family:'Inter',sans-serif;flex-shrink:0}
    .qty-btn:hover{opacity:.85}
    .qty-btn:disabled{opacity:.35;cursor:not-allowed}
    .qty-num{width:44px;height:36px;text-align:center;font-size:15px;font-weight:800;color:var(--p);border:none;border-left:2px solid var(--p);border-right:2px solid var(--p);background:white;font-family:'Inter',sans-serif;pointer-events:none}
    .cupom-sec{margin-top:16px;padding-top:16px;border-top:1px solid var(--bdr)}
    .cupom-lbl{font-size:12px;font-weight:600;color:var(--ink2);margin-bottom:8px}
    .cupom-row{display:flex;gap:8px}
    .cupom-in{flex:1;padding:10px 13px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);font-size:13px;font-family:'DM Mono',monospace;color:var(--ink);background:var(--sur);transition:border-color .18s;letter-spacing:1px}
    .cupom-in:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px var(--p-light)}
    .cupom-btn{padding:10px 18px;background:var(--sur3);border:1.5px solid var(--bdr);border-radius:var(--r-sm);font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;color:var(--ink2);transition:all .18s;white-space:nowrap}
    .cupom-btn:hover{background:var(--p);color:white;border-color:var(--p)}
    .cupom-ok{font-size:12px;color:#15803d;background:#dcfce7;padding:6px 10px;border-radius:6px;margin-top:6px;font-weight:500}
    .cupom-err{font-size:12px;color:#b91c1c;background:#fee2e2;padding:6px 10px;border-radius:6px;margin-top:6px}

    .btn-prox{width:100%;padding:15px;background:var(--p);color:white;border:none;border-radius:var(--r);font-size:15px;font-weight:600;cursor:pointer;margin-top:16px;font-family:'Inter',sans-serif;transition:opacity .18s,transform .18s,box-shadow .18s;letter-spacing:.1px}
    .btn-prox:hover{opacity:.9;transform:translateY(-2px)}

    /* FORM */
    .form-sec{overflow:hidden;max-height:0;opacity:0;transition:max-height .55s cubic-bezier(.4,0,.2,1),opacity .4s ease}
    .form-sec.open{max-height:6000px;opacity:1}
    .sec-title{font-size:11px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--bdr)}
    .tipo-participante{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
    .tipo-opt{border:1.5px solid var(--bdr);border-radius:var(--r);padding:14px 16px;cursor:pointer;transition:all .2s;text-align:center}
    .tipo-opt:hover{border-color:var(--p)}
    .tipo-opt.sel{border-color:var(--p);background:var(--p-light)}
    .tipo-ic{width:36px;height:36px;border-radius:9px;background:var(--sur3);margin:0 auto 8px;display:flex;align-items:center;justify-content:center}
    .tipo-opt.sel .tipo-ic{background:color-mix(in srgb,var(--p) 15%,white)}
    .tipo-ic svg{width:18px;height:18px;fill:var(--ink3)}
    .tipo-opt.sel .tipo-ic svg{fill:var(--p)}
    .tipo-lbl{font-size:13px;font-weight:700;color:var(--ink)}
    .tipo-sub{font-size:11px;color:var(--ink3);margin-top:2px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    @media(max-width:500px){.grid2{grid-template-columns:1fr}}
    .campo label{display:block;font-size:11px;font-weight:600;color:var(--ink2);margin-bottom:5px;letter-spacing:.2px}
    .req{color:#ef4444}
    .inp{width:100%;padding:10px 13px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);font-size:13px;font-family:'Inter',sans-serif;color:var(--ink);background:var(--sur);transition:border-color .18s,box-shadow .18s}
    .inp:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px var(--p-light)}
    .inp::placeholder{color:var(--ink4)}
    .inp-group{display:flex;gap:6px}
    .termos-box{background:var(--sur2);border:1px solid var(--bdr);border-radius:var(--r);padding:16px;margin-top:16px}
    .termo-check{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:13px;color:var(--ink2)}
    .termo-check:last-child{margin-bottom:0}
    .termo-check input{margin-top:2px;accent-color:var(--p);width:15px;height:15px;flex-shrink:0}
    .termo-link{color:var(--p);font-weight:600;text-decoration:underline;cursor:pointer;text-underline-offset:2px}
    .btn-sub{width:100%;padding:16px;background:var(--p);color:white;border:none;border-radius:var(--r);font-size:15px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;margin-top:16px;transition:opacity .18s,transform .18s}
    .btn-sub:hover{opacity:.9;transform:translateY(-2px)}
    .secure-note{text-align:center;font-size:11px;color:var(--ink4);margin-top:10px;display:flex;align-items:center;justify-content:center;gap:5px}
    .secure-note svg{width:12px;height:12px;fill:var(--ink4)}

    /* PROGRAMAÇÃO */
    .prog-item{border-left:2px solid var(--bdr);padding:12px 16px;margin-bottom:10px;border-radius:0 var(--r-sm) var(--r-sm) 0;background:var(--sur2);cursor:pointer;transition:border-color .2s,background .2s}
    .prog-item:hover,.prog-item.open{border-color:var(--p);background:var(--p-light)}
    .prog-item-hd{display:flex;justify-content:space-between;align-items:flex-start}
    .prog-hora{font-size:10px;font-weight:700;color:var(--p);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;font-family:'DM Mono',monospace}
    .prog-titulo{font-weight:600;font-size:14px;color:var(--ink)}
    .prog-chevron{color:var(--ink4);font-size:11px;transition:transform .25s;flex-shrink:0;margin-top:2px}
    .prog-item.open .prog-chevron{transform:rotate(180deg)}
    .prog-desc{max-height:0;overflow:hidden;transition:max-height .3s ease}
    .prog-desc.open{max-height:200px}
    .prog-desc-inner{font-size:13px;color:var(--ink2);line-height:1.6;padding-top:10px}

    /* PALESTRANTES — foto 130px quadrada */
    .pales-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:18px}
    .pales-card{border:1px solid var(--bdr);border-radius:var(--r-lg);padding:22px 16px;text-align:center;cursor:pointer;transition:all .22s;background:var(--sur)}
    .pales-card:hover{border-color:var(--p);box-shadow:var(--sh);transform:translateY(-3px)}
    .pales-card.open{border-color:var(--p);background:var(--p-light)}
    .pales-foto-wrap{position:relative;width:130px;height:130px;margin:0 auto 14px}
    .pales-foto{width:130px;height:130px;border-radius:18px;object-fit:cover;display:block;border:3px solid white;box-shadow:0 4px 16px rgba(0,0,0,.14)}
    .pales-foto-ring{position:absolute;inset:-3px;border-radius:21px;border:2px solid var(--p);opacity:0;transition:opacity .2s}
    .pales-card:hover .pales-foto-ring,.pales-card.open .pales-foto-ring{opacity:1}
    .pales-ph{width:130px;height:130px;border-radius:18px;background:var(--sur3);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;border:3px solid var(--bdr)}
    .pales-ph svg{width:52px;height:52px;fill:var(--ink4)}
    .pales-nome{font-weight:700;font-size:14px;color:var(--ink);line-height:1.3}
    .pales-inst{font-size:11px;color:var(--p);margin-top:4px;font-weight:600}
    .pales-bio-wrap{max-height:0;overflow:hidden;transition:max-height .3s ease}
    .pales-bio-wrap.open{max-height:500px}
    .pales-bio{padding:12px 0 4px;font-size:13px;color:var(--ink2);line-height:1.7;text-align:justify;border-top:1px solid color-mix(in srgb,var(--p) 20%,transparent);margin-top:12px}
    .pales-size-hint{font-size:10px;color:var(--ink4);text-align:center;margin-top:12px}

    /* CONTATO */
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:500px){.contact-grid{grid-template-columns:1fr}}
    .contact-btn{display:flex;align-items:center;gap:12px;padding:14px 16px;border-radius:var(--r);border:1px solid var(--bdr);text-decoration:none;color:var(--ink);font-size:13px;font-weight:500;transition:all .18s;cursor:pointer;background:var(--sur)}
    .contact-btn:hover{border-color:var(--p);background:var(--p-light);transform:translateY(-1px);box-shadow:var(--sh-sm)}
    .contact-ic{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .contact-ic svg{width:20px;height:20px}
    .contact-lbl{font-size:10px;color:var(--ink3);font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-bottom:1px}
    .contact-val{font-weight:600;font-size:13px;color:var(--ink)}
    .c-form{overflow:hidden;max-height:0;opacity:0;transition:max-height .4s ease,opacity .3s ease;margin-top:0}
    .c-form.open{max-height:500px;opacity:1;margin-top:14px}
    .c-inp{width:100%;padding:10px 13px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);font-size:13px;font-family:'Inter',sans-serif;margin-bottom:8px;transition:border-color .18s;color:var(--ink)}
    .c-inp:focus{outline:none;border-color:var(--p)}
    .c-send{width:100%;padding:11px;background:var(--p);color:white;border:none;border-radius:var(--r-sm);font-size:14px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif}

    /* SIDEBAR */
    .s-card{background:var(--sur);border-radius:var(--r-lg);box-shadow:var(--sh);border:1px solid var(--bdr);padding:22px;margin-bottom:18px}
    .s-title{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--bdr)}

    /* RESUMO */
    .resumo-card{border-radius:var(--r-lg);padding:22px;margin-bottom:18px;color:white;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--p) 0%,color-mix(in srgb,var(--p) 75%,#000) 100%);box-shadow:0 8px 28px color-mix(in srgb,var(--p) 35%,transparent)}
    .resumo-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.07)}
    .resumo-eyebrow{font-size:10px;font-weight:700;opacity:.7;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px}
    .resumo-nome{font-weight:700;font-size:17px;position:relative;z-index:1;line-height:1.3}
    .resumo-preco{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:700;margin-top:8px;position:relative;z-index:1;letter-spacing:-.5px}
    .resumo-divider{height:1px;background:rgba(255,255,255,.18);margin:14px 0;position:relative;z-index:1}
    .resumo-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:13px;background:white;color:var(--p);border-radius:10px;font-weight:700;font-size:14px;text-decoration:none;transition:all .2s;cursor:pointer;border:none;width:100%;font-family:'Inter',sans-serif;position:relative;z-index:1}
    .resumo-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.2)}
    .resumo-btn svg{width:16px;height:16px;fill:var(--p)}

    /* INFO */
    .info-it{display:flex;gap:12px;align-items:flex-start;margin-bottom:14px}
    .info-it:last-child{margin-bottom:0}
    .i-icon{width:36px;height:36px;border-radius:9px;background:var(--sur3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .i-icon svg{width:16px;height:16px;fill:var(--p)}
    .i-lbl{font-size:10px;color:var(--ink3);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
    .i-val{font-weight:600;font-size:13px;color:var(--ink);margin-top:2px}
    .i-sub{font-size:11px;color:var(--ink3);margin-top:1px}
    .org-strip{display:flex;align-items:center;gap:10px;background:var(--sur2);border-radius:var(--r-sm);padding:12px;margin-top:16px;border:1px solid var(--bdr)}
    .org-logo-box{width:38px;height:38px;border-radius:9px;overflow:hidden;background:var(--p);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .org-logo-box img{width:100%;height:100%;object-fit:contain}
    .org-logo-box svg{width:20px;height:20px;fill:white}
    .org-name{font-weight:700;font-size:13px;color:var(--ink)}
    .org-sub{font-size:11px;color:var(--ink3)}

    /* PATROCINADORES — grande e destacado */
    .patroc-list{display:flex;flex-direction:column;gap:14px}
    .patroc-item{border:2px solid var(--bdr);border-radius:var(--r);padding:28px 24px;display:flex;align-items:center;justify-content:center;min-height:140px;transition:all .22s;background:var(--sur);text-decoration:none}
    .patroc-item:hover{border-color:var(--p);box-shadow:0 4px 20px rgba(0,0,0,.1);transform:translateY(-2px)}
    .patroc-item img{max-height:100px;max-width:100%;object-fit:contain}
    .patroc-nome{font-size:14px;font-weight:700;color:var(--ink3);text-align:center}

    /* SOCIAL */
    .social-list{display:flex;flex-direction:column;gap:10px}
    .s-btn{display:flex;align-items:center;gap:12px;padding:13px 16px;border-radius:var(--r);text-decoration:none;color:white;font-weight:600;font-size:13px;transition:transform .18s,box-shadow .18s}
    .s-btn:hover{transform:translateY(-2px)}
    .s-btn-wpp{background:linear-gradient(135deg,#0a7a6e 0%,#25d366 100%)}
    .s-btn-wpp:hover{box-shadow:0 6px 20px rgba(37,211,102,.35)}
    .s-btn-ig{background:linear-gradient(45deg,#f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%)}
    .s-btn-ig:hover{box-shadow:0 6px 20px rgba(225,48,108,.35)}
    .s-btn-yt{background:linear-gradient(135deg,#c4302b 0%,#ff4444 60%,#ff8080 100%)}
    .s-btn-yt:hover{box-shadow:0 6px 20px rgba(196,48,43,.35)}
    .s-btn-logo{width:38px;height:38px;background:rgba(255,255,255,.18);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .s-btn-logo svg{width:22px;height:22px;fill:white}
    .s-btn-lbl{font-size:10px;opacity:.85;letter-spacing:.3px;text-transform:uppercase}
    .s-btn-name{font-weight:700;font-size:13px}

    /* MODAL */
    .modal-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px)}
    .modal-wrap.open{display:flex}
    .modal-box{background:white;border-radius:var(--r-lg);max-width:640px;width:100%;max-height:82vh;overflow:hidden;display:flex;flex-direction:column;animation:slideUp .3s ease;box-shadow:var(--sh-lg)}
    @keyframes slideUp{from{transform:translateY(24px);opacity:0}to{transform:translateY(0);opacity:1}}
    .modal-hd{padding:20px 24px;border-bottom:1px solid var(--bdr);display:flex;justify-content:space-between;align-items:center}
    .modal-hd h3{font-weight:700;font-size:15px;color:var(--ink)}
    .modal-close{border:none;background:var(--sur3);width:30px;height:30px;border-radius:7px;cursor:pointer;color:var(--ink2);font-size:18px;display:flex;align-items:center;justify-content:center;transition:background .18s}
    .modal-close:hover{background:var(--bdr)}
    .modal-body{padding:22px 24px;overflow-y:auto;font-size:13px;color:var(--ink2);line-height:1.8;white-space:pre-wrap;flex:1}
    .modal-ft{padding:14px 24px;border-top:1px solid var(--bdr);text-align:right}
    .modal-ok{background:var(--p);color:white;border:none;padding:10px 24px;border-radius:8px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;font-size:13px}
    .modal-ok:hover{opacity:.88}

    /* SUCESSO */
    .suc-wrap{min-height:70vh;display:flex;align-items:center;justify-content:center;padding:40px 20px}
    .suc-box{background:var(--sur);border-radius:24px;box-shadow:var(--sh-lg);padding:48px 36px;text-align:center;max-width:480px;width:100%;border:1px solid var(--bdr)}
    .suc-icon{width:76px;height:76px;background:var(--p);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;animation:popIn .5s cubic-bezier(.34,1.56,.64,1)}
    .suc-icon svg{width:38px;height:38px;fill:white}
    @keyframes popIn{0%{transform:scale(0);opacity:0}100%{transform:scale(1);opacity:1}}
    .suc-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:var(--ink);margin-bottom:10px}
    .suc-sub{font-size:14px;color:var(--ink2);line-height:1.6;margin-bottom:22px}
    .suc-cod{background:var(--sur3);border:1px solid var(--bdr);border-radius:10px;padding:14px 20px;font-family:'DM Mono',monospace;font-size:15px;font-weight:600;color:var(--p);margin-bottom:8px;letter-spacing:2px}
    .suc-cod-lbl{font-size:11px;color:var(--ink4);margin-bottom:24px}
    .suc-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:13px;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px;margin-bottom:10px;transition:opacity .18s;border:none;cursor:pointer;font-family:'Inter',sans-serif;width:100%}
    .suc-btn-wpp{background:#25d366;color:white}
    .suc-btn-p{background:var(--p);color:white}
    .suc-btn-sec{background:var(--sur3);color:var(--ink2)}
    .suc-btn svg{width:18px;height:18px;fill:currentColor}

    /* WPP FLOAT */
    .wpp-float{position:fixed;bottom:26px;right:26px;z-index:998;width:54px;height:54px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.4);text-decoration:none;transition:transform .2s,box-shadow .2s}
    .wpp-float:hover{transform:scale(1.1);box-shadow:0 8px 28px rgba(37,211,102,.5)}
    .wpp-float svg{width:26px;height:26px;fill:white}

    /* ALERTA DUPLICATA */
    .alerta-dup{max-width:640px;margin:32px auto;background:#fff;border:2px solid #fca5a5;border-radius:16px;padding:28px 32px;text-align:center;box-shadow:var(--sh-lg)}
    .alerta-dup-icon{width:64px;height:64px;background:#fee2e2;border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 18px}
    .alerta-dup-icon svg{width:32px;height:32px;fill:#dc2626}
    .alerta-dup h2{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#111827;margin-bottom:10px}
    .alerta-dup p{font-size:13px;color:#6b7280;line-height:1.7;margin-bottom:22px}
    .alerta-dup-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
    .alerta-btn-p{background:var(--p);color:white;padding:11px 24px;border-radius:9px;text-decoration:none;font-weight:700;font-size:13px;transition:opacity .15s}
    .alerta-btn-p:hover{opacity:.88}
    .alerta-btn-s{background:var(--sur3);color:var(--ink2);padding:11px 24px;border-radius:9px;text-decoration:none;font-weight:600;font-size:13px;border:1px solid var(--bdr)}

    footer{background:var(--ink);color:rgba(255,255,255,.45);text-align:center;padding:28px 20px;font-size:12px;margin-top:40px}
    footer strong{color:rgba(255,255,255,.85)}
    footer a{color:rgba(255,255,255,.5);text-decoration:none;transition:color .18s}
    footer a:hover{color:rgba(255,255,255,.85)}
  </style>
</head>
