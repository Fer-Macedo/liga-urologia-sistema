<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= evento.nome %> — LAURO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --p:<%= evento.cor_tema||'#1a3d2b' %>;
      --p10:color-mix(in srgb,<%= evento.cor_tema||'#1a3d2b' %> 10%,white);
      --p20:color-mix(in srgb,<%= evento.cor_tema||'#1a3d2b' %> 20%,white);
      --w:#fff;--g50:#f9fafb;--g100:#f3f4f6;--g200:#e5e7eb;--g400:#9ca3af;--g600:#4b5563;--g800:#1f2937;--g900:#111827;
      --sh:0 1px 3px rgba(0,0,0,.08),0 4px 16px rgba(0,0,0,.06);
    }
    body{font-family:'Inter',sans-serif;background:var(--g50);color:var(--g900);line-height:1.6}

    nav{background:var(--w);border-bottom:1px solid var(--g200);position:sticky;top:0;z-index:100}
    .nav-in{max-width:1200px;margin:0 auto;padding:0 24px;height:58px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .nav-logo img{height:32px;object-fit:contain}
    .nav-logo-txt{font-weight:800;font-size:17px;color:var(--p)}
    .nav-links{display:flex;gap:16px;align-items:center}
    .nav-a{font-size:13px;font-weight:500;color:var(--g600);text-decoration:none;transition:.2s}
    .nav-a:hover{color:var(--p)}
    .nav-cta{background:var(--p);color:white;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;transition:.2s}
    .nav-cta:hover{opacity:.88;transform:translateY(-1px)}

    .banner-wrap{width:100%;overflow:hidden;background:var(--g900);max-height:440px}
    .banner-img{width:100%;max-height:440px;object-fit:cover;display:block}
    .banner-ph{height:280px;background:linear-gradient(135deg,var(--p),#000);display:flex;align-items:center;justify-content:center;color:white;font-size:56px}

    .title-wrap{background:var(--w);border-bottom:1px solid var(--g200);padding:24px 0 20px}
    .title-in{max-width:1200px;margin:0 auto;padding:0 24px}
    .tipo-chip{display:inline-flex;align-items:center;gap:6px;background:var(--g100);border-radius:20px;padding:4px 12px;font-size:12px;font-weight:600;color:var(--g600);margin-bottom:10px}
    .title-in h1{font-size:clamp(20px,3.5vw,34px);font-weight:900;color:var(--g900);line-height:1.2}
    .title-meta{display:flex;flex-wrap:wrap;gap:14px;margin-top:12px}
    .t-chip{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--g600);font-weight:500}

    .wpp-banner{background:linear-gradient(90deg,#128c7e,#25d366);padding:12px 0}
    .wpp-in{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
    .wpp-btn{background:white;color:#128c7e;padding:8px 20px;border-radius:8px;font-weight:700;font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px;white-space:nowrap}

    .wrap{max-width:1200px;margin:0 auto;padding:28px 24px 80px}
    .grid{display:grid;grid-template-columns:1fr 380px;gap:24px;align-items:start}
    @media(max-width:900px){.grid{grid-template-columns:1fr}.sidebar{order:-1}}

    .card{background:var(--w);border-radius:16px;box-shadow:var(--sh);overflow:hidden;margin-bottom:18px}
    .card-hd{padding:18px 22px;border-bottom:1px solid var(--g100);display:flex;align-items:center;justify-content:space-between}
    .card-hd h2{font-size:15px;font-weight:700;color:var(--g900)}
    .card-bd{padding:20px 22px}

    /* LOTES */
    .lote{border:2px solid var(--g200);border-radius:12px;padding:16px 18px;margin-bottom:10px;cursor:pointer;transition:all .2s;position:relative}
    .lote:hover{border-color:var(--p);box-shadow:0 0 0 3px var(--p10)}
    .lote.sel{border-color:var(--p);background:var(--p10)}
    .lote-top{display:flex;justify-content:space-between;align-items:center;gap:12px}
    .lote-nome{font-weight:700;font-size:15px;color:var(--g900)}
    .lote-info{font-size:12px;color:var(--g400);margin-top:3px}
    .lote-preco{font-size:22px;font-weight:900;color:var(--p);white-space:nowrap}
    .badge-free{background:#dcfce7;color:#166534;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700}
    .lote-radio{width:20px;height:20px;border-radius:50%;border:2px solid var(--g200);flex-shrink:0;transition:.2s;display:flex;align-items:center;justify-content:center}
    .lote.sel .lote-radio{border-color:var(--p);background:var(--p)}
    .lote.sel .lote-radio::after{content:'';width:8px;height:8px;border-radius:50%;background:white}

    .qty-row{display:flex;align-items:center;gap:10px;margin-top:12px;padding-top:12px;border-top:1px solid var(--g100)}
    .qty-btn{width:34px;height:34px;border-radius:9px;border:1.5px solid var(--g200);background:var(--w);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--g700);transition:.2s;line-height:1}
    .qty-btn:hover{border-color:var(--p);color:var(--p)}
    .qty-n{font-size:18px;font-weight:800;min-width:28px;text-align:center}
    .qty-lbl{font-size:12px;color:var(--g400)}

    .btn-prox{width:100%;padding:15px;background:var(--p);color:white;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;margin-top:14px;font-family:'Inter',sans-serif;transition:.2s;display:flex;align-items:center;justify-content:center;gap:8px}
    .btn-prox:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.2)}

    .cupom-row{display:flex;gap:8px;margin-top:12px}
    .cupom-in{flex:1;padding:10px 12px;border:1.5px solid var(--g200);border-radius:9px;font-size:13px;font-family:'Inter',sans-serif;transition:.2s}
    .cupom-in:focus{outline:none;border-color:var(--p)}
    .cupom-btn{padding:10px 16px;background:var(--g100);border:1.5px solid var(--g200);border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;color:var(--g700);transition:.2s}
    .cupom-btn:hover{background:var(--p);color:white;border-color:var(--p)}
    .cupom-ok{font-size:12px;color:#166534;background:#dcfce7;padding:6px 10px;border-radius:7px;margin-top:6px}
    .cupom-err{font-size:12px;color:#991b1b;background:#fee2e2;padding:6px 10px;border-radius:7px;margin-top:6px}

    .form-sec{overflow:hidden;max-height:0;opacity:0;transition:max-height .5s cubic-bezier(.4,0,.2,1),opacity .4s ease}
    .form-sec.open{max-height:5000px;opacity:1}
    .part-bloco{border:1.5px solid var(--g200);border-radius:12px;padding:18px;margin-bottom:14px}
    .part-tit{font-size:13px;font-weight:700;color:var(--g700);margin-bottom:14px;display:flex;align-items:center;gap:8px}
    .part-num{width:22px;height:22px;background:var(--p);color:white;border-radius:50%;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .campo{margin-bottom:14px}
    .campo label{display:block;font-size:12px;font-weight:600;color:var(--g700);margin-bottom:5px}
    .req{color:#ef4444}
    .inp{width:100%;padding:10px 13px;border:1.5px solid var(--g200);border-radius:9px;font-size:13px;font-family:'Inter',sans-serif;transition:.2s;background:var(--w)}
    .inp:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px var(--p10)}
    .inp:required:invalid{border-color:var(--g200)}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    @media(max-width:500px){.grid2{grid-template-columns:1fr}}
    .btn-sub{width:100%;padding:16px;background:var(--p);color:white;border:none;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer;transition:.2s;font-family:'Inter',sans-serif;margin-top:10px}
    .btn-sub:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
    .secure{text-align:center;font-size:12px;color:var(--g400);margin-top:8px;display:flex;align-items:center;justify-content:center;gap:4px}

    /* TIPO PARTICIPANTE */
    .tipo-participante{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
    .tipo-opt{border:2px solid var(--g200);border-radius:10px;padding:12px 14px;cursor:pointer;transition:.2s;text-align:center}
    .tipo-opt:hover{border-color:var(--p)}
    .tipo-opt.sel{border-color:var(--p);background:var(--p10)}
    .tipo-opt .tipo-icon{font-size:22px;margin-bottom:4px}
    .tipo-opt .tipo-label{font-size:13px;font-weight:700;color:var(--g900)}
    .tipo-opt .tipo-sub{font-size:11px;color:var(--g600);margin-top:2px}

    /* PROGRAMAÇÃO */
    .prog-acc{border:1.5px solid var(--g200);border-radius:12px;overflow:hidden;margin-bottom:8px}
    .prog-hd{padding:14px 16px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:.2s;user-select:none}
    .prog-hd:hover{background:var(--g50)}
    .prog-hd.open{background:var(--p10);border-bottom:1px solid var(--g200)}
    .prog-info{flex:1}
    .prog-titulo{font-weight:700;font-size:14px;color:var(--g900)}
    .prog-hora{font-size:12px;color:var(--p);font-weight:600;margin-top:2px}
    .prog-arrow{font-size:12px;color:var(--g400);transition:.3s}
    .prog-hd.open .prog-arrow{transform:rotate(180deg)}
    .prog-body{max-height:0;overflow:hidden;transition:max-height .3s ease}
    .prog-body.open{max-height:200px}
    .prog-desc{padding:12px 16px;font-size:13px;color:var(--g600);line-height:1.6}

    /* PALESTRANTES — foto maior e quadrada */
    .pales-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:16px}
    .pales-card{border:1.5px solid var(--g200);border-radius:14px;padding:18px 14px;text-align:center;cursor:pointer;transition:.2s;overflow:hidden}
    .pales-card:hover{border-color:var(--p);box-shadow:0 0 0 3px var(--p10);transform:translateY(-2px)}
    .pales-card.open{border-color:var(--p);background:var(--p10)}
    .pales-foto{width:110px;height:110px;border-radius:18px;object-fit:cover;margin:0 auto 12px;display:block;border:3px solid var(--p);box-shadow:0 4px 14px rgba(0,0,0,.12)}
    .pales-ph{width:110px;height:110px;border-radius:18px;background:var(--g100);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:44px;border:3px solid var(--g200)}
    .pales-nome{font-weight:700;font-size:14px;color:var(--g900);line-height:1.3}
    .pales-inst{font-size:12px;color:var(--p);margin-top:4px;font-weight:500}
    .pales-bio-wrap{max-height:0;overflow:hidden;transition:max-height .3s ease}
    .pales-bio-wrap.open{max-height:400px}
    .pales-bio{padding:12px 0 4px;font-size:13px;color:var(--g600);line-height:1.6;text-align:left;border-top:1px solid var(--g200);margin-top:10px}

    /* CONTATO */
    .contato-btns{display:flex;flex-direction:column;gap:10px}
    .c-btn{display:flex;align-items:center;gap:12px;padding:13px 16px;border-radius:12px;border:1.5px solid var(--g200);text-decoration:none;color:var(--g800);font-size:14px;font-weight:600;transition:.2s;cursor:pointer}
    .c-btn:hover{border-color:var(--p);background:var(--p10);transform:translateX(4px)}
    .c-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
    .c-form{overflow:hidden;max-height:0;opacity:0;transition:max-height .4s ease,opacity .3s ease;margin-top:0}
    .c-form.open{max-height:500px;opacity:1;margin-top:14px}
    .c-inp{width:100%;padding:10px 12px;border:1.5px solid var(--g200);border-radius:9px;font-size:13px;font-family:'Inter',sans-serif;margin-bottom:8px;transition:.2s}
    .c-inp:focus{outline:none;border-color:var(--p)}
    .c-send{width:100%;padding:11px;background:var(--p);color:white;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif}

    /* SIDEBAR */
    .s-card{background:var(--w);border-radius:16px;box-shadow:var(--sh);padding:20px;margin-bottom:16px}
    .s-title{font-size:13px;font-weight:700;color:var(--g900);margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--g100)}
    .info-it{display:flex;gap:10px;align-items:flex-start;margin-bottom:12px}
    .i-icon{width:34px;height:34px;border-radius:9px;background:var(--g100);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
    .i-lbl{font-size:10px;color:var(--g400);font-weight:600;text-transform:uppercase;letter-spacing:.4px}
    .i-val{font-weight:600;font-size:13px;color:var(--g900);margin-top:1px}
    .i-sub{font-size:11px;color:var(--g600);margin-top:1px}
    .org-box{background:var(--g50);border-radius:10px;padding:12px;display:flex;align-items:center;gap:10px;margin-top:14px}
    .org-logo{width:40px;height:40px;border-radius:9px;overflow:hidden;background:var(--p);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .org-logo img{width:100%;height:100%;object-fit:contain}

    /* RESUMO INGRESSO */
    .resumo-card{background:var(--p);border-radius:14px;padding:18px;margin-bottom:16px;color:white;position:relative;overflow:hidden}
    .resumo-card::before{content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;background:rgba(255,255,255,.1);border-radius:50%}
    .resumo-card::after{content:'';position:absolute;bottom:-30px;left:-10px;width:80px;height:80px;background:rgba(255,255,255,.07);border-radius:50%}
    .resumo-label{font-size:11px;font-weight:600;opacity:.8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
    .resumo-nome{font-weight:800;font-size:16px;position:relative;z-index:1}
    .resumo-preco{font-size:30px;font-weight:900;margin-top:6px;position:relative;z-index:1}
    .resumo-qty{font-size:12px;opacity:.8;margin-top:2px;position:relative;z-index:1}
    .resumo-btn{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:14px;padding:12px;background:white;color:var(--p);border-radius:10px;font-weight:700;font-size:14px;text-decoration:none;transition:.2s;cursor:pointer;border:none;width:100%;font-family:'Inter',sans-serif}
    .resumo-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.2)}

    /* SOCIAL */
    .social-row{display:flex;flex-direction:column;gap:10px}
    .s-wpp{display:flex;align-items:center;gap:12px;padding:13px 16px;background:linear-gradient(135deg,#128c7e,#25d366);border-radius:12px;text-decoration:none;color:white;font-weight:700;font-size:14px;transition:.2s}
    .s-wpp:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(37,211,102,.3)}
    .s-ig{display:flex;align-items:center;gap:12px;padding:13px 16px;background:linear-gradient(45deg,#f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%);border-radius:12px;text-decoration:none;color:white;font-weight:700;font-size:14px;transition:.2s}
    .s-ig:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(225,48,108,.3)}
    .s-yt{display:flex;align-items:center;gap:12px;padding:13px 16px;background:linear-gradient(135deg,#c4302b,#ff0000);border-radius:12px;text-decoration:none;color:white;font-weight:700;font-size:14px;transition:.2s}
    .s-yt:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(255,0,0,.3)}
    .s-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .s-icon svg{width:24px;height:24px;fill:white}

    /* PATROCINADORES SIDEBAR — grande e destaque */
    .patroc-grid{display:grid;grid-template-columns:1fr;gap:14px}
    .patroc-item{border:1.5px solid var(--g200);border-radius:14px;padding:20px 16px;display:flex;align-items:center;justify-content:center;min-height:100px;transition:.2s;background:var(--w)}
    .patroc-item:hover{border-color:var(--p);box-shadow:0 4px 16px rgba(0,0,0,.1);transform:translateY(-2px)}
    .patroc-item img{max-height:72px;max-width:90%;object-fit:contain}
    .patroc-nome{font-size:14px;font-weight:700;color:var(--g700);text-align:center}

    /* TERMOS */
    .termo-check{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;font-size:13px;color:var(--g800)}
    .termo-check input{margin-top:2px;accent-color:var(--p);width:16px;height:16px;flex-shrink:0}
    .termo-link{color:var(--p);font-weight:600;text-decoration:underline;cursor:pointer}

    /* MODAL */
    .modal-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;align-items:center;justify-content:center;padding:20px}
    .modal-wrap.open{display:flex}
    .modal-box{background:white;border-radius:16px;max-width:640px;width:100%;max-height:82vh;overflow:hidden;display:flex;flex-direction:column;animation:mUp .3s ease}
    @keyframes mUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
    .modal-hd{padding:18px 22px;border-bottom:1px solid var(--g200);display:flex;justify-content:space-between;align-items:center}
    .modal-hd h3{font-weight:700;font-size:15px}
    .modal-close{border:none;background:none;font-size:22px;cursor:pointer;color:var(--g400);line-height:1}
    .modal-body{padding:20px 22px;overflow-y:auto;font-size:13px;color:var(--g700);line-height:1.8;white-space:pre-wrap;flex:1}
    .modal-ft{padding:14px 22px;border-top:1px solid var(--g200);text-align:right}
    .modal-ok{background:var(--p);color:white;border:none;padding:10px 24px;border-radius:9px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif}

    /* SUCESSO */
    .suc-wrap{min-height:70vh;display:flex;align-items:center;justify-content:center;padding:40px 20px}
    .suc-box{background:var(--w);border-radius:20px;box-shadow:0 4px 40px rgba(0,0,0,.12);padding:44px 32px;text-align:center;max-width:500px;width:100%}
    .suc-icon{width:72px;height:72px;background:var(--p);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 20px;animation:pop .4s ease}
    @keyframes pop{0%{transform:scale(0)}80%{transform:scale(1.1)}100%{transform:scale(1)}}
    .suc-cod{background:var(--g900);color:#10b981;font-family:monospace;font-size:15px;padding:12px 20px;border-radius:9px;margin:18px auto;display:inline-block;letter-spacing:2px}

    .wpp-float{position:fixed;bottom:24px;right:24px;z-index:998;width:56px;height:56px;background:#25d366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,.4);text-decoration:none;transition:.2s}
    .wpp-float:hover{transform:scale(1.1)}
    .wpp-float svg{width:28px;height:28px;fill:white}

    footer{background:var(--g900);color:rgba(255,255,255,.5);text-align:center;padding:22px;font-size:12px;margin-top:40px}
    footer strong{color:white}
  </style>
</head>
<body>

<nav>
  <div class="nav-in">
    <a href="/" class="nav-logo">
      <% if(config&&config.org_logo){%><img src="<%= config.org_logo %>" alt="LAURO"><%}else{%><div style="width:32px;height:32px;background:var(--p);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:14px">L</div><%}%>
      <span class="nav-logo-txt">LAURO</span>
    </a>
    <div class="nav-links">
      <a href="https://www.instagram.com/lauroucp.cde/" target="_blank" class="nav-a">Instagram</a>
      <a href="#contato" class="nav-a">Contato</a>
      <a href="#form-sec" class="nav-cta" onclick="abrirForm()">Inscrever-se</a>
    </div>
  </div>
</nav>

<% if(sucesso){ %>
<div class="suc-wrap">
  <div class="suc-box">
    <div class="suc-icon">✓</div>
    <h2 style="font-size:22px;font-weight:800;margin-bottom:8px">Inscrição Realizada!</h2>
    <p style="color:var(--g600);font-size:14px;line-height:1.6">Sua inscrição foi confirmada. Verifique seu email para mais informações.</p>
    <div class="suc-cod"><%= codigoInscricao %></div>
    <p style="font-size:12px;color:var(--g400)">Apresente este código no check-in</p>
