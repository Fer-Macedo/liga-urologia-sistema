    <div class="modal-footer" style="padding-top:0;">
      <button type="button" class="btn-cancelar" onclick="fecharCats()">Fechar</button>
    </div>
  </div>
</div>

<!-- MODAL VER EVENTO -->
<div class="modal-overlay" id="modalVer">
  <div class="modal-ver">
    <div class="modal-ver-head" id="verHead">
      <div class="modal-ver-cat" id="verCat"></div>
      <h2 class="modal-ver-titulo" id="verTitulo"></h2>
    </div>
    <div class="modal-ver-body">
      <div class="modal-ver-row" id="verData">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span id="verDataTxt"></span>
      </div>
      <div class="modal-ver-row" id="verLocalWrap" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span id="verLocal"></span>
      </div>
      <div class="modal-ver-row" id="verLinkWrap" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <a id="verLink" href="#" target="_blank"></a>
      </div>
      <div class="modal-ver-row" id="verDescWrap" style="display:none">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        <span id="verDesc"></span>
      </div>
    </div>
    <div class="modal-ver-footer">
      <button class="btn-cancelar" onclick="fecharVer()">Fechar</button>
      <button class="btn-icon-sm del" onclick="excluirEvento()" title="Excluir">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </button>
      <button class="btn-salvar" onclick="editarEvento()" style="padding:8px 16px;font-size:13px;">Editar</button>
    </div>
  </div>
</div>

<script>
// DADOS DO SERVIDOR
const todosEventos = <%- JSON.stringify(atividades) %>;
const icalUrl = '<%= icalUrl %>';

// CATEGORIAS E CORES
const catCores = {
  'Aula Pratica':   '#2b6803',
  'Aula Teorica':   '#3b82f6',
  'Evento Externo': '#f59e0b',
  'Reuniao':        '#8b5cf6',
  'Prazo':          '#dc2626',
  'So Diretivos':   '#374151',
  'Outro':          '#06b6d4',
  'Aniversario':    '#f97316'
};
const catNomes = {
  'Aula Pratica':'Aula Prática','Aula Teorica':'Aula Teórica',
  'Evento Externo':'Evento Externo','Reuniao':'Reunião',
  'Prazo':'Prazo','So Diretivos':'Só Diretivos','Outro':'Outro','Aniversario':'🎂 Aniversários'
};

const mesesNomes = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const diasSemana = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

let hoje = new Date();
let anoAtual = hoje.getFullYear();
let mesAtual = hoje.getMonth();
let viewAtual = 'mes';
let eventoSelecionado = null;
let categoriasFiltro = new Set();

// INIT
function init(){
  renderLegendas();
  render();
}

function render(){
  document.getElementById('labelMesAno').textContent = mesesNomes[mesAtual] + ' ' + anoAtual;
  if(viewAtual === 'mes') renderMes();
  else renderLista();
}

function navMes(d){
  mesAtual += d;
  if(mesAtual > 11){ mesAtual=0; anoAtual++; }
  if(mesAtual < 0){ mesAtual=11; anoAtual--; }
  render();
}

function irHoje(){
  mesAtual = hoje.getMonth();
  anoAtual = hoje.getFullYear();
  render();
}

function setView(v){
  viewAtual = v;
  document.getElementById('tab-mes').className = 'cal-tab' + (v==='mes'?' ativo':'');
  document.getElementById('tab-lista').className = 'cal-tab' + (v==='lista'?' ativo':'');
  document.getElementById('viewMes').style.display = v==='mes'?'':'none';
  document.getElementById('viewLista').style.display = v==='lista'?'':'none';
  render();
}

function eventosVisiveis(){
  return todosEventos.filter(e => categoriasFiltro.size===0 || !categoriasFiltro.has(e.categoria));
}

function renderLegendas(){
  const cats = [...new Set(todosEventos.map(e=>e.categoria))];
  const wrap = document.getElementById('legendas');
  wrap.innerHTML = '';
  Object.keys(catNomes).forEach(cat => {
    const cor = catCores[cat] || '#6b7280';
    const el = document.createElement('div');
    el.className = 'cal-legenda-item';
    el.dataset.cat = cat;
    el.innerHTML = `<div class="cal-legenda-dot" style="background:${cor}"></div>${catNomes[cat]}`;
    el.addEventListener('click', () => {
      if(categoriasFiltro.has(cat)) categoriasFiltro.delete(cat);
      else categoriasFiltro.add(cat);
      el.classList.toggle('filtrado', categoriasFiltro.has(cat));
      render();
    });
    wrap.appendChild(el);
  });
}

function renderMes(){
  const grade = document.getElementById('gradeCalendario');
  grade.innerHTML = '';
  const primeiroDia = new Date(anoAtual, mesAtual, 1).getDay();
  const diasNoMes = new Date(anoAtual, mesAtual+1, 0).getDate();
  const diasMesAnterior = new Date(anoAtual, mesAtual, 0).getDate();
  const eventos = eventosVisiveis();

  for(let i=0; i<42; i++){
    let dia, mes=mesAtual, ano=anoAtual, outroMes=false;
    if(i < primeiroDia){ dia=diasMesAnterior-(primeiroDia-i-1); mes=mesAtual-1; outroMes=true; if(mes<0){mes=11;ano--;} }
    else if(i >= primeiroDia+diasNoMes){ dia=i-primeiroDia-diasNoMes+1; mes=mesAtual+1; outroMes=true; if(mes>11){mes=0;ano++;} }
    else{ dia=i-primeiroDia+1; }

    const isHoje = !outroMes && dia===hoje.getDate() && mesAtual===hoje.getMonth() && anoAtual===hoje.getFullYear();
    const evsDia = eventos.filter(e => {
      const d = new Date(e.data_inicio);
      d.setMinutes(d.getMinutes() + d.getTimezoneOffset());
      return d.getFullYear()===ano && d.getMonth()===mes && d.getDate()===dia;
    });

    const el = document.createElement('div');
    el.className = 'cal-dia' + (outroMes?' outro-mes':'') + (isHoje?' hoje':'');

    const numEl = document.createElement('div');
    numEl.className = 'cal-dia-num';
    numEl.textContent = dia;
    el.appendChild(numEl);

    // Wrapper para eventos — limita a altura
    const wrap = document.createElement('div');
    wrap.className = 'cal-eventos-wrap';

    const max = 2;
    evsDia.slice(0,max).forEach(ev => {
      const cor = ev.cor || catCores[ev.categoria] || '#2b6803';
      const span = document.createElement('div');
      span.className = 'cal-evento';
      span.style.background = cor+'20';
      span.style.color = cor;
      span.style.borderLeft = `3px solid ${cor}`;
      span.textContent = ev.titulo;
      span.addEventListener('click', e => { e.stopPropagation(); verEvento(ev); });
      wrap.appendChild(span);
    });
    if(evsDia.length > max){
      const mais = document.createElement('div');
      mais.className = 'cal-mais';
      mais.textContent = `+${evsDia.length-max} mais`;
      mais.onclick = e => { e.stopPropagation(); };
      wrap.appendChild(mais);
    }

    el.appendChild(wrap);
    grade.appendChild(el);
  }
}

function renderLista(){
  const lista = document.getElementById('listaCalendario');
  lista.innerHTML = '';
  const eventos = eventosVisiveis().sort((a,b) => new Date(a.data_inicio)-new Date(b.data_inicio));
  
  // Filtrar a partir do mês atual
  const inicio = new Date(anoAtual, mesAtual, 1);
  const fim = new Date(anoAtual, mesAtual+1, 0, 23, 59);
  const evsMes = eventos.filter(e => {
    const d = new Date(e.data_inicio);
    return d >= inicio && d <= fim;
  });

  if(evsMes.length === 0){
    lista.innerHTML = `<div class="cal-vazio"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><p>Nenhuma atividade em ${mesesNomes[mesAtual]}.</p></div>`;
    return;
  }

  const header = document.createElement('div');
  header.className = 'cal-lista-mes';
  header.textContent = mesesNomes[mesAtual] + ' ' + anoAtual + ' — ' + evsMes.length + ' atividade' + (evsMes.length!==1?'s':'');
  lista.appendChild(header);

  evsMes.forEach(ev => {
    const d = new Date(ev.data_inicio);
    const cor = ev.cor || catCores[ev.categoria] || '#2b6803';
    const item = document.createElement('div');
    item.className = 'cal-lista-item';
    const hora = ev.dia_inteiro ? 'Dia inteiro' : d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    item.innerHTML = `
      <div class="cal-lista-data">
        <div class="cal-lista-dia">${String(d.getDate()).padStart(2,'0')}</div>
        <div class="cal-lista-diasem">${diasSemana[d.getDay()]}</div>
      </div>
      <div class="cal-lista-barra" style="background:${cor}"></div>
      <div class="cal-lista-info">
        <div class="cal-lista-titulo">${ev.titulo}</div>
        <div class="cal-lista-meta">
          <span><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${hora}</span>
          ${ev.local?`<span><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${ev.local}</span>`:''}
          <span class="cal-lista-cat" style="background:${cor}22;color:${cor}">${catNomes[ev.categoria]||ev.categoria}</span>
        </div>
      </div>
      <div class="cal-lista-acoes">
        <button class="btn-icon-sm" onclick="editarEv(${JSON.stringify(ev).replace(/"/g,'&quot;')})" title="Editar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
        <button class="btn-icon-sm del" onclick="excluirEv(${ev.id},'${ev.titulo.replace(/'/g,"\\'")}')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg></button>
      </div>
    `;
    item.querySelector('.cal-lista-info').addEventListener('click', ()=>verEvento(ev));
    lista.appendChild(item);
  });
}

function abrirModalNovo(){
  document.getElementById('formEvento').action = '/calendario/novo';
  document.getElementById('fId').value = '';
  document.getElementById('formEvento').reset();
  document.getElementById('fPublico').checked = true;
  selecionarCor('#2b6803');
  document.getElementById('modalEventoTitulo').textContent = 'Nova Atividade';
  // Data padrão = hoje
  const agora = new Date();
  agora.setMinutes(0,0,0);
  const local = new Date(agora.getTime() - agora.getTimezoneOffset()*60000);
  document.getElementById('fDataInicio').value = local.toISOString().slice(0,16);
  document.getElementById('modalEvento').classList.add('open');
}

function selecionarCor(cor){
  document.getElementById('fCor').value = cor;
  document.querySelectorAll('.cor-btn').forEach(b => b.classList.toggle('selecionada', b.dataset.cor===cor));
}

function setCor(cat){
  if(catCores[cat]) selecionarCor(catCores[cat]);
}

function fecharModal(){ document.getElementById('modalEvento').classList.remove('open'); }

function verEvento(ev){
  eventoSelecionado = ev;
  const cor = ev.cor || catCores[ev.categoria] || '#2b6803';
  document.getElementById('verHead').style.background = cor;
  document.getElementById('verCat').textContent = catNomes[ev.categoria] || ev.categoria;
  document.getElementById('verTitulo').textContent = ev.titulo;
  const d = new Date(ev.data_inicio);
  const df = ev.data_fim ? new Date(ev.data_fim) : null;
  let dataTxt = d.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
  if(!ev.dia_inteiro){ dataTxt += ' às ' + d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}); }
  if(df){ dataTxt += ' → ' + df.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}); }
  document.getElementById('verDataTxt').textContent = dataTxt;
  const lw = document.getElementById('verLocalWrap');
  if(ev.local){ lw.style.display='flex'; document.getElementById('verLocal').textContent=ev.local; } else lw.style.display='none';
  const linkw = document.getElementById('verLinkWrap');
  if(ev.link_externo){ linkw.style.display='flex'; const a=document.getElementById('verLink'); a.href=ev.link_externo; a.textContent=ev.link_externo; } else linkw.style.display='none';
  const dw = document.getElementById('verDescWrap');
  if(ev.descricao){ dw.style.display='flex'; document.getElementById('verDesc').textContent=ev.descricao; } else dw.style.display='none';
  document.getElementById('modalVer').classList.add('open');
}

function fecharVer(){ document.getElementById('modalVer').classList.remove('open'); }

function editarEvento(){
  fecharVer();
  editarEv(eventoSelecionado);
}

function editarEv(ev){
  document.getElementById('formEvento').action = '/calendario/'+ev.id+'/editar';
  document.getElementById('fId').value = ev.id;
  document.getElementById('fTitulo').value = ev.titulo;
  document.getElementById('fCategoria').value = ev.categoria;
  document.getElementById('fDesc').value = ev.descricao||'';
  document.getElementById('fLocal').value = ev.local||'';
  document.getElementById('fLink').value = ev.link_externo||'';
  document.getElementById('fDiaInteiro').checked = ev.dia_inteiro;
  document.getElementById('fPublico').checked = ev.publico;
  selecionarCor(ev.cor||'#2b6803');
  const toLocal = s => { const d=new Date(s); return new Date(d.getTime()-d.getTimezoneOffset()*60000).toISOString().slice(0,16); };
  document.getElementById('fDataInicio').value = toLocal(ev.data_inicio);
  if(ev.data_fim) document.getElementById('fDataFim').value = toLocal(ev.data_fim);
  document.getElementById('modalEventoTitulo').textContent = 'Editar Atividade';
  document.getElementById('modalEvento').classList.add('open');
}

function excluirEvento(){
  if(!eventoSelecionado) return;
  excluirEv(eventoSelecionado.id, eventoSelecionado.titulo);
}

function excluirEv(id, titulo){
  if(!confirm('Excluir "'+titulo+'"?\nEsta ação não pode ser desfeita.')) return;
  const f=document.createElement('form'); f.method='POST'; f.action='/calendario/'+id+'/excluir'; document.body.appendChild(f); f.submit();
}

function copiarIcal(){
  const url = window.location.origin + '/calendario.ics';
  navigator.clipboard.writeText(url).then(()=>{
    alert('Link iCal copiado!\n\n📱 iPhone: Calendário → Contas → Adicionar Conta → Outro → Assinatura de Calendário → cole o link\n\n🤖 Android: Google Calendar → + → Outros calendários → Da web → cole o link');
  }).catch(()=>{ prompt('Copie este link:', url); });
}

function copiarLinkPublico(){
  const url = window.location.origin + '/agenda';
  navigator.clipboard.writeText(url).then(()=>{
    alert('✅ Link copiado!\n\n' + url + '\n\nQualquer pessoa pode acessar este link sem precisar de senha!');
  }).catch(()=>{ prompt('Copie este link:', url); });
}

let destinatarioAtual = 'todos';
function abrirWhatsApp(){
  setDestinatario('todos');
  document.getElementById('modalWhatsApp').classList.add('open');
}
function fecharWhatsApp(){
  document.getElementById('modalWhatsApp').classList.remove('open');
}
function setDestinatario(dest){
  destinatarioAtual = dest;
  const btns = {todos:'wBtn-todos', diretivos:'wBtn-diretivos', ligantes:'wBtn-ligantes'};
  Object.entries(btns).forEach(([k,id])=>{
    const b = document.getElementById(id);
    if(k===dest){ b.style.background='#2b6803'; b.style.color='#fff'; }
    else { b.style.background='#f1f5f9'; b.style.color='#374151'; }
  });
  const url = window.location.origin + '/agenda';
  const msgs = {
    todos: `📅 *Agenda da Liga Acadêmica de Urologia*\n\nConfira todas as atividades programadas — aulas, eventos, reuniões e muito mais!\n\n🔗 Acesse aqui: ${url}\n\n_Não perca nenhuma atividade! 🩺_`,
    diretivos: `📅 *Agenda — Diretivos LAURO*\n\nLembrete: consulte as atividades programadas para a diretoria.\n\n🔗 ${url}\n\n_Mantenha-se atualizado! 🎓_`,
    ligantes: `📅 *Agenda da Liga — Ligantes*\n\nAcompanhe todas as aulas e eventos programados!\n\n🔗 ${url}\n\n_Não falte! Sua presença é fundamental 🩺_`
  };
  document.getElementById('wMensagem').value = msgs[dest];
}
function enviarWhatsApp(){
  const msg = document.getElementById('wMensagem').value;
  const url = 'https://wa.me/?text=' + encodeURIComponent(msg);
  window.open(url, '_blank');
  fecharWhatsApp();
}

document.getElementById('modalWhatsApp').addEventListener('click', e=>{ if(e.target===e.currentTarget) fecharWhatsApp(); });

// Fechar modais clicando fora
document.getElementById('modalEvento').addEventListener('click', e=>{ if(e.target===e.currentTarget) fecharModal(); });
document.getElementById('modalVer').addEventListener('click', e=>{ if(e.target===e.currentTarget) fecharVer(); });
document.getElementById('modalCats').addEventListener('click', e=>{ if(e.target===e.currentTarget) fecharCats(); });

// ── CATEGORIAS ──
const catsPadrao = ['Aula Pratica','Aula Teorica','Evento Externo','Reuniao','Prazo','So Diretivos','Outro'];
let catsCustom = [];

async function carregarCats(){
  try {
    const r = await fetch('/calendario/categorias');
    const data = await r.json();
    catsCustom = data;
    atualizarSelectCat();
  } catch(e){ console.log('Erro cats:', e); }
}

function atualizarSelectCat(){
  const sel = document.getElementById('fCategoria');
  // Manter as opções padrão e adicionar as custom
  const todasCats = [...catsCustom];
  // Remover opções antigas custom (após o optgroup padrão)
  const opts = sel.querySelectorAll('option[data-custom]');
  opts.forEach(o => o.remove());
  // Adicionar optgroup customizado se houver
  let grp = sel.querySelector('optgroup[label="Personalizadas"]');
  if(grp) grp.remove();
  if(catsCustom.length > 0){
    grp = document.createElement('optgroup');
    grp.label = 'Personalizadas';
    catsCustom.forEach(c => {
      const opt = document.createElement('option');
      opt.value = c.nome;
      opt.textContent = c.nome;
      opt.dataset.custom = '1';
      grp.appendChild(opt);
    });
    sel.appendChild(grp);
  }
  // Atualizar catCores e catNomes
  catsCustom.forEach(c => {
    catCores[c.nome] = c.cor;
    catNomes[c.nome] = c.nome;
  });
  renderLegendas();
}

function abrirModalCats(){
  renderCatLista();
  selecionarCorCat('#2b6803');
  document.getElementById('catNomeInput').value = '';
  document.getElementById('modalCats').classList.add('open');
}

function fecharCats(){
  document.getElementById('modalCats').classList.remove('open');
}

function renderCatLista(){
  const lista = document.getElementById('catLista');
  lista.innerHTML = '';

  // Padrão
  catsPadrao.forEach(c => {
    const cor = catCores[c] || '#6b7280';
    const nome = catNomes[c] || c;
    const item = document.createElement('div');
    item.className = 'cat-item';
    item.innerHTML = `<div class="cat-item-cor" style="background:${cor}"></div><div class="cat-item-nome">${nome}</div><span class="cat-item-padrao">padrão</span>`;
    lista.appendChild(item);
  });

  // Custom
  catsCustom.forEach(c => {
    const item = document.createElement('div');
    item.className = 'cat-item';
    item.innerHTML = `
      <div class="cat-item-cor" style="background:${c.cor}"></div>
      <div class="cat-item-nome">${c.nome}</div>
      <button class="btn-icon-sm del" onclick="excluirCat(${c.id},'${c.nome.replace(/'/g,"\\'")}')">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
      </button>
    `;
    lista.appendChild(item);
  });
}

function selecionarCorCat(cor){
  document.getElementById('catCorInput').value = cor;
  document.querySelectorAll('#catCoresWrap .cor-btn').forEach(b => b.classList.toggle('selecionada', b.dataset.cor===cor));
}

async function salvarCategoria(){
  const nome = document.getElementById('catNomeInput').value.trim();
  const cor = document.getElementById('catCorInput').value;
  if(!nome){ alert('Digite o nome da categoria!'); return; }
  try {
    const r = await fetch('/calendario/categorias', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({nome, cor})
    });
    const data = await r.json();
    if(data.ok){
      document.getElementById('catNomeInput').value = '';
      await carregarCats();
      renderCatLista();
    } else { alert('Erro: ' + (data.erro||'Tente novamente')); }
  } catch(e){ alert('Erro ao salvar categoria.'); }
}

async function excluirCat(id, nome){
  if(!confirm('Excluir categoria "'+nome+'"?')) return;
  try {
    const r = await fetch('/calendario/categorias/'+id, {method:'DELETE'});
    const data = await r.json();
    if(data.ok){ await carregarCats(); renderCatLista(); }
    else alert('Erro: ' + (data.erro||''));
  } catch(e){ alert('Erro ao excluir.'); }
}

init();
carregarCats();
</script>
</body>
</html>
