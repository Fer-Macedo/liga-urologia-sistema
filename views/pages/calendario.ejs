<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calendário — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root {
      --verde: #2b6803;
      --verde-light: #f0f7eb;
      --verde-mid: #dbefd3;
    }

    .cal-page { padding: 28px 32px; max-width: 1400px; }

    /* HEADER */
    .cal-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
    .cal-titulo { font-size:22px; font-weight:700; color:#1a2e0e; display:flex; align-items:center; gap:10px; }
    .cal-titulo svg { color:var(--verde); }
    .cal-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }

    /* TABS VISUALIZACAO */
    .cal-tabs { display:flex; background:#f1f5f9; border-radius:8px; padding:3px; gap:2px; }
    .cal-tab { border:none; background:transparent; border-radius:6px; padding:6px 14px; font-size:13px; font-weight:600; cursor:pointer; color:#6b7280; transition:.2s; display:flex; align-items:center; gap:5px; }
    .cal-tab.ativo { background:#fff; color:#1a2e0e; box-shadow:0 1px 3px rgba(0,0,0,.1); }

    /* NAVEGACAO MES */
    .cal-nav { display:flex; align-items:center; gap:16px; }
    .cal-nav-btn { background:#fff; border:1px solid #e2e8f0; border-radius:8px; width:34px; height:34px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#374151; transition:.2s; }
    .cal-nav-btn:hover { background:#f8fafc; border-color:#2b6803; color:#2b6803; }
    .cal-mes-ano { font-size:17px; font-weight:700; color:#1a2e0e; min-width:180px; text-align:center; }

    .btn-novo { background:var(--verde); color:#fff; border:none; border-radius:8px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; transition:.2s; }
    .btn-novo:hover { background:#235502; }
    .btn-ical { background:#fff; border:1px solid #e2e8f0; border-radius:8px; padding:9px 14px; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; color:#374151; transition:.2s; }
    .btn-ical:hover { border-color:#2b6803; color:#2b6803; }

    /* LEGENDA CATEGORIAS */
    .cal-legendas { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
    .cal-legenda-item { display:flex; align-items:center; gap:6px; font-size:12px; font-weight:600; color:#374151; cursor:pointer; padding:4px 10px; border-radius:20px; border:1.5px solid transparent; transition:.2s; }
    .cal-legenda-item:hover { background:#f8fafc; }
    .cal-legenda-item.filtrado { opacity:.35; }
    .cal-legenda-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

    /* CALENDÁRIO GRADE */
    .cal-grid-wrap { background:#fff; border-radius:14px; box-shadow:0 1px 4px rgba(0,0,0,.07); overflow:hidden; }
    .cal-dias-semana { display:grid; grid-template-columns:repeat(7,1fr); background:#f8fafc; border-bottom:1px solid #e9eef4; }
    .cal-dia-semana { padding:10px; text-align:center; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#6b7280; }
    .cal-grade { display:grid; grid-template-columns:repeat(7,1fr); }
    .cal-dia { min-height:110px; height:110px; border-right:1px solid #f1f5f9; border-bottom:1px solid #f1f5f9; padding:8px 6px 6px; position:relative; transition:.15s; overflow:hidden; display:flex; flex-direction:column; }
    .cal-dia:nth-child(7n) { border-right:none; }
    .cal-dia:hover { background:#fafffe; }
    .cal-dia.outro-mes { background:#fafafa; }
    .cal-dia.outro-mes .cal-dia-num { color:#d1d5db; }
    .cal-dia.hoje { background:#f0f7eb; }
    .cal-dia.hoje .cal-dia-num { background:var(--verde); color:#fff; }
    .cal-dia-num { width:26px; height:26px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-size:13px; font-weight:700; color:#374151; margin-bottom:4px; flex-shrink:0; }
    .cal-eventos-wrap { flex:1; overflow:hidden; display:flex; flex-direction:column; gap:2px; min-height:0; }
    .cal-evento { padding:2px 6px; border-radius:4px; font-size:10px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:pointer; transition:.15s; flex-shrink:0; line-height:1.6; }
    .cal-evento:hover { filter:brightness(.92); transform:translateX(1px); }
    .cal-mais { font-size:10px; color:#9ca3af; font-weight:600; padding:1px 4px; cursor:pointer; }
    .cal-mais:hover { color:var(--verde); }

    /* LISTA */
    .cal-lista { background:#fff; border-radius:14px; box-shadow:0 1px 4px rgba(0,0,0,.07); overflow:hidden; }
    .cal-lista-mes { padding:16px 22px 8px; font-size:13px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.5px; border-bottom:1px solid #f1f5f9; }
    .cal-lista-item { display:flex; align-items:flex-start; gap:16px; padding:16px 22px; border-bottom:1px solid #f8fafc; cursor:pointer; transition:.15s; }
    .cal-lista-item:last-child { border-bottom:none; }
    .cal-lista-item:hover { background:#fafffe; }
    .cal-lista-data { text-align:center; min-width:50px; }
    .cal-lista-dia { font-size:24px; font-weight:800; color:#1a2e0e; line-height:1; }
    .cal-lista-diasem { font-size:11px; font-weight:600; color:#9ca3af; text-transform:uppercase; }
    .cal-lista-barra { width:4px; border-radius:4px; align-self:stretch; flex-shrink:0; min-height:40px; }
    .cal-lista-info { flex:1; }
    .cal-lista-titulo { font-size:15px; font-weight:700; color:#1a2e0e; margin-bottom:4px; }
    .cal-lista-meta { display:flex; gap:12px; flex-wrap:wrap; align-items:center; }
    .cal-lista-meta span { font-size:12px; color:#6b7280; display:flex; align-items:center; gap:4px; }
    .cal-lista-cat { font-size:11px; font-weight:700; padding:2px 9px; border-radius:20px; }
    .cal-lista-acoes { display:flex; gap:4px; }
    .btn-icon-sm { border:none; background:transparent; cursor:pointer; padding:5px; border-radius:6px; color:#9ca3af; transition:.2s; }
    .btn-icon-sm:hover { background:#f1f5f9; color:var(--verde); }
    .btn-icon-sm.del:hover { color:#dc2626; background:#fee2e2; }
    .cal-vazio { text-align:center; padding:56px; color:#9ca3af; }
    .cal-vazio svg { display:block; margin:0 auto 12px; opacity:.2; }

    /* MODAL */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1000; align-items:center; justify-content:center; padding:20px; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff; border-radius:16px; width:100%; max-width:580px; box-shadow:0 20px 60px rgba(0,0,0,.2); max-height:92vh; overflow-y:auto; }
    .modal-head { padding:20px 24px; border-radius:16px 16px 0 0; background:linear-gradient(135deg,var(--verde),#1d4a02); display:flex; align-items:center; justify-content:space-between; }
    .modal-head h3 { color:#fff; font-size:17px; font-weight:700; margin:0; }
    .modal-close { background:rgba(255,255,255,.2); border:none; color:#fff; border-radius:8px; width:32px; height:32px; cursor:pointer; font-size:20px; display:flex; align-items:center; justify-content:center; }
    .modal-close:hover { background:rgba(255,255,255,.35); }
    .modal-body { padding:24px; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px; }
    .form-row.full { grid-template-columns:1fr; }
    .form-row.tri { grid-template-columns:1fr 1fr 1fr; }
    .form-group { display:flex; flex-direction:column; gap:5px; }
    .form-group label { font-size:11px; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:.4px; }
    .form-group input, .form-group select, .form-group textarea { border:1.5px solid #e2e8f0; border-radius:8px; padding:9px 12px; font-size:14px; color:#1f2937; transition:.2s; background:#fafafa; font-family:inherit; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline:none; border-color:var(--verde); background:#fff; }
    .form-group textarea { resize:vertical; min-height:80px; }
    .cores-wrap { display:flex; gap:8px; flex-wrap:wrap; margin-top:4px; }
    .cor-btn { width:28px; height:28px; border-radius:50%; border:3px solid transparent; cursor:pointer; transition:.2s; }
    .cor-btn.selecionada { border-color:#1a2e0e; transform:scale(1.15); }
    .switch-wrap { display:flex; align-items:center; gap:10px; margin-top:6px; }
    .switch { position:relative; width:40px; height:22px; }
    .switch input { opacity:0; width:0; height:0; }
    .switch-slider { position:absolute; inset:0; background:#d1d5db; border-radius:22px; cursor:pointer; transition:.2s; }
    .switch-slider:before { content:''; position:absolute; width:16px; height:16px; left:3px; top:3px; background:#fff; border-radius:50%; transition:.2s; }
    .switch input:checked + .switch-slider { background:var(--verde); }
    .switch input:checked + .switch-slider:before { transform:translateX(18px); }
    .modal-footer { display:flex; justify-content:flex-end; gap:10px; padding:0 24px 24px; }
    .btn-cancelar { background:#f1f5f9; color:#374151; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:600; cursor:pointer; }
    .btn-salvar { background:var(--verde); color:#fff; border:none; border-radius:8px; padding:10px 24px; font-size:14px; font-weight:700; cursor:pointer; }
    .btn-salvar:hover { background:#235502; }

    /* MODAL VER EVENTO */
    .modal-ver { background:#fff; border-radius:16px; width:100%; max-width:480px; box-shadow:0 20px 60px rgba(0,0,0,.2); overflow:hidden; }
    .modal-ver-head { padding:24px; position:relative; }
    .modal-ver-cat { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px; opacity:.85; }
    .modal-ver-titulo { font-size:20px; font-weight:800; color:#fff; margin:0; line-height:1.2; }
    .modal-ver-body { padding:20px 24px; }
    .modal-ver-row { display:flex; align-items:flex-start; gap:10px; margin-bottom:14px; font-size:14px; color:#374151; }
    .modal-ver-row svg { color:#6b7280; flex-shrink:0; margin-top:1px; }
    .modal-ver-row a { color:var(--verde); font-weight:600; text-decoration:none; }
    .modal-ver-row a:hover { text-decoration:underline; }
    .modal-ver-footer { padding:16px 24px; border-top:1px solid #f1f5f9; display:flex; gap:8px; justify-content:flex-end; }

    /* ICAL BANNER */
    .ical-banner { background:linear-gradient(135deg,#f0f7eb,#dbefd3); border:1px solid #b8dea0; border-radius:12px; padding:16px 20px; display:flex; align-items:center; gap:14px; margin-bottom:20px; }
    .ical-banner-icon { background:var(--verde); color:#fff; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .ical-banner-txt { flex:1; }
    .ical-banner-txt strong { display:block; font-size:14px; font-weight:700; color:#1a2e0e; margin-bottom:2px; }
    .ical-banner-txt span { font-size:12px; color:#4a7c2a; }
    .btn-ical-copy { background:var(--verde); color:#fff; border:none; border-radius:8px; padding:8px 16px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; }
    .btn-ical-copy:hover { background:#235502; }

    .flash-msg { padding:12px 18px; border-radius:8px; margin-bottom:16px; font-size:14px; font-weight:600; }
    .flash-msg.ok  { background:#dcfce7; color:#15803d; border:1px solid #bbf7d0; }
    .flash-msg.err { background:#fee2e2; color:#b91c1c; border:1px solid #fecaca; }


    /* MODAL CATEGORIAS */
    .cat-lista { display:flex; flex-direction:column; gap:8px; margin-bottom:16px; max-height:260px; overflow-y:auto; }
    .cat-item { display:flex; align-items:center; gap:10px; padding:10px 14px; background:#f8fafc; border-radius:8px; border:1px solid #e2e8f0; }
    .cat-item-cor { width:16px; height:16px; border-radius:50%; flex-shrink:0; }
    .cat-item-nome { flex:1; font-size:14px; font-weight:600; color:#1a2e0e; }
    .cat-item-padrao { font-size:10px; color:#9ca3af; font-weight:600; background:#f1f5f9; padding:2px 8px; border-radius:10px; }
    .cat-nova-linha { display:flex; gap:8px; align-items:center; }
    .cat-nova-linha input { flex:1; border:1.5px solid #e2e8f0; border-radius:8px; padding:8px 12px; font-size:14px; }
    .cat-nova-linha input:focus { outline:none; border-color:var(--verde); }

    @media(max-width:768px){
      .cal-page{padding:16px;}
      .cal-dia{min-height:70px;height:70px;}
      .cal-evento{font-size:9px;padding:1px 4px;}
      .form-row,.form-row.tri{grid-template-columns:1fr;}
    }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'calendario' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Calendário</h1>
    </div>
    <div class="content">
      <% if(msg&&msg.length){ %><div class="flash-msg ok"><%= msg[0] %></div><% } %>
      <% if(erro&&erro.length){ %><div class="flash-msg err"><%= erro[0] %></div><% } %>

      <div class="cal-page">

        <!-- ICAL BANNER -->
        <!-- BANNER COMPARTILHAMENTO -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;">

          <!-- CARD iCAL -->
          <div class="ical-banner" style="margin-bottom:0;">
            <div class="ical-banner-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="ical-banner-txt">
              <strong>Agenda no celular (iPhone/Android)</strong>
              <span>Adicione como calendário por assinatura — atualiza automaticamente!</span>
            </div>
            <button class="btn-ical-copy" onclick="copiarIcal()">📋 Copiar Link iCal</button>
          </div>

          <!-- CARD COMPARTILHAR -->
          <div class="ical-banner" style="margin-bottom:0;background:linear-gradient(135deg,#f0f7fb,#d3e8ef);border-color:#a0cede;">
            <div class="ical-banner-icon" style="background:#0369a1;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </div>
            <div class="ical-banner-txt">
              <strong>Compartilhar Agenda</strong>
              <span>Envie o link público ou dispare por WhatsApp para a equipe.</span>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button class="btn-ical-copy" style="background:#0369a1;" onclick="copiarLinkPublico()">🔗 Copiar Link</button>
              <button class="btn-ical-copy" style="background:#16a34a;" onclick="abrirWhatsApp()">💬 WhatsApp</button>
            </div>
          </div>

        </div>

        <!-- MODAL WHATSAPP -->
        <div class="modal-overlay" id="modalWhatsApp">
          <div class="modal-box" style="max-width:460px;">
            <div class="modal-head" style="background:linear-gradient(135deg,#16a34a,#15803d);">
              <h3>💬 Enviar por WhatsApp</h3>
              <button class="modal-close" onclick="fecharWhatsApp()">×</button>
            </div>
            <div class="modal-body">
              <div class="form-row full" style="margin-bottom:10px;">
                <div class="form-group">
                  <label>Para quem enviar?</label>
                  <div style="display:flex;gap:8px;margin-top:4px;">
                    <button type="button" id="wBtn-todos" class="btn-ical-copy" style="flex:1;justify-content:center;background:#2b6803;" onclick="setDestinatario('todos')">👥 Todos</button>
                    <button type="button" id="wBtn-diretivos" class="btn-ical-copy" style="flex:1;justify-content:center;background:#f1f5f9;color:#374151;" onclick="setDestinatario('diretivos')">🎓 Diretivos</button>
                    <button type="button" id="wBtn-ligantes" class="btn-ical-copy" style="flex:1;justify-content:center;background:#f1f5f9;color:#374151;" onclick="setDestinatario('ligantes')">👨‍⚕️ Ligantes</button>
                  </div>
                </div>
              </div>
              <div class="form-row full">
                <div class="form-group">
                  <label>Mensagem</label>
                  <textarea id="wMensagem" style="min-height:140px;border:1.5px solid #e2e8f0;border-radius:8px;padding:10px 12px;font-size:13px;font-family:inherit;resize:vertical;"></textarea>
                </div>
              </div>
              <div style="background:#f0f7eb;border-radius:8px;padding:10px 14px;font-size:12px;color:#4a7c2a;margin-top:-6px;">
                💡 O link da agenda abre direto no celular, sem precisar de senha!
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn-cancelar" onclick="fecharWhatsApp()">Cancelar</button>
              <button type="button" class="btn-salvar" style="background:#16a34a;" onclick="enviarWhatsApp()">📤 Abrir WhatsApp</button>
            </div>
          </div>
        </div>

        <!-- HEADER -->
        <div class="cal-header">
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
            <div class="cal-nav">
              <button class="cal-nav-btn" onclick="navMes(-1)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <div class="cal-mes-ano" id="labelMesAno"></div>
              <button class="cal-nav-btn" onclick="navMes(1)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
            <button class="cal-nav-btn" onclick="irHoje()" title="Hoje" style="font-size:12px;font-weight:700;width:auto;padding:0 12px;">Hoje</button>
          </div>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <div class="cal-tabs">
              <button class="cal-tab ativo" id="tab-mes" onclick="setView('mes')">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Mês
              </button>
              <button class="cal-tab" id="tab-lista" onclick="setView('lista')">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                Lista
              </button>
            </div>
            <button class="btn-ical" onclick="abrirModalCats()" style="gap:6px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                Categorias
              </button>
              <button class="btn-novo" onclick="abrirModalNovo()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Nova Atividade
            </button>
          </div>
        </div>

        <!-- LEGENDAS -->
        <div class="cal-legendas" id="legendas"></div>

        <!-- VIEW MÊS -->
        <div id="viewMes">
          <div class="cal-grid-wrap">
            <div class="cal-dias-semana">
              <% ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'].forEach(d => { %>
                <div class="cal-dia-semana"><%= d %></div>
              <% }) %>
            </div>
            <div class="cal-grade" id="gradeCalendario"></div>
          </div>
        </div>

        <!-- VIEW LISTA -->
        <div id="viewLista" style="display:none;">
          <div class="cal-lista" id="listaCalendario"></div>
        </div>

      </div>
    </div>
  </main>
</div>

<!-- MODAL NOVO/EDITAR -->
<div class="modal-overlay" id="modalEvento">
  <div class="modal-box">
    <div class="modal-head">
      <h3 id="modalEventoTitulo">Nova Atividade</h3>
      <button class="modal-close" onclick="fecharModal()">×</button>
    </div>
    <form id="formEvento" method="POST" action="/calendario/novo">
      <input type="hidden" name="id" id="fId">
      <div class="modal-body">
        <div class="form-row full">
          <div class="form-group">
            <label>Título *</label>
            <input type="text" name="titulo" id="fTitulo" placeholder="Ex: Aula de Sondagem Vesical" required maxlength="255">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Categoria *</label>
            <select name="categoria" id="fCategoria" required onchange="setCor(this.value)">
              <option value="">Selecione...</option>
              <option value="Aula Pratica">Aula Prática</option>
              <option value="Aula Teorica">Aula Teórica</option>
              <option value="Evento Externo">Evento Externo</option>
              <option value="Reuniao">Reunião</option>
              <option value="Prazo">Prazo</option>
              <option value="So Diretivos">Só Diretivos</option>
              <option value="Outro">Outro</option>
            </select>
          </div>
          <div class="form-group">
            <label>Cor</label>
            <div class="cores-wrap" id="coresWrap">
              <% [
                {c:'#2b6803',n:'verde'},
                {c:'#3b82f6',n:'azul'},
                {c:'#dc2626',n:'vermelho'},
                {c:'#f59e0b',n:'amarelo'},
                {c:'#8b5cf6',n:'roxo'},
                {c:'#ec4899',n:'rosa'},
                {c:'#06b6d4',n:'ciano'},
                {c:'#374151',n:'cinza'}
              ].forEach(function(item){ %>
                <button type="button" class="cor-btn" style="background:<%= item.c %>" data-cor="<%= item.c %>" onclick="selecionarCor('<%= item.c %>')"></button>
              <% }) %>
            </div>
            <input type="hidden" name="cor" id="fCor" value="#2b6803">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Data Início *</label>
            <input type="datetime-local" name="data_inicio" id="fDataInicio" required>
          </div>
          <div class="form-group">
            <label>Data Fim</label>
            <input type="datetime-local" name="data_fim" id="fDataFim">
          </div>
        </div>
        <div class="form-row full">
          <div class="form-group">
            <label>Local</label>
            <input type="text" name="local" id="fLocal" placeholder="Ex: Sala 3 — Bloco Médico">
          </div>
        </div>
        <div class="form-row full">
          <div class="form-group">
            <label>Link Externo</label>
            <input type="url" name="link_externo" id="fLink" placeholder="https://...">
          </div>
        </div>
        <div class="form-row full">
          <div class="form-group">
            <label>Descrição</label>
            <textarea name="descricao" id="fDesc" placeholder="Informações adicionais..."></textarea>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Dia Inteiro</label>
            <div class="switch-wrap">
              <label class="switch"><input type="checkbox" name="dia_inteiro" id="fDiaInteiro" value="true"><span class="switch-slider"></span></label>
              <span style="font-size:13px;color:#374151">Marcar como dia inteiro</span>
            </div>
          </div>
          <div class="form-group">
            <label>Visibilidade</label>
            <div class="switch-wrap">
              <label class="switch"><input type="checkbox" name="publico" id="fPublico" value="true" checked><span class="switch-slider"></span></label>
              <span style="font-size:13px;color:#374151">Visível para todos</span>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancelar" onclick="fecharModal()">Cancelar</button>
        <button type="submit" class="btn-salvar">Salvar</button>
      </div>
    </form>
  </div>
</div>


<!-- MODAL GERENCIAR CATEGORIAS -->
<div class="modal-overlay" id="modalCats">
  <div class="modal-box" style="max-width:480px;">
    <div class="modal-head">
      <h3>⚙️ Gerenciar Categorias</h3>
      <button class="modal-close" onclick="fecharCats()">×</button>
    </div>
    <div class="modal-body">
      <div class="cat-lista" id="catLista"></div>
      <div style="border-top:1px solid #f1f5f9;padding-top:14px;">
        <div style="font-size:11px;font-weight:700;color:#374151;text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px;">Nova Categoria</div>
        <div class="cat-nova-linha">
          <input type="text" id="catNomeInput" placeholder="Nome da categoria" maxlength="50">
          <div class="cores-wrap" id="catCoresWrap" style="margin:0;">
            <% [
              {c:'#2b6803'},{c:'#3b82f6'},{c:'#dc2626'},{c:'#f59e0b'},
              {c:'#8b5cf6'},{c:'#ec4899'},{c:'#06b6d4'},{c:'#374151'},
              {c:'#f97316'},{c:'#0d9488'}
            ].forEach(function(item){ %>
              <button type="button" class="cor-btn" style="background:<%= item.c %>" data-cor="<%= item.c %>" onclick="selecionarCorCat('<%= item.c %>')"></button>
            <% }) %>
