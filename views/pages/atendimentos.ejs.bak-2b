<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atendimentos WhatsApp</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%= config.org_cor||'#2b6803' %>;--rad:2px;}
    .at-tabs{display:flex;gap:6px;margin-bottom:20px;background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:6px;flex-wrap:wrap;}
    .at-tab{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--rad);border:none;background:transparent;cursor:pointer;font-weight:600;font-size:13px;transition:all .15s;color:var(--texto2);font-family:inherit;}
    .at-tab:hover{background:var(--fundo);}
    .at-tab.ativo{background:var(--cor-primaria);color:white;}
    .at-section{display:none;}.at-section.ativo{display:block;}
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
    .stat-card{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:16px;position:relative;overflow:hidden;transition:transform .18s,box-shadow .18s,border-color .18s;cursor:default;}
    .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--cor-stat,var(--cor-primaria));}
    .stat-card:hover{transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.08);border-color:var(--cor-stat,var(--cor-primaria));}
    .stat-num{font-size:28px;font-weight:800;line-height:1;margin-bottom:4px;color:var(--cor-stat,var(--cor-primaria));}
    .stat-lab{font-size:12px;color:var(--texto2);font-weight:600;}
    .table-card{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);overflow:hidden;margin-bottom:16px;}
    .table-header{padding:14px 18px;border-bottom:1px solid var(--borda);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
    table.tabela{width:100%;border-collapse:collapse;}
    table.tabela thead th{background:var(--fundo);padding:10px 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--texto2);text-align:left;border-bottom:1px solid var(--borda);}
    table.tabela tbody tr{border-bottom:1px solid var(--borda);transition:background .12s;}
    table.tabela tbody tr:last-child{border-bottom:none;}
    table.tabela tbody tr:hover{background:var(--fundo);}
    table.tabela tbody td{padding:10px 14px;font-size:13px;vertical-align:middle;}
    .badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:var(--rad);font-size:11px;font-weight:700;}
    .badge-aguardando{background:#fef3c7;color:#92400e;}
    .badge-transferido{background:#dbeafe;color:#1e40af;}
    .badge-encerrado{background:#dcfce7;color:#166534;}
    .area-badge{padding:3px 9px;border-radius:var(--rad);font-size:11px;font-weight:700;display:inline-block;}
    .area-secretaria{background:#dbefd3;color:#166534;}
    .area-financeiro{background:#dbeafe;color:#1e40af;}
    .area-presidencia{background:#f3e8ff;color:#6d28d9;}
    .area-cientifico{background:#fce7f3;color:#9d174d;}
    .area-extensao{background:#fef3c7;color:#92400e;}
    .area-ensino{background:#e0f2fe;color:#0369a1;}
    .area-marketing{background:#ffedd5;color:#c2410c;}
    .btn-xs{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:var(--rad);font-size:11px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);cursor:pointer;text-decoration:none;transition:all .15s;font-family:inherit;}
    .btn-xs:hover{border-color:var(--cor-primaria);color:var(--cor-primaria);transform:translateY(-1px);}
    .btn-xs.verm{color:#dc2626;border-color:#fecaca;}
    .btn-xs.azul{background:#1d4ed8;color:white;border-color:transparent;}
    .btn-xs.azul:hover{background:#1e40af;color:white;}
    .filter-pills{display:flex;gap:6px;flex-wrap:wrap;}
    .pill{padding:5px 14px;border-radius:var(--rad);border:1.5px solid var(--borda);background:var(--card);font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;color:var(--texto2);}
    .pill.ativo,.pill:hover{background:var(--cor-primaria);color:white;border-color:var(--cor-primaria);}
    .contato-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;}
    .contato-card{background:var(--card);border:1px solid var(--borda);border-radius:var(--rad);padding:18px;transition:border-color .15s,transform .15s;}
    .contato-card:hover{border-color:var(--cor-primaria);transform:translateY(-2px);}
    .contato-icon{width:44px;height:44px;border-radius:var(--rad);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .numero-display{font-family:monospace;font-size:13px;font-weight:700;color:var(--texto);letter-spacing:.5px;margin:8px 0 12px;}
    .numero-display.vazio{color:var(--texto2);font-style:italic;font-weight:400;}
    .pulse{display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;animation:pulse 1.5s ease infinite;}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(.85)}}
    .wpp-msg{max-width:80%;margin-bottom:8px;padding:7px 10px 4px;border-radius:6px;font-size:13px;line-height:1.4;word-break:break-word;}
    .wpp-user{background:white;margin-right:auto;border-top-left-radius:0;}
    .wpp-assistant{background:#d9fdd3;margin-left:auto;border-top-right-radius:0;}
    .wpp-area{background:#dbeafe;margin-left:auto;border-top-right-radius:0;}
    .wpp-time{font-size:10px;color:#9ca3af;margin-top:3px;}
    .wpp-label{font-size:10px;font-weight:700;margin-bottom:2px;color:#6b7280;}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media(max-width:768px){.stats-row{grid-template-columns:repeat(2,1fr);}}
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'atendimentos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Atendimentos WhatsApp</h1>
      <div class="topbar-acoes">
        <span style="font-size:12px;color:var(--texto2)">Auto-refresh 60s</span>
        <button class="btn btn-sm" onclick="location.reload()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.18-5"/></svg> Atualizar</button>
      </div>
    </div>
    <div class="content">
      <%if(msg&&msg.length>0){%><div class="alerta alerta-ok"><%=msg[0]%></div><%}%>
      <%if(erro&&erro.length>0){%><div class="alerta alerta-erro"><%=erro[0]%></div><%}%>

      <div class="stats-row">
        <div class="stat-card" style="--cor-stat:#f59e0b">
          <div class="stat-num"><span class="pulse"></span> <%=stats.aguardando||0%></div>
          <div class="stat-lab">Em Atendimento Agora</div>
        </div>
        <div class="stat-card" style="--cor-stat:#3b82f6">
          <div class="stat-num"><%=stats.transferidos_hoje||0%></div>
          <div class="stat-lab">Transferidos Hoje</div>
        </div>
        <div class="stat-card" style="--cor-stat:#10b981">
          <div class="stat-num"><%=stats.encerrados_hoje||0%></div>
          <div class="stat-lab">Encerrados Hoje</div>
        </div>
        <div class="stat-card" style="--cor-stat:var(--cor-primaria)">
          <div class="stat-num"><%=stats.total||0%></div>
          <div class="stat-lab">Total Histórico</div>
        </div>
      </div>

      <div class="at-tabs">
        <button class="at-tab ativo" onclick="showAtTab('atend',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Atendimentos</button>
        <button class="at-tab" onclick="showAtTab('contatos',this)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Contatos das Áreas</button>
      </div>

      <div class="at-section ativo" id="tab-atend">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:14px">
          <div class="filter-pills">
            <span class="pill ativo" onclick="filtrarAt('todos',this)">Todos (<%=atendimentos.length%>)</span>
            <span class="pill" onclick="filtrarAt('aguardando',this)">🟡 Aguardando</span>
            <span class="pill" onclick="filtrarAt('transferido',this)">🔵 Transferidos</span>
            <span class="pill" onclick="filtrarAt('encerrado',this)">🟢 Encerrados</span>
          </div>
          <select id="filtro-area" class="input" style="font-size:12px;padding:5px 8px;height:auto" onchange="filtrarPorArea(this.value)">
            <option value="">Todas as áreas</option>
            <option>secretaria</option><option>financeiro</option><option>presidencia</option>
            <option>cientifico</option><option>extensao</option><option>ensino</option><option>marketing</option>
          </select>
        </div>
        <div class="table-card">
          <div class="table-header">
            <span style="font-size:14px;font-weight:700">Histórico de Atendimentos</span>
          </div>
          <table class="tabela"><thead><tr>
            <th>Membro</th><th>Área</th><th>Status</th><th>Idioma</th><th>Início</th><th>Duração</th><th>Ações</th>
          </tr></thead><tbody>
          <%if(atendimentos.length===0){%>
          <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--texto2)">Nenhum atendimento registrado</td></tr>
          <%}%>
          <%atendimentos.forEach(a=>{
            const dur=a.encerrado_em?Math.round((new Date(a.encerrado_em)-new Date(a.criado_em))/60000):Math.round((Date.now()-new Date(a.criado_em))/60000);
            const durStr=dur>=60?(Math.floor(dur/60)+'h '+(dur%60)+'min'):dur+'min';
          %>
          <tr class="at-row" data-status="<%=a.status%>" data-area="<%=a.area%>">
            <td style="font-family:monospace;font-weight:600">
              ****<%=a.numero_membro.slice(-4)%>
              <div style="font-size:10px;color:var(--texto2)"><%=a.idioma==='es'?'🇵🇾 ES':'🇧🇷 PT'%></div>
            </td>
            <td><span class="area-badge area-<%=a.area%>"><%=a.area%></span></td>
            <td><span class="badge badge-<%=a.status%>"><%=a.status==='aguardando'?'🟡 Aguardando':a.status==='transferido'?'🔵 Transferido':'🟢 Encerrado'%></span></td>
            <td style="font-size:12px;color:var(--texto2)"><%=a.idioma==='es'?'Español':'Português'%></td>
            <td style="font-size:12px;color:var(--texto2)"><%=new Date(a.criado_em).toLocaleString('pt-BR',{timeZone:'America/Asuncion',day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})%></td>
            <td style="font-size:12px;font-weight:600;color:<%=a.status==='aguardando'?'#f59e0b':'var(--texto2)'%>"><%=durStr%></td>
            <td>
              <div style="display:flex;gap:4px;flex-wrap:wrap">
                <%if(a.status==='aguardando'){%>
                <button class="btn-xs azul" onclick="abrirTransferir(<%=a.id%>,'<%=a.area%>')">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/></svg> Transferir</button>
                <form method="POST" action="/atendimentos/<%=a.id%>/encerrar" style="display:inline;margin:0" onsubmit="return confirm('Encerrar?')">
                  <button type="submit" class="btn-xs verm">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Encerrar</button></form>
                <%}%>
                <button class="btn-xs" onclick="verChat(<%=a.id%>,'<%=a.area%>','<%=a.status%>')">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Ver Chat</button>
              </div>
            </td>
          </tr>
          <%});%>
          </tbody></table>
        </div>
      </div>

      <div class="at-section" id="tab-contatos">
        <p style="font-size:13px;color:var(--texto2);margin-bottom:16px">Gerencie os números WhatsApp de cada área. Alterações refletem imediatamente no robô.</p>
        <div class="contato-grid">
          <%
          const areaInfo={secretaria:{cor:'#166534',bg:'#dbefd3'},financeiro:{cor:'#1e40af',bg:'#dbeafe'},presidencia:{cor:'#6d28d9',bg:'#f3e8ff'},cientifico:{cor:'#9d174d',bg:'#fce7f3'},extensao:{cor:'#92400e',bg:'#fef3c7'},ensino:{cor:'#0369a1',bg:'#e0f2fe'},marketing:{cor:'#c2410c',bg:'#ffedd5'}};
          const nomeArea={secretaria:'Secretaria',financeiro:'Financeiro',presidencia:'Presidência',cientifico:'Científico',extensao:'Extensão',ensino:'Ensino',marketing:'Marketing'};
          const areasOrdem=['secretaria','financeiro','presidencia','cientifico','extensao','ensino','marketing'];
          const contatosMap={};
          contatos.forEach(c=>{contatosMap[c.area]=c.numero;});
          areasOrdem.forEach(area=>{
            const info=areaInfo[area]||{cor:'#6b7280',bg:'#f3f4f6'};
            const numero=contatosMap[area]||'';
          %>
          <div class="contato-card">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
              <div class="contato-icon" style="background:<%=info.bg%>">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="<%=info.cor%>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              </div>
              <div>
                <div style="font-weight:700;font-size:14px"><%=nomeArea[area]||area%></div>
                <div style="font-size:11px;color:var(--texto2)">Responsável pelo atendimento</div>
              </div>
            </div>
            <div class="numero-display <%=numero?'':'vazio'%>"><%=numero?'+'+numero:'Não configurado'%></div>
            <button class="btn-xs" style="width:100%;justify-content:center" onclick="editarContato('<%=area%>','<%=numero%>','<%=nomeArea[area]||area%>')">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Editar Número</button>
          </div>
          <%});%>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Modal Transferir -->
<div class="modal-overlay" id="modal-transferir" style="display:none">
  <div class="modal" style="max-width:420px">
    <div class="modal-header">
      <span class="modal-titulo">Transferir Atendimento</span>
      <button class="icon-btn" onclick="fecharModal('modal-transferir')">&#x2715;</button>
    </div>
    <form id="form-transferir" action="" method="POST">
      <div class="modal-body" style="padding:20px 24px">
        <div class="campo">
          <label class="label">Área de Destino</label>
          <select name="area_destino" class="input" required>
            <option value="">Selecione...</option>
            <option value="secretaria">Secretaria</option>
            <option value="financeiro">Financeiro</option>
            <option value="presidencia">Presidência</option>
            <option value="cientifico">Científico</option>
            <option value="extensao">Extensão</option>
            <option value="ensino">Ensino</option>
            <option value="marketing">Marketing</option>
          </select>
        </div>
        <div style="background:#eff6ff;border-radius:var(--rad);padding:10px 12px;font-size:12px;color:#1e40af;margin-top:10px">
          O membro será avisado automaticamente pelo WhatsApp.
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-transferir')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Transferir</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar Contato -->
<div class="modal-overlay" id="modal-contato" style="display:none">
  <div class="modal" style="max-width:420px">
    <div class="modal-header">
      <span class="modal-titulo" id="titulo-contato">Editar Contato</span>
      <button class="icon-btn" onclick="fecharModal('modal-contato')">&#x2715;</button>
    </div>
    <form action="/atendimentos/contatos" method="POST">
      <input type="hidden" name="area" id="contato-area">
      <div class="modal-body" style="padding:20px 24px;display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Número WhatsApp (somente dígitos com DDI)</label>
          <input type="tel" name="numero" id="contato-numero" class="input" placeholder="Ex: 5561993270096" required>
        </div>
        <div style="background:#f0f7eb;border-radius:var(--rad);padding:10px 12px;font-size:12px;color:#166534">
          <strong>Formato:</strong> DDI + DDD + número, sem espaços ou traços.<br>
          Ex: <code>5561993270096</code> = +55 61 99327-0096
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-contato')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Salvar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Chat -->
<div class="modal-overlay" id="modal-chat" style="display:none">
  <div class="modal" style="max-width:540px;height:88vh;display:flex;flex-direction:column;padding:0;overflow:hidden;border-radius:var(--rad)">
    <div class="modal-header" style="flex-shrink:0">
      <div>
        <div class="modal-titulo" id="chat-area-titulo">Chat</div>
        <div id="chat-membro-nome" style="font-size:11px;color:var(--texto2);margin-top:2px"></div>
      </div>
      <button class="icon-btn" onclick="fecharModal('modal-chat')">&#x2715;</button>
    </div>
    <div id="chat-loading" style="display:none;padding:32px;text-align:center;color:var(--texto2);font-size:13px">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite;display:block;margin:0 auto 10px"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      Carregando conversa...
    </div>
    <div id="chat-vazio" style="display:none;padding:32px;text-align:center;color:var(--texto2);font-size:13px">
      Nenhuma mensagem registrada.
    </div>
    <div id="chat-msgs" style="flex:1;overflow-y:auto;background:#e5ddd5;padding:12px;display:none;flex-direction:column"></div>
    <div id="chat-footer" style="display:none;padding:6px 14px;background:var(--fundo);border-top:1px solid var(--borda);font-size:11px;color:var(--texto2)"></div>
    <div id="chat-reply-box" style="display:none;padding:10px 14px;background:var(--card);border-top:1px solid var(--borda)">
      <div style="display:flex;gap:8px;align-items:flex-end">
        <textarea id="chat-reply-txt" class="input" rows="2" placeholder="Digite sua resposta... (Enter envia)" style="flex:1;resize:none;font-size:13px"></textarea>
        <button id="chat-send-btn" class="btn btn-primario btn-sm" onclick="enviarResposta()" style="flex-shrink:0">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </div>
    <div id="chat-acoes-box" style="display:none;padding:8px 14px;background:var(--fundo);border-top:1px solid var(--borda);gap:8px;flex-wrap:wrap">
      <button id="btn-chat-redir" class="btn-xs azul" style="flex:1;justify-content:center">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/></svg> Redirecionar
      </button>
      <button id="btn-chat-enc" class="btn-xs verm" style="flex:1;justify-content:center">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Encerrar
      </button>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
var _chatId=null;
var _chatMsgCount=0;
function showAtTab(id,btn){
  document.querySelectorAll('.at-section').forEach(function(s){s.classList.remove('ativo');});
  document.querySelectorAll('.at-tab').forEach(function(t){t.classList.remove('ativo');});
  document.getElementById('tab-'+id).classList.add('ativo');
  btn.classList.add('ativo');
}
function filtrarAt(status,el){
  document.querySelectorAll('.at-row').forEach(function(r){r.style.display=status==='todos'||r.dataset.status===status?'':'none';});
  document.querySelectorAll('.pill').forEach(function(p){p.classList.remove('ativo');});
  el.classList.add('ativo');
  document.getElementById('filtro-area').value='';
}
function filtrarPorArea(area){
  document.querySelectorAll('.at-row').forEach(function(r){r.style.display=!area||r.dataset.area===area?'':'none';});
  document.querySelectorAll('.pill').forEach(function(p){p.classList.remove('ativo');});
}
function abrirTransferir(id,areaAtual){
  document.getElementById('form-transferir').action='/atendimentos/'+id+'/transferir';
  var sel=document.querySelector('[name="area_destino"]');
  sel.value='';
  Array.from(sel.options).forEach(function(o){o.disabled=o.value===areaAtual;});
  abrirModal('modal-transferir');
}
function editarContato(area,numero,nome){
  document.getElementById('contato-area').value=area;
  document.getElementById('contato-numero').value=numero;
  document.getElementById('titulo-contato').textContent='Editar - '+nome;
  abrirModal('modal-contato');
}
function montarBolha(m,data){
  var div=document.createElement('div');
  var hora=new Date(m.criado_em).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
  var cls=m.papel==='user'?'wpp-user':m.papel==='assistant'?'wpp-assistant':'wpp-area';
  var nome=data.nomeMembro||'Membro';
  var label=m.papel==='user'?nome:m.papel==='assistant'?'Lauro (IA)':data.area;
  var _raw=(m.mensagem||'');
  var _corpo;
  if(_raw.indexOf('[[MIDIA]]')===0){
    var _p=_raw.substring(9).split('|||');
    var _tipo=_p[0]||'';
    var _src=(_p[1]||'').replace(/"/g,'%22');
    var _nome=(_p[2]||'arquivo').replace(/[<>"]/g,'');
    var _url=_src.indexOf('http')===0?_src:('/atendimentos/midia?chave='+encodeURIComponent(_src));
    if(_tipo==='image'){_corpo='<a href="'+_url+'" target="_blank"><img src="'+_url+'" style="max-width:220px;max-height:260px;border-radius:6px;display:block"></a>';}
    else if(_tipo==='audio'){_corpo='<audio controls src="'+_url+'" style="max-width:230px"></audio>';}
    else if(_tipo==='video'){_corpo='<video controls src="'+_url+'" style="max-width:230px;border-radius:6px"></video>';}
    else {_corpo='<a href="'+_url+'" target="_blank" style="display:inline-flex;align-items:center;gap:6px;color:#1e40af;font-weight:600;text-decoration:none">📄 '+(_nome||'Documento')+'</a>';}
  } else {
    var _txt=_raw.split('\n').join('<br>');
    _txt=_txt.replace(/\*([^*\n]+)\*/g,'<strong>$1</strong>');
    _corpo='<div>'+_txt+'</div>';
  }
  div.className='wpp-msg '+cls;
  div.innerHTML='<div class="wpp-label">'+label+'</div>'+_corpo+'<div class="wpp-time">'+hora+'</div>';
  return div;
}
function verChat(id,area,status){
  _chatId=id;
  _chatMsgCount=0;
  document.getElementById('chat-area-titulo').textContent='Chat - '+area+(status==='aguardando'?' (ativo)':'');
  document.getElementById('chat-membro-nome').textContent='';
  document.getElementById('chat-loading').style.display='block';
  document.getElementById('chat-msgs').style.display='none';
  document.getElementById('chat-vazio').style.display='none';
  document.getElementById('chat-footer').style.display='none';
  document.getElementById('chat-reply-box').style.display='none';
  document.getElementById('chat-acoes-box').style.display='none';
  abrirModal('modal-chat');
  fetch('/atendimentos/'+id+'/conversa')
    .then(function(r){return r.json();})
    .then(function(data){
      document.getElementById('chat-loading').style.display='none';
      if(data.nomeMembro){
        document.getElementById('chat-membro-nome').textContent=data.nomeMembro+' - '+data.numero;
      } else {
        document.getElementById('chat-membro-nome').textContent='Membro: '+data.numero;
      }
      if(!data.msgs||data.msgs.length===0){document.getElementById('chat-vazio').style.display='block';return;}
      var box=document.getElementById('chat-msgs');
      box.innerHTML='';
      box.style.display='flex';
      box.style.flexDirection='column';
      data.msgs.forEach(function(m){ box.appendChild(montarBolha(m,data)); });
      _chatMsgCount=data.msgs.length;
      box.scrollTop=box.scrollHeight;
      var ft=document.getElementById('chat-footer');
      ft.style.display='block';
      ft.textContent=data.msgs.length+' mensagens - Area: '+data.area;
      if(status==='aguardando'){
        document.getElementById('chat-reply-box').style.display='block';
        var ac=document.getElementById('chat-acoes-box');
        ac.style.display='flex';
        document.getElementById('btn-chat-redir').onclick=function(){fecharModal('modal-chat');abrirTransferir(id,area);};
        document.getElementById('btn-chat-enc').onclick=function(){
          if(!confirm('Encerrar este atendimento?'))return;
          fecharModal('modal-chat');
          var f=document.createElement('form');f.method='POST';f.action='/atendimentos/'+id+'/encerrar';
          document.body.appendChild(f);f.submit();
        };
      }
    })
    .catch(function(e){
      document.getElementById('chat-loading').style.display='none';
      document.getElementById('chat-vazio').style.display='block';
      document.getElementById('chat-vazio').textContent='Erro: '+e.message;
    });
}
function enviarResposta(){
  var txt=document.getElementById('chat-reply-txt');
  var msg=(txt.value||'').trim();
  if(!msg||!_chatId)return;
  var btn=document.getElementById('chat-send-btn');
  btn.disabled=true;
  fetch('/atendimentos/'+_chatId+'/responder',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'mensagem='+encodeURIComponent(msg)
  })
  .then(function(r){return r.json();})
  .then(function(data){
    if(data.ok){
      txt.value='';
      var box=document.getElementById('chat-msgs');
      var div=document.createElement('div');
      var hora=new Date().toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
      div.className='wpp-msg wpp-area';
      div.innerHTML='<div class="wpp-label">'+data.area+'</div><div>'+data.enviado.split('\n').join('<br>')+'</div><div class="wpp-time">'+hora+' - enviado</div>';
      box.appendChild(div);box.scrollTop=box.scrollHeight;
    } else {alert('Erro: '+(data.erro||'desconhecido'));}
    btn.disabled=false;
  })
  .catch(function(e){alert('Erro: '+e.message);btn.disabled=false;});
}
document.addEventListener('keydown',function(e){
  if(e.target.id==='chat-reply-txt'&&e.key==='Enter'&&!e.shiftKey){e.preventDefault();enviarResposta();}
});
// Auto-refresh inteligente: só recarrega com o chat FECHADO e ninguém digitando
setInterval(function(){
  var modalChat = document.getElementById('modal-chat');
  var chatFechado = !modalChat || window.getComputedStyle(modalChat).display === 'none';
  var txt = document.getElementById('chat-reply-txt');
  var digitando = txt && txt.value && txt.value.trim().length > 0;
  if(chatFechado && !digitando){
    location.reload();
  }
}, 60000);
function _pollConversa(){
  var mc=document.getElementById('modal-chat');
  var aberto=mc && window.getComputedStyle(mc).display!=='none';
  if(!aberto||!_chatId)return;
  fetch('/atendimentos/'+_chatId+'/conversa').then(function(r){return r.json();}).then(function(data){
    if(!data.msgs)return;
    if(data.msgs.length>_chatMsgCount){
      var box=document.getElementById('chat-msgs');
      for(var i=_chatMsgCount;i<data.msgs.length;i++){box.appendChild(montarBolha(data.msgs[i],data));}
      _chatMsgCount=data.msgs.length;
      box.scrollTop=box.scrollHeight;
      var ft=document.getElementById('chat-footer'); if(ft){ft.textContent=data.msgs.length+' mensagens - Area: '+data.area;}
    }
  }).catch(function(){});
}
setInterval(_pollConversa, 4000);
</script>
</body>
</html>
