<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro de Ligante — <%= config.org_nome || 'Liga Acadêmica de Urologia' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
    body { background: #f0f4ff; min-height: 100vh; padding: 32px 16px; }
    .container { max-width: 720px; margin: 0 auto; }
    .header { text-align: center; margin-bottom: 32px; }
    .logo { max-height: 80px; max-width: 200px; object-fit: contain; margin-bottom: 16px; }
    .header h1 { font-size: 24px; font-weight: 700; color: #1a56db; margin-bottom: 6px; }
    .header p { color: #6b7280; font-size: 14px; }
    .card { background: white; border-radius: 16px; padding: 32px; box-shadow: 0 4px 24px rgba(0,0,0,0.07); margin-bottom: 20px; }
    .card-titulo { font-size: 15px; font-weight: 700; color: #1a56db; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid #e5e7eb; display: flex; align-items: center; gap: 8px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .campo { display: flex; flex-direction: column; gap: 6px; }
    .campo.full { grid-column: 1 / -1; }
    label { font-size: 13px; font-weight: 600; color: #374151; }
    label span { color: #ef4444; margin-left: 2px; }
    input, select, textarea { padding: 10px 14px; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: 14px; color: #111827; background: #f9fafb; transition: border-color 0.2s, box-shadow 0.2s; font-family: 'Inter', sans-serif; width: 100%; }
    input:focus, select:focus, textarea:focus { outline: none; border-color: #1a56db; box-shadow: 0 0 0 3px rgba(26,86,219,0.1); background: white; }
    textarea { resize: vertical; min-height: 90px; }
    .radio-group { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
    .radio-option { display: flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1.5px solid #e5e7eb; border-radius: 8px; cursor: pointer; font-size: 13px; transition: all 0.2s; }
    .radio-option input { width: auto; margin: 0; }
    .radio-option:has(input:checked) { border-color: #1a56db; background: #eff6ff; color: #1a56db; font-weight: 600; }
    .foto-area { border: 2px dashed #1a56db; border-radius: 12px; padding: 24px; text-align: center; background: #f0f7ff; cursor: pointer; transition: all 0.2s; }
    .foto-area:hover { background: #dbeafe; }
    .foto-preview { max-width: 200px; max-height: 200px; border-radius: 10px; margin-top: 12px; display: none; }
    .btn-submit { width: 100%; padding: 14px; background: linear-gradient(135deg, #1a56db, #1e40af); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s; margin-top: 8px; }
    .btn-submit:hover { opacity: 0.95; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(26,86,219,0.3); }
    .alerta { padding: 14px 18px; border-radius: 10px; margin-bottom: 20px; font-size: 14px; font-weight: 500; }
    .alerta-ok { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
    .alerta-erro { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .footer { text-align: center; margin-top: 24px; color: #9ca3af; font-size: 12px; }
    .campos-formacao { display: none; margin-top: 10px; }
    .campos-cargo { display: none; margin-top: 10px; }
    @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } .card { padding: 20px; } }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <% if (config.org_logo) { %>
      <img src="<%= config.org_logo %>" alt="<%= config.org_nome %>" class="logo">
    <% } %>
    <h1>Cadastro de Ligante</h1>
    <p><%= config.org_nome || 'Liga Acadêmica de Urologia' %> — Preencha todos os campos obrigatórios</p>
  </div>

  <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> <%= msg[0] %></div><% } %>
  <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> <%= erro[0] %></div><% } %>

  <form action="/cadastro-ligante" method="POST" enctype="multipart/form-data" onsubmit="validarForm(event)">

    <!-- DADOS PESSOAIS -->
    <div class="card">
      <div class="card-titulo"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Dados Pessoais</div>
      <div class="grid">
        <div class="campo full">
          <label>Nome Completo (igual ao documento) <span>*</span></label>
          <input name="nome" required placeholder="Seu nome completo" value="<%= form.nome || '' %>">
        </div>
        <div class="campo">
          <label>Data de Nascimento <span>*</span></label>
          <input name="data_nascimento" type="date" required value="<%= form.data_nascimento || '' %>">
        </div>
        <div class="campo">
          <label>Sexo <span>*</span></label>
          <select name="sexo" required>
            <option value="">Selecione...</option>
            <option value="Masculino" <%= form.sexo==='Masculino'?'selected':'' %>>Masculino</option>
            <option value="Feminino" <%= form.sexo==='Feminino'?'selected':'' %>>Feminino</option>
            <option value="Prefiro não informar" <%= form.sexo==='Prefiro não informar'?'selected':'' %>>Prefiro não informar</option>
          </select>
        </div>
        <div class="campo">
          <label>E-mail (preferencialmente Gmail) <span>*</span></label>
          <input name="email" type="email" required placeholder="seu@gmail.com" value="<%= form.email || '' %>">
        </div>
        <div class="campo">
          <label>Endereço de E-mail alternativo</label>
          <input name="email_alternativo" type="email" placeholder="outro@email.com" value="<%= form.email_alternativo || '' %>">
        </div>
        <div class="campo">
          <label>Telefone / WhatsApp <span>*</span></label>
          <div style="display:flex;gap:8px">
            <select name="ddi" style="width:130px;flex-shrink:0;padding:10px 8px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:13px;background:#f9fafb">
              <option value="+595" <%= (form.ddi||'+595')==='+595'?'selected':'' %>>🇵🇾 +595</option>
              <option value="+55" <%= (form.ddi||'')==='+55'?'selected':'' %>>🇧🇷 +55</option>
              <option value="+54" <%= (form.ddi||'')==='+54'?'selected':'' %>>🇦🇷 +54</option>
              <option value="+1" <%= (form.ddi||'')==='+1'?'selected':'' %>>🇺🇸 +1</option>
              <option value="+351" <%= (form.ddi||'')==='+351'?'selected':'' %>>🇵🇹 +351</option>
              <option value="+598" <%= (form.ddi||'')==='+598'?'selected':'' %>>🇺🇾 +598</option>
              <option value="+56" <%= (form.ddi||'')==='+56'?'selected':'' %>>🇨🇱 +56</option>
              <option value="+57" <%= (form.ddi||'')==='+57'?'selected':'' %>>🇨🇴 +57</option>
            </select>
            <input name="whatsapp_num" required placeholder="(00) 00000-0000" value="<%= form.whatsapp_num || form.whatsapp || '' %>" style="flex:1">
          </div>
        </div>
        <div class="campo">
          <label>RG / C.I. / D.N.I. (igual ao documento) <span>*</span></label>
          <input name="rg" required placeholder="Ex: 12.345.678-9" value="<%= form.rg || '' %>">
        </div>
        <div class="campo">
          <label>CPF</label>
          <input name="cpf" oninput="this.value=mascaraCPF(this.value)" placeholder="000.000.000-00" value="<%= form.cpf || '' %>">
        </div>
      </div>
    </div>

    <!-- DADOS ACADÊMICOS -->
    <div class="card">
      <div class="card-titulo"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg> Dados Acadêmicos</div>
      <div class="grid">
        <div class="campo">
          <label>Semestre <span>*</span></label>
          <input name="semestre" required placeholder="Ex: 3" value="<%= form.semestre || '' %>">
        </div>
        <div class="campo">
          <label>Turma <span>*</span></label>
          <input name="turma" required placeholder="Ex: 2B, 5A, 7C..." value="<%= form.turma || '' %>">
        </div>
        <div class="campo">
          <label>Catraca (matrícula)</label>
          <input name="catraca" placeholder="Número da catraca" value="<%= form.catraca || '' %>">
        </div>
        <div class="campo">
          <label>Nº ORCID</label>
          <input name="orcid" placeholder="0000-0000-0000-0000" value="<%= form.orcid || '' %>">
        </div>
        <div class="campo">
          <label>Já tem alguma formação? <span>*</span></label>
          <div class="radio-group">
            <label class="radio-option"><input type="radio" name="tem_formacao" value="Sim" onchange="toggleFormacao(true)" <%= form.tem_formacao==='Sim'?'checked':'' %>> Sim</label>
            <label class="radio-option"><input type="radio" name="tem_formacao" value="Não" onchange="toggleFormacao(false)" <%= form.tem_formacao==='Não'?'checked':'' %>> Não</label>
          </div>
          <div class="campos-formacao" id="campos-formacao">
            <label style="margin-top:8px">Qual a formação?</label>
            <input name="qual_formacao" placeholder="Ex: Técnico em Enfermagem, Bacharel em..." value="<%= form.qual_formacao || '' %>">
          </div>
        </div>
      </div>
    </div>

    <!-- PERFIL E MOTIVAÇÃO -->
    <div class="card">
      <div class="card-titulo"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="3"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="2" y1="12" x2="3" y2="12"/><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> Perfil e Motivação</div>
      <div class="grid">
        <div class="campo full">
          <label>Você possui alguma habilidade específica que gostaria de contribuir com a liga?</label>
          <textarea name="habilidades" placeholder="Ex: designer gráfico, redes sociais, organização de eventos..."><%= form.habilidades || '' %></textarea>
        </div>
        <div class="campo">
          <label>Estaria disposto(a) a ocupar cargos organizacionais? <span>*</span></label>
          <div class="radio-group">
            <label class="radio-option"><input type="radio" name="aceita_cargo" value="Sim" onchange="toggleCargo(true)" <%= form.aceita_cargo==='Sim'?'checked':'' %>> Sim</label>
            <label class="radio-option"><input type="radio" name="aceita_cargo" value="Não" onchange="toggleCargo(false)" <%= form.aceita_cargo==='Não'?'checked':'' %>> Não</label>
            <label class="radio-option"><input type="radio" name="aceita_cargo" value="Talvez" onchange="toggleCargo(false)" <%= form.aceita_cargo==='Talvez'?'checked':'' %>> Talvez</label>
          </div>
          <div class="campos-cargo" id="campos-cargo">
            <label style="margin-top:8px">Qual cargo estaria disposto(a) a ocupar?</label>
            <input name="qual_cargo" placeholder="Ex: Secretaria, Tesouraria, Ensino, Extensão..." value="<%= form.qual_cargo || '' %>">
          </div>
        </div>
        <div class="campo full">
          <label>Como você costuma contribuir em trabalhos em grupo?</label>
          <input name="contribuicao_grupo" placeholder="Ex: liderança, execução, organização..." value="<%= form.contribuicao_grupo || '' %>">
        </div>
        <div class="campo full">
          <label>Cite uma ideia inovadora que você acredita que poderia ser aplicada na liga.</label>
          <textarea name="ideia_inovadora" placeholder="Descreva sua ideia..."><%= form.ideia_inovadora || '' %></textarea>
        </div>
        <div class="campo full">
          <label>Qual tema dentro da área da liga mais desperta seu interesse atualmente?</label>
          <input name="tema_interesse" placeholder="Ex: Urologia oncológica, minimamente invasiva..." value="<%= form.tema_interesse || '' %>">
        </div>
        <div class="campo full">
          <label>Por que você escolheu a LAURO? <span>*</span></label>
          <textarea name="porque_lauro" required placeholder="Conte sua motivação..."><%= form.porque_lauro || '' %></textarea>
        </div>
        <div class="campo full">
          <label>Faça uma breve apresentação sobre você. <span>*</span></label>
          <textarea name="apresentacao" required placeholder="Fale um pouco sobre você, seus interesses, experiências..."><%= form.apresentacao || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- FOTO -->
    <div class="card">
      <div class="card-titulo"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Foto</div>
      <p style="font-size:13px;color:#6b7280;margin-bottom:16px">
        Anexe uma foto sua onde destaque bem o seu rosto. De preferência com jaleco ou chomba azul da universidade. 
        Esta foto poderá ser utilizada em publicações da liga nas redes sociais.
      </p>
      <div class="foto-area" onclick="document.getElementById('input-foto').click()">
        <div style="font-size:36px;margin-bottom:8px"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>
        <div style="font-size:14px;font-weight:600;color:#1a56db">Clique para selecionar sua foto</div>
        <div style="font-size:12px;color:#6b7280;margin-top:4px">JPG, PNG ou WEBP — máximo 5MB</div>
        <img id="foto-preview" class="foto-preview">
      </div>
      <input type="file" id="input-foto" name="foto" accept="image/*" style="display:none" onchange="previewFoto(this)">
    </div>

    <button type="submit" class="btn-submit"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Enviar Cadastro</button>
  </form>

  <div class="footer">
    <%= config.org_nome || 'Liga Acadêmica de Urologia' %> — Cadastro registrado em <%= new Date(new Date().toLocaleString('en-US',{timeZone:'America/Asuncion'})).toLocaleString('pt-BR') %>
  </div>
</div>

<script>
// ── Validação CPF ──
function validarCPF(cpf) {
  cpf = cpf.replace(/[^\d]/g,'');
  if (cpf.length !== 11 || /^(\d)+$/.test(cpf)) return false;
  let soma=0;
  for(let i=0;i<9;i++) soma+=parseInt(cpf[i])*(10-i);
  let r=(soma*10)%11; if(r===10||r===11) r=0;
  if(r!==parseInt(cpf[9])) return false;
  soma=0;
  for(let i=0;i<10;i++) soma+=parseInt(cpf[i])*(11-i);
  r=(soma*10)%11; if(r===10||r===11) r=0;
  return r===parseInt(cpf[10]);
}
function validarEmail(e){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
function mascaraCPF(v){
  v=v.replace(/\D/g,'').substring(0,11);
  if(v.length>9) v=v.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/,'$1.$2.$3-$4');
  else if(v.length>6) v=v.replace(/(\d{3})(\d{3})(\d+)/,'$1.$2.$3');
  else if(v.length>3) v=v.replace(/(\d{3})(\d+)/,'$1.$2');
  return v;
}
function validarForm(e){
  const erros=[];
  const nome=document.querySelector('[name=nome]')?.value.trim()||'';
  const cpf=document.querySelector('[name=cpf]')?.value.trim()||'';
  const email=document.querySelector('[name=email]')?.value.trim()||'';
  const wapp=document.querySelector('[name=whatsapp_num]')?.value.trim()||'';
  const rg=document.querySelector('[name=rg]')?.value.trim()||'';
  const nasc=document.querySelector('[name=data_nascimento]')?.value||'';

  if(nome.length<5) erros.push('Nome completo muito curto (mínimo 5 caracteres).');
  if(!/^[a-zA-ZÀ-ÿ\s]+$/.test(nome)) erros.push('Nome deve conter apenas letras.');
  if(cpf.replace(/\D/g,'').length>0 && !validarCPF(cpf)) erros.push('CPF inválido.');
  if(!validarEmail(email)) erros.push('E-mail inválido.');
  if(wapp.replace(/\D/g,'').length<7) erros.push('Telefone/WhatsApp muito curto.');
  if(rg && rg.length<4) erros.push('RG/CI muito curto.');
  if(nasc){
    const dn=new Date(nasc), hoje=new Date();
    const idade=(hoje-dn)/(1000*60*60*24*365.25);
    if(idade<14||idade>80) erros.push('Data de nascimento inválida.');
  }
  if(erros.length>0){
    e.preventDefault();
    let div=document.getElementById('erros-validacao');
    if(!div){div=document.createElement('div');div.id='erros-validacao';div.className='alerta alerta-erro';document.querySelector('form').prepend(div);}
    div.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> '+erros.join('<br><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> ');
    div.scrollIntoView({behavior:'smooth',block:'center'});
  }
}

function toggleFormacao(sim) {
  document.getElementById('campos-formacao').style.display = sim ? 'block' : 'none';
}
function toggleCargo(sim) {
  document.getElementById('campos-cargo').style.display = sim ? 'block' : 'none';
}
function previewFoto(input) {
  const preview = document.getElementById('foto-preview');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
    reader.readAsDataURL(input.files[0]);
  }
}
window.addEventListener('load', function() {
  if (document.querySelector('input[name="tem_formacao"][value="Sim"]')?.checked) toggleFormacao(true);
  if (document.querySelector('input[name="aceita_cargo"][value="Sim"]')?.checked) toggleCargo(true);
});
</script>
</body>
</html>
