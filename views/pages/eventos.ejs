<%
var cfg = (typeof config !== 'undefined' && config) ? config : {};
var orgNome = cfg.org_nome || 'LAURO';
var brl = function(v){ try { return Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); } catch(e){ return '0,00'; } };
var statusTxt = function(s){ return s==='ativo'?'Ativo':s==='encerrado'?'Encerrado':s==='cancelado'?'Cancelado':'Rascunho'; };
%>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Eventos — <%= orgNome %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --ink:#10201A; --ink-soft:#3A4A43; --ink-faint:#74837C;
      --line:#E2E6E1; --line-strong:#CDD4CE; --paper:#F2F4F0; --card:#FFFFFF;
      --green-900:#0C231B; --green-800:#103024; --green-700:#15402F; --green-600:#1C5A41;
      --green-500:#23704F; --green-400:#2E9168; --accent:#2FA873; --accent-bright:#37C98B;
      --amber:#C98A1E; --amber-bg:#FBF3E0; --red:#C0392B; --red-bg:#FBE9E7;
      --blue:#2C6BB3; --blue-bg:#E8F0FA; --purple:#6D4FB3; --purple-bg:#EEE9F7;
      --shadow-md:0 12px 28px -14px rgba(16,32,26,.28);
    }
    body{margin:0;font-family:'IBM Plex Sans',system-ui,sans-serif;color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;
      background-image:linear-gradient(rgba(16,32,26,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(16,32,26,.022) 1px,transparent 1px);background-size:34px 34px;}
    #ev-page *{box-sizing:border-box}
    #ev-page{margin-left:240px;min-height:100vh;display:flex;flex-direction:column}
    #ev-page svg{display:block}
    #ev-page .ic{stroke:currentColor;stroke-width:1.7;fill:none;stroke-linecap:square;stroke-linejoin:miter}

    /* topbar */
    #ev-page .topbar{height:54px;display:flex;align-items:center;gap:18px;padding:0 28px;background:var(--card);border-bottom:1px solid var(--line)}
    #ev-page .crumb{font-family:'IBM Plex Mono';font-size:11px;letter-spacing:1.5px;color:var(--ink-faint);text-transform:uppercase}
    #ev-page .crumb b{color:var(--ink)}
    #ev-page .topbar .right{margin-left:auto;display:flex;gap:10px}

    #ev-page .btn{display:inline-flex;align-items:center;gap:8px;font-family:'IBM Plex Sans';font-weight:600;font-size:13px;padding:9px 15px;cursor:pointer;border:1px solid var(--line-strong);background:#fff;color:var(--ink);text-decoration:none;transition:.16s ease}
    #ev-page .btn .ic{width:15px;height:15px}
    #ev-page .btn:hover{border-color:var(--accent);color:var(--green-600)}
    #ev-page .btn.primary{background:var(--accent);border-color:var(--accent);color:var(--green-900)}
    #ev-page .btn.primary .ic{stroke:var(--green-900)}
    #ev-page .btn.primary:hover{background:var(--accent-bright);color:var(--green-900);box-shadow:0 8px 20px -8px rgba(47,168,115,.7)}

    #ev-page .content{padding:28px;max-width:1320px;width:100%}

    #ev-page .alerta{padding:11px 14px;font-size:13px;font-weight:500;margin-bottom:16px;border:1px solid var(--line-strong)}
    #ev-page .alerta-ok{background:#EDF6F1;color:var(--green-500);border-color:rgba(35,112,79,.35)}
    #ev-page .alerta-erro{background:var(--red-bg);color:var(--red);border-color:rgba(192,57,43,.3)}

    /* stats */
    #ev-page .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
    #ev-page .stat{background:var(--card);border:1px solid var(--line);padding:20px;position:relative;overflow:hidden;transition:border-color .18s,transform .18s,box-shadow .18s}
    #ev-page .stat::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--bar,var(--accent));transform:scaleX(0);transform-origin:left;transition:transform .28s cubic-bezier(.2,.7,.3,1)}
    #ev-page .stat:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);border-color:var(--line-strong)}
    #ev-page .stat:hover::before{transform:scaleX(1)}
    #ev-page .stat-head{display:flex;justify-content:flex-end;margin-bottom:16px}
    #ev-page .stat-icon{width:40px;height:40px;display:grid;place-items:center;border:1px solid var(--line-strong);color:var(--tint,var(--accent));background:var(--tint-bg,#EAF6F0);transition:transform .18s}
    #ev-page .stat:hover .stat-icon{transform:scale(1.06) rotate(-2deg)}
    #ev-page .stat-icon .ic{width:20px;height:20px;stroke:var(--tint,var(--accent))}
    #ev-page .stat-label{font-family:'IBM Plex Mono';font-size:10px;letter-spacing:1.6px;color:var(--ink-faint);text-transform:uppercase}
    #ev-page .stat-value{font-family:'Archivo';font-weight:800;font-size:34px;line-height:1;letter-spacing:-1px;color:var(--tint,var(--ink));margin-top:6px}

    /* tabs */
    #ev-page .ev-tabs{display:flex;gap:2px;margin-bottom:22px;border-bottom:1px solid var(--line)}
    #ev-page .ev-tab{padding:11px 18px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:600;color:var(--ink-faint);border-bottom:2px solid transparent;margin-bottom:-1px;font-family:'IBM Plex Sans';transition:.15s}
    #ev-page .ev-tab:hover{color:var(--ink)}
    #ev-page .ev-tab.ativo{color:var(--green-600);border-bottom-color:var(--accent)}
    #ev-page .ev-section{display:none}
    #ev-page .ev-section.ativo{display:block}

    /* event cards */
    #ev-page .evento-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px}
    #ev-page .evento-card{background:var(--card);border:1px solid var(--line);overflow:hidden;transition:border-color .18s,transform .18s,box-shadow .18s}
    #ev-page .evento-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:var(--shadow-md)}
    #ev-page .evento-banner{width:100%;height:140px;object-fit:cover;display:block}
    #ev-page .evento-banner-ph{width:100%;height:140px;display:flex;align-items:center;justify-content:center;padding:0 16px;text-align:center;font-family:'Archivo';font-size:14px;font-weight:700;letter-spacing:.3px;color:rgba(255,255,255,.95)}
    #ev-page .evento-body{padding:18px}
    #ev-page .pill{display:inline-block;padding:3px 9px;font-family:'IBM Plex Mono';font-size:9.5px;letter-spacing:.8px;text-transform:uppercase;border:1px solid var(--line-strong);margin-bottom:10px}
    #ev-page .pill.ativo{background:#EDF6F1;color:var(--green-500);border-color:rgba(35,112,79,.35)}
    #ev-page .pill.rascunho{background:#F1F3F1;color:var(--ink-faint);border-color:var(--line-strong)}
    #ev-page .pill.encerrado{background:var(--red-bg);color:var(--red);border-color:rgba(192,57,43,.3)}
    #ev-page .pill.cancelado{background:var(--amber-bg);color:var(--amber);border-color:rgba(201,138,30,.3)}
    #ev-page .evento-nome{font-family:'Archivo';font-size:15px;font-weight:700;margin-bottom:10px;line-height:1.3;color:var(--ink)}
    #ev-page .evento-meta{font-size:12px;color:var(--ink-faint);margin-bottom:5px;display:flex;align-items:center;gap:7px}
    #ev-page .evento-meta .ic{width:13px;height:13px;flex:0 0 13px;stroke:var(--ink-faint)}
    #ev-page .progress-wrap{margin:13px 0 4px}
    #ev-page .progress-bar{height:6px;background:var(--line);overflow:hidden}
    #ev-page .progress-fill{height:100%;transition:width .3s ease}
    #ev-page .progress-legend{display:flex;justify-content:space-between;margin-top:5px;font-family:'IBM Plex Mono';font-size:10.5px;color:var(--ink-faint)}
    #ev-page .evento-acoes{display:flex;gap:6px;margin-top:14px;padding-top:14px;border-top:1px solid var(--line);flex-wrap:wrap}
    #ev-page .ev-btn{display:inline-flex;align-items:center;gap:5px;padding:7px 11px;font-size:11.5px;font-weight:600;text-decoration:none;border:1px solid var(--line-strong);background:#fff;color:var(--ink);cursor:pointer;transition:.15s;font-family:'IBM Plex Sans'}
    #ev-page .ev-btn .ic{width:13px;height:13px}
    #ev-page .ev-btn:hover{border-color:var(--accent);color:var(--green-600)}
    #ev-page .ev-btn.primary{background:var(--green-700);color:#fff;border-color:var(--green-700)}
    #ev-page .ev-btn.primary .ic{stroke:#fff}
    #ev-page .ev-btn.primary:hover{background:var(--green-600);color:#fff}
    #ev-page .ev-btn.verde{background:var(--accent);color:var(--green-900);border-color:var(--accent)}
    #ev-page .ev-btn.verde .ic{stroke:var(--green-900)}
    #ev-page .ev-btn.verde:hover{background:var(--accent-bright);color:var(--green-900)}
    #ev-page .ev-btn.ghost{background:#fff}
    #ev-page .ev-btn.danger{color:var(--red);border-color:rgba(192,57,43,.3);background:#fff}
    #ev-page .ev-btn.danger .ic{stroke:var(--red)}
    #ev-page .ev-btn.danger:hover{background:var(--red-bg)}

    #ev-page .ativos-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:16px 0;text-align:center}
    #ev-page .ativos-metrics .n{font-family:'Archivo';font-size:22px;font-weight:800}
    #ev-page .ativos-metrics .l{font-family:'IBM Plex Mono';font-size:9.5px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
    #ev-page .receita-line{font-family:'IBM Plex Mono';font-size:12.5px;font-weight:600;color:var(--purple);margin-bottom:14px}

    #ev-page .empty{text-align:center;padding:70px 20px;color:var(--ink-faint)}
    #ev-page .empty .ic{width:54px;height:54px;margin:0 auto 16px;stroke:var(--line-strong)}
    #ev-page .empty .t{font-family:'Archivo';font-size:15px;font-weight:700;color:var(--ink-soft);margin-bottom:12px}

    /* table */
    #ev-page .table-card{background:var(--card);border:1px solid var(--line)}
    #ev-page .table-head{padding:16px 18px;border-bottom:1px solid var(--line);font-family:'Archivo';font-size:13px;font-weight:700;letter-spacing:.3px;text-transform:uppercase}
    #ev-page table{width:100%;border-collapse:collapse}
    #ev-page thead th{background:#F6F8F5;padding:11px 14px;font-family:'IBM Plex Mono';font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1.2px;color:var(--ink-faint);text-align:left;border-bottom:1px solid var(--line)}
    #ev-page tbody tr{border-bottom:1px solid var(--line);transition:background .14s}
    #ev-page tbody tr:last-child{border-bottom:none}
    #ev-page tbody tr:hover{background:#F6F8F5}
    #ev-page tbody td{padding:12px 14px;font-size:13px;color:var(--ink);vertical-align:middle}

    /* modal */
    #ev-page .modal-overlay{position:fixed;inset:0;background:rgba(12,35,27,.55);display:none;align-items:flex-start;justify-content:center;z-index:200;padding:40px 16px;overflow-y:auto}
    #ev-page .modal-overlay.open{display:flex}
    #ev-page .modal{background:#fff;border:1px solid var(--line-strong);width:100%;max-width:640px;max-height:90vh;overflow-y:auto}
    #ev-page .modal-header{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;border-bottom:1px solid var(--line)}
    #ev-page .modal-titulo{font-family:'Archivo';font-weight:800;font-size:16px}
    #ev-page .icon-btn{background:none;border:1px solid var(--line-strong);width:32px;height:32px;display:grid;place-items:center;cursor:pointer;color:var(--ink-faint);transition:.15s}
    #ev-page .icon-btn:hover{border-color:var(--red);color:var(--red);background:var(--red-bg)}
    #ev-page .icon-btn .ic{width:15px;height:15px}
    #ev-page .modal-body{padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:14px}
    #ev-page .campo{margin:0}
    #ev-page .campo.full{grid-column:1/-1}
    #ev-page .label{display:block;font-family:'IBM Plex Mono';font-size:10px;letter-spacing:1.4px;text-transform:uppercase;color:var(--ink-faint);margin-bottom:7px}
    #ev-page .input{width:100%;padding:10px 12px;border:1px solid var(--line-strong);background:#fff;font-family:'IBM Plex Sans';font-size:14px;color:var(--ink);outline:none;transition:border-color .16s,box-shadow .16s}
    #ev-page .input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(47,168,115,.12)}
    #ev-page textarea.input{resize:vertical}
    #ev-page .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:16px 20px;border-top:1px solid var(--line)}
    #ev-page .cor-swatch{width:26px;height:26px;cursor:pointer;border:2px solid transparent;transition:.15s}
    #ev-page .cor-swatch:hover{transform:scale(1.12);box-shadow:0 0 0 2px var(--accent)}

    @media(max-width:1100px){#ev-page .stats-row{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:820px){#ev-page{margin-left:64px}#ev-page .modal-body{grid-template-columns:1fr}}
  </style>
</head>
<body>
<%- include('../partials/sidebar', { paginaAtual: 'eventos' }) %>

<div id="ev-page">
  <header class="topbar">
    <div class="crumb">LAURO / <b>Eventos</b></div>
    <div class="right">
      <button class="btn primary" onclick="evModal(true)">
        <svg viewBox="0 0 24 24" class="ic"><path d="M12 5v14M5 12h14"/></svg>
        Novo evento
      </button>
    </div>
  </header>

  <main class="content">
    <% if (typeof msg !== 'undefined' && msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
    <% if (typeof erro !== 'undefined' && erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

    <!-- STATS -->
    <div class="stats-row">
      <div class="stat" style="--tint:var(--green-600);--tint-bg:#EAF6F0;--bar:var(--accent)">
        <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/></svg></div></div>
        <div class="stat-label">Total de eventos</div>
        <div class="stat-value"><%= eventos.length %></div>
      </div>
      <div class="stat" style="--tint:var(--green-500);--tint-bg:#EAF6F0;--bar:var(--green-400)">
        <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><circle cx="9" cy="8" r="3.2"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M16 4.5a3 3 0 0 1 0 6M21 20c0-2.6-1.5-4.4-3.5-5"/></svg></div></div>
        <div class="stat-label">Total inscritos</div>
        <div class="stat-value"><%= totalInscritos %></div>
      </div>
      <div class="stat" style="--tint:var(--purple);--tint-bg:var(--purple-bg);--bar:var(--purple)">
        <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="6" width="18" height="12"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg></div></div>
        <div class="stat-label">Receita total</div>
        <div class="stat-value" style="font-size:26px">R$ <%= brl(totalReceita) %></div>
      </div>
      <div class="stat" style="--tint:var(--amber);--tint-bg:var(--amber-bg);--bar:var(--amber)">
        <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><path d="M20 6L9 17l-5-5"/></svg></div></div>
        <div class="stat-label">Check-ins</div>
        <div class="stat-value"><%= totalCheckins %></div>
      </div>
    </div>

    <!-- TABS -->
    <div class="ev-tabs">
      <button class="ev-tab ativo" onclick="showTab('lista', this)">Todos os eventos</button>
      <button class="ev-tab" onclick="showTab('ativos', this)">Ativos</button>
      <button class="ev-tab" onclick="showTab('relatorio', this)">Relatório</button>
    </div>

    <!-- TAB LISTA -->
    <div class="ev-section ativo" id="tab-lista">
      <% if (eventos.length === 0) { %>
      <div class="empty">
        <svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
        <div class="t">Nenhum evento criado</div>
        <button class="btn primary" style="margin:0 auto" onclick="evModal(true)">
          <svg viewBox="0 0 24 24" class="ic"><path d="M12 5v14M5 12h14"/></svg>
          Criar primeiro evento
        </button>
      </div>
      <% } %>
      <div class="evento-grid">
        <% eventos.forEach(ev => {
          const pct = ev.vagas_total > 0 ? Math.min(100, Math.round((ev.total_inscritos||0) / ev.vagas_total * 100)) : 0;
          const corBarra = pct >= 90 ? '#C0392B' : pct >= 60 ? '#C98A1E' : '#2FA873';
          const corTema = ev.cor_tema || '#15402F';
        %>
        <div class="evento-card">
          <% if (ev.banner_chave) { %>
            <img src="/eventos/<%= ev.id %>/banner" class="evento-banner" alt="<%= ev.nome %>">
          <% } else { %>
            <div class="evento-banner-ph" style="background:linear-gradient(135deg,<%= corTema %>,<%= corTema %>cc)"><%= ev.nome.substring(0,40) %></div>
          <% } %>
          <div class="evento-body">
            <span class="pill <%= ev.status %>"><%= statusTxt(ev.status) %></span>
            <div class="evento-nome"><%= ev.nome %></div>
            <div class="evento-meta">
              <svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
              <%= ev.data_inicio ? new Date(ev.data_inicio).toLocaleDateString('pt-BR',{day:'2-digit',month:'short',year:'numeric'}) : 'Data a definir' %>
            </div>
            <div class="evento-meta">
              <svg viewBox="0 0 24 24" class="ic"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <%= ev.local || 'Local a definir' %>
            </div>
            <div class="progress-wrap">
              <div class="progress-bar"><div class="progress-fill" style="width:<%= pct %>%;background:<%= corBarra %>"></div></div>
              <div class="progress-legend">
                <span><%= ev.total_inscritos||0 %> inscritos</span>
                <span><%= pct %>% — <%= ev.vagas_total %> vagas</span>
              </div>
            </div>
            <div class="evento-acoes">
              <a href="/eventos/<%= ev.id %>" class="ev-btn primary">
                <svg viewBox="0 0 24 24" class="ic"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9z"/></svg>
                Gerenciar
              </a>
              <a href="/eventos/<%= ev.id %>/checkin" class="ev-btn verde">
                <svg viewBox="0 0 24 24" class="ic"><path d="M20 6L9 17l-5-5"/></svg>
                Check-in
              </a>
              <a href="/inscricao/<%= ev.id %>" target="_blank" class="ev-btn ghost">
                <svg viewBox="0 0 24 24" class="ic"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6M10 14L21 3"/></svg>
                Página
              </a>
              <% if (usuario.perfil==='admin'||usuario.perfil==='presidencia') { %>
              <form method="POST" action="/eventos/<%= ev.id %>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir o evento <%= ev.nome.replace(/'/g,"\\'") %>?')">
                <button type="submit" class="ev-btn danger">
                  <svg viewBox="0 0 24 24" class="ic"><path d="M3 6h18M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6M10 11v6M14 11v6M9 6V4h6v2"/></svg>
                </button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- TAB ATIVOS -->
    <div class="ev-section" id="tab-ativos">
      <% const ativos = eventos.filter(e => e.status === 'ativo'); %>
      <% if (ativos.length === 0) { %>
        <div class="empty"><div class="t" style="margin:0">Nenhum evento ativo no momento.</div></div>
      <% } %>
      <div class="evento-grid">
        <% ativos.forEach(ev => { const corTema = ev.cor_tema || '#15402F'; %>
        <div class="evento-card">
          <% if (ev.banner_chave) { %>
            <img src="/eventos/<%= ev.id %>/banner" class="evento-banner" alt="<%= ev.nome %>">
          <% } else { %>
            <div class="evento-banner-ph" style="background:linear-gradient(135deg,<%= corTema %>,<%= corTema %>cc)"><%= ev.nome.substring(0,40) %></div>
          <% } %>
          <div class="evento-body">
            <div class="evento-nome"><%= ev.nome %></div>
            <div class="evento-meta">
              <svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
              <%= ev.data_inicio ? new Date(ev.data_inicio).toLocaleDateString('pt-BR',{day:'2-digit',month:'long',year:'numeric'}) : 'Data a definir' %>
            </div>
            <div class="ativos-metrics">
              <div><div class="n" style="color:var(--green-600)"><%= ev.total_inscritos||0 %></div><div class="l">Inscritos</div></div>
              <div><div class="n" style="color:var(--accent)"><%= ev.total_pagos||0 %></div><div class="l">Pagos</div></div>
              <div><div class="n" style="color:var(--amber)"><%= ev.total_checkins||0 %></div><div class="l">Check-ins</div></div>
            </div>
            <div class="receita-line">R$ <%= brl(ev.receita) %> arrecadados</div>
            <div class="evento-acoes">
              <a href="/eventos/<%= ev.id %>/checkin" class="ev-btn verde" style="flex:1;justify-content:center">
                <svg viewBox="0 0 24 24" class="ic"><path d="M20 6L9 17l-5-5"/></svg> Check-in
              </a>
              <a href="/eventos/<%= ev.id %>" class="ev-btn primary" style="flex:1;justify-content:center">Gerenciar</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- TAB RELATÓRIO -->
    <div class="ev-section" id="tab-relatorio">
      <div class="stats-row" style="margin-bottom:20px">
        <div class="stat" style="--tint:var(--green-600);--tint-bg:#EAF6F0;--bar:var(--accent)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4"/></svg></div></div>
          <div class="stat-label">Eventos criados</div><div class="stat-value"><%= eventos.length %></div>
        </div>
        <div class="stat" style="--tint:var(--green-500);--tint-bg:#EAF6F0;--bar:var(--green-400)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><circle cx="9" cy="8" r="3.2"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M16 4.5a3 3 0 0 1 0 6M21 20c0-2.6-1.5-4.4-3.5-5"/></svg></div></div>
          <div class="stat-label">Total inscritos</div><div class="stat-value"><%= totalInscritos %></div>
        </div>
        <div class="stat" style="--tint:var(--purple);--tint-bg:var(--purple-bg);--bar:var(--purple)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="6" width="18" height="12"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg></div></div>
          <div class="stat-label">Receita total</div><div class="stat-value" style="font-size:26px">R$ <%= brl(totalReceita) %></div>
        </div>
        <div class="stat" style="--tint:var(--amber);--tint-bg:var(--amber-bg);--bar:var(--amber)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><path d="M20 6L9 17l-5-5"/></svg></div></div>
          <div class="stat-label">Check-ins</div><div class="stat-value"><%= totalCheckins %></div>
        </div>
      </div>

      <div class="table-card">
        <div class="table-head">Resumo por evento</div>
        <table>
          <thead>
            <tr>
              <th>Evento</th><th>Data</th>
              <th style="text-align:center">Inscritos</th>
              <th style="text-align:center">Pagos</th>
              <th style="text-align:center">Check-ins</th>
              <th style="text-align:right">Receita</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% eventos.forEach(ev => { %>
            <tr>
              <td style="font-weight:600"><%= ev.nome %></td>
              <td style="color:var(--ink-faint)"><%= ev.data_inicio ? new Date(ev.data_inicio).toLocaleDateString('pt-BR') : '—' %></td>
              <td style="text-align:center;font-weight:600"><%= ev.total_inscritos||0 %></td>
              <td style="text-align:center;color:var(--green-500);font-weight:600"><%= ev.total_pagos||0 %></td>
              <td style="text-align:center;color:var(--amber);font-weight:600"><%= ev.total_checkins||0 %></td>
              <td style="text-align:right;font-weight:600;color:var(--purple)">R$ <%= brl(ev.receita) %></td>
              <td><span class="pill <%= ev.status %>"><%= statusTxt(ev.status) %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

<!-- MODAL NOVO EVENTO -->
<div class="modal-overlay" id="modal-novo-evento">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <span class="modal-titulo">Novo evento</span>
      <button class="icon-btn" onclick="evModal(false)"><svg viewBox="0 0 24 24" class="ic"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
    </div>
    <form action="/eventos" method="POST" enctype="multipart/form-data">
      <div class="modal-body">
        <div class="campo full">
          <label class="label">Nome do evento *</label>
          <input name="nome" class="input" placeholder="Ex: Congresso de Urologia 2026" required>
        </div>
        <div class="campo full">
          <label class="label">Descrição</label>
          <textarea name="descricao" class="input" rows="3" placeholder="Descrição do evento..."></textarea>
        </div>
        <div class="campo"><label class="label">Data/hora início</label><input type="datetime-local" name="data_inicio" class="input"></div>
        <div class="campo"><label class="label">Data/hora fim</label><input type="datetime-local" name="data_fim" class="input"></div>
        <div class="campo"><label class="label">Local</label><input name="local" class="input" placeholder="Nome do local"></div>
        <div class="campo"><label class="label">Total de vagas</label><input type="number" name="vagas_total" class="input" value="100" min="1"></div>
        <div class="campo full"><label class="label">Endereço</label><input name="endereco" class="input" placeholder="Endereço completo"></div>
        <div class="campo full"><label class="label">Banner (imagem)</label><input type="file" name="banner" class="input" accept="image/*" style="padding:8px"></div>
        <div class="campo">
          <label class="label">Tipo de evento</label>
          <select name="tipo_evento" class="input"><option value="presencial">Presencial</option><option value="online">Online</option><option value="hibrido">Híbrido</option></select>
        </div>
        <div class="campo">
          <label class="label">Status</label>
          <select name="status" class="input"><option value="rascunho">Rascunho</option><option value="ativo">Ativo</option></select>
        </div>
        <div class="campo">
          <label class="label">Inscrições públicas</label>
          <select name="publico" class="input"><option value="true">Sim — página pública</option><option value="false">Não — somente interno</option></select>
        </div>
        <div class="campo">
          <label class="label">Cor tema</label>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;align-items:center">
            <div class="cor-swatch" style="background:#15402F" onclick="setCor('#15402F')"></div>
            <div class="cor-swatch" style="background:#1C5A41" onclick="setCor('#1C5A41')"></div>
            <div class="cor-swatch" style="background:#2C6BB3" onclick="setCor('#2C6BB3')"></div>
            <div class="cor-swatch" style="background:#6D4FB3" onclick="setCor('#6D4FB3')"></div>
            <div class="cor-swatch" style="background:#C0392B" onclick="setCor('#C0392B')"></div>
            <div class="cor-swatch" style="background:#C98A1E" onclick="setCor('#C98A1E')"></div>
            <input type="color" onchange="setCor(this.value)" style="width:26px;height:26px;border:none;cursor:pointer;padding:0">
          </div>
          <input type="text" name="cor_tema" id="cor-nova" class="input" value="#15402F" style="max-width:130px">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="evModal(false)">Cancelar</button>
        <button type="submit" class="btn primary">
          <svg viewBox="0 0 24 24" class="ic"><path d="M12 5v14M5 12h14"/></svg>
          Criar evento
        </button>
      </div>
    </form>
  </div>
</div>
</div>

<script>
  function showTab(id, btn) {
    document.querySelectorAll('.ev-section').forEach(s => s.classList.remove('ativo'));
    document.querySelectorAll('.ev-tab').forEach(t => t.classList.remove('ativo'));
    document.getElementById('tab-' + id).classList.add('ativo');
    btn.classList.add('ativo');
  }
  function setCor(val){ document.getElementById('cor-nova').value = val; }
  function evModal(open){
    var ov = document.getElementById('modal-novo-evento');
    ov.classList.toggle('open', !!open);
  }
  // fecha clicando fora do modal
  document.getElementById('modal-novo-evento').addEventListener('click', function(){ evModal(false); });
</script>
</body>
</html>
