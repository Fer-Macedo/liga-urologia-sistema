<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Meus Atendimentos — Lauro</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    .wrap { max-width:860px; margin:30px auto; padding:0 16px; }
    .card { background:#fff; border:1px solid #e2e8f0; border-radius:10px; padding:24px; margin-bottom:24px; }
    .card h2 { font-size:16px; font-weight:700; color:#0f172a; margin:0 0 18px; }
    table { width:100%; border-collapse:collapse; font-size:13px; }
    th { background:#f1f5f9; padding:8px 12px; text-align:left; font-weight:600; color:#475569; }
    td { padding:8px 12px; border-top:1px solid #f1f5f9; color:#0f172a; }
    .badge { display:inline-block; padding:2px 8px; border-radius:12px; font-size:11px; font-weight:600; }
    .badge-ag { background:#dbeafe; color:#1e40af; }
    .badge-enc { background:#f1f5f9; color:#64748b; }
    .btn-sm { padding:5px 12px; border-radius:6px; border:none; cursor:pointer; font-size:12px; font-weight:600; }
    .btn-enc { background:#ef4444; color:#fff; }
    .flash-ok { background:#dcfce7; color:#166534; padding:10px 16px; border-radius:8px; margin-bottom:16px; }
    .flash-err { background:#fee2e2; color:#991b1b; padding:10px 16px; border-radius:8px; margin-bottom:16px; }
    .area-tag { text-transform:capitalize; font-weight:700; color:#1a56db; }
    .info-box { background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px; padding:14px 16px; font-size:13px; color:#0369a1; margin-bottom:20px; }
  </style>
</head>
<body>
<%- include('../partials/sidebar', { pagina: 'lauro-atendimentos' }) %>
<div class="main-content">
  <div class="wrap">
    <h1 style="font-size:22px;font-weight:800;color:#0f172a;margin:0 0 8px">Atendimentos — <span class="area-tag"><%= area %></span></h1>
    <p style="color:#64748b;font-size:13px;margin:0 0 24px">Atendimentos do Lauro direcionados para a sua área.</p>

    <% if (msg && msg.length) { %><div class="flash-ok"><%= msg %></div><% } %>
    <% if (erro && erro.length) { %><div class="flash-err"><%= erro %></div><% } %>

    <div class="info-box">
      💬 Para responder ao membro: envie a mensagem diretamente pelo WhatsApp a partir do número corporativo (<strong>+595 994 868368</strong>). O Lauro vai encaminhar automaticamente ao membro.<br>
      Para encerrar via WhatsApp, envie <strong>SAIR</strong>. Para ver fila, envie <strong>LISTA</strong>.
    </div>

    <div class="card">
      <h2>📋 Atendimentos da <%= area.charAt(0).toUpperCase() + area.slice(1) %></h2>
      <% if (!atendimentos.length) { %>
        <p style="color:#64748b;font-size:13px">Nenhum atendimento registrado para sua área ainda.</p>
      <% } else { %>
      <table>
        <thead><tr><th>ID</th><th>Membro</th><th>Status</th><th>Data</th><th></th></tr></thead>
        <tbody>
          <% atendimentos.forEach(a => { %>
          <tr>
            <td>#<%= a.id %></td>
            <td><%= a.nome_contato || a.numero_membro %></td>
            <td>
              <% if (a.status === 'aguardando') { %>
                <span class="badge badge-ag">Aguardando</span>
              <% } else { %>
                <span class="badge badge-enc">Encerrado</span>
              <% } %>
            </td>
            <td style="font-size:11px;color:#64748b"><%= new Date(a.criado_em).toLocaleString('pt-BR',{timeZone:'America/Asuncion'}) %></td>
            <td>
              <% if (a.status === 'aguardando') { %>
              <form method="POST" action="/lauro-encerrar/<%= a.id %>" style="display:inline">
                <button class="btn-sm btn-enc" onclick="return confirm('Encerrar este atendimento?')">Encerrar</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>
