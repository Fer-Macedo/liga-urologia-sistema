<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diretivos — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    * { font-family: 'Inter', sans-serif; }
    .dir-card { background:var(--card);border:1px solid var(--borda);border-radius:14px;padding:18px 20px;margin-bottom:12px;transition:box-shadow 0.2s; }
    .dir-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.08); }
    .dir-header { display:flex;align-items:center;gap:14px;margin-bottom:12px; }
    .dir-avatar { width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,var(--cor-primaria),#6366f1);color:white;font-size:16px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0; }
    .dir-nome { font-size:15px;font-weight:700;margin-bottom:3px; }
    .dir-cargo { font-size:12px;color:var(--cor-primaria);font-weight:600;background:var(--cor-primaria)15;padding:3px 10px;border-radius:20px;display:inline-block; }
    .dir-info { display:flex;flex-wrap:wrap;gap:12px;font-size:12px;color:var(--texto2); }
    .dir-info span { display:flex;align-items:center;gap:4px; }
    .dir-acoes { display:flex;gap:8px;margin-top:12px; }
    .filtros { display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;align-items:center; }
    .filtro-input { padding:8px 14px;border:1.5px solid var(--borda);border-radius:10px;font-size:13px;background:var(--fundo); }
    .link-cadastro { background:var(--fundo);border:1.5px dashed var(--cor-primaria);border-radius:12px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px; }
    .link-url { font-size:13px;color:var(--cor-primaria);font-weight:600;word-break:break-all; }
    .badge-cargo { padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:var(--cor-primaria)15;color:var(--cor-primaria); }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'diretivos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">🏛️ Diretivos</h1>
      <div class="topbar-acoes">
        <a href="/cadastro-diretivo" target="_blank" class="btn">🔗 Link de cadastro</a>
        <button class="btn btn-primario" onclick="abrirModal('modal-diretivo')">+ Cadastrar diretivo</button>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- Link de cadastro público -->
      <div class="link-cadastro">
        <div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px">📋 Link de cadastro para diretivos</div>
          <div class="link-url" id="link-publico"><%= appUrl %>/cadastro-diretivo</div>
        </div>
        <button class="btn btn-primario" style="font-size:12px" onclick="copiarLink()">📋 Copiar link</button>
      </div>

      <!-- Stats -->
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px">
        <div class="stat-card azul">
          <div class="stat-label">Total diretivos</div>
          <div class="stat-valor azul"><%= diretivos.length %></div>
          <div class="stat-sub azul">ativos</div>
        </div>
        <% const cargosCount = {}; diretivos.forEach(d => { cargosCount[d.cargo] = (cargosCount[d.cargo]||0)+1; }); %>
        <div class="stat-card verde">
          <div class="stat-label">Presidência</div>
          <div class="stat-valor verde"><%= (cargosCount['Presidente(a)']||0) + (cargosCount['Vice-presidente(a)']||0) %></div>
          <div class="stat-sub verde">membros</div>
        </div>
        <div class="stat-card amarelo">
          <div class="stat-label">Diretores</div>
          <div class="stat-valor amarelo"><%= diretivos.filter(d => d.cargo && d.cargo.startsWith('Diretor')).length %></div>
          <div class="stat-sub amarelo">membros</div>
        </div>
        <div class="stat-card roxo" style="--roxo:#8b5cf6">
          <div class="stat-label">Vice-Diretores</div>
          <div class="stat-valor" style="color:#8b5cf6"><%= diretivos.filter(d => d.cargo && d.cargo.startsWith('Vice Dir')).length %></div>
          <div class="stat-sub" style="color:#8b5cf6">membros</div>
        </div>
      </div>

      <!-- Filtro -->
      <div class="filtros">
        <input type="text" class="filtro-input" placeholder="🔍 Buscar por nome ou cargo..." id="busca" oninput="filtrar()" style="flex:1;min-width:200px">
        <select class="filtro-input" id="filtro-cargo" onchange="filtrar()">
          <option value="">Todos os cargos</option>
          <option>Presidente(a)</option>
          <option>Vice-presidente(a)</option>
          <option>Secretário(a)</option>
          <option>Diretor(a) Financeiro(a)</option>
          <option>Diretor(a) Científico</option>
          <option>Vice Diretor(a) Científico</option>
          <option>Diretor(a) de Extensão</option>
          <option>Vice Diretor(a) de Extensão</option>
          <option>Diretor(a) de Ensino</option>
          <option>Vice Diretor(a) de Ensino</option>
          <option>Diretor(a) de Marketing</option>
          <option>Vice Diretor(a) de Marketing</option>
        </select>
      </div>

      <!-- Lista de diretivos -->
      <div id="lista-diretivos">
        <% if (diretivos.length === 0) { %>
          <div class="vazio">Nenhum diretivo cadastrado. Envie o link de cadastro para os diretivos!</div>
        <% } %>
        <% diretivos.forEach(d => { %>
        <div class="dir-card" data-nome="<%= d.nome.toLowerCase() %>" data-cargo="<%= d.cargo || '' %>">
          <div class="dir-header">
            <div class="dir-avatar"><%= d.nome.substring(0,2).toUpperCase() %></div>
            <div style="flex:1">
              <div class="dir-nome"><%= d.nome %></div>
              <span class="dir-cargo"><%= d.cargo || 'Sem cargo' %></span>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn" style="font-size:12px;padding:6px 12px" onclick="abrirEditar(<%= d.id %>)">✏️ Editar</button>
              <form action="/diretivos/<%= d.id %>/toggle" method="POST" style="display:inline">
                <button class="btn" style="font-size:12px;padding:6px 12px;color:var(--vermelho)" title="Desativar">🗑</button>
              </form>
            </div>
          </div>
          <div class="dir-info">
            <% if (d.email) { %><span>📧 <%= d.email %></span><% } %>
            <% if (d.whatsapp) { %><span>📱 <%= d.whatsapp %></span><% } %>
            <% if (d.semestre_turma) { %><span>🎓 <%= d.semestre_turma %></span><% } %>
            <% if (d.onde_reside) { %><span>📍 <%= d.onde_reside %></span><% } %>
            <% if (d.disponibilidade) { %><span>🕐 <%= d.disponibilidade %></span><% } %>
            <span style="color:#9ca3af">Cadastrado em <%= new Date(d.cadastrado_em).toLocaleDateString('pt-BR') %></span>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<!-- Modal cadastro manual -->
<div class="modal-overlay" id="modal-diretivo" style="display:none">
  <div class="modal" style="max-width:640px;max-height:90vh;overflow-y:auto">
    <div class="modal-header">
      <span class="modal-titulo">Cadastrar Diretivo</span>
      <button class="icon-btn" onclick="fecharModal('modal-diretivo')">✕</button>
    </div>
    <form action="/diretivos" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div class="campo" style="grid-column:1/-1"><label class="label">Nome completo *</label><input name="nome" class="input" required></div>
        <div class="campo"><label class="label">RG / C.I.</label><input name="rg" class="input"></div>
        <div class="campo"><label class="label">CPF</label><input name="cpf" class="input"></div>
        <div class="campo"><label class="label">E-mail *</label><input name="email" type="email" class="input" required></div>
        <div class="campo"><label class="label">WhatsApp *</label><input name="whatsapp" class="input" required></div>
        <div class="campo" style="grid-column:1/-1">
          <label class="label">Cargo *</label>
          <select name="cargo" class="input" required>
            <option value="">Selecione...</option>
            <option>Presidente(a)</option>
            <option>Vice-presidente(a)</option>
            <option>Secretário(a)</option>
            <option>Diretor(a) Financeiro(a)</option>
            <option>Diretor(a) Científico</option>
            <option>Vice Diretor(a) Científico</option>
            <option>Diretor(a) de Extensão</option>
            <option>Vice Diretor(a) de Extensão</option>
            <option>Diretor(a) de Ensino</option>
            <option>Vice Diretor(a) de Ensino</option>
            <option>Diretor(a) de Marketing</option>
            <option>Vice Diretor(a) de Marketing</option>
          </select>
        </div>
        <div class="campo"><label class="label">Semestre/Turma</label><input name="semestre_turma" class="input" placeholder="Ex: 2025.2"></div>
        <div class="campo"><label class="label">Data de nascimento</label><input name="data_nascimento" type="date" class="input"></div>
        <div class="campo"><label class="label">Onde reside</label><input name="onde_reside" class="input"></div>
        <div class="campo"><label class="label">Disponibilidade</label><input name="disponibilidade" class="input" placeholder="Ex: Manhã, Tarde"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-diretivo')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Cadastrar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal editar diretivo -->
<div class="modal-overlay" id="modal-editar" style="display:none">
  <div class="modal" style="max-width:640px;max-height:90vh;overflow-y:auto">
    <div class="modal-header">
      <span class="modal-titulo">Editar Diretivo</span>
      <button class="icon-btn" onclick="fecharModal('modal-editar')">✕</button>
    </div>
    <form id="form-editar" action="" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div class="campo" style="grid-column:1/-1"><label class="label">Nome completo *</label><input name="nome" id="e-nome" class="input" required></div>
        <div class="campo"><label class="label">RG / C.I.</label><input name="rg" id="e-rg" class="input"></div>
        <div class="campo"><label class="label">CPF</label><input name="cpf" id="e-cpf" class="input"></div>
        <div class="campo"><label class="label">E-mail</label><input name="email" id="e-email" type="email" class="input"></div>
        <div class="campo"><label class="label">WhatsApp</label><input name="whatsapp" id="e-whatsapp" class="input"></div>
        <div class="campo"><label class="label">Instagram</label><input name="instagram" id="e-instagram" class="input"></div>
        <div class="campo"><label class="label">Catraca</label><input name="catraca" id="e-catraca" class="input"></div>
        <div class="campo" style="grid-column:1/-1">
          <label class="label">Cargo</label>
          <select name="cargo" id="e-cargo" class="input">
            <option>Presidente(a)</option>
            <option>Vice-presidente(a)</option>
            <option>Secretário(a)</option>
            <option>Diretor(a) Financeiro(a)</option>
            <option>Diretor(a) Científico</option>
            <option>Vice Diretor(a) Científico</option>
            <option>Diretor(a) de Extensão</option>
            <option>Vice Diretor(a) de Extensão</option>
            <option>Diretor(a) de Ensino</option>
            <option>Vice Diretor(a) de Ensino</option>
            <option>Diretor(a) de Marketing</option>
            <option>Vice Diretor(a) de Marketing</option>
          </select>
        </div>
        <div class="campo"><label class="label">Semestre/Turma</label><input name="semestre_turma" id="e-semestre" class="input"></div>
        <div class="campo"><label class="label">Data de nascimento</label><input name="data_nascimento" id="e-nascimento" type="date" class="input"></div>
        <div class="campo"><label class="label">Onde reside</label><input name="onde_reside" id="e-reside" class="input"></div>
        <div class="campo"><label class="label">Disponibilidade</label><input name="disponibilidade" id="e-disponibilidade" class="input"></div>
        <div class="campo"><label class="label">Ano ingresso</label><input name="ano_ingresso" id="e-ingresso" class="input"></div>
        <div class="campo"><label class="label">ORCID</label><input name="orcid" id="e-orcid" class="input"></div>
        <div class="campo" style="grid-column:1/-1"><label class="label">Graduação/Curso técnico</label><input name="graduacao" id="e-graduacao" class="input"></div>
        <div class="campo" style="grid-column:1/-1"><label class="label">Experiência com Urologia</label><textarea name="experiencia_urologia" id="e-experiencia" class="input" style="min-height:70px"></textarea></div>
        <div class="campo"><label class="label">Transporte próprio</label><select name="transporte_proprio" id="e-transporte" class="input"><option value="">-</option><option>Sim</option><option>Não</option></select></div>
        <div class="campo"><label class="label">Tipo de transporte</label><input name="tipo_transporte" id="e-tipo-transporte" class="input"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-editar')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Salvar alterações</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const diretivos = <%- JSON.stringify(diretivos) %>;

function filtrar() {
  const busca = document.getElementById('busca').value.toLowerCase();
  const cargo = document.getElementById('filtro-cargo').value;
  document.querySelectorAll('.dir-card').forEach(c => {
    const nome = c.dataset.nome;
    const cargoDirt = c.dataset.cargo;
    const ok = (!busca || nome.includes(busca) || cargoDirt.toLowerCase().includes(busca))
              && (!cargo || cargoDirt === cargo);
    c.style.display = ok ? '' : 'none';
  });
}

function abrirEditar(id) {
  const d = diretivos.find(x => x.id == id);
  if (!d) return;
  document.getElementById('form-editar').action = '/diretivos/' + id + '/editar';
  document.getElementById('e-nome').value = d.nome || '';
  document.getElementById('e-rg').value = d.rg || '';
  document.getElementById('e-cpf').value = d.cpf || '';
  document.getElementById('e-email').value = d.email || '';
  document.getElementById('e-whatsapp').value = d.whatsapp || '';
  document.getElementById('e-instagram').value = d.instagram || '';
  document.getElementById('e-catraca').value = d.catraca || '';
  document.getElementById('e-cargo').value = d.cargo || '';
  document.getElementById('e-semestre').value = d.semestre_turma || '';
  document.getElementById('e-nascimento').value = d.data_nascimento ? d.data_nascimento.substring(0,10) : '';
  document.getElementById('e-reside').value = d.onde_reside || '';
  document.getElementById('e-disponibilidade').value = d.disponibilidade || '';
  document.getElementById('e-ingresso').value = d.ano_ingresso || '';
  document.getElementById('e-orcid').value = d.orcid || '';
  document.getElementById('e-graduacao').value = d.graduacao || '';
  document.getElementById('e-experiencia').value = d.experiencia_urologia || '';
  document.getElementById('e-transporte').value = d.transporte_proprio || '';
  document.getElementById('e-tipo-transporte').value = d.tipo_transporte || '';
  abrirModal('modal-editar');
}

function copiarLink() {
  const url = document.getElementById('link-publico').textContent;
  navigator.clipboard.writeText(url).then(() => alert('Link copiado!'));
}
</script>
</body>
</html>
