<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }
    .stat-mini {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 20px 22px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .stat-mini::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--cor-primaria), #06b6d4);
    }
    .stat-mini .num {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .stat-mini .lab {
      font-size: 12px;
      color: var(--texto2);
      margin-top: 4px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .filtros-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }

    .ligantes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 14px;
    }

    .ligante-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 18px;
      transition: all 0.18s ease;
      cursor: pointer;
      position: relative;
    }
    .ligante-card:hover {
      border-color: var(--cor-primaria);
      box-shadow: 0 6px 20px rgba(26,86,219,.10);
      transform: translateY(-2px);
    }
    .ligante-card.inativo {
      opacity: 0.6;
      border-style: dashed;
    }

    .ligante-foto {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--fundo);
      border: 2px solid var(--borda);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
      overflow: hidden;
    }
    .ligante-foto img {
      width: 52px; height: 52px;
      border-radius: 12px;
      object-fit: cover;
    }
    .ligante-header {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    .ligante-nome {
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -.01em;
    }
    .ligante-sub {
      font-size: 11.5px;
      color: var(--texto2);
      margin-top: 2px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .ligante-info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }
    .ligante-info-item { display: flex; flex-direction: column; gap: 1px; }
    .info-label {
      color: var(--texto2);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 9.5px;
      letter-spacing: .06em;
    }
    .info-valor { color: var(--texto); font-weight: 600; font-size: 13px; }

    .badge-status {
      position: absolute;
      top: 12px; right: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 10.5px;
      font-weight: 700;
    }
    .badge-ativo { background: #dcfce7; color: #166534; }
    .badge-inativo { background: #fee2e2; color: #991b1b; }

    @keyframes piscar { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.7;transform:scale(1.05)} }
    .modal-titulo { font-family:'Plus Jakarta Sans','Outfit',sans-serif !important;font-weight:700 !important;font-size:18px !important; }
    .modal { font-family:'Plus Jakarta Sans','Outfit',sans-serif !important; }
    .card-acoes {
      display: flex;
      gap: 6px;
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid var(--borda);
      flex-wrap: wrap;
    }
    .card-acoes .btn {
      font-size: 12px !important;
      padding: 6px 12px !important;
    }
    .btn-icon-danger {
      padding: 6px 10px !important;
      background: transparent !important;
      border: 1px solid var(--borda) !important;
      border-radius: 9px !important;
      color: var(--vermelho, #ef4444) !important;
      cursor: pointer;
      transition: all .15s ease;
      font-size: 14px;
      line-height: 1;
    }
    .btn-icon-danger:hover {
      background: #fee2e2 !important;
      border-color: #fecaca !important;
    }

    .sem-ligantes {
      text-align: center;
      padding: 60px;
      color: var(--texto2);
      grid-column: 1/-1;
    }
    .sem-ligantes .icon {
      font-size: 48px;
      margin-bottom: 12px;
    }

    /* MODAL DETALHES */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.55); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(3px); }
    .modal-overlay.aberto { display: flex; }
    .modal-grande {
      background: var(--card);
      border-radius: 18px;
      padding: 28px;
      max-width: 680px;
      width: 95%;
      max-height: 88vh;
      overflow-y: auto;
      box-shadow: 0 24px 60px rgba(15,23,42,.18);
      animation: popIn .18s ease;
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(.96); }
      to   { opacity: 1; transform: scale(1); }
    }
    .modal-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 20px;
      border-bottom: 1.5px solid var(--borda);
    }
    .modal-tab {
      padding: 8px 18px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      color: var(--texto2);
      border-bottom: 2.5px solid transparent;
      margin-bottom: -1.5px;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: inherit;
      transition: all .15s;
    }
    .modal-tab.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .detalhe-linha { display: flex; flex-direction: column; gap: 2px; margin-bottom: 12px; }
    .detalhe-label { font-size: 10.5px; font-weight: 700; color: var(--texto2); text-transform: uppercase; letter-spacing: .06em; }
    .detalhe-valor { font-size: 13.5px; color: var(--texto); font-weight: 500; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'ligantes' }) %>
  <main class="main">

    <div class="topbar">
      <h1 class="page-titulo">🎓 Ligantes</h1>
      <div class="topbar-acoes">
        <a href="/ligantes/relatorio" class="btn">📊 Relatório</a>
        <a href="/cadastro-ligante" target="_blank" class="btn btn-primario">🔗 Link de Cadastro</a>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-mini">
          <div class="num" style="color:var(--cor-primaria)"><%= total %></div>
          <div class="lab">Total de ligantes</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#16a34a"><%= ativos %></div>
          <div class="lab">Ativos</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#dc2626"><%= inativos %></div>
          <div class="lab">Inativos</div>
        </div>
      </div>

      <!-- FILTROS -->
      <div class="filtros-row">
        <input type="text" id="busca-input" class="input"
          placeholder="Buscar por nome, email ou turma..."
          style="flex:1;max-width:380px"
          oninput="buscar(this.value)">
        <div style="display:flex;gap:4px">
          <% const sf = typeof statusFiltro !== 'undefined' ? statusFiltro : 'ativos'; %>
          <a href="/ligantes?status=ativos" class="btn" style="font-size:12px;padding:6px 12px;<%= sf==='ativos'||!sf ? 'background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white' : 'background:var(--fundo);color:var(--texto);box-shadow:none;border:1px solid var(--borda)' %>">Ativos</a>
          <a href="/ligantes?status=inativos" class="btn" style="font-size:12px;padding:6px 12px;<%= sf==='inativos' ? 'background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white' : 'background:var(--fundo);color:var(--texto);box-shadow:none;border:1px solid var(--borda)' %>">Inativos</a>
          <% if(typeof pendentesCount!=='undefined'&&pendentesCount>0){ %>
          <a href="/ligantes?status=pendente" class="btn btn-pendente-piscar" style="font-size:12px;padding:6px 12px;background:#f59e0b;color:white;border-color:#f59e0b;font-weight:700;animation:piscar 1.2s ease-in-out infinite">⏳ Pendentes (<%= pendentesCount %>)</a>
          <% } else { %>
          <a href="/ligantes?status=pendente" class="btn" style="font-size:12px;padding:6px 12px;background:#22c55e;color:white;border-color:#16a34a;font-weight:600">✅ Pendentes</a>
          <% } %>
          <a href="/ligantes?status=todos" class="btn" style="font-size:12px;padding:6px 12px;<%= sf==='todos' ? 'background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white' : 'background:var(--fundo);color:var(--texto);box-shadow:none;border:1px solid var(--borda)' %>">Todos</a>
        </div>
        <span id="contador" style="font-size:13px;color:var(--texto2);white-space:nowrap"><%= ligantes.length %> exibidos</span>
      </div>

      <!-- GRID -->
      <div class="ligantes-grid" id="grid-ligantes">
        <% if (ligantes.length === 0) { %>
          <div class="sem-ligantes">
            <div class="icon">🎓</div>
            <div style="font-size:15px;font-weight:600;margin-bottom:8px">Nenhum ligante cadastrado</div>
            <a href="/cadastro-ligante" target="_blank" class="btn btn-primario">🔗 Abrir formulário</a>
          </div>
        <% } %>

        <% ligantes.forEach(l => { %>
        <div class="ligante-card <%= l.ativo == 0 ? 'inativo' : '' %>"
          data-nome="<%= (l.nome||'').toLowerCase() %>"
          data-email="<%= (l.email||'').toLowerCase() %>"
          data-turma="<%= (l.turma||'').toLowerCase() %>"
          data-status="<%= l.ativo == 0 ? 'inativo' : 'ativo' %>"
          onclick="abrirDetalhe(<%= l.id %>)">

          <span class="badge-status <%= l.ativo == 0 ? 'badge-inativo' : 'badge-ativo' %>">
            <%= l.ativo == 0 ? 'Inativo' : 'Ativo' %>
          </span>

          <div class="ligante-header">
            <div class="ligante-foto">
              <% if (l.foto_chave) { %>
                <img src="/ligantes/<%= l.id %>/foto" alt="<%= l.nome %>">
              <% } else { %>👤<% } %>
            </div>
            <div style="min-width:0;flex:1">
              <div class="ligante-nome"><%= l.nome %></div>
              <div class="ligante-sub">📧 <%= l.email || '—' %></div>
              <div class="ligante-sub">📱 <%= l.whatsapp || '—' %></div>
            </div>
          </div>

          <div class="ligante-info-grid">
            <div class="ligante-info-item">
              <span class="info-label">Semestre</span>
              <span class="info-valor"><%= l.semestre || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Turma</span>
              <span class="info-valor"><%= l.turma || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">RG/CI</span>
              <span class="info-valor"><%= l.rg || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Catraca</span>
              <span class="info-valor"><%= l.catraca || '—' %></span>
            </div>
          </div>

          <div class="card-acoes" onclick="event.stopPropagation()">
            <button class="btn btn-primario" onclick="abrirDetalhe(<%= l.id %>)">👁 Detalhes</button>
            <a href="/ligantes/<%= l.id %>/editar" class="btn">✏️ Editar</a>
            <% if(typeof statusFiltro!=='undefined' && statusFiltro==='pendente' && l.pendente){ %>
            <button class="btn" style="background:#22c55e;color:white;border:none;font-weight:600;font-size:12px" onclick="if(confirm('Liberar este ligante?')) { const f=document.createElement('form');f.method='POST';f.action='/ligantes/<%= l.id %>/toggle';document.body.append(f);f.submit(); }">✅ Liberar</button>
            <a href="/ligantes/<%= l.id %>/excluir-pendente" class="btn" style="background:#ef4444;color:white;border:none;font-weight:600;font-size:12px" onclick="return confirm('Recusar e excluir permanentemente?')">❌ Recusar</a>
            <% } %>
            <% if (usuario.perfil === 'admin' && statusFiltro !== 'pendente') { %>
            <form action="/ligantes/<%= l.id %>/deletar" method="POST"
              onsubmit="return confirm('Excluir este ligante?')"
              style="display:inline;margin:0">
              <button type="submit" class="btn-icon-danger">🗑</button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<!-- MODAL DETALHES -->
<div class="modal-overlay" id="modal-detalhe" onclick="fecharModalClick(event)">
  <div class="modal-grande">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <span style="font-family:'Outfit',sans-serif;font-size:18px;font-weight:700" id="modal-titulo">Detalhes</span>
      <button onclick="document.getElementById('modal-detalhe').classList.remove('aberto')"
        style="background:none;border:none;font-size:22px;cursor:pointer;color:var(--texto2);line-height:1">✕</button>
    </div>
    <div class="modal-tabs">
      <button class="modal-tab ativo" onclick="trocarTab('dados', this)">📋 Dados</button>
      <button class="modal-tab" onclick="trocarTab('perfil', this)">💡 Perfil</button>
    </div>
    <div id="tab-dados" class="tab-content ativo"></div>
    <div id="tab-perfil" class="tab-content"></div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const ligantes = <%- JSON.stringify(ligantes) %>;

function buscar(termo) {
  const t = termo.toLowerCase().trim();
  let vis = 0;
  document.querySelectorAll('.ligante-card').forEach(c => {
    const match = !t || c.dataset.nome.includes(t) || c.dataset.email.includes(t) || c.dataset.turma.includes(t);
    c.style.display = match ? '' : 'none';
    if (match) vis++;
  });
  document.getElementById('contador').textContent = vis + ' exibidos';
}

function trocarTab(tab, btn) {
  document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('ativo'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('ativo'));
  btn.classList.add('ativo');
  document.getElementById('tab-' + tab).classList.add('ativo');
}

function campo(label, valor) {
  return `<div class="detalhe-linha">
    <span class="detalhe-label">${label}</span>
    <span class="detalhe-valor">${valor || '—'}</span>
  </div>`;
}

function abrirDetalhe(id) {
  const l = ligantes.find(x => x.id === id);
  if (!l) return;
  document.getElementById('modal-titulo').textContent = l.nome;

  // Foto + botão download (só exibe se tiver foto)
  const fotoHtml = l.foto_chave ? `
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;padding:16px;background:var(--fundo);border-radius:12px;border:1px solid var(--borda)">
      <img src="/ligantes/${id}/foto"
        style="width:72px;height:72px;border-radius:12px;object-fit:cover;border:2px solid var(--borda);flex-shrink:0"
        alt="Foto de ${l.nome}">
      <div>
        <div style="font-weight:700;font-size:14px;margin-bottom:6px">${l.nome.split(' ')[0]}</div>
        <a href="/ligantes/${id}/foto" download="${l.nome.replace(/ /g,'_')}_foto"
          target="_blank"
          style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white;border-radius:9px;font-size:12.5px;font-weight:600;text-decoration:none">
          ⬇️ Baixar foto
        </a>
        <div style="font-size:11px;color:var(--texto2);margin-top:5px">
          Clique em "Baixar foto" — abrirá em nova aba para salvar
        </div>
      </div>
    </div>` : `
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:14px 16px;background:var(--fundo);border-radius:12px;border:1px solid var(--borda);color:var(--texto2);font-size:13px">
      👤 <span>Este ligante não anexou foto no cadastro.</span>
    </div>`;

  document.getElementById('tab-dados').innerHTML = fotoHtml + `
    <div class="form-grid-2">
      ${campo('Nome completo', l.nome)}
      ${campo('E-mail', l.email)}
      ${campo('WhatsApp', l.whatsapp)}
      ${campo('Nascimento', l.data_nascimento ? new Date(l.data_nascimento + 'T12:00:00').toLocaleDateString('pt-BR') : null)}
      ${campo('Sexo', l.sexo)}
      ${campo('RG/CI/DNI', l.rg)}
      ${campo('CPF', l.cpf)}
      ${campo('Semestre', l.semestre)}
      ${campo('Turma', l.turma)}
      ${campo('Catraca', l.catraca)}
      ${campo('ORCID', l.orcid)}
      ${campo('Formação', l.tem_formacao === 'Sim' ? 'Sim — ' + (l.qual_formacao||'') : l.tem_formacao)}
      ${campo('Status', l.ativo == 0 ? '🔴 Inativo' : '🟢 Ativo')}
      ${campo('Cadastrado em', new Date(l.criado_em).toLocaleString('pt-BR'))}
    </div>
    <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
      <a href="/ligantes/${id}/editar" class="btn btn-primario">✏️ Editar dados</a>
      ${l.ativo==0?
        `<form action="/ligantes/${id}/toggle" method="POST" style="display:inline;margin:0"><button class="btn" style="color:#16a34a">Reativar</button></form>`
        :`<button class="btn" style="color:#dc2626" onclick="document.getElementById('modal-detalhe').classList.remove('aberto');abrirInativL(${id})">Inativar</button>`
      }
    </div>`;

  document.getElementById('tab-perfil').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:10px">
      ${campo('Habilidades', l.habilidades)}
      ${campo('Aceita cargo', l.aceita_cargo + (l.qual_cargo ? ' — ' + l.qual_cargo : ''))}
      ${campo('Contribuição em grupo', l.contribuicao_grupo)}
      ${campo('Ideia inovadora', l.ideia_inovadora)}
      ${campo('Tema de interesse', l.tema_interesse)}
      ${campo('Por que a LAURO?', l.porque_lauro)}
      ${campo('Apresentação', l.apresentacao)}
    </div>`;

  document.getElementById('modal-detalhe').classList.add('aberto');
}

function fecharModalClick(e) {
  if (e.target === document.getElementById('modal-detalhe'))
    document.getElementById('modal-detalhe').classList.remove('aberto');
}
</script>

<div class="modal-overlay" id="modal-inativ-l" style="display:none">
  <div class="modal" style="max-width:460px">
    <div class="modal-header">
      <span class="modal-titulo">Inativar ligante</span>
      <button class="icon-btn" onclick="fecharModal('modal-inativ-l')">&#x2715;</button>
    </div>
    <p style="font-size:13px;color:var(--texto2);margin:0 0 16px;line-height:1.6">
      Ao inativar, o ligante nao receberao mais notificacoes do sistema.
    </p>
    <div class="campo" style="margin-bottom:12px">
      <label class="label">Motivo *</label>
      <select id="sel-motivo-l" class="input" onchange="atualizarMotivoL()">
        <option value="">Selecione...</option>
        <option>Desligamento voluntario</option>
        <option>Desvinculacao</option>
        <option>Conclusao de curso</option>
        <option>Transferencia de instituicao</option>
        <option>Desempenho insatisfatorio</option>
        <option>Outro</option>
      </select>
    </div>
    <div id="outro-l" style="display:none;margin-bottom:12px">
      <label class="label">Especifique *</label>
      <textarea id="txt-outro-l" class="input" rows="2" oninput="atualizarMotivoL()"></textarea>
    </div>
    <form id="form-inativ-l" action="" method="POST">
      <input type="hidden" name="motivo" id="motivo-l">
      <div class="modal-footer" style="padding:0;margin-top:8px">
        <button type="button" class="btn" onclick="fecharModal('modal-inativ-l')">Cancelar</button>
        <button type="submit" class="btn btn-primario" onclick="return validarL()"
          style="background:linear-gradient(135deg,#dc2626,#b91c1c)">Confirmar</button>
      </div>
    </form>
  </div>
</div>
<script>
function abrirInativL(id){
  document.getElementById('form-inativ-l').action='/ligantes/'+id+'/toggle';
  document.getElementById('sel-motivo-l').value='';
  document.getElementById('motivo-l').value='';
  document.getElementById('outro-l').style.display='none';
  abrirModal('modal-inativ-l');
}
function atualizarMotivoL(){
  const s=document.getElementById('sel-motivo-l').value;
  document.getElementById('outro-l').style.display=s==='Outro'?'':'none';
  document.getElementById('motivo-l').value=s==='Outro'?document.getElementById('txt-outro-l').value:s;
}
function validarL(){
  if(!document.getElementById('motivo-l').value){alert('Informe o motivo.');return false;}
  return true;
}
</script>
</body>
</html>
