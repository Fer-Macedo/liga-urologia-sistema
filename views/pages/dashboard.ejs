<%
/* ============================================================
   DASHBOARD — LAURO (redesign)
   Leitura defensiva: usa a variável da rota se existir,
   senão cai num valor-padrão. Ajuste os nomes à direita
   conforme o que seu res.render('pages/dashboard', {...}) passa.
   ============================================================ */
var L = locals || {};
var pg            = L.paginaAtual || 'dashboard';
var nomeUsuario   = (L.usuario && (L.usuario.nome || L.usuario.usuario)) || 'Administrador';
var perfilUsuario = (L.usuario && (L.usuario.perfil || L.usuario.cargo)) || 'ADMIN';
var orgNome       = (L.config && L.config.org_nome) || 'LAURO — Liga Acadêmica de Urologia';
var dataHoje      = L.dataHoje || (function(){
  try { return new Date().toLocaleDateString('pt-BR',{weekday:'long',day:'numeric',month:'long',year:'numeric',timeZone:'America/Asuncion'}); }
  catch(e){ return ''; }
})();

var num = function(v){ var n = parseInt(v,10); return isNaN(n) ? 0 : n; };
var S = L.stats || {};
var totMembros    = num(S.total);
var pagosN        = num(S.pagos);
var pagosValor    = (S.totalRecebido != null) ? S.totalRecebido : 0;
var pendN         = num(S.pendentes);
var pendValor     = (S.totalPendente != null) ? S.totalPendente : 0;
var atrasoN       = num(S.atrasados);
var atrasoValor   = (S.totalAtrasado != null) ? S.totalAtrasado : 0;

var brl = function(v){ try { return Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); } catch(e){ return '0,00'; } };

var cobrancasRecentes = Array.isArray(L.recentes) ? L.recentes : (Array.isArray(L.cobrancasRecentes) ? L.cobrancasRecentes : []);
var proxAniversarios  = Array.isArray(L.aniversariantes) ? L.aniversariantes : (Array.isArray(L.proximosAniversarios) ? L.proximosAniversarios : []);

/* permissões: se houver lista, filtra a sidebar; senão mostra tudo */
var perms = (L.usuario && Array.isArray(L.usuario.permissoes)) ? L.usuario.permissoes : null;
var pode = function(mod){ return !perms || perms.indexOf(mod) !== -1; };
%>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= orgNome %> · Painel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#10201A; --ink-soft:#3A4A43; --ink-faint:#74837C;
    --line:#E2E6E1; --line-strong:#CDD4CE; --paper:#F2F4F0; --card:#FFFFFF;
    --green-900:#0C231B; --green-800:#103024; --green-700:#15402F; --green-600:#1C5A41;
    --green-500:#23704F; --green-400:#2E9168; --accent:#2FA873; --accent-bright:#37C98B;
    --amber:#C98A1E; --amber-bg:#FBF3E0; --red:#C0392B; --red-bg:#FBE9E7;
    --blue:#2C6BB3; --blue-bg:#E8F0FA; --radius:3px;
    --shadow-md:0 12px 28px -14px rgba(16,32,26,.28);
  }
  /* scope tudo em #lauro-dash pra não brigar com seu style.css global */
  body{margin:0}
  #lauro-dash *{box-sizing:border-box;margin:0;padding:0}
  #lauro-dash{
    font-family:'IBM Plex Sans',system-ui,sans-serif; background:var(--paper); color:var(--ink);
    -webkit-font-smoothing:antialiased; display:block; min-height:100vh; margin-left:240px;
    background-image:linear-gradient(rgba(16,32,26,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(16,32,26,.022) 1px,transparent 1px);
    background-size:34px 34px;
  }
  #lauro-dash svg{display:block}
  #lauro-dash .ic{width:20px;height:20px;stroke:currentColor;stroke-width:1.7;fill:none;stroke-linecap:square;stroke-linejoin:miter}


  #lauro-dash .main{min-width:0;display:flex;flex-direction:column}
  #lauro-dash .topbar{height:54px;display:flex;align-items:center;gap:18px;padding:0 28px;background:var(--card);border-bottom:1px solid var(--line)}
  #lauro-dash .crumb{font-family:'IBM Plex Mono';font-size:11px;letter-spacing:1.5px;color:var(--ink-faint);text-transform:uppercase}
  #lauro-dash .crumb b{color:var(--ink)}
  #lauro-dash .topbar-search{margin-left:auto;display:flex;align-items:center;gap:8px;border:1px solid var(--line-strong);padding:7px 12px;width:280px;color:var(--ink-faint);transition:.16s}
  #lauro-dash .topbar-search:focus-within{border-color:var(--accent);color:var(--ink)}
  #lauro-dash .topbar-search input{border:none;outline:none;font-family:inherit;font-size:13px;width:100%;background:none;color:var(--ink)}
  #lauro-dash .topbar-search .ic{width:16px;height:16px}
  #lauro-dash .content{padding:28px;max-width:1320px;width:100%}

  #lauro-dash .hero{background:radial-gradient(120% 140% at 100% 0%,rgba(47,168,115,.22),transparent 60%),linear-gradient(120deg,var(--green-800),var(--green-900));border:1px solid var(--green-700);color:#fff;padding:30px 32px;display:flex;align-items:center;gap:24px;flex-wrap:wrap;position:relative;overflow:hidden}
  #lauro-dash .hero::after{content:"";position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:48px 48px;-webkit-mask:linear-gradient(90deg,transparent,#000 80%);mask:linear-gradient(90deg,transparent,#000 80%)}
  #lauro-dash .hero-tag{display:inline-flex;align-items:center;gap:8px;font-family:'IBM Plex Mono';font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--accent-bright);border:1px solid rgba(47,168,115,.4);padding:5px 11px;margin-bottom:14px}
  #lauro-dash .hero-tag .ic{width:13px;height:13px;stroke:var(--accent-bright)}
  #lauro-dash .hero h1{font-family:'Archivo';font-weight:800;font-size:30px;letter-spacing:-.5px;line-height:1.05}
  #lauro-dash .hero p{margin-top:8px;color:#A9C2B6;font-size:13.5px}
  #lauro-dash .hero-actions{margin-left:auto;display:flex;gap:12px;position:relative;z-index:1}
  #lauro-dash .btn{display:inline-flex;align-items:center;gap:9px;font-family:'IBM Plex Sans';font-weight:600;font-size:13px;padding:11px 18px;cursor:pointer;border:1px solid transparent;transition:.16s;text-decoration:none}
  #lauro-dash .btn .ic{width:16px;height:16px}
  #lauro-dash .btn-ghost{background:transparent;border-color:rgba(255,255,255,.25);color:#fff}
  #lauro-dash .btn-ghost:hover{background:rgba(255,255,255,.10);border-color:#fff}
  #lauro-dash .btn-primary{background:var(--accent);color:var(--green-900);border-color:var(--accent)}
  #lauro-dash .btn-primary .ic{stroke:var(--green-900)}
  #lauro-dash .btn-primary:hover{background:var(--accent-bright);box-shadow:0 8px 20px -8px rgba(47,168,115,.7)}

  #lauro-dash .grid-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:18px}
  #lauro-dash .stat{background:var(--card);border:1px solid var(--line);padding:20px;position:relative;overflow:hidden;transition:border-color .18s,transform .18s,box-shadow .18s}
  #lauro-dash .stat::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--bar,var(--accent));transform:scaleX(0);transform-origin:left;transition:transform .28s cubic-bezier(.2,.7,.3,1)}
  #lauro-dash .stat:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);border-color:var(--line-strong)}
  #lauro-dash .stat:hover::before{transform:scaleX(1)}
  #lauro-dash .stat-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
  #lauro-dash .stat-icon{width:42px;height:42px;display:grid;place-items:center;border:1px solid var(--line-strong);color:var(--tint,var(--accent));background:var(--tint-bg,#EAF6F0);transition:transform .18s}
  #lauro-dash .stat:hover .stat-icon{transform:scale(1.06) rotate(-2deg)}
  #lauro-dash .stat-icon .ic{width:21px;height:21px;stroke:var(--tint,var(--accent))}
  #lauro-dash .stat-label{font-family:'IBM Plex Mono';font-size:10px;letter-spacing:1.8px;color:var(--ink-faint);text-transform:uppercase}
  #lauro-dash .stat-value{font-family:'Archivo';font-weight:800;font-size:42px;line-height:1;letter-spacing:-1px;color:var(--ink)}
  #lauro-dash .stat-value.tinted{color:var(--tint)}
  #lauro-dash .stat-sub{margin-top:8px;font-size:12px;color:var(--ink-faint);font-family:'IBM Plex Mono'}

  #lauro-dash .section-title{display:flex;align-items:center;gap:10px;margin:30px 0 14px}
  #lauro-dash .section-title .ic{width:17px;height:17px;stroke:var(--green-500)}
  #lauro-dash .section-title h2{font-family:'Archivo';font-weight:700;font-size:15px;letter-spacing:.2px;text-transform:uppercase}
  #lauro-dash .section-title .rule{flex:1;height:1px;background:var(--line)}

  #lauro-dash .grid-actions{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
  #lauro-dash .action{background:var(--card);border:1px solid var(--line);padding:22px 16px;display:flex;flex-direction:column;align-items:center;gap:13px;cursor:pointer;text-decoration:none;color:var(--ink);position:relative;overflow:hidden;transition:border-color .18s,transform .18s,box-shadow .18s}
  #lauro-dash .action::after{content:"";position:absolute;top:0;right:0;width:0;height:0;border-style:solid;border-width:0 18px 18px 0;border-color:transparent var(--accent) transparent transparent;opacity:0;transition:opacity .18s}
  #lauro-dash .action:hover{transform:translateY(-3px);border-color:var(--accent);box-shadow:var(--shadow-md)}
  #lauro-dash .action:hover::after{opacity:1}
  #lauro-dash .action-ic{width:50px;height:50px;display:grid;place-items:center;border:1px solid var(--line-strong);color:var(--green-600);transition:.2s}
  #lauro-dash .action-ic .ic{width:25px;height:25px;stroke:var(--green-600);transition:stroke .2s}
  #lauro-dash .action:hover .action-ic{background:var(--green-800);border-color:var(--green-800)}
  #lauro-dash .action:hover .action-ic .ic{stroke:var(--accent-bright)}
  #lauro-dash .action span{font-size:13px;font-weight:600}

  #lauro-dash .grid-panels{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  #lauro-dash .panel{background:var(--card);border:1px solid var(--line)}
  #lauro-dash .panel-head{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--line)}
  #lauro-dash .panel-head .ttl{display:flex;align-items:center;gap:9px;font-family:'Archivo';font-weight:700;font-size:13px;letter-spacing:.3px;text-transform:uppercase}
  #lauro-dash .panel-head .ttl .ic{width:16px;height:16px;stroke:var(--green-500)}
  #lauro-dash .panel-head a{font-family:'IBM Plex Mono';font-size:10.5px;letter-spacing:1px;color:var(--accent);text-decoration:none;display:flex;align-items:center;gap:4px;transition:.16s}
  #lauro-dash .panel-head a:hover{gap:7px;color:var(--green-500)}
  #lauro-dash .panel-head a .ic{width:12px;height:12px;stroke:currentColor}
  #lauro-dash .row{display:flex;align-items:center;gap:13px;padding:13px 18px;border-bottom:1px solid var(--line);transition:background .14s}
  #lauro-dash .row:last-child{border-bottom:none}
  #lauro-dash .row:hover{background:#F6F8F5}
  #lauro-dash .row-ic{width:36px;height:36px;flex:0 0 36px;display:grid;place-items:center;border:1px solid var(--line-strong);color:var(--green-600)}
  #lauro-dash .row-ic .ic{width:18px;height:18px;stroke:var(--green-600)}
  #lauro-dash .row-main{flex:1;min-width:0}
  #lauro-dash .row-main b{display:block;font-size:13.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  #lauro-dash .row-main span{display:block;font-size:11.5px;color:var(--ink-faint);font-family:'IBM Plex Mono';margin-top:2px}
  #lauro-dash .row-amt{font-family:'IBM Plex Mono';font-weight:600;font-size:13px;text-align:right}
  #lauro-dash .pill{font-family:'IBM Plex Mono';font-size:9.5px;letter-spacing:.8px;text-transform:uppercase;padding:3px 8px;border:1px solid var(--line-strong)}
  #lauro-dash .pill.ok{color:var(--green-500);border-color:rgba(35,112,79,.35);background:#EDF6F1}
  #lauro-dash .pill.late{color:var(--red);border-color:rgba(192,57,43,.3);background:var(--red-bg)}
  #lauro-dash .pill.soon{color:var(--blue);border-color:rgba(44,107,179,.3);background:var(--blue-bg)}
  #lauro-dash .empty{padding:26px 18px;text-align:center;color:var(--ink-faint);font-size:12.5px;font-family:'IBM Plex Mono'}

  @media(max-width:1100px){#lauro-dash .grid-stats{grid-template-columns:repeat(2,1fr)}#lauro-dash .grid-actions{grid-template-columns:repeat(3,1fr)}#lauro-dash .grid-panels{grid-template-columns:1fr}}
  @media(max-width:820px){#lauro-dash{margin-left:64px}}
</style>
</head>
<body>
<%- include('../partials/sidebar', { paginaAtual: 'dashboard' }) %>
<div id="lauro-dash">


  <!-- ===== MAIN ===== -->
  <div class="main">
    <header class="topbar">
      <div class="crumb">LAURO / <b>Dashboard</b></div>
      <form class="topbar-search" action="/buscar" method="get">
        <svg viewBox="0 0 24 24" class="ic"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <input name="q" placeholder="Buscar membros, eventos, cobranças...">
      </form>
    </header>

    <main class="content">

      <section class="hero">
        <div>
          <div class="hero-tag"><svg viewBox="0 0 24 24" class="ic"><rect x="4" y="4" width="16" height="16"/><path d="M9 9h6v6H9z"/></svg>Painel de Controle</div>
          <h1>Olá, <%= nomeUsuario %></h1>
          <p><%= orgNome %><% if (dataHoje) { %> · <%= dataHoje %><% } %></p>
        </div>
        <div class="hero-actions">
          <a class="btn btn-ghost" href="/perfil"><svg viewBox="0 0 24 24" class="ic"><circle cx="12" cy="8" r="3.5"/><path d="M5 21c0-3.9 3.1-6.5 7-6.5s7 2.6 7 6.5"/></svg>Meu Perfil</a>
          <a class="btn btn-primary" href="/cobrancas/gerar"><svg viewBox="0 0 24 24" class="ic"><path d="M13 3L4 14h7l-1 7 9-11h-7z"/></svg>Gerar Cobranças</a>
        </div>
      </section>

      <section class="grid-stats">
        <div class="stat" style="--tint:var(--green-600);--tint-bg:#EAF6F0;--bar:var(--accent)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><circle cx="9" cy="8" r="3.2"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M16 4.5a3 3 0 0 1 0 6M21 20c0-2.6-1.5-4.4-3.5-5"/></svg></div></div>
          <div class="stat-label">Total de Membros</div>
          <div class="stat-value"><%= totMembros %></div>
          <div class="stat-sub">membros ativos</div>
        </div>
        <div class="stat" style="--tint:var(--green-500);--tint-bg:#EAF6F0;--bar:var(--green-400)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="6" width="18" height="12"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg></div></div>
          <div class="stat-label">Pagamentos em Dia</div>
          <div class="stat-value tinted"><%= pagosN %></div>
          <div class="stat-sub">R$ <%= brl(pagosValor) %> recebido</div>
        </div>
        <div class="stat" style="--tint:var(--amber);--tint-bg:var(--amber-bg);--bar:var(--amber)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><path d="M6 3h12M6 21h12M7 3c0 5 5 6 5 9s-5 4-5 9M17 3c0 5-5 6-5 9"/></svg></div></div>
          <div class="stat-label">Pendentes</div>
          <div class="stat-value tinted"><%= pendN %></div>
          <div class="stat-sub">R$ <%= brl(pendValor) %> a receber</div>
        </div>
        <div class="stat" style="--tint:var(--red);--tint-bg:var(--red-bg);--bar:var(--red)">
          <div class="stat-head"><div class="stat-icon"><svg viewBox="0 0 24 24" class="ic"><path d="M12 3L2 20h20z"/><path d="M12 10v5M12 17.5v.5"/></svg></div></div>
          <div class="stat-label">Em Atraso</div>
          <div class="stat-value tinted"><%= atrasoN %></div>
          <div class="stat-sub">R$ <%= brl(atrasoValor) %> inadimplente</div>
        </div>
      </section>

      <div class="section-title">
        <svg viewBox="0 0 24 24" class="ic"><path d="M13 3L4 14h7l-1 7 9-11h-7z"/></svg>
        <h2>Acesso Rápido</h2><span class="rule"></span>
      </div>

      <section class="grid-actions">
        <a class="action" href="/ligantes"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><circle cx="9" cy="8" r="3.2"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M16 4.5a3 3 0 0 1 0 6M21 20c0-2.6-1.5-4.4-3.5-5"/></svg></div><span>Ligantes</span></a>
        <a class="action" href="/frequencia"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><rect x="5" y="3" width="14" height="18"/><path d="M9 3v3h6V3M8.5 10l1.5 1.5L13 8M8.5 16l1.5 1.5L13 14"/></svg></div><span>Frequência</span></a>
        <a class="action" href="/eventos"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="4" width="18" height="17"/><path d="M3 9h18M8 2v4M16 2v4M9 14h6"/></svg></div><span>Eventos</span></a>
        <a class="action" href="/cobrancas"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="6" width="18" height="13"/><path d="M3 10h18M7 15h4"/></svg></div><span>Cobranças</span></a>
        <a class="action" href="/marketing"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><path d="M4 9v6h4l6 4V5L8 9z"/><path d="M17 9a4 4 0 0 1 0 6"/></svg></div><span>Marketing</span></a>
        <a class="action" href="/aniversarios"><div class="action-ic"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="9" width="18" height="12"/><path d="M3 13h18M12 9v12M12 9c-1.5-3-5-3-5-1s2 1 5 1zM12 9c1.5-3 5-3 5-1s-2 1-5 1z"/></svg></div><span>Aniversários</span></a>
      </section>

      <div class="grid-panels" style="margin-top:24px">
        <section class="panel">
          <div class="panel-head">
            <div class="ttl"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="6" width="18" height="13"/><path d="M3 10h18M7 15h4"/></svg>Cobranças Recentes</div>
            <a href="/cobrancas">Ver todas <svg viewBox="0 0 24 24" class="ic"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </div>
          <% if (cobrancasRecentes.length) { %>
            <% cobrancasRecentes.slice(0,4).forEach(function(c){
                 var st = (c.status||'').toLowerCase();
                 var pillCls = st.indexOf('atras')>-1 ? 'late' : (st.indexOf('pend')>-1 ? 'soon' : 'ok');
                 var pillTxt = st.indexOf('atras')>-1 ? 'Em atraso' : (st.indexOf('pend')>-1 ? 'Pendente' : 'Pago');
                 var valor = (c.valor_desconto != null && Number(c.valor_desconto) > 0) ? c.valor_desconto : c.valor_cheio;
                 var quando = '';
                 try { if (L.dayjs && c.criado_em) quando = L.dayjs(c.criado_em).format('DD/MM/YYYY'); } catch(e){}
            %>
            <div class="row">
              <div class="row-ic"><svg viewBox="0 0 24 24" class="ic"><circle cx="12" cy="8" r="3.2"/><path d="M5 20c0-3.3 3-5.5 7-5.5s7 2.2 7 5.5"/></svg></div>
              <div class="row-main"><b><%= c.nome || 'Membro' %></b><span><%= quando %></span></div>
              <div style="text-align:right"><div class="row-amt">R$ <%= brl(valor) %></div><span class="pill <%= pillCls %>"><%= pillTxt %></span></div>
            </div>
            <% }); %>
          <% } else { %>
            <div class="empty">Sem cobranças recentes para exibir.</div>
          <% } %>
        </section>

        <section class="panel">
          <div class="panel-head">
            <div class="ttl"><svg viewBox="0 0 24 24" class="ic"><rect x="3" y="9" width="18" height="12"/><path d="M3 13h18M12 9v12M12 9c-1.5-3-5-3-5-1s2 1 5 1zM12 9c1.5-3 5-3 5-1s-2 1-5 1z"/></svg>Próximos Aniversários</div>
            <a href="/aniversarios">Ver todos <svg viewBox="0 0 24 24" class="ic"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          </div>
          <% if (proxAniversarios.length) { %>
            <% proxAniversarios.slice(0,4).forEach(function(a){
                 var tipoTxt = (a.tipo === 'diretivo') ? 'Diretivo' : 'Ligante';
                 var diaTxt = '';
                 try {
                   if (a.aniv) { var p = String(a.aniv).split('-'); diaTxt = p[1] + '/' + p[0]; }
                   else if (L.dayjs && a.data_nascimento) { diaTxt = L.dayjs(a.data_nascimento).format('DD/MM'); }
                 } catch(e){}
            %>
            <div class="row">
              <div class="row-ic"><svg viewBox="0 0 24 24" class="ic"><rect x="4" y="9" width="16" height="11"/><path d="M4 13h16M12 9V6"/></svg></div>
              <div class="row-main"><b><%= a.nome || 'Membro' %></b><span><%= tipoTxt %></span></div>
              <div style="text-align:right"><span class="pill soon"><%= diaTxt %></span></div>
            </div>
            <% }); %>
          <% } else { %>
            <div class="empty">Nenhum aniversário próximo.</div>
          <% } %>
        </section>
      </div>

    </main>
  </div>
</div>
</body>
</html>
