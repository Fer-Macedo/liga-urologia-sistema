<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — <%= config.org_nome || 'Liga Urologia' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>:root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }</style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Dashboard</h1>
      <div class="topbar-acoes">
        <button onclick="abrirPerfil()" class="btn" title="Meu perfil">👤 <%= usuario.nome.split(' ')[0] %></button>
        <a href="/cobrancas" onclick="return confirm('Gerar cobranças do mês para todos os membros?')" class="btn btn-primario">+ Gerar cobranças</a>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total de membros</div>
          <div class="stat-valor"><%= stats.total %></div>
          <div class="stat-sub">membros ativos</div>
        </div>
        <div class="stat-card verde">
          <div class="stat-label">Pagamentos em dia</div>
          <div class="stat-valor verde"><%= stats.pagos %></div>
          <div class="stat-sub verde">R$ <%= Number(stats.totalRecebido).toFixed(2).replace('.',',') %> recebido</div>
        </div>
        <div class="stat-card amarelo">
          <div class="stat-label">Pendentes (este mês)</div>
          <div class="stat-valor amarelo"><%= stats.pendentes %></div>
          <div class="stat-sub amarelo">R$ <%= Number(stats.totalPendente).toFixed(2).replace('.',',') %> a receber</div>
        </div>
        <div class="stat-card vermelho">
          <div class="stat-label">Em atraso</div>
          <div class="stat-valor vermelho"><%= stats.atrasados %></div>
          <div class="stat-sub vermelho">R$ <%= Number(stats.totalAtrasado).toFixed(2).replace('.',',') %> inadimplente</div>
        </div>
      </div>

      <div class="dois-colunas">
        <!-- Cobranças recentes -->
        <div>
          <div class="section-titulo">Cobranças recentes</div>
          <div class="table-wrap">
            <table class="table">
              <thead><tr>
                <th>Membro</th><th>Referência</th><th>Vencimento</th><th>Status</th>
              </tr></thead>
              <tbody>
                <% if (recentes.length === 0) { %>
                  <tr><td colspan="4" style="text-align:center;color:#888;padding:20px">Nenhuma cobrança ainda</td></tr>
                <% } %>
                <% recentes.forEach(c => { %>
                <tr>
                  <td><div class="membro-cell"><div class="avatar"><%= c.nome.substring(0,2).toUpperCase() %></div><%= c.nome.split(' ').slice(0,2).join(' ') %></div></td>
                  <td><%= c.referencia %></td>
                  <td><%= new Date(c.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR') %></td>
                  <td>
                    <% if (c.status === 'pago') { %><span class="badge verde">Pago</span>
                    <% } else if (c.status === 'atrasado') { %><span class="badge vermelho">Atrasado</span>
                    <% } else { %><span class="badge amarelo">Pendente</span><% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <a href="/cobrancas" class="link-ver-mais">Ver todas as cobranças →</a>
        </div>

        <!-- Aniversários -->
        <div>
          <div class="section-titulo">Aniversários próximos</div>
          <% if (aniversariantes.length === 0) { %>
            <div class="vazio">Nenhum aniversariante cadastrado</div>
          <% } %>
          <% aniversariantes.forEach(m => {
            const hoje_md = new Date().toLocaleDateString('pt-BR',{month:'2-digit',day:'2-digit'}).split('/').reverse().join('-');
            const md = m.data_nascimento ? m.data_nascimento.substring(5) : '';
            const isHoje = md === hoje_md;
          %>
          <div class="aniv-card <%= isHoje ? 'hoje' : '' %>">
            <div class="aniv-icone">🎂</div>
            <div class="aniv-info">
              <div class="aniv-nome"><%= m.nome.split(' ').slice(0,3).join(' ') %></div>
              <div class="aniv-data"><%= new Date(m.data_nascimento + 'T12:00:00').toLocaleDateString('pt-BR', {day:'numeric',month:'long'}) %></div>
            </div>
            <% if (isHoje) { %><span class="badge azul">🎉 Hoje!</span><% } %>
          </div>
          <% }) %>
          <a href="/aniversarios" class="link-ver-mais">Ver todos os aniversários →</a>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- MODAL MEU PERFIL -->
<div id="modalPerfil" class="modal-overlay" style="display:none">
  <div class="modal" style="max-width:480px">
    <div class="modal-header">
      <div class="modal-titulo">👤 Meu Perfil</div>
      <button onclick="fecharPerfil()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#666">✕</button>
    </div>

    <!-- Info atual -->
    <div class="info-box" style="margin-bottom:20px">
      <strong>Usuário:</strong> <%= usuario.nome %><br>
      <strong>E-mail atual:</strong> <%= usuario.email %><br>
      <strong>Perfil:</strong> <span style="text-transform:capitalize"><%= usuario.perfil %></span>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--borda);padding-bottom:0">
      <button onclick="mostrarTab('senha')" id="tab-senha"
        style="padding:8px 16px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:600;color:var(--cor-primaria);border-bottom:2px solid var(--cor-primaria);font-family:Outfit,sans-serif">
        🔒 Alterar Senha
      </button>
      <button onclick="mostrarTab('email')" id="tab-email"
        style="padding:8px 16px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:500;color:var(--texto2);border-bottom:2px solid transparent;font-family:Outfit,sans-serif">
        📧 Alterar E-mail
      </button>
    </div>

    <!-- Tab Senha -->
    <div id="form-senha">
      <form action="/minha-senha" method="POST">
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="campo">
            <label class="label">Senha atual</label>
            <input type="password" name="senha_atual" class="input" required placeholder="Digite sua senha atual">
          </div>
          <div class="campo">
            <label class="label">Nova senha</label>
            <input type="password" name="nova_senha" class="input" required placeholder="Mínimo 8 caracteres" minlength="8">
          </div>
          <div class="campo">
            <label class="label">Confirmar nova senha</label>
            <input type="password" name="confirmar_senha" class="input" required placeholder="Repita a nova senha">
          </div>
          <div style="background:var(--amarelo-claro);border-radius:8px;padding:10px 14px;font-size:12px;color:var(--amarelo)">
            ⚠️ Após alterar a senha você precisará fazer login novamente.
          </div>
          <button type="submit" class="btn btn-primario" style="width:100%;justify-content:center">🔒 Alterar senha</button>
        </div>
      </form>
    </div>

    <!-- Tab Email -->
    <div id="form-email" style="display:none">
      <form action="/meu-email" method="POST">
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="campo">
            <label class="label">Novo e-mail</label>
            <input type="email" name="novo_email" class="input" required placeholder="novo@email.com">
          </div>
          <div class="campo">
            <label class="label">Confirme sua senha</label>
            <input type="password" name="senha_confirmacao" class="input" required placeholder="Digite sua senha para confirmar">
          </div>
          <div style="background:var(--azul-claro);border-radius:8px;padding:10px 14px;font-size:12px;color:var(--azul)">
            ℹ️ Você usará o novo e-mail para fazer login a partir de agora.
          </div>
          <button type="submit" class="btn btn-primario" style="width:100%;justify-content:center">📧 Alterar e-mail</button>
        </div>
      </form>
    </div>

  </div>
</div>

<script src="/js/app.js"></script>
<script>
function abrirPerfil() {
  document.getElementById('modalPerfil').style.display = 'flex';
}
function fecharPerfil() {
  document.getElementById('modalPerfil').style.display = 'none';
}
function mostrarTab(tab) {
  document.getElementById('form-senha').style.display = tab === 'senha' ? 'block' : 'none';
  document.getElementById('form-email').style.display = tab === 'email' ? 'block' : 'none';
  document.getElementById('tab-senha').style.color = tab === 'senha' ? 'var(--cor-primaria)' : 'var(--texto2)';
  document.getElementById('tab-senha').style.borderBottomColor = tab === 'senha' ? 'var(--cor-primaria)' : 'transparent';
  document.getElementById('tab-email').style.color = tab === 'email' ? 'var(--cor-primaria)' : 'var(--texto2)';
  document.getElementById('tab-email').style.borderBottomColor = tab === 'email' ? 'var(--cor-primaria)' : 'transparent';
}
// Fecha modal clicando fora
document.getElementById('modalPerfil').addEventListener('click', function(e) {
  if (e.target === this) fecharPerfil();
});
// Abre automaticamente se houver erro
<% if (erro && erro.length > 0) { %>
window.addEventListener('load', function() { abrirPerfil(); });
<% } %>
</script>
</body>
</html>
