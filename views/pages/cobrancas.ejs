<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cobranças — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .qr-modal { text-align:center; }
    .qr-modal img { width:200px;height:200px;border:2px solid var(--borda);border-radius:8px;margin:12px auto;display:block; }
    .pix-copia { background:var(--fundo);border:1px solid var(--borda);border-radius:8px;padding:10px;font-size:11px;word-break:break-all;font-family:monospace;margin:10px 0;cursor:pointer;text-align:left; }
    .pix-copia:hover { background:var(--cor-primaria-claro); }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'cobrancas' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Cobranças</h1>
      <div class="topbar-acoes">
        <form action="/cobrancas/gerar" method="POST" style="display:inline">
          <button class="btn" onclick="return confirm('Gerar cobranças do mês?')">↻ Gerar do mês</button>
        </form>
        <button class="btn btn-primario" onclick="abrirModal('modal-nova')">+ Nova cobrança</button>
        <a href="/financeiro-arquivos" class="btn" style="background:#4285f4;color:white;text-decoration:none">📁 Arquivos</a>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <div class="filtro-bar">
        <a href="/cobrancas" class="filtro-btn <%= filtro==='todas'?'ativo':'' %>">Todas</a>
        <a href="/cobrancas?filtro=pagas" class="filtro-btn <%= filtro==='pagas'?'ativo':'' %>">Pagas</a>
        <a href="/cobrancas?filtro=pendentes" class="filtro-btn <%= filtro==='pendentes'?'ativo':'' %>">Pendentes</a>
        <a href="/cobrancas?filtro=atrasadas" class="filtro-btn <%= filtro==='atrasadas'?'ativo':'' %>" style="border-color:#c81e1e;color:#c81e1e">Atrasadas</a>
      </div>

      <div class="table-wrap">
        <table class="table">
          <thead><tr>
            <th>Membro</th><th>Referência</th><th>Vencimento</th><th>Valor cheio</th><th>Com desconto</th><th>Status</th><th>Ações</th>
          </tr></thead>
          <tbody>
            <% if (cobrancas.length === 0) { %>
              <tr><td colspan="7" style="text-align:center;padding:30px;color:#888">Nenhuma cobrança encontrada</td></tr>
            <% } %>
            <% cobrancas.forEach(c => { %>
            <tr>
              <td><div class="membro-cell"><div class="avatar"><%= c.nome.substring(0,2).toUpperCase() %></div><%= c.nome.split(' ').slice(0,2).join(' ') %></div></td>
              <td><%= c.referencia %></td>
              <td><%= new Date(c.data_vencimento+'T12:00:00').toLocaleDateString('pt-BR') %></td>
              <td>R$ <%= Number(c.valor_cheio).toFixed(2).replace('.',',') %></td>
              <td>R$ <%= Number(c.valor_desconto).toFixed(2).replace('.',',') %></td>
              <td>
                <% if (c.status==='pago') { %><span class="badge verde">✅ Pago</span>
                <% } else if (c.status==='atrasado') { %><span class="badge vermelho">⚠️ Atrasado</span>
                <% } else { %><span class="badge amarelo">⏳ Pendente</span><% } %>
              </td>
              <td>
                <div class="btn-acoes">
                  <% if (c.status !== 'pago') { %>
                    <% if (c.pix_qr_code || c.pix_qr_code_base64) { %>
                      <button class="icon-btn" title="Ver QR Code PIX"
                        onclick="abrirPix('<%= c.id %>', '<%= c.nome.split(' ')[0] %>', '<%= c.valor_desconto %>', '<%= (c.pix_qr_code_base64||'').substring(0,20) %>', `<%= c.pix_qr_code %>`)">
                        📱
                      </button>
                    <% } %>
                    <% if (c.pagbank_link) { %>
                      <a href="<%= c.pagbank_link %>" target="_blank" class="icon-btn" title="Link cartão crédito">💳</a>
                    <% } %>
                    <form action="/cobrancas/<%= c.id %>/notificar" method="POST" style="display:inline">
                      <button class="icon-btn" title="Enviar notificação" type="submit">✉</button>
                    </form>
                    <form action="/cobrancas/<%= c.id %>/pago" method="POST" style="display:inline" onsubmit="return confirm('Marcar como pago?')">
                      <button class="icon-btn verde" title="Marcar como pago">✓</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Modal QR Code PIX -->
<div class="modal-overlay" id="modal-pix" style="display:none">
  <div class="modal" style="max-width:420px">
    <div class="modal-header">
      <span class="modal-titulo" id="pix-titulo">QR Code PIX</span>
      <button class="icon-btn" onclick="fecharModal('modal-pix')">✕</button>
    </div>
    <div class="qr-modal">
      <p style="font-size:13px;color:var(--texto2);margin-bottom:8px">Escaneie o QR Code ou copie o código abaixo</p>
      <img id="pix-qr-img" src="" alt="QR Code PIX">
      <p style="font-size:12px;font-weight:600;margin:8px 0 4px">Valor: <span id="pix-valor" style="color:var(--cor-primaria)"></span></p>
      <p style="font-size:11px;color:var(--texto2);margin-bottom:6px">📋 Pix Copia e Cola:</p>
      <div class="pix-copia" id="pix-codigo" onclick="copiarPix()"></div>
      <button class="btn btn-primario" style="width:100%;margin-top:8px" onclick="copiarPix()">📋 Copiar código PIX</button>
    </div>
  </div>
</div>

<!-- Modal nova cobrança manual -->
<div class="modal-overlay" id="modal-nova" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Nova cobrança manual</span>
      <button class="icon-btn" onclick="fecharModal('modal-nova')">✕</button>
    </div>
    <form action="/cobrancas/nova" method="POST">
      <div class="form-grid">
        <div class="campo full">
          <label class="label">Membro</label>
          <select name="membro_id" class="input" required>
            <option value="">Selecione...</option>
          </select>
        </div>
        <div class="campo"><label class="label">Referência (ex: 2025-05)</label><input name="referencia" class="input" required placeholder="ID-AAAA-MM"></div>
        <div class="campo"><label class="label">Vencimento</label><input name="data_vencimento" type="date" class="input" required></div>
        <div class="campo"><label class="label">Valor cheio (R$)</label><input name="valor_cheio" type="number" step="0.01" class="input" required></div>
        <div class="campo"><label class="label">Valor com desconto (R$)</label><input name="valor_desconto" type="number" step="0.01" class="input" required></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-nova')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Criar cobrança</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const pixData = {};
<% cobrancas.forEach(c => { %>
  <% if (c.pix_qr_code) { %>
  pixData['<%= c.id %>'] = {
    qr_code: `<%= c.pix_qr_code %>`,
    qr_code_base64: '<%= c.pix_qr_code_base64 || "" %>',
    valor: 'R$ <%= Number(c.valor_desconto).toFixed(2).replace(".",",") %>',
    nome: '<%= c.nome.split(" ")[0] %>'
  };
  <% } %>
<% }) %>

function abrirPix(id, nome, valor, qrBase64Prefix, qrCode) {
  const dados = pixData[id];
  if (!dados) return;
  document.getElementById('pix-titulo').textContent = 'PIX — ' + dados.nome;
  document.getElementById('pix-valor').textContent = dados.valor;
  document.getElementById('pix-codigo').textContent = dados.qr_code;
  if (dados.qr_code_base64) {
    document.getElementById('pix-qr-img').src = 'data:image/png;base64,' + dados.qr_code_base64;
    document.getElementById('pix-qr-img').style.display = 'block';
  } else {
    document.getElementById('pix-qr-img').style.display = 'none';
  }
  abrirModal('modal-pix');
}

function copiarPix() {
  const codigo = document.getElementById('pix-codigo').textContent;
  navigator.clipboard.writeText(codigo).then(() => {
    const btn = document.querySelector('#modal-pix .btn-primario');
    btn.textContent = '✅ Copiado!';
    setTimeout(() => { btn.textContent = '📋 Copiar código PIX'; }, 2000);
  });
}
</script>
</body>
</html>
