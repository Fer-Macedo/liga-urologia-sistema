<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lista de Assinaturas — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .badge { padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700; }
    .badge-pendente { background:#fef3c7;color:#92400e; }
    .badge-assinado { background:#dcfce7;color:#166534; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'lista-assinaturas' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">✍️ Lista de Assinaturas</h1>
      <div class="topbar-acoes">
        <button class="btn btn-primario" onclick="abrirModal('modal-nova')">+ Nova Lista</button>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <div class="card">
        <table class="tabela">
          <thead>
            <tr>
              <th>#</th>
              <th>Nome do Evento</th>
              <th>Data</th>
              <th>Descrição</th>
              <th>Status</th>
              <th>Criado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (listas.length === 0) { %>
            <tr><td colspan="7" style="text-align:center;color:var(--texto2);padding:40px">Nenhuma lista cadastrada</td></tr>
            <% } %>
            <% listas.forEach(l => { %>
            <tr>
              <td><%= l.id %></td>
              <td><strong><%= l.nome %></strong></td>
              <td><%= l.data_evento ? new Date(l.data_evento).toLocaleDateString('pt-BR') : '—' %></td>
              <td><%= l.descricao || '—' %></td>
              <td>
                <% if (l.status === 'assinado') { %>
                  <span class="badge badge-assinado">✅ Assinado</span>
                <% } else { %>
                  <span class="badge badge-pendente">⏳ Pendente</span>
                <% } %>
              </td>
              <td><%= new Date(l.criado_em).toLocaleDateString('pt-BR') %></td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  <a href="/lista-assinaturas/<%= l.id %>/visualizar" target="_blank" class="btn" style="font-size:11px;padding:4px 8px" title="Visualizar">👁</a>
                  <a href="/lista-assinaturas/<%= l.id %>/imprimir" target="_blank" class="btn" style="font-size:11px;padding:4px 8px;background:#6366f1;color:white" title="Imprimir">🖨️</a>
                  <button onclick="abrirUpload(<%= l.id %>)" class="btn" style="font-size:11px;padding:4px 8px;background:#059669;color:white" title="Upload assinada">📎 Upload</button>
                  <% if (l.pdf_assinado_chave) { %>
                  <a href="/lista-assinaturas/<%= l.id %>/assinada" target="_blank" class="btn" style="font-size:11px;padding:4px 8px;background:#0891b2;color:white" title="Ver assinada">📄 Assinada</a>
                  <% } %>
                  <% if (usuario.perfil === 'admin' || usuario.perfil === 'presidencia') { %>
                  <form method="POST" action="/lista-assinaturas/<%= l.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;color:var(--vermelho)">🗑</button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Modal Nova Lista -->
<div class="modal-overlay" id="modal-nova" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">✍️ Nova Lista de Assinaturas</span>
      <button class="icon-btn" onclick="fecharModal('modal-nova')">✕</button>
    </div>
    <form action="/lista-assinaturas" method="POST">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Nome do Evento *</label>
          <input type="text" name="nome" class="input" placeholder="Ex: Reunião Mensal — Junho 2026" required>
        </div>
        <div class="campo">
          <label class="label">Data do Evento</label>
          <input type="date" name="data_evento" class="input" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="campo">
          <label class="label">Descrição (opcional)</label>
          <textarea name="descricao" class="input" rows="2" placeholder="Descrição do evento..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-nova')">Cancelar</button>
        <button type="submit" class="btn btn-primario">✍️ Criar</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Upload Assinada -->
<div class="modal-overlay" id="modal-upload" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">📎 Upload da Lista Assinada</span>
      <button class="icon-btn" onclick="fecharModal('modal-upload')">✕</button>
    </div>
    <form id="form-upload" action="" method="POST" enctype="multipart/form-data">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Arquivo PDF da lista assinada *</label>
          <input type="file" name="pdf_assinado" class="input" accept=".pdf,.jpg,.jpeg,.png" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-upload')">Cancelar</button>
        <button type="submit" class="btn btn-primario">📎 Enviar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
function abrirUpload(id) {
  document.getElementById('form-upload').action = '/lista-assinaturas/' + id + '/upload-assinada';
  abrirModal('modal-upload');
}
</script>
</body>
</html>
