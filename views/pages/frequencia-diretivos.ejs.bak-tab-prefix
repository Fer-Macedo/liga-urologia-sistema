<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Frequência Diretivos — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .freq-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 20px;
      margin-bottom: 16px;
    }

    .freq-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--borda);
    }
    .freq-tab {
      padding: 10px 20px;
      border: none;
      background: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--texto2);
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      font-family: Outfit, sans-serif;
      transition: all .15s;
    }
    .freq-tab.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); font-weight: 600; }
    .freq-tab:hover { color: var(--texto); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }
    .stat-mini {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 18px 20px;
      position: relative;
      overflow: hidden;
    }
    .stat-mini::before { content:'';position:absolute;top:0;left:0;right:0;height:3px; }
    .stat-mini.verde::before { background:linear-gradient(90deg,#10b981,#34d399); }
    .stat-mini.amr::before   { background:linear-gradient(90deg,#f59e0b,#fbbf24); }
    .stat-mini.verm::before  { background:linear-gradient(90deg,#ef4444,#f87171); }
    .stat-mini .num { font-family:'Outfit',sans-serif;font-size:28px;font-weight:700;margin-bottom:4px; }
    .stat-mini.verde .num { color:#10b981; }
    .stat-mini.amr   .num { color:#f59e0b; }
    .stat-mini.verm  .num { color:#ef4444; }
    .stat-mini .lab { font-size:11.5px;color:var(--texto2);font-weight:600;text-transform:uppercase;letter-spacing:.06em; }

    .presenca-row {
      display: flex;
      align-items: center;
      padding: 12px 14px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1px solid var(--borda);
      gap: 12px;
      margin-bottom: 8px;
    }
    .barra-wrap { background:#e5e7eb;border-radius:20px;height:7px;flex:1;max-width:160px; }
    .barra { height:7px;border-radius:20px; }
    .barra.apto   { background:#10b981; }
    .barra.risco  { background:#f59e0b; }
    .barra.inapto { background:#ef4444; }

    .atividade-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 14px;
    }
    .atividade-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px;
      border-bottom: 1px solid var(--borda);
      flex-wrap: wrap;
      gap: 10px;
      cursor: pointer;
      user-select: none;
    }
    .atividade-header:hover { background: var(--fundo); }
    .atividade-body { padding: 16px 18px; }

    .presenca-lista {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 8px;
      margin-bottom: 14px;
    }
    .presenca-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--fundo);
      border-radius: 10px;
      border: 1.5px solid var(--borda);
      cursor: pointer;
      transition: all .15s ease;
    }
    .presenca-item:hover { border-color: var(--cor-primaria); }
    .presenca-item input[type=checkbox] {
      width: 18px; height: 18px;
      accent-color: var(--cor-primaria);
      flex-shrink: 0;
      cursor: pointer;
    }
    .presenca-item.presente { border-color:#10b981;background:#f0fdf4; }
    .presenca-item.presente .presenca-nome { color:#166534; }
    .presenca-nome { font-size:13px;font-weight:500; }

    .badge-tipo {
      font-size:10px;padding:2px 8px;border-radius:4px;font-weight:600;color:white;white-space:nowrap;
    }

    .btn-excluir-membro {
      display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:8px;
      background:transparent;color:#dc2626;border:1px solid #fecaca;font-size:11.5px;
      font-weight:600;cursor:pointer;transition:all .15s ease;font-family:inherit;
    }
    .btn-excluir-membro:hover { background:#fee2e2; }

    .turma-btn {
      padding:6px 14px;border-radius:999px;font-size:12.5px;font-weight:600;
      border:1.5px solid var(--borda);background:var(--fundo);color:var(--texto2);
      cursor:pointer;text-decoration:none;transition:all .15s;
    }
    .turma-btn.ativo { background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white;border-color:transparent; }
    .turma-btn:hover:not(.ativo) { border-color:var(--cor-primaria);color:var(--cor-primaria); }

    .selecionar-row {
      display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap;
    }
  
    /* === PADRÃO VERDE ESCURO — Frequência Diretivos === */
    .freq-card { border-radius:0!important; }
    .freq-tab { border-radius:0!important; }
    .freq-tab.ativo { color:#1a3410!important; border-bottom-color:#1a3410!important; }
    .freq-tab:hover { color:#253d18!important; }
    .stat-mini { border-radius:0!important; }
    .barra-wrap { border-radius:0!important; }
    .barra { border-radius:0!important; }
    .presenca-row { border-radius:0!important; }
    .atividade-card { border-radius:0!important; }
    .presenca-item { border-radius:0!important; transition:border-color .12s ease; }
    .presenca-item:hover { border-color:#253d18!important; }
    .presenca-item.presente { border-color:#1a3410!important; background:#f0f7eb!important; }
    .presenca-item.presente .presenca-nome { color:#1a3410!important; }
    .presenca-item input[type=checkbox] { accent-color:#253d18!important; }
    .badge-tipo { border-radius:0!important; }
    .btn-excluir-membro { border-radius:0!important; }
    .turma-btn { border-radius:0!important; font-size:13px!important; }
    .turma-btn.ativo { background:linear-gradient(135deg,#1a3410,#253d18)!important; border-color:transparent!important; }
    .turma-btn:hover:not(.ativo) { border-color:#253d18!important; color:#1a3410!important; }
    input[type=checkbox] { accent-color:#253d18; }
    .selecionar-row button, .selecionar-row a { border-radius:0!important; }
.freq-pill{display:inline-flex;align-items:center;padding:5px 14px;border-radius:999px;font-size:12px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto2);cursor:pointer;transition:all .15s;font-family:inherit;}.freq-pill.active{background:#1a3a20;color:white!important;border-color:#1a3a20;}.freq-pill.apto.active{background:#10b981!important;border-color:#10b981!important;color:white!important;}.freq-pill.risco.active{background:#f59e0b!important;border-color:#f59e0b!important;color:white!important;}.freq-pill.inapto.active{background:#ef4444!important;border-color:#ef4444!important;color:white!important;}
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'frequencia-diretivos' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Frequência Diretivos</h1>
      <div class="topbar-acoes">
        <button class="btn btn-sm" onclick="abrirModal('modal-turma')">+ Nova turma</button>
        <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-atividade')">+ Nova atividade</button>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

      <!-- SELETOR DE TURMA -->
      <div class="freq-card" style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--texto2)">Turma</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;flex:1">
          <% turmas.forEach(t => { %>
            <a href="/frequencia-diretivos?turma=<%= t.id %>" class="turma-btn <%= turmaAtual && turmaAtual.id == t.id ? 'ativo' : '' %>">
              <%= t.nome %>
            </a>
          <% }) %>
          <% if (turmas.length === 0) { %>
            <span style="color:var(--texto2);font-size:13px">Nenhuma turma. Crie uma para começar.</span>
          <% } %>
        </div>
        <% if (turmaAtual) { %>
          <form method="POST" action="/frequencia-diretivos/turma/<%= turmaAtual.id %>/sincronizar" style="display:inline">
            <button type="submit" class="btn btn-sm" onclick="return confirm('Sincronizar diretivos desta gestão com a turma?')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Sincronizar Diretivos</button>
          </form>
          <a href="/frequencia-diretivos/relatorio/<%= turmaAtual.id %>" class="btn btn-sm" target="_blank">Relatório</a>
        <% } %>
      </div>

      <% if (turmaAtual) { %>

      <!-- TABS -->
      <div class="freq-tabs">
        <button class="freq-tab ativo" data-tab="tab-resumo">Resumo</button>
        <button class="freq-tab" data-tab="tab-atividades">Atividades (<%= atividades.length %>)</button>
        <button class="freq-tab" onclick="mostrarTab('tab-diretivos',this)">Diretivos (<%= membrosFrequencia.length %>)</button>
      </div>

      <!-- TAB RESUMO -->
      <div id="tab-resumo" class="tab-content ativo">
        <div class="stats-row">
          <div class="stat-mini verde">
            <div class="num"><%= resumo.aptos %></div>
            <div class="lab">Aptos (≥75%)</div>
          </div>
          <div class="stat-mini amr">
            <div class="num"><%= resumo.risco %></div>
            <div class="lab">Em risco (50–74%)</div>
          </div>
          <div class="stat-mini verm">
            <div class="num"><%= resumo.inaptos %></div>
            <div class="lab">Não aptos (&lt;50%)</div>
          </div>
        </div>

        <div class="freq-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
            <div style="font-size:15px;font-weight:700;font-family:'Outfit',sans-serif">Frequência por Diretivo</div>
            <span style="font-size:12px;color:var(--texto2)">Mínimo 75% para certificado</span>
          </div>
          <div data-filter-group style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px">
            <button class="freq-pill active" onclick="filtrarFreq('todos',this)">Todos</button>
            <button class="freq-pill apto" onclick="filtrarFreq('apto',this)">Aptos</button>
            <button class="freq-pill risco" onclick="filtrarFreq('risco',this)">Em Risco</button>
            <button class="freq-pill inapto" onclick="filtrarFreq('inapto',this)">Nao Aptos</button>
          </div>
          <% if (membrosFrequencia.length === 0) { %>
            <div style="text-align:center;padding:30px;color:var(--texto2)">Nenhum diretivo na turma ainda</div>
          <% } %>
          <% membrosFrequencia.forEach(m => {
            const pct = m.total_atividades > 0 ? Math.round((m.presencas / m.total_atividades) * 100) : 0;
            const faltas = m.total_atividades - m.presencas;
            const cor = pct >= 75 ? 'apto' : pct >= 50 ? 'risco' : 'inapto';
            const corTexto = pct >= 75 ? '#10b981' : pct >= 50 ? '#f59e0b' : '#ef4444';
            const badgeBg = pct >= 75 ? '#dcfce7' : pct >= 50 ? '#fef3c7' : '#fee2e2';
            const badgeCor = pct >= 75 ? '#166534' : pct >= 50 ? '#92400e' : '#991b1b';
          %>
          <div class="presenca-row" data-freq-status="<%= cor %>" style="cursor:pointer" onclick="abrirDetalheFreq(<%= m.membro_id %>)">
            <div class="avatar" style="width:34px;height:34px;font-size:11px;flex-shrink:0"><%= m.nome.substring(0,2).toUpperCase() %></div>
            <div style="flex:1;min-width:0">
              <div style="font-size:13.5px;font-weight:600;margin-bottom:2px;display:flex;align-items:center;gap:6px"><%= m.nome %> <span style="font-size:10px;color:var(--texto2);background:var(--fundo);border:1px solid var(--borda);border-radius:4px;padding:1px 5px;font-weight:500;flex-shrink:0">ver detalhes</span></div>
              <div style="font-size:11.5px;color:var(--texto2);margin-bottom:5px"><%= m.cargo || '' %></div>
              <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <div class="barra-wrap"><div class="barra <%= cor %>" style="width:<%= pct %>%"></div></div>
                <span style="font-size:12px;color:var(--texto2)"><%= m.presencas %> pres. / <%= faltas %> faltas / <%= m.total_atividades %> total</span>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
              <span style="font-size:14px;font-weight:700;color:<%= corTexto %>"><%= pct %>%</span>
              <span style="background:<%= badgeBg %>;color:<%= badgeCor %>;border-radius:999px;font-size:11px;font-weight:700;padding:3px 10px">
                <%= pct >= 75 ? 'Apto' : pct >= 50 ? 'Em risco' : 'Não apto' %>
              </span>
              <form action="/frequencia-diretivos/turma/<%= turmaAtual.id %>/remover-membro" method="POST"
                onsubmit="return confirm('Excluir <%= m.nome.replace(/'/g,"\\'") %> desta turma?')"
                style="display:inline;margin:0">
                <input type="hidden" name="diretivo_id" value="<%= m.membro_id %>">
                <button type="submit" class="btn-excluir-membro">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
                  Excluir
                </button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- TAB ATIVIDADES -->
      <div id="tab-atividades" class="tab-content">
        <% if (atividades.length === 0) { %>
          <div style="text-align:center;padding:60px;color:var(--texto2)">Nenhuma atividade cadastrada</div>
        <% } %>

        <% const coresTipo = {
          'Aula Presencial':'#1a56db','Aula On-line':'#7c3aed','Extensão':'#059669',
          'Reunião':'#d97706','Bienvenidas':'#db2777','Expoligas':'#dc2626','Outras':'#6b7280'
        }; %>

        <% atividades.forEach(a => { %>
        <div class="atividade-card">
          <div class="atividade-header" onclick="toggleAtividade(<%= a.id %>)">
            <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0">
              <span class="badge-tipo" style="background:<%= coresTipo[a.tipo]||'#6b7280' %>"><%= a.tipo %></span>
              <div>
                <div style="font-size:14px;font-weight:700"><%= a.descricao %></div>
                <div style="font-size:12px;color:var(--texto2);margin-top:2px">
                  <%= (() => { try { const d=new Date(a.data_atividade); return d.toLocaleDateString('pt-BR',{weekday:'long',day:'numeric',month:'long',year:'numeric',timeZone:'UTC'}); } catch(e){return '';} })() %>
                </div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;flex-shrink:0">
              <span style="font-size:13px;font-weight:600;color:var(--texto2)">
                <span style="color:#10b981"><%= a.presentes %></span> / <%= a.total_membros %> presentes
              </span>
              <button class="btn btn-sm btn-editar-atividade-dir" data-id="<%- a.id %>" data-desc="<%- (a.descricao||'').replace(/"/g,'&quot;') %>" data-tipo="<%- a.tipo||'' %>" data-data="<%= a.data_atividade ? new Date(a.data_atividade).toISOString().substring(0,10) : '' %>" style="padding:4px 10px;font-size:11px;border:1px solid #e2e8f0;background:#fff;cursor:pointer" title="Editar atividade">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <form action="/frequencia-diretivos/atividade/<%= a.id %>/deletar" method="POST"
                onsubmit="return confirm('Excluir esta atividade?')" style="display:inline;margin:0"
                onclick="event.stopPropagation()">
                <button class="btn-excluir-membro" type="submit">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
              </form>
              <svg id="chevron-<%= a.id %>" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .2s;color:var(--texto2)"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>

          <div class="atividade-body" id="body-<%= a.id %>" style="display:none">
            <form action="/frequencia-diretivos/atividade/<%= a.id %>/presenca" method="POST">
              <div class="selecionar-row">
                <span style="font-size:12px;font-weight:600;color:var(--texto2)">Marcar presença:</span>
                <button type="button" class="btn btn-sm"
                  onclick="marcarTodos(<%= a.id %>, true)"
                  style="font-size:12px;background:#f0fdf4;color:#166534;border:1px solid #bbf7d0">
                  Todos presentes
                </button>
                <button type="button" class="btn btn-sm"
                  onclick="marcarTodos(<%= a.id %>, false)"
                  style="font-size:12px;background:var(--fundo);color:var(--texto2);border:1px solid var(--borda)">
                  Desmarcar todos
                </button>
              </div>

              <div class="presenca-lista" id="lista-<%= a.id %>">
                <% a.membros.forEach(m => { %>
                <label class="presenca-item <%= m.presente ? 'presente' : '' %>" id="item-<%= a.id %>-<%= m.diretivo_id %>">
                  <input type="checkbox" name="presentes" value="<%= m.diretivo_id %>"
                    <%= m.presente ? 'checked' : '' %>
                    onchange="togglePresente(this, <%= a.id %>, <%= m.diretivo_id %>)">
                  <span class="presenca-nome"><%= m.nome %></span>
                </label>
                <% }) %>
              </div>

              <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                <span id="contagem-<%= a.id %>" style="font-size:13px;color:var(--texto2)">
                  <%= a.membros.filter(m=>m.presente).length %> de <%= a.membros.length %> presentes
                </span>
                <button type="submit" class="btn btn-primario btn-sm">Salvar presenças</button>
              </div>
            </form>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- TAB DIRETIVOS -->
      <div id="tab-diretivos" class="tab-content">
        <div class="freq-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
            <div>
              <div style="font-size:15px;font-weight:700;font-family:'Outfit',sans-serif">Diretivos da turma</div>
              <div style="font-size:12px;color:var(--texto2);margin-top:2px">Turma <%= turmaAtual.nome %></div>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-sm" onclick="abrirModal('modal-add-todos')"
                style="background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;font-size:12px">
                + Adicionar todos os diretivos
              </button>
              <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-add-membro')">+ Adicionar diretivo</button>
            </div>
          </div>

          <div data-filter-group style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px">
            <button class="freq-pill active" onclick="filtrarFreq('todos',this)">Todos</button>
            <button class="freq-pill apto" onclick="filtrarFreq('apto',this)">Aptos</button>
            <button class="freq-pill risco" onclick="filtrarFreq('risco',this)">Em Risco</button>
            <button class="freq-pill inapto" onclick="filtrarFreq('inapto',this)">Nao Aptos</button>
          </div>
          <% if (membrosFrequencia.length === 0) { %>
            <div style="text-align:center;padding:30px;color:var(--texto2)">Nenhum diretivo na turma</div>
          <% } %>

          <% membrosFrequencia.forEach(m => {
            const pct = m.total_atividades > 0 ? Math.round((m.presencas / m.total_atividades) * 100) : 0;
            const faltas = m.total_atividades - m.presencas;
            const cor = pct >= 75 ? 'apto' : pct >= 50 ? 'risco' : 'inapto';
