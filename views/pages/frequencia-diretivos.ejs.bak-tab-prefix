<script src="/js/app.js"></script>
<script>
const turmaAtualId = <%= turmaAtual ? turmaAtual.id : 'null' %>;

// Abrir aba via URL ?tab=
(function(){
  var tab = new URLSearchParams(window.location.search).get('tab');
  if(tab){
    var el = document.getElementById(tab);
    var btn = document.querySelector('.freq-tab[data-tab="'+tab+'"]');
    if(el){
      document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('ativo'));
      document.querySelectorAll('.freq-tab').forEach(b=>b.classList.remove('ativo'));
      el.classList.add('ativo');
      if(btn) btn.classList.add('ativo');
    }
  }
})();
// Listeners das abas
document.querySelectorAll('.freq-tab[data-tab]').forEach(function(btn){
  btn.addEventListener('click', function(){ mostrarTab(this.dataset.tab, this); });
});
function mostrarTab(tabId, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('ativo'));
  document.querySelectorAll('.freq-tab').forEach(t => t.classList.remove('ativo'));
  document.getElementById(tabId).classList.add('ativo');
  btn.classList.add('ativo');
}

function toggleAtividade(id) {
  const body = document.getElementById('body-' + id);
  const chevron = document.getElementById('chevron-' + id);
  const aberto = body.style.display !== 'none';
  body.style.display = aberto ? 'none' : 'block';
  chevron.style.transform = aberto ? '' : 'rotate(180deg)';
}

function marcarTodos(atividadeId, marcar) {
  const lista = document.getElementById('lista-' + atividadeId);
  lista.querySelectorAll('input[type=checkbox]').forEach(cb => {
    cb.checked = marcar;
    const item = document.getElementById('item-' + atividadeId + '-' + cb.value);
    if (item) item.classList.toggle('presente', marcar);
  });
  atualizarContagem(atividadeId);
}

function togglePresente(cb, atividadeId, dirId) {
  const item = document.getElementById('item-' + atividadeId + '-' + dirId);
  if (item) item.classList.toggle('presente', cb.checked);
  atualizarContagem(atividadeId);
}

function atualizarContagem(atividadeId) {
  const lista = document.getElementById('lista-' + atividadeId);
  const total = lista.querySelectorAll('input[type=checkbox]').length;
  const marcados = lista.querySelectorAll('input[type=checkbox]:checked').length;
  const span = document.getElementById('contagem-' + atividadeId);
  if (span) span.textContent = marcados + ' de ' + total + ' presentes';
}

function selecionarTodosDiretivos(val) {
  document.querySelectorAll('.check-add-todos').forEach(c => c.checked = val);
}

function adicionarTodosSelecionados() {
  const selecionados = Array.from(document.querySelectorAll('.check-add-todos:checked')).map(c => c.value);
  if (selecionados.length === 0) { alert('Selecione pelo menos um diretivo.'); return; }
  const dataEntrada = new Date().toISOString().split('T')[0];
  const promessas = selecionados.map(id => {
    const form = new FormData();
    form.append('diretivo_id', id);
    form.append('data_entrada', dataEntrada);
    return fetch('/frequencia-diretivos/turma/' + turmaAtualId + '/adicionar-membro', {
      method: 'POST', body: form, redirect: 'manual'
    });
  });
  Promise.all(promessas).then(() => {
    alert(selecionados.length + ' diretivo(s) adicionado(s)!');
    location.reload();
  }).catch(() => alert('Erro ao adicionar.'));
}
</script>

<!-- Modal Detalhe Frequencia -->
<div id="modal-freq-detalhe" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,0.5);align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto" onclick="if(event.target===this)fecharModalFreq()">
  <div style="background:var(--card);border-radius:12px;max-width:520px;width:100%;margin:60px auto 20px;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.3)">
    <div style="padding:18px 20px;border-bottom:1px solid var(--borda);display:flex;align-items:center;justify-content:space-between">
      <div>
        <div style="font-size:15px;font-weight:700;font-family:'Outfit',sans-serif" id="modal-freq-nome"></div>
        <div style="font-size:12px;color:var(--texto2);margin-top:2px">Frequencia por atividade</div>
      </div>
      <button onclick="fecharModalFreq()" style="background:none;border:none;cursor:pointer;font-size:24px;color:var(--texto2);line-height:1;padding:0 4px">x</button>
    </div>
    <div style="padding:14px 20px;border-bottom:1px solid var(--borda)" id="modal-freq-stats"></div>
    <div style="padding:12px 20px;max-height:50vh;overflow-y:auto" id="modal-freq-lista"></div>
  </div>
</div><script>
(function(){
  var _atv=<%- JSON.stringify((atividades||[]).map(function(a){return{nome:a.descricao,data:a.data_atividade,membros:(a.membros||[]).map(function(mb){return{id:mb.diretivo_id||mb.membro_id||mb.id,presente:mb.presente}})}})) %>;
  var _mfr=<%- JSON.stringify((membrosFrequencia||[]).map(function(m){return{id:m.membro_id,nome:m.nome,presencas:parseInt(m.presencas)||0,total:parseInt(m.total_atividades)||0}})) %>;
  var porMembro={},infoMembro={};
  var svgOk='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="8 12 11 15 16 9"/></svg>';
  var svgFalta='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
  var svgChk='<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  var svgX='<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  _atv.forEach(function(a){(a.membros||[]).forEach(function(mb){if(!porMembro[mb.id])porMembro[mb.id]=[];porMembro[mb.id].push({nome:a.nome,data:a.data,presente:mb.presente});});});
  _mfr.forEach(function(m){infoMembro[m.id]=m;});
  function _fmt(d){try{return new Date(d).toLocaleDateString('pt-BR',{timeZone:'America/Asuncion',day:'2-digit',month:'2-digit',year:'numeric'});}catch(e){return d||'';}}
  window.abrirDetalheFreq=function(id){
    var info=infoMembro[id]||{};
    var lista=(porMembro[id]||[]).slice().sort(function(a,b){return new Date(b.data)-new Date(a.data);});
    var pct=info.total>0?Math.round((info.presencas/info.total)*100):0;
    var faltas=(info.total||0)-(info.presencas||0);
    var corPct=pct>=75?'#10b981':pct>=50?'#f59e0b':'#ef4444';
    var bgPct=pct>=75?'#dcfce7':pct>=50?'#fef3c7':'#fee2e2';
    document.getElementById('modal-freq-nome').textContent=info.nome||'';
    document.getElementById('modal-freq-stats').innerHTML='<div style="display:flex;gap:8px;flex-wrap:wrap"><span style="background:#dcfce7;color:#166534;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700">&#10003; '+(info.presencas||0)+' presen&#231;as</span><span style="background:#fee2e2;color:#991b1b;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700">&#10007; '+faltas+' faltas</span><span style="background:#f1f5f9;color:#475569;border-radius:999px;padding:3px 10px;font-size:12px;font-weight:700">'+(info.total||0)+' atividades</span><span style="background:'+bgPct+';color:'+corPct+';border-radius:999px;padding:3px 10px;font-size:13px;font-weight:800">'+pct+'%</span></div>';
    if(!lista.length){document.getElementById('modal-freq-lista').innerHTML='<p style="text-align:center;padding:24px;color:var(--texto2)">Nenhuma atividade registrada</p>';}
    else{document.getElementById('modal-freq-lista').innerHTML=lista.map(function(a){return'<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--borda)"><span style="font-size:20px">'+(a.presente?svgOk:svgFalta)+'</span><div style="flex:1"><div style="font-size:13px;font-weight:600;color:var(--texto)">'+a.nome+'</div><div style="font-size:11px;color:var(--texto2);margin-top:2px">'+_fmt(a.data)+'</div></div><span style="font-size:11px;font-weight:700;padding:2px 8px;border-radius:999px;'+(a.presente?'background:#dcfce7;color:#166534':'background:#fee2e2;color:#991b1b')+'">'+(a.presente?'PRESENTE':'FALTA')+'</span></div>';}).join('');}
    document.getElementById('modal-freq-detalhe').style.display='flex';
  };
  window.filtrarFreq=function(status,btn){
    var grp=btn.closest('[data-filter-group]');
    grp.querySelectorAll('.freq-pill').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    var tab=btn.closest('.tab-content');
    tab.querySelectorAll('[data-freq-status]').forEach(function(r){
      r.style.display=(status==='todos'||r.dataset.freqStatus===status)?''  :'none';
    });
  };
  window.fecharModalFreq=function(){document.getElementById('modal-freq-detalhe').style.display='none';};
  document.addEventListener('keydown',function(e){if(e.key==='Escape')fecharModalFreq();});
})();
</script>

