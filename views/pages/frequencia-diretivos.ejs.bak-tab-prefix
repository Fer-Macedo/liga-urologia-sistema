<script>
// Editar atividade — data-attributes para evitar CSP
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.btn-editar-atividade-dir');
  if (btn) {
    e.stopPropagation();
    abrirEditarAtividade(btn.dataset.id, btn.dataset.desc, btn.dataset.tipo, btn.dataset.data);
  }
  if (e.target.closest('.btn-fechar-modal-editar-dir') || e.target.closest('.btn-cancelar-editar-dir')) {
    fecharModal('modal-editar-atividade');
  }
});
function abrirEditarAtividade(id, desc, tipo, data) {
  document.getElementById('form-editar-atividade').action = '/frequencia-diretivos/atividade/' + id + '/editar';
  document.getElementById('edit-atv-desc').value = desc;
  document.getElementById('edit-atv-data').value = data;
  var sel = document.getElementById('edit-atv-tipo');
  for (var i=0; i<sel.options.length; i++) {
    if (sel.options[i].value === tipo) { sel.selectedIndex = i; break; }
  }
  abrirModal('modal-editar-atividade');
}
</script>
</body>
</html>
