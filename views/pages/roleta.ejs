<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Roleta — <%= config.org_nome %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --verde: #2b6803; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #050e00;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* FUNDO */
    .bg-glow { position: fixed; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(43,104,3,.2), transparent 70%); pointer-events: none; }

    /* HEADER */
    .roleta-header { position: fixed; top: 0; left: 0; right: 0; padding: 20px 32px; display: flex; align-items: center; justify-content: space-between; z-index: 10; }
    .roleta-logo { display: flex; align-items: center; gap: 12px; }
    .roleta-logo img { width: 44px; height: 44px; border-radius: 50%; border: 2px solid rgba(92,184,6,.3); }
    .roleta-org { font-size: 14px; font-weight: 700; color: rgba(255,255,255,.6); }
    .roleta-back { color: rgba(255,255,255,.4); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 6px; }
    .roleta-back:hover { color: rgba(255,255,255,.7); }

    /* TELA CONFIGURAÇÃO */
    .config-screen { text-align: center; padding: 40px 24px; max-width: 600px; width: 100%; }
    .config-titulo { font-family: 'DM Serif Display', serif; font-size: clamp(28px,4vw,42px); color: #fff; margin-bottom: 8px; }
    .config-sub { font-size: 15px; color: rgba(255,255,255,.5); margin-bottom: 40px; }
    .config-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: 16px; padding: 28px; margin-bottom: 20px; text-align: left; }
    .config-label { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .6px; margin-bottom: 8px; }
    .config-select { width: 100%; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); border-radius: 10px; padding: 12px 14px; font-size: 14px; color: #fff; font-family: 'DM Sans', sans-serif; margin-bottom: 16px; }
    .config-select option { background: #1a2e0e; }
    .config-textarea { width: 100%; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); border-radius: 10px; padding: 12px 14px; font-size: 13px; color: #fff; font-family: 'DM Sans', sans-serif; resize: vertical; min-height: 120px; }
    .config-textarea::placeholder { color: rgba(255,255,255,.3); }
    .btn-iniciar { background: linear-gradient(135deg, var(--verde), #3d8f04); color: #fff; border: none; border-radius: 12px; padding: 16px 40px; font-size: 18px; font-weight: 800; cursor: pointer; font-family: 'DM Sans', sans-serif; box-shadow: 0 4px 20px rgba(43,104,3,.4); transition: all .2s; width: 100%; margin-top: 8px; }
    .btn-iniciar:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(43,104,3,.5); }

    /* TELA ROLETA */
    .roleta-screen { display: none; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; width: 100%; padding: 80px 24px 40px; }
    .roleta-titulo { font-family: 'DM Serif Display', serif; font-size: clamp(16px,2vw,22px); color: rgba(255,255,255,.5); margin-bottom: 32px; letter-spacing: 1px; text-transform: uppercase; }

    /* DISPLAY PRINCIPAL */
    .roleta-display { width: min(700px, 95vw); background: linear-gradient(160deg, #0d2001, #1a4002); border-radius: 24px; padding: 48px 40px; text-align: center; position: relative; overflow: hidden; box-shadow: 0 0 60px rgba(43,104,3,.3), inset 0 1px 0 rgba(255,255,255,.1); margin-bottom: 40px; }
    .roleta-display::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(92,184,6,.12), transparent 60%); }
    .roleta-display-label { font-size: 12px; font-weight: 700; color: rgba(255,255,255,.3); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px; position: relative; }
    .roleta-nome { font-family: 'DM Serif Display', serif; font-size: clamp(32px,6vw,72px); color: #fff; line-height: 1.1; min-height: 90px; display: flex; align-items: center; justify-content: center; word-break: break-word; position: relative; transition: all .05s; }
    .roleta-nome.rolando { animation: nomeRoll .07s ease infinite; color: #a8e063; }
    .roleta-nome.ganhador { animation: nomeGlow 1.5s ease infinite; color: #fbbf24; text-shadow: 0 0 40px rgba(251,191,36,.4); }
    @keyframes nomeRoll { 0%,100%{transform:scale(1) translateY(0)} 50%{transform:scale(1.02) translateY(-3px)} }
    @keyframes nomeGlow { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.9;transform:scale(1.03)} }

    /* CONTADOR */
    .roleta-count { font-size: 13px; color: rgba(255,255,255,.3); margin-bottom: 32px; }

    /* BOTÕES */
    .roleta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-girar { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; border: none; border-radius: 14px; padding: 18px 56px; font-size: 20px; font-weight: 800; cursor: pointer; font-family: 'DM Sans', sans-serif; box-shadow: 0 4px 24px rgba(245,158,11,.5); transition: all .2s; }
    .btn-girar:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(245,158,11,.6); }
    .btn-girar:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .btn-reiniciar { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.7); border-radius: 12px; padding: 14px 28px; font-size: 15px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: .2s; }
    .btn-reiniciar:hover { background: rgba(255,255,255,.18); }

    /* LISTA LATERAL */
    .roleta-lista-wrap { position: fixed; right: 24px; top: 50%; transform: translateY(-50%); width: 200px; display: none; }
    .roleta-lista-titulo { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.3); text-transform: uppercase; letter-spacing: .6px; margin-bottom: 10px; }
    .roleta-lista { display: flex; flex-direction: column; gap: 4px; max-height: 60vh; overflow-y: auto; }
    .roleta-lista::-webkit-scrollbar { width: 4px; }
    .roleta-lista::-webkit-scrollbar-track { background: rgba(255,255,255,.05); border-radius: 4px; }
    .roleta-lista::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 4px; }
    .lista-item { font-size: 12px; color: rgba(255,255,255,.4); padding: 5px 10px; border-radius: 6px; transition: .2s; }
    .lista-item.ativo { background: rgba(92,184,6,.15); color: #a8e063; font-weight: 700; }
    .lista-item.eliminado { text-decoration: line-through; opacity: .3; }

    /* GANHADOR OVERLAY */
    .ganhador-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.8); z-index: 100; align-items: center; justify-content: center; flex-direction: column; text-align: center; padding: 24px; }
    .ganhador-overlay.show { display: flex; }
    .ganhador-trophy { font-size: 80px; margin-bottom: 16px; animation: troféuBounce .6s cubic-bezier(.34,1.56,.64,1); }
    @keyframes troféuBounce { from{transform:scale(0) rotate(-20deg)} to{transform:scale(1) rotate(0)} }
    .ganhador-titulo { font-size: 18px; font-weight: 600; color: rgba(255,255,255,.6); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 2px; }
    .ganhador-nome-overlay { font-family: 'DM Serif Display', serif; font-size: clamp(36px,8vw,80px); color: #fbbf24; text-shadow: 0 0 60px rgba(251,191,36,.4); margin-bottom: 32px; line-height: 1.1; }
    .ganhador-overlay-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
    .btn-prox { background: linear-gradient(135deg, var(--verde), #3d8f04); color: #fff; border: none; border-radius: 12px; padding: 14px 32px; font-size: 16px; font-weight: 700; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-fechar-overlay { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); color: #fff; border-radius: 12px; padding: 14px 32px; font-size: 16px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; }

    /* CONFETES */
    .confete-piece { position: fixed; pointer-events: none; z-index: 200; animation: confeteFall linear forwards; }
    @keyframes confeteFall { 0%{transform:translateY(-20px) rotate(0);opacity:1} 100%{transform:translateY(110vh) rotate(720deg);opacity:0} }

    @media(max-width:768px){ .roleta-lista-wrap{display:none!important;} }
  </style>
</head>
<body>
<div class="bg-glow"></div>

<div class="roleta-header">
  <div class="roleta-logo">
    <img src="<%= config.org_logo %>" alt="Logo">
    <span class="roleta-org"><%= config.org_nome %></span>
  </div>
  <a href="/sorteios" class="roleta-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    Voltar
  </a>
</div>

<!-- TELA DE CONFIGURAÇÃO -->
<div class="config-screen" id="configScreen">
  <h1 class="config-titulo">🎰 Roleta Animada</h1>
  <p class="config-sub">Configure os participantes e inicie o sorteio</p>

  <div class="config-card">
    <div class="config-label">Fonte dos participantes</div>
    <select class="config-select" id="fonteSelect" onchange="atualizarFonte()">
      <option value="manual">Lista manual (digitar nomes)</option>
      <option value="ligantes">Ligantes ativos do sistema</option>
      <option value="diretivos">Diretivos ativos do sistema</option>
      <option value="ambos">Ligantes + Diretivos</option>
    </select>

    <div id="campoManual">
      <div class="config-label">Participantes (um por linha)</div>
      <textarea class="config-textarea" id="participantesTexto" placeholder="João Silva&#10;Maria Santos&#10;Pedro Lima&#10;Ana Costa"></textarea>
    </div>

    <div id="campoSistema" style="display:none">
      <div style="font-size:13px;color:rgba(255,255,255,.5);text-align:center;padding:16px 0">
        Carregando participantes do sistema...
      </div>
    </div>
  </div>

  <div class="config-card">
    <div class="config-label">Título do sorteio (opcional)</div>
    <input type="text" class="config-textarea" style="min-height:auto;padding:10px 14px;font-size:14px;" id="tituloSorteio" placeholder="Ex: Sorteio de Natal — Liga Urologia">
  </div>

  <button class="btn-iniciar" onclick="iniciarRoleta()">🎯 Iniciar Roleta</button>
</div>

<!-- TELA DA ROLETA -->
<div class="roleta-screen" id="roletaScreen">
  <div class="roleta-titulo" id="roletaTitulo">Sorteio</div>

  <div class="roleta-display">
    <div class="roleta-display-label">Participante</div>
    <div class="roleta-nome" id="roletaNome">Clique em Girar!</div>
  </div>

  <div class="roleta-count" id="roletaCount"></div>

  <div class="roleta-btns">
    <button class="btn-girar" id="btnGirar" onclick="girar()">🎰 Girar!</button>
    <button class="btn-reiniciar" onclick="reiniciar()">↩ Recomeçar</button>
  </div>
</div>

<!-- LISTA LATERAL -->
<div class="roleta-lista-wrap" id="listaWrap">
  <div class="roleta-lista-titulo">Participantes</div>
  <div class="roleta-lista" id="listaParticipantes"></div>
</div>

<!-- OVERLAY GANHADOR -->
<div class="ganhador-overlay" id="ganhadorOverlay">
  <div class="ganhador-trophy">🏆</div>
  <div class="ganhador-titulo">Ganhador</div>
  <div class="ganhador-nome-overlay" id="ganhadorNomeOverlay"></div>
  <div class="ganhador-overlay-btns">
    <button class="btn-prox" onclick="proximoGanhador()" id="btnProxGanhador">Próximo Ganhador</button>
    <button class="btn-fechar-overlay" onclick="fecharOverlay()">Continuar</button>
  </div>
</div>

<script>
const ligantesDoSistema = <%- JSON.stringify(ligantes) %>;
const diretivosDoSistema = <%- JSON.stringify(diretivos) %>;

let participantes = [];
let disponiveis = [];
let ganhadores = [];
let rodando = false;

function atualizarFonte(){
  const v = document.getElementById('fonteSelect').value;
  document.getElementById('campoManual').style.display = v==='manual'?'block':'none';
  document.getElementById('campoSistema').style.display = v!=='manual'?'block':'none';

  let nomes = [];
  if(v==='ligantes') nomes = ligantesDoSistema;
  else if(v==='diretivos') nomes = diretivosDoSistema;
  else if(v==='ambos') nomes = [...ligantesDoSistema,...diretivosDoSistema];

  if(v !== 'manual'){
    document.getElementById('campoSistema').innerHTML = `
      <div style="font-size:13px;color:rgba(255,255,255,.6);padding:12px;background:rgba(255,255,255,.05);border-radius:8px;">
        <strong style="color:#a8e063">${nomes.length} participantes</strong> carregados:<br>
        <span style="color:rgba(255,255,255,.4);font-size:12px">${nomes.slice(0,5).join(', ')}${nomes.length>5?'...':''}</span>
      </div>`;
  }
}

function iniciarRoleta(){
  const fonte = document.getElementById('fonteSelect').value;
  if(fonte === 'manual'){
    const texto = document.getElementById('participantesTexto').value.trim();
    participantes = texto.split('\n').map(n=>n.trim()).filter(n=>n.length>0);
  } else if(fonte === 'ligantes'){
    participantes = [...ligantesDoSistema];
  } else if(fonte === 'diretivos'){
    participantes = [...diretivosDoSistema];
  } else {
    participantes = [...ligantesDoSistema,...diretivosDoSistema];
  }

  if(participantes.length < 2){
    alert('Adicione pelo menos 2 participantes!');
    return;
  }

  disponiveis = [...participantes].sort(()=>Math.random()-.5);
  ganhadores = [];

  const titulo = document.getElementById('tituloSorteio').value || 'Sorteio';
  document.getElementById('roletaTitulo').textContent = titulo;

  document.getElementById('configScreen').style.display = 'none';
  document.getElementById('roletaScreen').style.display = 'flex';
  document.getElementById('listaWrap').style.display = 'block';

  atualizarLista();
  atualizarContador();
}

function atualizarLista(){
  const lista = document.getElementById('listaParticipantes');
  lista.innerHTML = '';
  participantes.forEach(p => {
    const div = document.createElement('div');
    div.className = 'lista-item' + (ganhadores.includes(p)?' eliminado':'');
    div.id = 'lp-'+p.replace(/\s/g,'_');
    div.textContent = p;
    lista.appendChild(div);
  });
}

function atualizarContador(){
  document.getElementById('roletaCount').textContent = disponiveis.length + ' participante' + (disponiveis.length!==1?'s':'') + ' restante' + (disponiveis.length!==1?'s':'');
}

function girar(){
  if(rodando || disponiveis.length === 0) return;
  rodando = true;
  document.getElementById('btnGirar').disabled = true;

  const nome = document.getElementById('roletaNome');
  nome.className = 'roleta-nome rolando';

  let count = 0;
  const total = 35 + Math.floor(Math.random()*25);
  const interval = setInterval(()=>{
    nome.textContent = disponiveis[Math.floor(Math.random()*disponiveis.length)];
    count++;
    if(count >= total){
      clearInterval(interval);
      // Escolher ganhador
      const idx = Math.floor(Math.random()*disponiveis.length);
      const ganhador = disponiveis[idx];
      disponiveis.splice(idx, 1);
      ganhadores.push(ganhador);

      nome.className = 'roleta-nome ganhador';
      nome.textContent = '🏆 ' + ganhador;

      // Highlight na lista
      const el = document.getElementById('lp-'+ganhador.replace(/\s/g,'_'));
      if(el){ el.className='lista-item ativo'; setTimeout(()=>{ el.className='lista-item eliminado'; },3000); }

      atualizarContador();
      lancarConfetes();

      setTimeout(()=>{
        mostrarOverlay(ganhador);
        rodando = false;
      }, 1500);
    }
  }, 75);
}

function mostrarOverlay(nome){
  document.getElementById('ganhadorNomeOverlay').textContent = nome;
  document.getElementById('btnProxGanhador').style.display = disponiveis.length > 0 ? '' : 'none';
  document.getElementById('ganhadorOverlay').classList.add('show');
}

function fecharOverlay(){
  document.getElementById('ganhadorOverlay').classList.remove('show');
  document.getElementById('roletaNome').className = 'roleta-nome';
  document.getElementById('roletaNome').textContent = disponiveis.length > 0 ? 'Clique em Girar!' : '✅ Fim!';
  if(disponiveis.length > 0) document.getElementById('btnGirar').disabled = false;
  atualizarLista();
}

function proximoGanhador(){
  fecharOverlay();
}

function reiniciar(){
  if(!confirm('Reiniciar do zero?')) return;
  document.getElementById('ganhadorOverlay').classList.remove('show');
  document.getElementById('roletaScreen').style.display = 'none';
  document.getElementById('listaWrap').style.display = 'none';
  document.getElementById('configScreen').style.display = 'block';
  rodando = false;
  ganhadores = [];
  disponiveis = [];
  document.getElementById('roletaNome').className = 'roleta-nome';
  document.getElementById('roletaNome').textContent = 'Clique em Girar!';
  document.getElementById('btnGirar').disabled = false;
}

function lancarConfetes(){
  const cores=['#2b6803','#5cb806','#f59e0b','#3b82f6','#ec4899','#fbbf24','#a8e063'];
  for(let i=0;i<100;i++){
    const div=document.createElement('div');
    div.className='confete-piece';
    const size=Math.random()*12+6;
    div.style.cssText=`left:${Math.random()*100}vw;top:-10px;background:${cores[Math.floor(Math.random()*cores.length)]};width:${size}px;height:${size}px;border-radius:${Math.random()>.5?'50%':'3px'};animation-duration:${Math.random()*2+1.5}s;animation-delay:${Math.random()*.8}s;`;
    document.body.appendChild(div);
    setTimeout(()=>div.remove(),5000);
  }
}
</script>
</body>
</html>
