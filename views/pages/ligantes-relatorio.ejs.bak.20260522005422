<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatório de Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .filtros-card { background:var(--card);border:1.5px solid var(--borda);border-radius:12px;padding:20px;margin-bottom:20px; }
    .filtros-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px; }
    .preview-table { width:100%;border-collapse:collapse;font-size:12px; }
    .preview-table th { background:var(--cor-primaria);color:white;padding:8px 10px;text-align:left;font-size:11px; }
    .preview-table td { padding:7px 10px;border-bottom:1px solid var(--borda); }
    .preview-table tr:nth-child(even) { background:var(--fundo); }
    .preview-table tr:hover { background:var(--cor-primaria-claro); }
    .resultado-info { font-size:13px;color:var(--texto2);margin-bottom:12px; }
    .btn-acoes-rel { display:flex;gap:10px;margin-top:16px;flex-wrap:wrap; }
    @media print {
      .sidebar, .topbar, .filtros-card, .btn-acoes-rel, .topbar-acoes { display:none !important; }
      .main { margin:0 !important;padding:0 !important; }
      .content { padding:0 !important; }
      .print-header { display:block !important; }
      body { background:white !important; }
    }
    .print-header { display:none;text-align:center;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid #000; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'ligantes' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">📊 Relatório de Ligantes</h1>
      <div class="topbar-acoes">
        <a href="/ligantes" class="btn">← Voltar</a>
      </div>
    </div>
    <div class="content">

      <!-- Filtros -->
      <div class="filtros-card">
        <div style="font-size:14px;font-weight:700;margin-bottom:16px">🔍 Filtros do Relatório</div>
        <form method="GET" action="/ligantes/relatorio" id="form-filtros">
          <div class="filtros-grid">
            <div class="campo">
              <label class="label">Status</label>
              <select name="status" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.status==='todos'?'selected':'' %>>Todos</option>
                <option value="ativo" <%= filtros.status==='ativo'?'selected':'' %>>Somente ativos</option>
                <option value="inativo" <%= filtros.status==='inativo'?'selected':'' %>>Somente inativos</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Sexo</label>
              <select name="sexo" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.sexo==='todos'?'selected':'' %>>Todos</option>
                <option value="Masculino" <%= filtros.sexo==='Masculino'?'selected':'' %>>Masculino</option>
                <option value="Feminino" <%= filtros.sexo==='Feminino'?'selected':'' %>>Feminino</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Semestre</label>
              <select name="semestre" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.semestre==='todos'?'selected':'' %>>Todos</option>
                <% semestres.forEach(s => { %>
                <option value="<%= s %>" <%= filtros.semestre===s?'selected':'' %>><%= s %>º semestre</option>
                <% }) %>
              </select>
            </div>
            <div class="campo">
              <label class="label">Turma</label>
              <select name="turma" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.turma==='todos'?'selected':'' %>>Todas</option>
                <% turmas.forEach(t => { %>
                <option value="<%= t %>" <%= filtros.turma===t?'selected':'' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="campo">
              <label class="label">Aceita cargo</label>
              <select name="aceita_cargo" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.aceita_cargo==='todos'?'selected':'' %>>Todos</option>
                <option value="Sim" <%= filtros.aceita_cargo==='Sim'?'selected':'' %>>Sim</option>
                <option value="Não" <%= filtros.aceita_cargo==='Não'?'selected':'' %>>Não</option>
                <option value="Talvez" <%= filtros.aceita_cargo==='Talvez'?'selected':'' %>>Talvez</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Tem formação</label>
              <select name="tem_formacao" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.tem_formacao==='todos'?'selected':'' %>>Todos</option>
                <option value="Sim" <%= filtros.tem_formacao==='Sim'?'selected':'' %>>Sim</option>
                <option value="Não" <%= filtros.tem_formacao==='Não'?'selected':'' %>>Não</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Ordenar por</label>
              <select name="ordem" class="input" onchange="this.form.submit()">
                <option value="nome" <%= filtros.ordem==='nome'?'selected':'' %>>Nome (A-Z)</option>
                <option value="nome_desc" <%= filtros.ordem==='nome_desc'?'selected':'' %>>Nome (Z-A)</option>
                <option value="idade" <%= filtros.ordem==='idade'?'selected':'' %>>Idade (mais novo)</option>
                <option value="idade_desc" <%= filtros.ordem==='idade_desc'?'selected':'' %>>Idade (mais velho)</option>
                <option value="semestre" <%= filtros.ordem==='semestre'?'selected':'' %>>Semestre</option>
                <option value="turma" <%= filtros.ordem==='turma'?'selected':'' %>>Turma</option>
                <option value="criado_em" <%= filtros.ordem==='criado_em'?'selected':'' %>>Data de cadastro</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Colunas a exibir</label>
              <select name="colunas" class="input" multiple id="sel-colunas" style="height:auto" onchange="this.form.submit()">
                <option value="nome" <%= (filtros.colunas||[]).includes('nome')?'selected':'' %>>Nome</option>
                <option value="email" <%= (filtros.colunas||[]).includes('email')?'selected':'' %>>E-mail</option>
                <option value="whatsapp" <%= (filtros.colunas||[]).includes('whatsapp')?'selected':'' %>>WhatsApp</option>
                <option value="sexo" <%= (filtros.colunas||[]).includes('sexo')?'selected':'' %>>Sexo</option>
                <option value="data_nascimento" <%= (filtros.colunas||[]).includes('data_nascimento')?'selected':'' %>>Nascimento</option>
                <option value="semestre" <%= (filtros.colunas||[]).includes('semestre')?'selected':'' %>>Semestre</option>
                <option value="turma" <%= (filtros.colunas||[]).includes('turma')?'selected':'' %>>Turma</option>
                <option value="catraca" <%= (filtros.colunas||[]).includes('catraca')?'selected':'' %>>Catraca</option>
                <option value="rg" <%= (filtros.colunas||[]).includes('rg')?'selected':'' %>>RG/CI</option>
                <option value="cpf" <%= (filtros.colunas||[]).includes('cpf')?'selected':'' %>>CPF</option>
                <option value="orcid" <%= (filtros.colunas||[]).includes('orcid')?'selected':'' %>>ORCID</option>
                <option value="tem_formacao" <%= (filtros.colunas||[]).includes('tem_formacao')?'selected':'' %>>Formação</option>
                <option value="aceita_cargo" <%= (filtros.colunas||[]).includes('aceita_cargo')?'selected':'' %>>Aceita cargo</option>
                <option value="habilidades" <%= (filtros.colunas||[]).includes('habilidades')?'selected':'' %>>Habilidades</option>
                <option value="status" <%= (filtros.colunas||[]).includes('status')?'selected':'' %>>Status</option>
                <option value="criado_em" <%= (filtros.colunas||[]).includes('criado_em')?'selected':'' %>>Data cadastro</option>
              </select>
            </div>
          </div>
          <div style="margin-top:12px;display:flex;gap:10px">
            <a href="/ligantes/relatorio" class="btn">🔄 Limpar filtros</a>
          </div>
        </form>
      </div>

      <!-- Resultado -->
      <div class="print-header">
        <div style="font-size:18px;font-weight:700"><%= config.org_nome || 'Liga Acadêmica de Urologia — LAURO' %></div>
        <div style="font-size:14px;margin-top:4px">Relatório de Ligantes</div>
        <div style="font-size:12px;color:#666;margin-top:4px">Gerado em <%= new Date().toLocaleString('pt-BR') %></div>
      </div>

      <div class="resultado-info">
        Exibindo <strong><%= ligantes.length %></strong> ligante(s) com os filtros selecionados.
      </div>

      <div style="overflow-x:auto">
        <table class="preview-table" id="tabela-relatorio">
          <thead>
            <tr>
              <th>#</th>
              <% colunasVisiveis.forEach(col => { %><th><%= labelColuna(col) %></th><% }) %>
            </tr>
          </thead>
          <tbody>
            <% ligantes.forEach((l, i) => { %>
            <tr>
              <td><%= i+1 %></td>
              <% colunasVisiveis.forEach(col => { %>
              <td>
                <% if (col === 'data_nascimento') { %>
                  <%= l.data_nascimento ? new Date(l.data_nascimento).toLocaleDateString('pt-BR') : '—' %>
                <% } else if (col === 'status') { %>
                  <%= l.ativo == 0 ? 'Inativo' : 'Ativo' %>
                <% } else if (col === 'criado_em') { %>
                  <%= new Date(l.criado_em).toLocaleDateString('pt-BR') %>
                <% } else { %>
                  <%= l[col] || '—' %>
                <% } %>
              </td>
              <% }) %>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="btn-acoes-rel">
        <button class="btn btn-primario" onclick="window.print()">🖨️ Imprimir</button>
        <button class="btn btn-primario" onclick="gerarPDF()">📄 Gerar PDF</button>
        <button class="btn" onclick="exportarCSV()">📊 Exportar CSV</button>
      </div>

    </div>
  </main>
</div>

<script src="/js/app.js"></script>
<script>
function gerarPDF() {
  const win = window.open('', '_blank');
  const tabela = document.getElementById('tabela-relatorio').outerHTML;
  const org = '<%= config.org_nome || "Liga Acadêmica de Urologia — LAURO" %>';
  const total = <%= ligantes.length %>;
  win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8">
  <title>Relatório Ligantes</title>
  <style>
    body { font-family: Arial, sans-serif; font-size: 11px; padding: 20px; }
    h2 { text-align:center; margin-bottom:4px; }
    p { text-align:center; color:#666; margin-bottom:16px; font-size:10px; }
    table { width:100%; border-collapse:collapse; }
    th { background:#1a56db; color:white; padding:6px 8px; font-size:10px; text-align:left; }
    td { padding:5px 8px; border-bottom:1px solid #eee; font-size:10px; }
    tr:nth-child(even) { background:#f9f9f9; }
    .rodape { margin-top:20px; text-align:center; font-size:9px; color:#999; }
  </style></head><body>
  <h2>${org}</h2>
  <p>Relatório de Ligantes — ${total} registro(s) — Gerado em ${new Date().toLocaleString('pt-BR')}</p>
  ${tabela}
  <div class="rodape">Liga Acadêmica de Urologia — LAURO</div>
  </body></html>`);
  win.document.close();
  setTimeout(() => win.print(), 500);
}

function exportarCSV() {
  const tabela = document.getElementById('tabela-relatorio');
  const linhas = [];
  tabela.querySelectorAll('tr').forEach(tr => {
    const cols = [];
    tr.querySelectorAll('th,td').forEach(td => cols.push('"' + td.innerText.replace(/"/g,'""') + '"'));
    linhas.push(cols.join(','));
  });
  const csv = '\uFEFF' + linhas.join('\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'ligantes-relatorio.csv'; a.click();
}
</script>
</body>
</html>
