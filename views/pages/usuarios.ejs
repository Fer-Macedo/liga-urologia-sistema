<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuários — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>:root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }</style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'usuarios' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Usuários do sistema</h1>
      <button class="btn btn-primario" onclick="abrirModal('modal-usuario')">+ Novo usuário</button>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><%= erro[0] %></div><% } %>

      <div class="table-wrap">
        <table class="table">
          <thead><tr>
            <th>Nome</th><th>E-mail</th><th>Perfil</th><th>Status</th><th>Criado em</th><th>Ações</th>
          </tr></thead>
          <tbody>
            <% usuarios.forEach(u => { %>
            <tr>
              <td><div class="membro-cell"><div class="avatar"><%= u.nome.substring(0,2).toUpperCase() %></div><%= u.nome %></div></td>
              <td><%= u.email %></td>
              <td>
                <% if (u.perfil === 'admin') { %><span class="badge azul">Administrador</span>
                <% } else if (u.perfil === 'financeiro') { %><span class="badge amarelo">Financeiro</span>
                <% } else { %><span class="badge cinza">Visualizador</span><% } %>
              </td>
              <td><span class="badge <%= u.ativo ? 'verde' : 'vermelho' %>"><%= u.ativo ? 'Ativo' : 'Inativo' %></span></td>
              <td><%= new Date(u.criado_em).toLocaleDateString('pt-BR') %></td>
              <td>
                <div class="btn-acoes">
                  <% if (u.perfil !== 'admin') { %>
                    <form action="/usuarios/<%= u.id %>/toggle" method="POST" style="display:inline" onsubmit="return confirm('<%= u.ativo ? "Desativar" : "Ativar" %> este usuário?')">
                      <button class="icon-btn" title="<%= u.ativo ? 'Desativar' : 'Ativar' %>"><%= u.ativo ? '⏸' : '▶' %></button>
                    </form>
                    <button class="icon-btn" onclick="abrirSenha(<%= u.id %>, '<%= u.nome %>')" title="Redefinir senha">🔑</button>
                  <% } else { %>
                    <span style="color:#bbb;font-size:12px">Admin principal</span>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="info-box" style="margin-top:14px">
        <strong>Perfis disponíveis:</strong><br>
        <span style="color:var(--cor-primaria)">Administrador</span> — acesso total ao sistema, configurações e usuários<br>
        <span style="color:#9f580a">Financeiro</span> — gerencia membros e cobranças, envia notificações<br>
        <span style="color:#6b7280">Visualizador</span> — somente visualização, sem poder alterar dados
      </div>
    </div>
  </main>
</div>

<!-- Modal novo usuário -->
<div class="modal-overlay" id="modal-usuario" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">Novo usuário</span>
      <button class="icon-btn" onclick="fecharModal('modal-usuario')">✕</button>
    </div>
    <form action="/usuarios" method="POST">
      <div class="form-grid">
        <div class="campo full"><label class="label">Nome completo</label><input name="nome" class="input" required></div>
        <div class="campo full"><label class="label">E-mail (será usado para login)</label><input name="email" type="email" class="input" required></div>
        <div class="campo full"><label class="label">Senha inicial</label><input name="senha" type="password" class="input" required minlength="6" placeholder="Mínimo 6 caracteres"></div>
        <div class="campo full">
          <label class="label">Perfil de acesso</label>
          <select name="perfil" class="input">
            <option value="secretaria">Secretaria</option>
            <option value="financeiro">Financeiro</option>
            <option value="visualizador">Visualizador</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-usuario')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Criar usuário</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal redefinir senha -->
<div class="modal-overlay" id="modal-senha" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo" id="titulo-senha">Redefinir senha</span>
      <button class="icon-btn" onclick="fecharModal('modal-senha')">✕</button>
    </div>
    <form id="form-senha" action="" method="POST">
      <div class="campo" style="margin-bottom:16px">
        <label class="label">Nova senha</label>
        <input name="nova_senha" type="password" class="input" required minlength="6" placeholder="Mínimo 6 caracteres">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-senha')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Salvar nova senha</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
function abrirSenha(id, nome) {
  document.getElementById('titulo-senha').textContent = 'Redefinir senha — ' + nome;
  document.getElementById('form-senha').action = '/usuarios/' + id + '/senha';
  abrirModal('modal-senha');
}
</script>
</body></html>
