<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Desvinculacoes</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%= config.org_cor||'#1a56db' %>;}
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px;}
    .stat-box{background:var(--card);border:1px solid var(--borda);border-radius:12px;padding:16px 18px;display:flex;align-items:center;gap:14px;position:relative;overflow:hidden;}
    .stat-box::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--cor-stat,var(--cor-primaria));}
    .stat-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .stat-num{font-family:'Outfit',sans-serif;font-size:22px;font-weight:700;line-height:1;margin-bottom:2px;}
    .stat-lab{font-size:12px;color:var(--texto2);font-weight:600;}
    .table-card{background:var(--card);border:1px solid var(--borda);border-radius:14px;overflow:hidden;}
    .table-header{padding:14px 18px;border-bottom:1px solid var(--borda);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
    .table-titulo{font-size:14px;font-weight:700;font-family:'Outfit',sans-serif;}
    table.tabela{width:100%;border-collapse:collapse;}
    table.tabela thead th{background:var(--fundo);padding:10px 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--texto2);text-align:left;border-bottom:1px solid var(--borda);}
    table.tabela tbody tr{border-bottom:1px solid var(--borda);transition:background .15s;}
    table.tabela tbody tr:last-child{border-bottom:none;}
    table.tabela tbody tr:hover{background:var(--fundo);}
    table.tabela tbody td{padding:12px 14px;font-size:13px;color:var(--texto);vertical-align:middle;}
    .badge-status{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;}
    .badge-pendente{background:#fef3c7;color:#92400e;}
    .badge-enviado{background:#dbeafe;color:#1e40af;}
    .badge-assinado{background:#dcfce7;color:#166534;}
    .badge-tipo{background:var(--fundo);color:var(--texto2);border:1px solid var(--borda);padding:2px 8px;border-radius:6px;font-size:11px;font-weight:600;}
    .btn-xs{display:inline-flex;align-items:center;gap:4px;padding:5px 10px;border-radius:7px;font-size:11px;font-weight:600;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);cursor:pointer;text-decoration:none;transition:all .15s;font-family:inherit;white-space:nowrap;}
    .btn-xs:hover{border-color:var(--cor-primaria);color:var(--cor-primaria);}
    .btn-xs.roxo{background:#6366f1;color:white;border-color:transparent;}
    .btn-xs.verde{background:#059669;color:white;border-color:transparent;}
    .btn-xs.amarelo{background:#f59e0b;color:white;border-color:transparent;}
    .btn-xs.azul{background:#0891b2;color:white;border-color:transparent;}
    .btn-xs.verm{color:#dc2626;border-color:#fecaca;}
    .btn-xs.verm:hover{background:#fee2e2;}
    .ligante-nome{font-weight:600;font-size:13px;}
    .ligante-email{font-size:11px;color:var(--texto2);margin-top:1px;}
    .search-bar{display:flex;align-items:center;gap:8px;background:var(--fundo);border:1px solid var(--borda);border-radius:8px;padding:0 12px;height:34px;}
    .search-bar input{border:none;background:transparent;font-size:13px;color:var(--texto);outline:none;width:160px;font-family:inherit;}
    .adv-links{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px;}
    .adv-link{font-size:10px;padding:2px 7px;border-radius:5px;background:#eff6ff;color:#1e40af;text-decoration:none;font-weight:600;border:1px solid #bfdbfe;}
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'desvinculacoes' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Desvinculacoes</h1>
      <div class="topbar-acoes">
        <button class="btn btn-primario btn-sm" onclick="abrirModal('modal-nova')">+ Nova Desvinculacao</button>
      </div>
    </div>
    <div class="content">
      <%if(msg&&msg.length>0){%><div class="alerta alerta-ok"><%=msg[0]%></div><%}%>
      <%if(erro&&erro.length>0){%><div class="alerta alerta-erro"><%=erro[0]%></div><%}%>
      <%const total=desvinculacoes.length;const pendentes=desvinculacoes.filter(d=>d.status==='pendente').length;const enviados=desvinculacoes.filter(d=>d.status==='enviado'||d.status==='assinado').length;%>
      <div class="stats-row">
        <div class="stat-box" style="--cor-stat:var(--cor-primaria)">
          <div class="stat-icon" style="background:#eff6ff"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a56db" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
          <div><div class="stat-num" style="color:var(--cor-primaria)"><%=total%></div><div class="stat-lab">Total</div></div>
        </div>
        <div class="stat-box" style="--cor-stat:#f59e0b">
          <div class="stat-icon" style="background:#fffbeb"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><div class="stat-num" style="color:#f59e0b"><%=pendentes%></div><div class="stat-lab">Pendentes</div></div>
        </div>
        <div class="stat-box" style="--cor-stat:#10b981">
          <div class="stat-icon" style="background:#f0fdf4"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
          <div><div class="stat-num" style="color:#10b981"><%=enviados%></div><div class="stat-lab">Enviados/Assinados</div></div>
        </div>
      </div>
      <div class="table-card">
        <div class="table-header">
          <span class="table-titulo">Todas as desvinculacoes (<%=total%>)</span>
          <div class="search-bar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--texto2)"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
            <input type="text" placeholder="Buscar ligante..." oninput="filtrar(this.value)">
          </div>
        </div>
        <table class="tabela">
          <thead><tr>
            <th>Ligante</th><th>Tipo</th><th>Adv.</th>
            <th>Status</th><th>Enviado em</th><th>Assinado em</th><th>Acoes</th>
          </tr></thead>
          <tbody>
          <%if(desvinculacoes.length===0){%>
          <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--texto2)">
            <div style="font-size:32px;margin-bottom:12px">&#9984;</div>
            <div style="font-weight:600;margin-bottom:4px">Nenhuma desvinculacao registrada</div>
            <div style="font-size:12px">Clique em + Nova Desvinculacao para comecar</div>
          </td></tr>
          <%}%>
          <%desvinculacoes.forEach(d=>{%>
          <tr class="desvinc-row">
            <td>
              <div class="ligante-nome"><%=d.ligante_nome||'&#8212;'%></div>
              <div class="ligante-email"><%=d.ligante_email||''%></div>
            </td>
            <td><span class="badge-tipo"><%=d.tipo_membro%></span></td>
            <td>
              <div style="font-weight:600;font-size:13px"><%=d.num_advertencias||3%></div>
              <div class="adv-links">
                <%if(d.adv1_chave){%><a href="/desvinculacoes/<%=d.id%>/adv/1" target="_blank" class="adv-link">Adv 1</a><%}%>
                <%if(d.adv2_chave){%><a href="/desvinculacoes/<%=d.id%>/adv/2" target="_blank" class="adv-link">Adv 2</a><%}%>
                <%if(d.adv3_chave){%><a href="/desvinculacoes/<%=d.id%>/adv/3" target="_blank" class="adv-link">Adv 3</a><%}%>
              </div>
            </td>
            <td>
              <%if(d.status==='assinado'){%><span class="badge-status badge-assinado">Assinado</span>
              <%}else if(d.status==='enviado'){%><span class="badge-status badge-enviado">Enviado</span>
              <%}else{%><span class="badge-status badge-pendente">Pendente</span><%}%>
            </td>
            <td style="color:var(--texto2);font-size:12px"><%=d.enviado_em?new Date(d.enviado_em).toLocaleDateString('pt-BR'):'&#8212;'%></td>
            <td style="color:var(--texto2);font-size:12px"><%=d.assinado_em?new Date(d.assinado_em).toLocaleDateString('pt-BR'):'&#8212;'%></td>
            <td><div style="display:flex;gap:5px;flex-wrap:wrap">
              <button onclick="editarDesvinc(<%=d.id%>,<%=d.num_advertencias||3%>)" class="btn-xs azul">Editar</button>
              <a href="/desvinculacoes/<%=d.id%>/visualizar" target="_blank" class="btn-xs">Ver</a>
              <a href="/desvinculacoes/<%=d.id%>/imprimir" target="_blank" class="btn-xs roxo">Imprimir</a>
              <form method="POST" action="/desvinculacoes/<%=d.id%>/enviar" style="display:inline;margin:0"><button type="submit" class="btn-xs verde">Enviar</button></form>
              <form method="POST" action="/desvinculacoes/<%=d.id%>/reenviar" style="display:inline;margin:0"><button type="submit" class="btn-xs amarelo">Reenviar</button></form>
              <%if(d.status==='enviado'||d.status==='assinado'){%>
              <button class="btn-xs verde" onclick="abrirUploadAssinado(<%=d.id%>,'<%=d.ligante_nome%>')">Anexar Assinado</button>
              <%}%>
              <%if(d.pdf_assinado_chave){%>
              <a href="/desvinculacoes/<%=d.id%>/assinado" target="_blank" class="btn-xs azul">Ver Assinado</a>
              <%}%>
              <%if(usuario.perfil==='admin'||usuario.perfil==='presidencia'){%>
              <form method="POST" action="/desvinculacoes/<%=d.id%>/deletar" style="display:inline;margin:0" onsubmit="return confirm('Excluir?')">
                <button type="submit" class="btn-xs verm">Excluir</button></form>
              <%}%>
            </div></td>
          </tr>
          <%});%>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<div class="modal-overlay" id="modal-editar" style="display:none">
  <div class="modal">
    <div class="modal-header"><span class="modal-titulo">Editar Desvinculacao</span><button class="icon-btn" onclick="fecharModal('modal-editar')">&#x2715;</button></div>
    <form id="form-editar" action="" method="POST" enctype="multipart/form-data">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo"><label class="label">Numero de Advertencias</label>
          <select name="num_advertencias" id="edit-num-adv" class="input">
          <%for(let i=1;i<=10;i++){%><option value="<%=i%>"><%=i%> advertencia(s)</option><%}%>
          </select>
        </div>
        <div class="campo"><label class="label">Substituir PDF Advertencia 1</label><input type="file" name="adv1" class="input" accept=".pdf,.jpg,.jpeg,.png"></div>
        <div class="campo"><label class="label">Substituir PDF Advertencia 2</label><input type="file" name="adv2" class="input" accept=".pdf,.jpg,.jpeg,.png"></div>
        <div class="campo"><label class="label">Substituir PDF Advertencia 3</label><input type="file" name="adv3" class="input" accept=".pdf,.jpg,.jpeg,.png"></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn" onclick="fecharModal('modal-editar')">Cancelar</button><button type="submit" class="btn btn-primario">Salvar</button></div>
    </form>
  </div>
</div>
<div class="modal-overlay" id="modal-assinado-desvinc" style="display:none">
  <div class="modal" style="max-width:440px">
    <div class="modal-header">
      <span class="modal-titulo" id="titulo-assinado-desvinc">Anexar documento assinado</span>
      <button class="icon-btn" onclick="fecharModal('modal-assinado-desvinc')">&#x2715;</button>
    </div>
    <form id="form-assinado-desvinc" action="" method="POST" enctype="multipart/form-data">
      <div style="background:var(--fundo);border:2px dashed var(--borda);border-radius:10px;padding:20px;text-align:center;margin-bottom:16px">
        <div style="font-size:13px;font-weight:600;margin-bottom:4px">Documento assinado (PDF)</div>
        <div style="font-size:11px;color:var(--texto2);margin-bottom:10px">Selecione o PDF do termo de desvinculacao assinado</div>
        <input type="file" name="pdf_assinado" class="input" accept=".pdf" required style="max-width:260px;margin:0 auto">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-assinado-desvinc')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Anexar</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/app.js"></script>
<script>
function editarDesvinc(id,numAdv){
  document.getElementById('form-editar').action='/desvinculacoes/'+id+'/editar';
  document.getElementById('edit-num-adv').value=numAdv;
  abrirModal('modal-editar');
}
function abrirUploadAssinado(id,nome){
  document.getElementById('titulo-assinado-desvinc').textContent='Anexar assinado — '+nome;
  document.getElementById('form-assinado-desvinc').action='/desvinculacoes/'+id+'/assinado';
  abrirModal('modal-assinado-desvinc');
}
function filtrar(q){document.querySelectorAll('.desvinc-row').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q.toLowerCase())?'':' none';});}
</script>
</body>
</html>