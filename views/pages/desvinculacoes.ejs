<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Desvinculações — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .badge { padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700; }
    .badge-pendente { background:#fef3c7;color:#92400e; }
    .badge-enviado { background:#dbeafe;color:#1e40af; }
    .badge-assinado { background:#dcfce7;color:#166534; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'desvinculacoes' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">✂️ Desvinculações</h1>
      <div class="topbar-acoes">
        <button class="btn btn-primario" onclick="abrirModal('modal-nova')">+ Nova Desvinculação</button>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <div class="card">
        <table class="tabela">
          <thead>
            <tr>
              <th>#</th>
              <th>Ligante</th>
              <th>Email</th>
              <th>Tipo</th>
              <th>Advertências</th>
              <th>Status</th>
              <th>Enviado em</th>
              <th>Assinado em</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% if (desvinculacoes.length === 0) { %>
            <tr><td colspan="8" style="text-align:center;color:var(--texto2);padding:40px">Nenhuma desvinculação cadastrada</td></tr>
            <% } %>
            <% desvinculacoes.forEach(d => { %>
            <tr>
              <td><%= d.id %></td>
              <td><strong><%= d.ligante_nome || '—' %></strong></td>
              <td><%= d.ligante_email || '—' %></td>
              <td><span class="badge badge-pendente"><%= d.tipo_membro %></span></td>
              <td style="text-align:center"><%= d.num_advertencias || 3 %> <% if(d.adv1_chave){%><a href="/desvinculacoes/<%= d.id %>/adv/1" target="_blank" class="btn" style="font-size:10px;padding:2px 5px">📄1</a><%}%><% if(d.adv2_chave){%><a href="/desvinculacoes/<%= d.id %>/adv/2" target="_blank" class="btn" style="font-size:10px;padding:2px 5px">📄2</a><%}%><% if(d.adv3_chave){%><a href="/desvinculacoes/<%= d.id %>/adv/3" target="_blank" class="btn" style="font-size:10px;padding:2px 5px">📄3</a><%}%></td>
              <td>
                <% if (d.status === 'assinado') { %>
                  <span class="badge badge-assinado">✅ Assinado</span>
                <% } else if (d.status === 'enviado') { %>
                  <span class="badge badge-enviado">📧 Enviado</span>
                <% } else { %>
                  <span class="badge badge-pendente">⏳ Pendente</span>
                <% } %>
              </td>
              <td><%= d.enviado_em ? new Date(d.enviado_em).toLocaleString('pt-BR') : '—' %></td>
              <td><%= d.assinado_em ? new Date(d.assinado_em).toLocaleString('pt-BR') : '—' %></td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:wrap">
                  <a href="/desvinculacoes/<%= d.id %>/visualizar" target="_blank" class="btn" style="font-size:11px;padding:4px 8px" title="Visualizar">👁</a>
                  <a href="/desvinculacoes/<%= d.id %>/imprimir" target="_blank" class="btn" style="font-size:11px;padding:4px 8px;background:#6366f1;color:white" title="Imprimir PDF">🖨️</a>
                  <form method="POST" action="/desvinculacoes/<%= d.id %>/enviar" style="display:inline">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;background:#059669;color:white" title="Enviar email">📧 Enviar</button>
                  </form>
                  <form method="POST" action="/desvinculacoes/<%= d.id %>/reenviar" style="display:inline">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;background:#f59e0b;color:white" title="Reenviar email">🔄 Reenviar</button>
                  </form>
                  <% if (usuario.perfil === 'admin' || usuario.perfil === 'presidencia') { %>
                  <form method="POST" action="/desvinculacoes/<%= d.id %>/deletar" style="display:inline" onsubmit="return confirm('Excluir?')">
                    <button type="submit" class="btn" style="font-size:11px;padding:4px 8px;color:var(--vermelho)" title="Excluir">🗑</button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Modal Nova Desvinculação -->
<div class="modal-overlay" id="modal-nova" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-titulo">✂️ Nova Desvinculação</span>
      <button class="icon-btn" onclick="fecharModal('modal-nova')">✕</button>
    </div>
    <form action="/desvinculacoes" method="POST" enctype="multipart/form-data">
      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="campo">
          <label class="label">Ligante *</label>
          <select name="ligante_id" class="input" required>
            <option value="">Selecione...</option>
            <% ligantes.forEach(l => { %>
            <option value="<%= l.id %>"><%= l.nome %> — <%= l.email %></option>
            <% }) %>
          </select>
        </div>
        <div class="campo">
          <label class="label">Data</label>
          <input type="date" name="data_solicitacao" class="input" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="campo">
          <label class="label">Motivo (opcional)</label>
          <textarea name="motivo" class="input" rows="3" placeholder="Motivo da desvinculação..."></textarea>
        </div>
        <div class="campo">
          <label class="label">Nº de Advertências emitidas *</label>
          <select name="num_advertencias" class="input" required>
            <option value="1">1 advertência</option>
            <option value="2">2 advertências</option>
            <option value="3" selected>3 advertências</option>
          </select>
        </div>
        <div class="campo">
          <label class="label">📎 PDF Advertência 1</label>
          <input type="file" name="adv1" class="input" accept=".pdf,.jpg,.jpeg,.png">
        </div>
        <div class="campo">
          <label class="label">📎 PDF Advertência 2 (opcional)</label>
          <input type="file" name="adv2" class="input" accept=".pdf,.jpg,.jpeg,.png">
        </div>
        <div class="campo">
          <label class="label">📎 PDF Advertência 3 (opcional)</label>
          <input type="file" name="adv3" class="input" accept=".pdf,.jpg,.jpeg,.png">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" onclick="fecharModal('modal-nova')">Cancelar</button>
        <button type="submit" class="btn btn-primario">✂️ Criar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
</body>
</html>
