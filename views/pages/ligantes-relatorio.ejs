<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatório de Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#2b6803' %>; }
    .filtros-card { background:var(--card);border:1.5px solid var(--borda);border-radius:14px;padding:22px 24px;margin-bottom:24px; }
    .filtros-titulo { font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--cor-primaria);margin-bottom:18px;display:flex;align-items:center;gap:8px; }
    .filtros-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px; }
    .filtro-destaque { border-left:3px solid var(--cor-primaria);padding-left:10px;border-radius:0 8px 8px 0;background:color-mix(in srgb,var(--cor-primaria) 6%,transparent); }
    .filtros-acoes { margin-top:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap; }
    #sel-colunas { height:130px;border-radius:8px; }
    .col-checks { display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px 16px;padding:14px;border:1.5px solid var(--borda);border-radius:10px;background:var(--fundo); }
    .col-check { display:flex;align-items:center;gap:7px;font-size:13px;font-weight:500;color:var(--texto);cursor:pointer;white-space:nowrap; }
    .col-check input { width:16px;height:16px;cursor:pointer;accent-color:var(--cor-primaria); }
    .btn-mini { font-size:12px;font-weight:600;padding:6px 12px;border:1.5px solid var(--cor-primaria);background:transparent;color:var(--cor-primaria);border-radius:7px;cursor:pointer;transition:all .15s; }
    .btn-mini:hover { background:var(--cor-primaria);color:#fff; }
    .resultado-bar { display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:14px; }
    .resultado-badge { display:inline-flex;align-items:center;gap:7px;background:color-mix(in srgb,var(--cor-primaria) 10%,transparent);color:var(--cor-primaria);border:1px solid color-mix(in srgb,var(--cor-primaria) 25%,transparent);border-radius:20px;padding:5px 14px;font-size:13px;font-weight:600; }
    .btn-acoes-rel { display:flex;gap:8px;flex-wrap:wrap; }
    .table-wrap { overflow-x:auto;border-radius:12px;border:1.5px solid var(--borda); }
    .preview-table { width:100%;border-collapse:collapse;font-size:12.5px; }
    .preview-table thead tr { background:linear-gradient(135deg,#1a3410,#253d18); }
    .preview-table th { color:white;padding:10px 12px;text-align:left;font-size:11.5px;font-weight:600;letter-spacing:.03em;white-space:nowrap; }
    .preview-table th:first-child { border-radius:10px 0 0 0;width:40px;text-align:center; }
    .preview-table th:last-child { border-radius:0 10px 0 0; }
    .preview-table td { padding:8px 12px;border-bottom:1px solid var(--borda);vertical-align:middle; }
    .preview-table td:first-child { text-align:center;color:var(--texto2);font-size:11px; }
    .preview-table tr:nth-child(even) { background:var(--fundo); }
    .preview-table tr:hover { background:color-mix(in srgb,var(--cor-primaria) 6%,transparent); }
    .preview-table tbody tr:last-child td { border-bottom:none; }
    .badge-ativo { display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;background:color-mix(in srgb,#22c55e 12%,transparent);color:#16a34a; }
    .badge-inativo { display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:600;background:color-mix(in srgb,#ef4444 10%,transparent);color:#dc2626; }
    .tag-semestre { display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;background:color-mix(in srgb,var(--cor-primaria) 12%,transparent);color:var(--cor-primaria);border:1px solid color-mix(in srgb,var(--cor-primaria) 22%,transparent); }
    @media print {
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      html, body { margin:0 !important; padding:0 !important; background:white !important; }
      #sidebar-print-hide,
      #sidebar-print-hide * { display:none !important; width:0 !important; height:0 !important; overflow:hidden !important; position:absolute !important; }
      .topbar, .filtros-card, .btn-acoes-rel, .topbar-acoes, .resultado-bar { display:none !important; }
      .layout { display:block !important; margin:0 !important; padding:0 !important; }
      .main { margin:0 !important; padding:0 !important; width:100% !important; max-width:100% !important; float:none !important; display:block !important; }
      .content { padding:0 8px !important; }
      .print-header { display:block !important; }
      .table-wrap { border:none !important; border-radius:0 !important; box-shadow:none !important; overflow:visible !important; }
      .preview-table th { background:var(--cor-primaria) !important; }
      .preview-table tr:nth-child(even) td { background:#f7fbf4 !important; }
      #rpag, .rel-pag { display:none !important; }
      #tabela-relatorio tbody tr { display:table-row !important; }
      .preview-table thead tr { background:linear-gradient(135deg,#1a3410,#253d18) !important; }
      .preview-table th { background:transparent !important; color:white !important; }
      @page { margin:8mm 10mm; size:A4 landscape; }
    }
    }
    }
    }
    #sidebar-print-hide { display:none !important; }
    .print-header { display:none; margin-bottom:16px; }
    .print-header-org { font-size:16px; font-weight:800; color:#fff; letter-spacing:-.2px; }
    .print-header-sub { font-size:12px; color:rgba(255,255,255,.75); margin-top:2px; font-weight:600; }
    .print-header-data { font-size:10px; color:rgba(255,255,255,.55); margin-top:2px; }
  
/* paginacao relatorio */
.rpb{width:36px;height:36px;border:1.5px solid #e2e8f0;background:#fff;color:#374151;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s ease;border-radius:0!important;}
.rpb:hover:not([disabled]){background:#f0f7eb;border-color:#253d18;color:#253d18;transform:translateY(-1px);}
.rpb.on{background:linear-gradient(135deg,#1a3410,#253d18);color:#fff;border-color:transparent;}
.rpb[disabled]{opacity:.3;cursor:default;}
.rpb.pn{width:auto;padding:0 14px;font-size:12px;gap:4px;}
.rpi{font-size:12px;color:#64748b;padding:0 8px;}
</style>
</head>
<body>
<div class="layout">
  <div id='sidebar-print-hide'><%- include('../partials/sidebar', { paginaAtual: 'ligantes' }) %></div>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo" style="display:flex;align-items:center;gap:10px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Relatório de Ligantes</h1>
      <div class="topbar-acoes"><a href="/ligantes" class="btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>Voltar</a></div>
    </div>
    <div class="content">
      <div class="print-header">
        <div style="background:linear-gradient(135deg,#1a3410,#253d18);padding:18px 22px;display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
          <div style="display:flex;align-items:center;gap:14px;">
            <img src="/img/logo-lauro-clean.png" style="width:56px;height:56px;object-fit:contain;flex-shrink:0" alt="Logo">
            <div>
              <div class="print-header-org"><%= config.org_nome || 'Liga Acadêmica de Urologia — LAURO' %></div>
              <div class="print-header-sub">Relatório de Ligantes</div>
              <div class="print-header-data">Gerado em <%= new Date(new Date().toLocaleString('en-US', {timeZone: 'America/Asuncion'})).toLocaleString('pt-BR') %></div>
            </div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:30px;font-weight:800;color:#fff;line-height:1;"><%= ligantes.length %></div>
            <div style="font-size:10px;color:rgba(255,255,255,.7);margin-top:3px;font-weight:600;text-transform:uppercase;letter-spacing:.5px">ligante<%= ligantes.length!==1?'s':'' %></div>
          </div>
        </div>
        <% if(Object.values(filtros).some(v=>v&&v!=='todos')){ %>
        <div style="background:#f0f7eb;border-left:4px solid #253d18;padding:8px 14px;margin-bottom:14px;font-size:11px;color:#1a3410;font-weight:600;">
          Filtros aplicados:
          <% if(filtros.status&&filtros.status!=='todos'){ %> Status: <%= filtros.status %> •<% } %>
          <% if(filtros.sexo&&filtros.sexo!=='todos'){ %> Sexo: <%= filtros.sexo %> •<% } %>
          <% if(filtros.semestre&&filtros.semestre!=='todos'){ %> Semestre: <%= filtros.semestre %>º •<% } %>
          <% if(filtros.turma&&filtros.turma!=='todos'){ %> Turma: <%= filtros.turma %> •<% } %>
        </div>
        <% } %>
      </div>

      <div class="filtros-card">
        <div class="filtros-titulo"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>Filtros do Relatório</div>
        <form method="GET" action="/ligantes/relatorio" id="form-filtros">
          <div class="filtros-grid">
            <div class="campo">
              <label class="label">Status</label>
              <select name="status" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.status==='todos'?'selected':'' %>>Todos</option>
                <option value="ativo" <%= filtros.status==='ativo'?'selected':'' %>>Somente ativos</option>
                <option value="inativo" <%= filtros.status==='inativo'?'selected':'' %>>Somente inativos</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Sexo</label>
              <select name="sexo" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.sexo==='todos'?'selected':'' %>>Todos</option>
                <option value="Masculino" <%= filtros.sexo==='Masculino'?'selected':'' %>>Masculino</option>
                <option value="Feminino" <%= filtros.sexo==='Feminino'?'selected':'' %>>Feminino</option>
              </select>
            </div>
            <div class="campo filtro-destaque">
              <label class="label" style="display:flex;align-items:center;gap:5px"><span style="color:var(--cor-primaria);font-weight:700"></span>Semestre de Ingresso</label>
              <select name="semestre_ingresso" class="input" onchange="this.form.submit()">
                <option value="todos" <%= (filtros.semestre_ingresso||'todos')==='todos'?'selected':'' %>>Todos</option>
                <% if (typeof semestresIngresso !== 'undefined') { semestresIngresso.forEach(s => { %>
                <option value="<%= s %>" <%= filtros.semestre_ingresso===s?'selected':'' %>><%= s %></option>
                <% }) } %>
              </select>
            </div>
            <div class="campo">
              <label class="label">Semestre</label>
              <select name="semestre" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.semestre==='todos'?'selected':'' %>>Todos</option>
                <% semestres.forEach(s => { %>
                <option value="<%= s %>" <%= filtros.semestre===s?'selected':'' %>><%= s %>º semestre</option>
                <% }) %>
              </select>
            </div>
            <div class="campo">
              <label class="label">Turma</label>
              <select name="turma" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.turma==='todos'?'selected':'' %>>Todas</option>
                <% turmas.forEach(t => { %>
                <option value="<%= t %>" <%= filtros.turma===t?'selected':'' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="campo">
              <label class="label">Aceita cargo</label>
              <select name="aceita_cargo" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.aceita_cargo==='todos'?'selected':'' %>>Todos</option>
                <option value="Sim" <%= filtros.aceita_cargo==='Sim'?'selected':'' %>>Sim</option>
                <option value="Não" <%= filtros.aceita_cargo==='Não'?'selected':'' %>>Não</option>
                <option value="Talvez" <%= filtros.aceita_cargo==='Talvez'?'selected':'' %>>Talvez</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Tem formação</label>
              <select name="tem_formacao" class="input" onchange="this.form.submit()">
                <option value="todos" <%= filtros.tem_formacao==='todos'?'selected':'' %>>Todos</option>
                <option value="Sim" <%= filtros.tem_formacao==='Sim'?'selected':'' %>>Sim</option>
                <option value="Não" <%= filtros.tem_formacao==='Não'?'selected':'' %>>Não</option>
              </select>
            </div>
            <div class="campo">
              <label class="label">Ordenar por</label>
              <select name="ordem" class="input" onchange="this.form.submit()">
                <option value="nome" <%= filtros.ordem==='nome'?'selected':'' %>>Nome (A-Z)</option>
                <option value="nome_desc" <%= filtros.ordem==='nome_desc'?'selected':'' %>>Nome (Z-A)</option>
                <option value="idade" <%= filtros.ordem==='idade'?'selected':'' %>>Idade (mais novo)</option>
                <option value="idade_desc" <%= filtros.ordem==='idade_desc'?'selected':'' %>>Idade (mais velho)</option>
                <option value="semestre" <%= filtros.ordem==='semestre'?'selected':'' %>>Semestre</option>
                <option value="turma" <%= filtros.ordem==='turma'?'selected':'' %>>Turma</option>
                <option value="criado_em" <%= filtros.ordem==='criado_em'?'selected':'' %>>Data de cadastro</option>
              </select>
            </div>
            <div class="campo" style="grid-column:1/-1">
              <label class="label" style="margin-bottom:8px;display:block">Colunas a exibir no relatório <span style="font-weight:400;color:var(--texto2);font-size:12px">(marque só o que precisar — protege dados sensíveis)</span></label>
              <div class="col-checks">
                <label class="col-check"><input type="checkbox" name="colunas" value="nome" <%= (filtros.colunas||[]).includes('nome')?'checked':'' %> onchange="this.form.submit()"> Nome</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="email" <%= (filtros.colunas||[]).includes('email')?'checked':'' %> onchange="this.form.submit()"> E-mail</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="whatsapp" <%= (filtros.colunas||[]).includes('whatsapp')?'checked':'' %> onchange="this.form.submit()"> WhatsApp</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="sexo" <%= (filtros.colunas||[]).includes('sexo')?'checked':'' %> onchange="this.form.submit()"> Sexo</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="data_nascimento" <%= (filtros.colunas||[]).includes('data_nascimento')?'checked':'' %> onchange="this.form.submit()"> Nascimento</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="semestre" <%= (filtros.colunas||[]).includes('semestre')?'checked':'' %> onchange="this.form.submit()"> Semestre</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="turma" <%= (filtros.colunas||[]).includes('turma')?'checked':'' %> onchange="this.form.submit()"> Turma</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="catraca" <%= (filtros.colunas||[]).includes('catraca')?'checked':'' %> onchange="this.form.submit()"> Catraca</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="rg" <%= (filtros.colunas||[]).includes('rg')?'checked':'' %> onchange="this.form.submit()"> RG/CI</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="cpf" <%= (filtros.colunas||[]).includes('cpf')?'checked':'' %> onchange="this.form.submit()"> CPF</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="status" <%= (filtros.colunas||[]).includes('status')?'checked':'' %> onchange="this.form.submit()"> Status</label>
                <label class="col-check"><input type="checkbox" name="colunas" value="criado_em" <%= (filtros.colunas||[]).includes('criado_em')?'checked':'' %> onchange="this.form.submit()"> Data cadastro</label>
              </div>
              <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap">
                <button type="button" class="btn-mini" onclick="presetColunas(['nome','email'])">Apenas Nome + E-mail</button>
                <button type="button" class="btn-mini" onclick="presetColunas(['nome','whatsapp'])">Apenas Nome + WhatsApp</button>
                <button type="button" class="btn-mini" onclick="presetColunas(['nome','email','whatsapp','semestre','turma','status'])">Padrão</button>
              </div>
            </div>
          </div>
          <div class="filtros-acoes">
            <a href="/ligantes/relatorio" class="btn"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>Limpar filtros</a>
          </div>
        </form>
      </div>

      <div class="resultado-bar">
        <span class="resultado-badge"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><strong><%= ligantes.length %></strong> ligante<%= ligantes.length!==1?'s':'' %> encontrado<%= ligantes.length!==1?'s':'' %></span>
        <div class="btn-acoes-rel">
          <button class="btn btn-primario" onclick="window.print()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>Imprimir</button>
          <button class="btn btn-primario" onclick="gerarPDF()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Gerar PDF</button>
          <button class="btn" onclick="exportarCSV()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Exportar CSV</button>
        </div>
      </div>

      <div class="table-wrap">
        <table class="preview-table" id="tabela-relatorio">
          <thead>
            <tr>
              <th>#</th>
              <% colunasVisiveis.forEach(col => { %><th><%= labelColuna(col) %></th><% }) %>
            </tr>
          </thead>
          <tbody>
            <% ligantes.forEach((l, i) => { %>
            <tr>
              <td><%= i+1 %></td>
              <% colunasVisiveis.forEach(col => { %>
              <td>
                <% if (col==='data_nascimento') { %>
                  <%= l.data_nascimento ? new Date(String(l.data_nascimento).substring(0,10)+'T12:00:00').toLocaleDateString('pt-BR') : '—' %>
                <% } else if (col==='status') { %>
                  <% if (l.ativo==0) { %><span class="badge-inativo">Inativo</span><% } else { %><span class="badge-ativo">Ativo</span><% } %>
                <% } else if (col==='criado_em') { %>
                  <%= new Date(l.criado_em).toLocaleDateString('pt-BR') %>
                <% } else if (col==='semestre_ingresso') { %>
                  <% if (l.semestre_ingresso) { %><span class="tag-semestre"><%= l.semestre_ingresso %></span><% } else { %>—<% } %>
                <% } else { %>
                  <%= l[col] || '—' %>
                <% } %>
              </td>
              <% }) %>
            </tr>
            <% }) %>
            <% if (ligantes.length===0) { %>
            <tr><td colspan="<%= colunasVisiveis.length+1 %>" style="text-align:center;padding:32px;color:var(--texto2)">Nenhum ligante encontrado com os filtros selecionados.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <div id="rpag" style="display:flex;gap:5px;align-items:center;justify-content:center;padding:20px 0 8px;flex-wrap:wrap;"></div>

    </div>
  </main>
</div>
<script src="/js/app.js"></script>
<script>
function gerarPDF() {
  const win = window.open('','_blank');
  const _allRows=document.querySelectorAll('#tabela-relatorio tbody tr');
  _allRows.forEach((r,i)=>{r._d=r.style.display;r.style.display='';const td=r.querySelector('td:first-child');if(td)td.textContent=i+1;});
  const tabela = document.getElementById('tabela-relatorio').outerHTML;
  _allRows.forEach(r=>{r.style.display=r._d;});
  const org = '<%= config.org_nome || "Liga Acadêmica de Urologia — LAURO" %>';
  const total = <%= ligantes.length %>;
  const cor = '<%= config.org_cor || "#2b6803" %>';
  const agora = new Date(new Date().toLocaleString('en-US', {timeZone: 'America/Asuncion'})).toLocaleString('pt-BR');
  const base = location.origin;
  const estiloTabela = tabela
