function exportarCSV() {
  const tabela = document.getElementById('tabela-relatorio');
  const linhas = [];
  tabela.querySelectorAll('tr').forEach(tr => {
    const cols = [];
    tr.querySelectorAll('th,td').forEach(td => cols.push('"'+td.innerText.replace(/"/g,'""')+'"'));
    linhas.push(cols.join(','));
  });
  const csv = '\uFEFF'+linhas.join('\n');
  const blob = new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href=url; a.download='ligantes-relatorio.csv'; a.click();
}


function presetColunas(lista){
  document.querySelectorAll('input[name="colunas"]').forEach(function(cb){ cb.checked = lista.includes(cb.value); });
  var form = document.getElementById('form-filtros');
  if (form) form.submit();
}

// Paginacao relatorio
(function(){
  var P=1,N=25;
  var SL='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>';
  var SR='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
  function go(){
    var rows=Array.from(document.querySelectorAll('#tabela-relatorio tbody tr'));
    if(!rows.length)return;
    var tp=Math.ceil(rows.length/N);
    rows.forEach(function(r,i){r.style.display=(i>=(P-1)*N&&i<P*N)?'':'none';});
    rows.filter(function(r){return r.style.display!=='none';}).forEach(function(r,i){
      var td=r.querySelector('td:first-child');if(td)td.textContent=(P-1)*N+i+1;
    });
    var w=document.getElementById('rpag');if(!w)return;
    if(tp<=1){w.innerHTML='';return;}
    var h='<button class="rpb pn"'+(P<=1?' disabled':'')+' onclick="irP('+(P-1)+')">'+SL+' Anterior</button>';
    for(var p=1;p<=tp;p++){
      if(p===1||p===tp||Math.abs(p-P)<=1)h+='<button class="rpb'+(P===p?' on':'')+'" onclick="irP('+p+')">'+p+'</button>';
      else if((p===2&&P>3)||(p===tp-1&&P<tp-2))h+='<span class="rpi">...</span>';
    }
    h+='<button class="rpb pn"'+(P>=tp?' disabled':'')+' onclick="irP('+(P+1)+')">Próximo '+SR+'</button>';
    h+='<span class="rpi">Pág '+P+'/'+tp+' · '+rows.length+' ligantes</span>';
    w.innerHTML=h;
  }
  window.irP=function(p){
    var rows=document.querySelectorAll('#tabela-relatorio tbody tr');
    var tp=Math.ceil(rows.length/N);
    if(p<1||p>tp)return;P=p;go();
    var tw=document.querySelector('.table-wrap');
    if(tw)window.scrollTo({top:tw.offsetTop-80,behavior:'smooth'});
  };
  document.addEventListener('DOMContentLoaded',go);
})();

</script>
</body>
</html>