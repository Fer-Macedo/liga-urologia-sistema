<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="shortcut icon" href="/favicon.ico">
  <title><%=projeto.titulo%> — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%=config.org_cor||'#1a56db'%>}
    .pg-header{display:flex;align-items:center;gap:14px;margin-bottom:24px;flex-wrap:wrap}
    .pg-header a{color:var(--texto2);text-decoration:none;font-size:13px;display:flex;align-items:center;gap:5px}
    .pg-header h1{font-size:20px;font-weight:700;color:var(--texto);margin:0;flex:1}
    .badge{display:inline-flex;align-items:center;padding:3px 10px;font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;border:1px solid}
    .badge-aberto{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
    .badge-encerrado{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .badge-revisao{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
    .info-bar{background:var(--card);border:1px solid var(--borda);padding:18px 22px;margin-bottom:24px;display:flex;gap:24px;flex-wrap:wrap;align-items:center}
    .info-item{font-size:13px;color:var(--texto2);display:flex;align-items:center;gap:7px}
    .info-item strong{color:var(--texto);font-weight:600}
    .doc-links{display:flex;gap:10px;margin-left:auto}
    .btn{padding:8px 16px;font-size:13px;font-weight:600;border:1px solid var(--borda);background:var(--card);color:var(--texto);cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px;border-radius:0}
    .btn:hover{background:var(--hover)}
    .btn.pri{background:var(--cor-primaria);color:#fff;border-color:var(--cor-primaria)}
    .btn.pri:hover{opacity:.9}
    .btn.verde{background:#10b981;color:#fff;border-color:#10b981}
    .btn-sm{padding:6px 12px;font-size:12px}
    .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .section-header h2{font-size:15px;font-weight:700;color:var(--texto);margin:0}
    .grupos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:32px}
    .grupo-card{background:var(--card);border:1px solid var(--borda);padding:18px}
    .grupo-nome{font-size:14px;font-weight:700;color:var(--texto);margin-bottom:10px}
    .grupo-membros{font-size:12px;color:var(--texto2);margin-bottom:12px}
    .grupo-status{display:inline-flex;padding:2px 8px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid;margin-bottom:12px}
    .status-aguardando{background:#f8fafc;color:#64748b;border-color:#cbd5e1}
    .status-em_revisao{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
    .status-devolvido{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .status-aprovado{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
    .grupo-acoes{display:flex;gap:8px}
    .aviso-form{background:var(--card);border:1px solid var(--borda);padding:20px;margin-bottom:20px}
    .aviso-form h3{font-size:13px;font-weight:700;color:var(--texto);margin:0 0 12px}
    .aviso-form textarea{width:100%;padding:9px 12px;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);font-size:13px;resize:vertical;min-height:70px;font-family:inherit;box-sizing:border-box;border-radius:0}
    .aviso-form textarea:focus{outline:none;border-color:var(--cor-primaria)}
    .aviso-form select{padding:7px 10px;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);font-size:12px;border-radius:0;font-family:inherit}
    .aviso-list{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
    .aviso-item{background:var(--card);border:1px solid var(--borda);padding:14px 16px}
    .aviso-meta{font-size:11px;color:var(--texto2);margin-bottom:6px;display:flex;gap:10px}
    .aviso-texto{font-size:13px;color:var(--texto)}
    .alert-ok{padding:12px 16px;background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:13px;margin-bottom:20px}
    .alert-err{padding:12px 16px;background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;font-size:13px;margin-bottom:20px}
    .empty-small{padding:24px;text-align:center;color:var(--texto2);font-size:13px;background:var(--card);border:1px solid var(--borda)}
  </style>
</head>
<body>
<%- include('../../partials/sidebar',{paginaAtual:'cientifico',config,usuario,permissoesAtivas:permissoesAtivas||[]}) %>
<div style="margin-left:240px;padding:32px 36px;min-height:100vh;background:var(--fundo)">
<%- include('../../partials/_notificacoes') %>
<%if(msg&&msg.length){%><div class="alert-ok"><%=msg[0]%></div><%}%>
<%if(erro&&erro.length){%><div class="alert-err"><%=erro[0]%></div><%}%>
<div class="pg-header">
  <a href="/cientifico"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>Projetos</a>
  <h1><%=projeto.titulo%></h1>
  <span class="badge <%=projeto.status==='aberto'?'badge-aberto':projeto.status==='encerrado'?'badge-encerrado':'badge-revisao'%>"><%=projeto.status%></span>
  <a href="/cientifico/projeto/<%=projeto.id%>/editar" class="btn btn-sm">Editar</a>
</div>
<div class="info-bar">
  <%if(projeto.descricao){%><div class="info-item"><%=projeto.descricao%></div><%}%>
  <%if(projeto.prazo){%><div class="info-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg><strong>Prazo:</strong> <%=new Date(projeto.prazo).toLocaleDateString('pt-BR')%></div><%}%>
  <div class="doc-links">
    <%if(projeto.edital_chave){%><a href="/cientifico/arquivo/<%=projeto.id%>/edital" class="btn btn-sm" target="_blank"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Edital</a><%}%>
    <%if(projeto.modelo_chave){%><a href="/cientifico/arquivo/<%=projeto.id%>/modelo" class="btn btn-sm" target="_blank"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Modelo</a><%}%>
  </div>
</div>

<div class="section-header">
  <h2>Grupos (<%=grupos.length%>)</h2>
  <a href="/cientifico/projeto/<%=projeto.id%>/grupo/novo" class="btn btn-sm pri">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Novo Grupo
  </a>
</div>
<%if(grupos.length===0){%>
<div class="empty-small">Nenhum grupo criado neste projeto ainda.</div>
<%}else{%>
<div class="grupos-grid">
<%grupos.forEach(function(g){%>
<div class="grupo-card">
  <div class="grupo-nome"><%=g.nome%></div>
  <div class="grupo-membros"><%=g.total_membros||0%> membro<%=g.total_membros!=1?'s':''%></div>
  <%if(g.ultimo_status){%><div class="grupo-status status-<%=g.ultimo_status%>"><%=g.ultimo_status.replace('_',' ')%></div><%}%>
  <div class="grupo-acoes">
    <a href="/cientifico/projeto/<%=projeto.id%>/grupo/<%=g.id%>" class="btn btn-sm pri">Abrir</a>
    <a href="/cientifico/projeto/<%=projeto.id%>/grupo/<%=g.id%>/membros" class="btn btn-sm">Membros</a>
  </div>
</div>
<%})%>
</div>
<%}%>

<div class="section-header">
  <h2>Avisos para os Grupos</h2>
</div>
<div class="aviso-form">
  <h3>Novo aviso</h3>
  <form method="POST" action="/cientifico/projeto/<%=projeto.id%>/aviso">
    <div style="display:flex;gap:10px;margin-bottom:10px">
      <select name="grupo_id">
        <option value="">Todos os grupos</option>
        <%grupos.forEach(function(g){%><option value="<%=g.id%>"><%=g.nome%></option><%})%>
      </select>
    </div>
    <textarea name="texto" placeholder="Mensagem para os grupos..." required></textarea>
    <div style="margin-top:10px">
      <button type="submit" class="btn btn-sm pri">Publicar aviso</button>
    </div>
  </form>
</div>
<%if(avisos.length===0){%>
<div class="empty-small">Nenhum aviso publicado ainda.</div>
<%}else{%>
<div class="aviso-list">
<%avisos.forEach(function(a){%>
<div class="aviso-item">
  <div class="aviso-meta">
    <span><%=new Date(a.criado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})%></span>
    <%if(a.grupo_nome){%><span>Para: <%=a.grupo_nome%></span><%}else{%><span>Para: Todos os grupos</span><%}%>
    <span>Por: <%=a.autor_nome||'Sistema'%></span>
  </div>
  <div class="aviso-texto"><%=a.texto%></div>
</div>
<%})%>
</div>
<%}%>
</div>
</body></html>
