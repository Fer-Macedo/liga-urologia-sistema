<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="shortcut icon" href="/favicon.ico">
  <title><%=grupo.nome%> — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root{--cor-primaria:<%=config.org_cor||'#1a56db'%>}
    .pg-header{display:flex;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap}
    .pg-header a.back{color:var(--texto2);text-decoration:none;font-size:13px;display:flex;align-items:center;gap:5px}
    .pg-header h1{font-size:20px;font-weight:700;color:var(--texto);margin:0;flex:1}
    .tabs{display:flex;border-bottom:2px solid var(--borda);margin-bottom:24px;gap:0}
    .tab{padding:10px 20px;font-size:13px;font-weight:600;color:var(--texto2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;background:none;border-top:none;border-left:none;border-right:none;font-family:inherit}
    .tab:hover{color:var(--texto)}
    .tab.ativo{color:var(--cor-primaria);border-bottom-color:var(--cor-primaria)}
    .tab-content{display:none}.tab-content.ativo{display:block}
    .btn{padding:8px 16px;font-size:13px;font-weight:600;border:1px solid var(--borda);background:var(--card);color:var(--texto);cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px;border-radius:0}
    .btn:hover{background:var(--hover)}
    .btn.pri{background:var(--cor-primaria);color:#fff;border-color:var(--cor-primaria)}
    .btn.pri:hover{opacity:.9}
    .btn.verde{background:#10b981;color:#fff;border-color:#10b981}
    .btn.vermelho{background:#ef4444;color:#fff;border-color:#ef4444}
    .btn-sm{padding:6px 12px;font-size:12px}
    .card{background:var(--card);border:1px solid var(--borda);padding:20px;margin-bottom:16px}
    .card h3{font-size:13px;font-weight:700;color:var(--texto);margin:0 0 14px;padding-bottom:10px;border-bottom:1px solid var(--borda)}
    .versao-item{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border:1px solid var(--borda);margin-bottom:8px;background:var(--card)}
    .versao-info{flex:1}
    .versao-nome{font-size:13px;font-weight:600;color:var(--texto)}
    .versao-meta{font-size:11px;color:var(--texto2);margin-top:3px}
    .versao-acoes{display:flex;gap:8px;align-items:center}
    .vstatus{display:inline-flex;padding:2px 8px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid}
    .vstatus-aguardando{background:#f8fafc;color:#64748b;border-color:#cbd5e1}
    .vstatus-em_revisao{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
    .vstatus-devolvido{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .vstatus-aprovado{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
    .comentario-box{background:#fffbeb;border:1px solid #fde68a;padding:10px 14px;font-size:12.5px;color:#92400e;margin-top:8px}
    .upload-area{border:1.5px dashed var(--borda);padding:24px;text-align:center;cursor:pointer;background:var(--fundo);margin-bottom:12px}
    .upload-area:hover{border-color:var(--cor-primaria)}
    .upload-area p{font-size:12.5px;color:var(--texto2);margin:6px 0 0}
    .revisao-form{background:var(--card);border:1px solid var(--borda);padding:16px;margin-top:10px}
    .revisao-form h4{font-size:12px;font-weight:700;color:var(--texto);margin:0 0 10px;text-transform:uppercase;letter-spacing:.5px}
    .revisao-form textarea{width:100%;padding:9px 12px;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);font-size:13px;resize:vertical;min-height:70px;font-family:inherit;box-sizing:border-box;border-radius:0}
    .revisao-form textarea:focus{outline:none;border-color:var(--cor-primaria)}
    .membros-lista{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
    .membro-item{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;border:1px solid var(--borda);background:var(--card)}
    .membro-nome{font-size:13px;font-weight:600;color:var(--texto)}
    .membro-tipo{font-size:11px;color:var(--texto2)}
    .membro-papel{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:2px 7px;border:1px solid;display:inline-flex}
    .papel-lider{background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe}
    .papel-membro{background:#f8fafc;color:#64748b;border-color:#e2e8f0}
    .add-membro-form{background:var(--card);border:1px solid var(--borda);padding:16px}
    .add-membro-form h3{font-size:13px;font-weight:700;color:var(--texto);margin:0 0 12px}
    .add-membro-form select{width:100%;padding:9px 12px;border:1px solid var(--borda);background:var(--fundo);color:var(--texto);font-size:13px;border-radius:0;font-family:inherit;margin-bottom:10px}
    .chat-wrap{display:flex;flex-direction:column;gap:0}
    .chat-msgs{border:1px solid var(--borda);background:var(--fundo);padding:16px;min-height:280px;max-height:400px;overflow-y:auto;margin-bottom:12px;display:flex;flex-direction:column;gap:10px}
    .chat-msg{padding:10px 13px;max-width:80%}
    .chat-msg.sistema{background:var(--card);border:1px solid var(--borda);align-self:flex-start}
    .chat-msg.portal{background:var(--cor-primaria);color:#fff;align-self:flex-end}
    .chat-msg.portal .chat-autor{color:rgba(255,255,255,.75)}
    .chat-autor{font-size:11px;font-weight:600;margin-bottom:4px;color:var(--texto2)}
    .chat-texto{font-size:13px;line-height:1.4}
    .chat-hora{font-size:10.5px;color:var(--texto2);margin-top:4px}
    .chat-msg.portal .chat-hora{color:rgba(255,255,255,.6)}
    .chat-input-wrap{display:flex;gap:8px}
    .chat-input-wrap textarea{flex:1;padding:9px 12px;border:1px solid var(--borda);background:var(--card);color:var(--texto);font-size:13px;resize:none;height:48px;font-family:inherit;border-radius:0}
    .chat-input-wrap textarea:focus{outline:none;border-color:var(--cor-primaria)}
    .timeline-list{display:flex;flex-direction:column;gap:0}
    .tl-item{display:flex;gap:16px;padding-bottom:20px;position:relative}
    .tl-item:not(:last-child)::before{content:'';position:absolute;left:15px;top:32px;bottom:0;width:2px;background:var(--borda)}
    .tl-dot{width:32px;height:32px;border:2px solid var(--borda);background:var(--card);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1}
    .tl-dot svg{color:var(--texto2)}
    .tl-body{flex:1;padding-top:4px}
    .tl-evento{font-size:13px;font-weight:600;color:var(--texto)}
    .tl-desc{font-size:12.5px;color:var(--texto2);margin-top:3px}
    .tl-hora{font-size:11px;color:var(--texto3);margin-top:4px}
    .alert-ok{padding:12px 16px;background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:13px;margin-bottom:20px}
    .alert-err{padding:12px 16px;background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;font-size:13px;margin-bottom:20px}
    .empty-small{padding:24px;text-align:center;color:var(--texto2);font-size:13px}
  </style>
</head>
<body>
<%- include('../../partials/sidebar',{paginaAtual:'cientifico',config,usuario,permissoesAtivas:permissoesAtivas||[]}) %>
<div style="margin-left:240px;padding:32px 36px;min-height:100vh;background:var(--fundo)">
<%- include('../../partials/_notificacoes') %>
<%if(msg&&msg.length){%><div class="alert-ok"><%=msg[0]%></div><%}%>
<%if(erro&&erro.length){%><div class="alert-err"><%=erro[0]%></div><%}%>
<div class="pg-header">
  <a href="/cientifico/projeto/<%=projeto.id%>" class="back"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg><%=projeto.titulo%></a>
  <h1><%=grupo.nome%></h1>
</div>

<div class="tabs">
  <button class="tab ativo" onclick="mudarTab(this,'trabalho')">Trabalho</button>
  <button class="tab" onclick="mudarTab(this,'membros')">Membros (<%=membros.length%>)</button>
  <button class="tab" onclick="mudarTab(this,'chat')">Chat</button>
  <button class="tab" onclick="mudarTab(this,'timeline')">Linha do Tempo</button>
</div>

<!-- ABA TRABALHO -->
<div id="tab-trabalho" class="tab-content ativo">
  <div style="display:grid;grid-template-columns:1fr 340px;gap:20px">
    <div>
      <div class="card">
        <h3 style="display:flex;align-items:center;gap:10px">Versoes do Trabalho
          <%if(grupo.tipo_trabalho==='individual'){%><span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:3px 8px;background:#eef2ff;color:#4338ca;border:1px solid #c7d2fe">Individual</span><%}else{%><span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:3px 8px;background:#ecfdf5;color:#047857;border:1px solid #a7f3d0">Colaborativo</span><%}%>
        </h3>

        <%/* ---- MODO COLABORATIVO ---- */%>
        <%if(grupo.tipo_trabalho!=='individual'){%>
          <%if(versoes.length===0){%>
          <div class="empty-small">Nenhuma versao enviada ainda. Os membros do grupo enviam pelo portal externo.</div>
          <%}else{versoes.forEach(function(v,i){%>
          <div class="versao-item">
            <div class="versao-info">
              <div class="versao-nome">v<%=versoes.length-i%> — <%=v.arquivo_nome%></div>
              <div class="versao-meta">Enviado em <%=new Date(v.enviado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})%> por <%=v.enviado_por_nome||'Membro'%></div>
              <%if(v.comentario_revisor){%><div class="comentario-box"><strong>Comentario do revisor:</strong> <%=v.comentario_revisor%></div><%}%>
            </div>
            <div class="versao-acoes">
              <span class="vstatus vstatus-<%=v.status%>"><%=v.status.replace('_',' ')%></span>
              <a href="/cientifico/versao/<%=v.id%>/download" class="btn btn-sm" target="_blank"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Baixar</a>
              <%if(v.status==='aguardando'||v.status==='devolvido'){%>
              <form method="POST" action="/cientifico/versao/<%=v.id%>/iniciar-revisao" style="display:inline;margin:0"><button class="btn btn-sm" style="background:#fff7ed;color:#c2410c;border-color:#fed7aa">Revisar</button></form>
              <%}%>
            </div>
          </div>
          <%if(v.status==='em_revisao'){%>
          <div class="revisao-form">
            <h4>Devolver ou Aprovar</h4>
            <form method="POST" action="/cientifico/versao/<%=v.id%>/revisar">
              <textarea name="comentario" placeholder="Comentario para o grupo (opcional ao aprovar, recomendado ao devolver)"></textarea>
              <div style="display:flex;gap:8px;margin-top:10px">
                <button type="submit" name="acao" value="devolver" class="btn btn-sm vermelho">Devolver com correcoes</button>
                <button type="submit" name="acao" value="aprovar" class="btn btn-sm verde">Aprovar trabalho</button>
              </div>
            </form>
          </div>
          <%}%>
          <%})}%>

        <%/* ---- MODO INDIVIDUAL ---- */%>
        <%}else{%>
          <%if(versoesPorAutor.length===0){%>
          <div class="empty-small">Nenhum membro no grupo ainda.</div>
          <%}%>
          <%versoesPorAutor.forEach(function(grp){%>
          <div style="border:1px solid var(--borda);margin-bottom:14px">
            <div style="background:var(--fundo);padding:10px 14px;border-bottom:1px solid var(--borda);display:flex;align-items:center;justify-content:space-between">
              <div style="font-size:13px;font-weight:700;color:var(--texto);display:flex;align-items:center;gap:7px">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <%=grp.autor_nome%>
              </div>
              <span style="font-size:11px;color:var(--texto2)"><%=grp.versoes.length%> <%=grp.versoes.length===1?'envio':'envios'%></span>
            </div>
            <div style="padding:12px 14px">
              <%if(grp.versoes.length===0){%>
              <div style="font-size:12.5px;color:var(--texto2);text-align:center;padding:8px">Ainda nao enviou nenhum trabalho.</div>
              <%}else{grp.versoes.forEach(function(v,i){%>
              <div class="versao-item">
                <div class="versao-info">
                  <div class="versao-nome">v<%=grp.versoes.length-i%> — <%=v.arquivo_nome%></div>
                  <div class="versao-meta">Enviado em <%=new Date(v.enviado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})%></div>
                  <%if(v.comentario_revisor){%><div class="comentario-box"><strong>Comentario do revisor:</strong> <%=v.comentario_revisor%></div><%}%>
                </div>
                <div class="versao-acoes">
                  <span class="vstatus vstatus-<%=v.status%>"><%=v.status.replace('_',' ')%></span>
                  <a href="/cientifico/versao/<%=v.id%>/download" class="btn btn-sm" target="_blank"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Baixar</a>
                  <%if(v.status==='aguardando'||v.status==='devolvido'){%>
                  <form method="POST" action="/cientifico/versao/<%=v.id%>/iniciar-revisao" style="display:inline;margin:0"><button class="btn btn-sm" style="background:#fff7ed;color:#c2410c;border-color:#fed7aa">Revisar</button></form>
                  <%}%>
                </div>
              </div>
              <%if(v.status==='em_revisao'){%>
              <div class="revisao-form">
                <h4>Devolver ou Aprovar</h4>
                <form method="POST" action="/cientifico/versao/<%=v.id%>/revisar">
                  <textarea name="comentario" placeholder="Comentario para o autor (opcional ao aprovar, recomendado ao devolver)"></textarea>
                  <div style="display:flex;gap:8px;margin-top:10px">
                    <button type="submit" name="acao" value="devolver" class="btn btn-sm vermelho">Devolver com correcoes</button>
                    <button type="submit" name="acao" value="aprovar" class="btn btn-sm verde">Aprovar trabalho</button>
                  </div>
                </form>
              </div>
              <%}%>
              <%})}%>
            </div>
          </div>
          <%})%>
        <%}%>
      </div>
    </div>
    <div>
      <div class="card">
        <h3>Documentos do Projeto</h3>
        <div style="display:flex;flex-direction:column;gap:8px">
          <%if(projeto.edital_chave){%>
          <a href="/cientifico/arquivo/<%=projeto.id%>/edital" class="btn" target="_blank" style="justify-content:center"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Baixar Edital</a>
          <%}%>
          <%if(projeto.modelo_chave){%>
          <a href="/cientifico/arquivo/<%=projeto.id%>/modelo" class="btn" target="_blank" style="justify-content:center"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Baixar Modelo</a>
          <%}%>
          <%if(!projeto.edital_chave&&!projeto.modelo_chave){%><p style="font-size:12.5px;color:var(--texto2);text-align:center">Nenhum documento anexado ao projeto ainda.</p><%}%>
        </div>
      </div>
      <div class="card">
        <h3>Avisos Recentes</h3>
        <%if(avisos.length===0){%><p style="font-size:12.5px;color:var(--texto2)">Nenhum aviso.</p><%}%>
        <%avisos.slice(0,3).forEach(function(a){%>
        <div style="padding:10px 0;border-bottom:1px solid var(--borda)">
          <div style="font-size:11px;color:var(--texto2);margin-bottom:4px"><%=new Date(a.criado_em).toLocaleDateString('pt-BR')%></div>
          <div style="font-size:13px;color:var(--texto)"><%=a.texto%></div>
        </div>
        <%})%>
      </div>
    </div>
  </div>
</div>

<!-- ABA MEMBROS -->
<div id="tab-membros" class="tab-content">
  <div style="max-width:600px">
    <div class="membros-lista">
      <%if(membros.length===0){%><div class="empty-small">Nenhum membro neste grupo ainda.</div><%}%>
      <%membros.forEach(function(m){%>
      <div class="membro-item">
        <div>
          <div class="membro-nome"><%=m.nome%></div>
          <div class="membro-tipo"><%=m.origem_tipo==='ligante'?'Ligante':'Diretivo'%> — <%=m.email||''%></div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          <span class="membro-papel <%=m.papel==='lider'?'papel-lider':'papel-membro'%>"><%=m.papel%></span>
          <form method="POST" action="/cientifico/grupo/<%=grupo.id%>/membro/<%=m.id%>/remover" style="display:inline;margin:0">
            <button class="btn btn-sm" style="color:#ef4444" onclick="return confirm('Remover membro do grupo?')">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </form>
        </div>
      </div>
      <%})%>
    </div>
    <div class="add-membro-form">
      <h3>Adicionar membro</h3>
      <form method="POST" action="/cientifico/grupo/<%=grupo.id%>/membro/adicionar">
        <select name="origem_tipo" onchange="filtrarMembros(this.value)" style="width:auto;display:inline-block;margin-right:8px;margin-bottom:8px">
          <option value="ligante">Ligante</option>
          <option value="diretivo">Diretivo</option>
        </select>
        <select name="origem_id" id="sel-membro" style="width:100%;margin-bottom:8px">
          <%ligantesDisponiveis.forEach(function(l){%><option value="<%=l.id%>" data-tipo="ligante"><%=l.nome%></option><%})%>
          <%diretivosDisponiveis.forEach(function(d){%><option value="<%=d.id%>" data-tipo="diretivo" style="display:none"><%=d.nome%></option><%})%>
        </select>
        <select name="papel" style="width:auto;display:inline-block;margin-right:8px;margin-bottom:8px">
          <option value="membro">Membro</option>
          <option value="lider">Lider</option>
        </select>
        <button type="submit" class="btn btn-sm pri">Adicionar</button>
      </form>
    </div>
  </div>
</div>

<!-- ABA CHAT -->
<div id="tab-chat" class="tab-content">
  <div style="max-width:680px">
    <div class="chat-msgs" id="chat-msgs">
      <%if(chat.length===0){%><div style="text-align:center;color:var(--texto2);font-size:13px;margin:auto">Nenhuma mensagem ainda. Inicie a conversa.</div><%}%>
      <%chat.forEach(function(c){%>
      <div class="chat-msg <%=c.autor_tipo%>">
        <div class="chat-autor"><%=c.autor_nome%></div>
        <%if(c.texto){%><div class="chat-texto"><%=c.texto%></div><%}%>
        <%if(c.arquivo_nome){%><div style="margin-top:5px"><a href="/cientifico/chat-arquivo/<%=c.id%>" target="_blank" style="font-size:12px;display:inline-flex;align-items:center;gap:5px;padding:4px 8px;background:rgba(0,0,0,.07);text-decoration:none;color:inherit;border-radius:2px"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg><%=c.arquivo_nome%></a></div><%}%>
        <div class="chat-hora"><%=new Date(c.criado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})%></div>
      </div>
      <%})%>
    </div>
    <form method="POST" action="/cientifico/grupo/<%=grupo.id%>/chat" enctype="multipart/form-data" class="chat-input-wrap" style="flex-direction:column;gap:8px">
      <div style="display:flex;gap:8px">
        <textarea name="texto" placeholder="Escreva uma mensagem..." onkeydown="if(event.ctrlKey&&event.key==='Enter'){this.form.submit()}" style="flex:1;padding:9px 12px;border:1px solid var(--borda);background:var(--card);color:var(--texto);font-size:13px;resize:none;height:48px;font-family:inherit;border-radius:0"></textarea>
        <button type="submit" class="btn pri" style="height:48px;padding:0 16px">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <label style="cursor:pointer;font-size:12px;color:var(--texto2);display:inline-flex;align-items:center;gap:5px;border:1px solid var(--borda);padding:5px 10px;background:var(--fundo)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          Anexar arquivo
          <input type="file" name="arquivo_chat" style="display:none" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg,.gif" onchange="document.getElementById('nc-sis').textContent=this.files[0]?this.files[0].name:''">
        </label>
        <span id="nc-sis" style="font-size:11px;color:var(--cor-primaria)"></span>
      </div>
    </form>
    <p style="font-size:11px;color:var(--texto2);margin-top:4px">Ctrl+Enter para enviar</p>
  </div>
</div>

<!-- ABA TIMELINE -->
<div id="tab-timeline" class="tab-content">
  <style>
    .tl-wrap{max-width:600px}
    .tl-item2{display:flex;gap:16px;padding-bottom:24px;position:relative}
    .tl-item2:not(:last-child)::before{content:'';position:absolute;left:18px;top:38px;bottom:0;width:2px;background:var(--borda)}
    .tl-dot2{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;z-index:1;border:2px solid}
    .tl-dot2.criado{background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8}
    .tl-dot2.membro{background:#f0fdf4;border-color:#bbf7d0;color:#15803d}
    .tl-dot2.enviado{background:#fff7ed;border-color:#fed7aa;color:#c2410c}
    .tl-dot2.revisao{background:#fef9c3;border-color:#fde047;color:#a16207}
    .tl-dot2.aprovado{background:#f0fdf4;border-color:#4ade80;color:#15803d}
    .tl-dot2.devolvido{background:#fef2f2;border-color:#fecaca;color:#b91c1c}
    .tl-dot2.aviso{background:#faf5ff;border-color:#e9d5ff;color:#7c3aed}
    .tl-dot2.default{background:var(--card);border-color:var(--borda);color:var(--texto2)}
    .tl-body2{flex:1;padding-top:6px}
    .tl-evento2{font-size:13px;font-weight:700;color:var(--texto);margin-bottom:3px}
    .tl-desc2{font-size:12.5px;color:var(--texto2);line-height:1.4;margin-bottom:4px}
    .tl-hora2{font-size:11px;color:var(--texto3)}
    .tl-badge{display:inline-flex;padding:2px 8px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid;margin-bottom:4px}
    .tl-badge.criado{background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe}
    .tl-badge.membro{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
    .tl-badge.enviado{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
    .tl-badge.revisao{background:#fef9c3;color:#a16207;border-color:#fde047}
    .tl-badge.aprovado{background:#f0fdf4;color:#15803d;border-color:#4ade80}
    .tl-badge.devolvido{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .tl-badge.aviso{background:#faf5ff;color:#7c3aed;border-color:#e9d5ff}
    .tl-badge.default{background:var(--hover);color:var(--texto2);border-color:var(--borda)}
  </style>
  <div class="tl-wrap">
    <%if(timeline.length===0){%><div class="empty-small">Nenhum evento registrado ainda.</div><%}%>
    <div class="timeline-list">
      <%timeline.forEach(function(t){
        var ev=t.evento.toLowerCase();
        var tipo='default';
        var icone='<circle cx="12" cy="12" r="4"/>';
        var label=t.evento;
        if(ev.includes('criado')){tipo='criado';icone='<path d="M12 5v14M5 12h14"/>';}
        else if(ev.includes('membro adicionado')){tipo='membro';icone='<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>';}
        else if(ev.includes('membro removido')){tipo='devolvido';icone='<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';}
        else if(ev.includes('versao')||ev.includes('versão')){tipo='enviado';icone='<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>';}
        else if(ev.includes('revisao')||ev.includes('revisão')){tipo='revisao';icone='<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>';}
        else if(ev.includes('aprovado')){tipo='aprovado';icone='<polyline points="20 6 9 17 4 12"/>';}
        else if(ev.includes('devolvido')||ev.includes('correcao')){tipo='devolvido';icone='<polyline points="1 4 1 20 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.96"/>';}
        else if(ev.includes('aviso')){tipo='aviso';icone='<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>';}
      %>
      <div class="tl-item2">
        <div class="tl-dot2 <%=tipo%>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><%- icone %></svg>
        </div>
        <div class="tl-body2">
          <div><span class="tl-badge <%=tipo%>"><%=tipo==='criado'?'Criacao':tipo==='membro'?'Equipe':tipo==='enviado'?'Envio':tipo==='revisao'?'Revisao':tipo==='aprovado'?'Aprovado':tipo==='devolvido'?'Devolvido':tipo==='aviso'?'Aviso':'Evento'%></span></div>
          <div class="tl-evento2"><%=t.evento%></div>
          <%if(t.descricao){%><div class="tl-desc2"><%=t.descricao%></div><%}%>
          <div class="tl-hora2"><%=new Date(t.criado_em).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})%></div>
        </div>
      </div>
      <%})%>
    </div>
  </div>
</div>

</div>
<script>
function mudarTab(btn,id){
  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('ativo')});
  document.querySelectorAll('.tab-content').forEach(function(t){t.classList.remove('ativo')});
  btn.classList.add('ativo');
  document.getElementById('tab-'+id).classList.add('ativo');
  if(id==='chat'){var m=document.getElementById('chat-msgs');if(m)m.scrollTop=m.scrollHeight;}
}
function filtrarMembros(tipo){
  var sel=document.getElementById('sel-membro');
  Array.from(sel.options).forEach(function(o){
    o.style.display=(o.dataset.tipo===tipo)?'':'none';
    if(o.dataset.tipo===tipo&&!o.selected){}
  });
  var primeiro=Array.from(sel.options).find(function(o){return o.dataset.tipo===tipo});
  if(primeiro)sel.value=primeiro.value;
}
document.addEventListener('DOMContentLoaded',function(){
  var m=document.getElementById('chat-msgs');
  if(m)m.scrollTop=m.scrollHeight;
  var tabParam=new URLSearchParams(window.location.search).get('tab');
  if(tabParam){
    var btn=document.querySelector('.tab[onclick*="\''+tabParam+'\'"]');
    if(btn)mudarTab(btn,tabParam);
  }
});
</script>
</body></html>
