<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Materiais de Estudo — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#2b6803' %>; --rad: 2px; }
    .mat-table { width:100%;border-collapse:collapse; }
    .mat-table th { padding:12px 16px;text-align:left;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;background:#f8fafc; }
    .mat-table td { padding:14px 16px;border-top:1px solid #f1f5f9;font-size:14px; }
    .badge { font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px; }
    .badge-green { background:#dcfce7;color:#166534; }
    .badge-yellow { background:#fef3c7;color:#92400e; }
    .badge-gray { background:#f1f5f9;color:#64748b; }
    .modal-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff;border-radius:8px;width:100%;max-width:540px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2); }
    .modal-head { background:linear-gradient(135deg,#1a3d2b,#0a1f1a);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;border-radius:8px 8px 0 0; }
    .modal-body { padding:24px;display:flex;flex-direction:column;gap:16px; }
    .campo label { display:block;font-size:12px;font-weight:600;color:#374151;margin-bottom:5px; }
    .campo input,.campo textarea { width:100%;border:1px solid #e2e8f0;border-radius:6px;padding:9px 12px;font-size:13px;color:#0f172a;box-sizing:border-box; }
    .chk-row { display:flex;align-items:center;gap:10px;padding:12px;background:#f8fafc;border-radius:6px;border:1px solid #e2e8f0; }
    .chk-row input { width:18px;height:18px;cursor:pointer;flex-shrink:0; }
    .chk-row label { font-size:14px;color:#374151;cursor:pointer;font-weight:500; }
    .modal-foot { display:flex;gap:10px;justify-content:flex-end;padding-top:8px; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'materiais' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Materiais de Estudo</h1>
      <div class="topbar-acoes">
        <button id="btn-novo-material" class="btn btn-primario btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Novo Material
        </button>
      </div>
    </div>
    <div class="content">

      <% if(locals.msg && msg.length){ %><div class="alert alert-success" style="margin-bottom:16px"><%= msg[0] %></div><% } %>
      <% if(locals.erro && erro.length){ %><div class="alert alert-danger" style="margin-bottom:16px"><%= erro[0] %></div><% } %>

      <p style="font-size:13px;color:#64748b;margin-bottom:20px">Gerencie os materiais disponíveis no portal do membro. Controle quais arquivos podem ser baixados.</p>

      <div style="background:white;border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden">
        <% if(materiais.length === 0){ %>
        <div style="padding:48px;text-align:center;color:#94a3b8">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 12px;display:block;opacity:.3"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="font-size:14px;font-weight:600">Nenhum material cadastrado</p>
          <p style="font-size:13px;margin-top:4px">Clique em "Novo Material" para adicionar</p>
        </div>
        <% } else { %>
        <table class="mat-table">
          <thead><tr>
            <th>Material</th>
            <th>Categoria</th>
            <th style="text-align:center">Download</th>
            <th style="text-align:center">Status</th>
            <th style="text-align:center">Acoes</th>
          </tr></thead>
          <tbody>
          <% materiais.forEach(function(m){ %>
          <tr>
            <td>
              <div style="font-weight:600;color:#0f172a"><%=m.titulo%></div>
              <% if(m.descricao){ %><div style="font-size:12px;color:#64748b;margin-top:2px"><%=m.descricao%></div><% } %>
              <% if(m.arquivo_nome){ %><div style="font-size:11px;color:#94a3b8;margin-top:2px"><%=m.arquivo_nome%></div><% } %>
            </td>
            <td style="color:#475569"><%=m.categoria||'—'%></td>
            <td style="text-align:center">
              <span class="badge <%=m.permite_download?'badge-green':'badge-yellow'%>"><%=m.permite_download?'Permitido':'Bloqueado'%></span>
            </td>
            <td style="text-align:center">
              <span class="badge <%=m.ativo?'badge-green':'badge-gray'%>"><%=m.ativo?'Ativo':'Inativo'%></span>
            </td>
            <td>
              <div style="display:flex;gap:6px;justify-content:center">
                <% if(m.arquivo_chave){ %>
                <a href="/materiais/<%=m.id%>/arquivo-admin" target="_blank" class="btn" style="font-size:11px;padding:5px 10px">Ver</a>
                <% } %>
                <button class="btn btn-editar-mat"
                  data-id="<%=m.id%>"
                  data-titulo="<%=(m.titulo||'').replace(/\"/g,'&quot;')%>"
                  data-descricao="<%=(m.descricao||'').replace(/\"/g,'&quot;')%>"
                  data-categoria="<%=(m.categoria||'').replace(/\"/g,'&quot;')%>"
                  data-ordem="<%=m.ordem||0%>"
                  data-download="<%=m.permite_download?'1':'0'%>"
                  data-ativo="<%=m.ativo?'1':'0'%>"
                  style="font-size:11px;padding:5px 10px">Editar</button>
                <form method="POST" action="/materiais/<%=m.id%>/excluir" style="margin:0" onsubmit="return confirm('Excluir este material?')">
                  <button type="submit" style="font-size:11px;padding:5px 10px;background:#fee2e2;color:#dc2626;border:none;border-radius:4px;cursor:pointer">Excluir</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </main>
</div>

<!-- Modal Novo -->
<div class="modal-overlay" id="modal-novo">
  <div class="modal-box">
    <div class="modal-head">
      <span style="color:#fff;font-weight:700;font-size:16px">Novo Material</span>
      <button id="btn-fechar-novo" style="background:rgba(255,255,255,.2);border:none;color:#fff;width:28px;height:28px;cursor:pointer;font-size:20px;border-radius:4px">&times;</button>
    </div>
    <form method="POST" action="/materiais/criar" enctype="multipart/form-data" class="modal-body">
      <div class="campo"><label>Titulo *</label><input name="titulo" required placeholder="Ex: Apostila de Urologia Basica"></div>
      <div class="campo"><label>Descricao</label><textarea name="descricao" rows="2" placeholder="Descricao breve..."></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="campo"><label>Categoria</label><input name="categoria" placeholder="Ex: Urologia, Anatomia..."></div>
        <div class="campo"><label>Ordem</label><input name="ordem" type="number" value="0" min="0"></div>
      </div>
      <div class="campo"><label>Arquivo (PDF, DOC, PPT, MP4, imagem...)</label><input name="arquivo" type="file" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.mp4,.avi,.mov,.jpg,.jpeg,.png,.gif"></div>
      <div class="chk-row">
        <input type="checkbox" name="permite_download" value="1" id="chk-download">
        <label for="chk-download">Permitir download pelos membros</label>
      </div>
      <div class="modal-foot">
        <button type="button" id="btn-cancelar-novo" class="btn">Cancelar</button>
        <button type="submit" class="btn btn-primario">Salvar Material</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal Editar -->
<div class="modal-overlay" id="modal-editar">
  <div class="modal-box">
    <div class="modal-head">
      <span style="color:#fff;font-weight:700;font-size:16px">Editar Material</span>
      <button id="btn-fechar-editar" style="background:rgba(255,255,255,.2);border:none;color:#fff;width:28px;height:28px;cursor:pointer;font-size:20px;border-radius:4px">&times;</button>
    </div>
    <form method="POST" id="form-editar" action="" class="modal-body">
      <div class="campo"><label>Titulo *</label><input name="titulo" id="e-titulo" required></div>
      <div class="campo"><label>Descricao</label><textarea name="descricao" id="e-descricao" rows="2"></textarea></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="campo"><label>Categoria</label><input name="categoria" id="e-categoria"></div>
        <div class="campo"><label>Ordem</label><input name="ordem" id="e-ordem" type="number" min="0"></div>
      </div>
      <div style="display:flex;gap:12px">
        <div class="chk-row" style="flex:1"><input type="checkbox" name="permite_download" value="1" id="e-download"><label for="e-download">Permitir download</label></div>
        <div class="chk-row" style="flex:1"><input type="checkbox" name="ativo" value="1" id="e-ativo"><label for="e-ativo">Material ativo</label></div>
      </div>
      <div class="modal-foot">
        <button type="button" id="btn-cancelar-editar" class="btn">Cancelar</button>
        <button type="submit" class="btn btn-primario">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
document.getElementById('btn-novo-material').addEventListener('click',function(){ document.getElementById('modal-novo').classList.add('open'); });
document.getElementById('btn-fechar-novo').addEventListener('click',function(){ document.getElementById('modal-novo').classList.remove('open'); });
document.getElementById('btn-cancelar-novo').addEventListener('click',function(){ document.getElementById('modal-novo').classList.remove('open'); });
document.getElementById('btn-fechar-editar').addEventListener('click',function(){ document.getElementById('modal-editar').classList.remove('open'); });
document.getElementById('btn-cancelar-editar').addEventListener('click',function(){ document.getElementById('modal-editar').classList.remove('open'); });
document.querySelectorAll('.btn-editar-mat').forEach(function(btn){
  btn.addEventListener('click',function(){
    var d=this.dataset;
    document.getElementById('form-editar').action='/materiais/'+d.id+'/editar';
    document.getElementById('e-titulo').value=d.titulo;
    document.getElementById('e-descricao').value=d.descricao;
    document.getElementById('e-categoria').value=d.categoria;
    document.getElementById('e-ordem').value=d.ordem;
    document.getElementById('e-download').checked=d.download==='1';
    document.getElementById('e-ativo').checked=d.ativo==='1';
    document.getElementById('modal-editar').classList.add('open');
  });
});
</script>
</body>
</html>
