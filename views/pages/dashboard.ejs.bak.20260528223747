<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — <%= config.org_nome || 'Liga Urologia' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --cor: <%= config.org_cor || '#2b6803' %>;
      --cor2: <%= config.org_cor || '#2b6803' %>dd;
      --verde: #10b981; --verde-l: #10b98118;
      --amarelo: #f59e0b; --amarelo-l: #f59e0b18;
      --vermelho: #ef4444; --vermelho-l: #ef444418;
      --roxo: #8b5cf6; --roxo-l: #8b5cf618;
      --azul: #3b82f6; --azul-l: #3b82f618;
    }
    * { font-family: 'Plus Jakarta Sans', sans-serif; }

    /* HERO */
    .hero {
      background: linear-gradient(135deg, #0a1628 0%, #0d2137 40%, #0f3d1a 100%);
      border-radius: 20px;
      padding: 32px 36px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      position: relative;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 320px; height: 320px;
      background: radial-gradient(circle, var(--cor)44, transparent 70%);
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -60px; left: 20%;
      width: 200px; height: 200px;
      background: radial-gradient(circle, #3b82f622, transparent 70%);
      pointer-events: none;
    }
    .hero-left { position: relative; z-index: 1; }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.15);
      color: rgba(255,255,255,.8);
      font-size: 11px; font-weight: 600;
      padding: 4px 12px; border-radius: 20px;
      margin-bottom: 12px; letter-spacing: .4px; text-transform: uppercase;
    }
    .hero h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 28px; font-weight: 800;
      color: white; margin: 0 0 6px;
      letter-spacing: -.03em;
    }
    .hero p { color: rgba(255,255,255,.6); font-size: 14px; margin: 0; }
    .hero-actions { display: flex; gap: 10px; align-items: center; position: relative; z-index: 1; flex-wrap: wrap; }
    .btn-ghost {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.15);
      color: white; padding: 10px 18px;
      border-radius: 12px; cursor: pointer;
      font-size: 13px; font-weight: 600;
      display: flex; align-items: center; gap: 6px;
      transition: all .2s; text-decoration: none;
      font-family: inherit;
    }
    .btn-ghost:hover { background: rgba(255,255,255,.16); transform: translateY(-1px); }
    .btn-white {
      background: white; color: #0a1628;
      border: none; padding: 10px 20px;
      border-radius: 12px; cursor: pointer;
      font-size: 13px; font-weight: 700;
      text-decoration: none; display: flex; align-items: center; gap: 6px;
      transition: all .2s;
      box-shadow: 0 4px 16px rgba(0,0,0,.15);
      font-family: inherit;
    }
    .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.2); }

    /* STATS */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px; margin-bottom: 24px;
    }
    .stat-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 16px; padding: 22px 20px;
      position: relative; overflow: hidden;
      transition: transform .2s, box-shadow .2s;
      cursor: default;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,.08); }
    .stat-card .glow {
      position: absolute; top: -30px; right: -30px;
      width: 100px; height: 100px; border-radius: 50%;
      opacity: .12; pointer-events: none;
    }
    .stat-card.azul .glow { background: var(--cor); }
    .stat-card.verde .glow { background: var(--verde); }
    .stat-card.amarelo .glow { background: var(--amarelo); }
    .stat-card.verm .glow { background: var(--vermelho); }
    .stat-icon {
      width: 46px; height: 46px; border-radius: 13px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: 16px;
    }
    .azul .stat-icon { background: var(--azul-l); }
    .verde .stat-icon { background: var(--verde-l); }
    .amarelo .stat-icon { background: var(--amarelo-l); }
    .verm .stat-icon { background: var(--vermelho-l); }
    .stat-lbl {
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .8px;
      color: var(--texto2); margin-bottom: 6px;
    }
    .stat-val {
      font-family: 'Outfit', sans-serif;
      font-size: 34px; font-weight: 800;
      line-height: 1; letter-spacing: -.03em; margin-bottom: 6px;
    }
    .azul .stat-val { color: var(--cor); }
    .verde .stat-val { color: var(--verde); }
    .amarelo .stat-val { color: var(--amarelo); }
    .verm .stat-val { color: var(--vermelho); }
    .stat-sub { font-size: 12px; color: var(--texto2); font-weight: 500; }

    /* QUICK ACCESS */
    .quick-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 12px; margin-bottom: 24px;
    }
    .quick-card {
      background: var(--card); border: 1px solid var(--borda);
      border-radius: 14px; padding: 18px 12px;
      text-align: center; text-decoration: none;
      transition: all .2s;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    .quick-card:hover {
      transform: translateY(-3px);
      border-color: var(--cor);
      box-shadow: 0 8px 24px rgba(0,0,0,.08);
    }
    .quick-icon {
      width: 46px; height: 46px; border-radius: 13px;
      display: grid; place-items: center; font-size: 22px;
      transition: transform .2s;
    }
    .quick-card:hover .quick-icon { transform: scale(1.1); }
    .q0 .quick-icon { background: linear-gradient(135deg, var(--cor)22, var(--cor)11); }
    .q1 .quick-icon { background: linear-gradient(135deg, #06b6d422, #06b6d411); }
    .q2 .quick-icon { background: linear-gradient(135deg, var(--verde-l), var(--verde-l)); }
    .q3 .quick-icon { background: linear-gradient(135deg, var(--amarelo-l), var(--amarelo-l)); }
    .q4 .quick-icon { background: linear-gradient(135deg, var(--roxo-l), var(--roxo-l)); }
    .q5 .quick-icon { background: linear-gradient(135deg, #ec489922, #ec489911); }
    .quick-lbl { font-size: 12px; font-weight: 700; color: var(--texto); }

    /* BOTTOM GRID */
    .bottom-grid { display: grid; grid-template-columns: 1.7fr 1fr; gap: 18px; margin-bottom: 24px; }

    /* CARD */
    .card { background: var(--card); border: 1px solid var(--borda); border-radius: 16px; overflow: hidden; }
    .card-head {
      padding: 18px 20px;
      border-bottom: 1px solid var(--borda);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-title { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; color: var(--texto); display: flex; align-items: center; gap: 8px; }
    .card-link { font-size: 12px; color: var(--cor); text-decoration: none; font-weight: 700; }
    .card-link:hover { text-decoration: underline; }

    /* PROGRESS */
    .prog-wrap { padding: 16px 20px; border-bottom: 1px solid var(--borda); }
    .prog-top { display: flex; justify-content: space-between; font-size: 12px; color: var(--texto2); margin-bottom: 8px; font-weight: 500; }
    .prog-pct { font-weight: 800; color: var(--verde); font-size: 14px; }
    .prog-bar { height: 8px; background: var(--borda); border-radius: 10px; overflow: hidden; }
    .prog-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, var(--verde), #34d399); transition: width .8s cubic-bezier(.4,0,.2,1); }

    /* COBRANÇA TABLE */
    .cob-table { width: 100%; border-collapse: collapse; }
    .cob-table thead th {
      padding: 10px 16px; font-size: 10.5px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .8px;
      color: var(--texto2); background: var(--fundo); text-align: left;
    }
    .cob-table tbody tr { border-bottom: 1px solid var(--borda); transition: background .15s; }
    .cob-table tbody tr:hover { background: var(--fundo); }
    .cob-table tbody tr:last-child { border-bottom: none; }
    .cob-table tbody td { padding: 11px 16px; font-size: 13px; }
    .mem-cell { display: flex; align-items: center; gap: 10px; }
    .mem-av {
      width: 34px; height: 34px; border-radius: 10px;
      background: linear-gradient(135deg, var(--cor), #166534);
      color: white; font-size: 11px; font-weight: 800;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .mem-nome { font-weight: 700; font-size: 13px; }
    .mem-ref { font-size: 11px; color: var(--texto2); margin-top: 1px; }
    .badge {
      padding: 3px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 700; display: inline-flex; align-items: center; gap: 4px;
    }
    .badge.pago { background: var(--verde-l); color: var(--verde); }
    .badge.pendente { background: var(--amarelo-l); color: var(--amarelo); }
    .badge.atrasado { background: var(--vermelho-l); color: var(--vermelho); }
    .venc-txt { font-size: 12px; color: var(--texto2); }
    .venc-txt.atrasado { color: var(--vermelho); font-weight: 600; }

    /* ANIVERSÁRIOS */
    .aniv-list { padding: 0; }
    .aniv-item {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 20px; border-bottom: 1px solid var(--borda);
      transition: background .15s; position: relative;
    }
    .aniv-item:hover { background: var(--fundo); }
    .aniv-item:last-child { border-bottom: none; }
    .aniv-foto {
      width: 44px; height: 44px; border-radius: 13px;
      overflow: hidden; flex-shrink: 0; position: relative;
    }
    .aniv-foto img { width: 100%; height: 100%; object-fit: cover; }
    .aniv-foto .no-foto {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, var(--amarelo), #ef4444);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .aniv-foto.hoje-foto { box-shadow: 0 0 0 3px var(--verde); animation: pulso 2s infinite; }
    @keyframes pulso {
      0%,100% { box-shadow: 0 0 0 3px var(--verde)88; }
      50% { box-shadow: 0 0 0 6px var(--verde)22; }
    }
    .aniv-info { flex: 1; min-width: 0; }
    .aniv-nome { font-weight: 700; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .aniv-data { font-size: 12px; color: var(--texto2); margin-top: 2px; }
    .aniv-tipo { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; color: var(--cor); }
    .badge-hoje {
      background: linear-gradient(135deg, var(--verde), var(--cor));
      color: white; padding: 4px 10px; border-radius: 20px;
      font-size: 11px; font-weight: 700; white-space: nowrap;
      animation: pisca 1.5s infinite;
    }
    @keyframes pisca { 0%,100%{opacity:1} 50%{opacity:.7} }
    .vazio { padding: 48px 20px; text-align: center; color: var(--texto2); font-size: 13px; }
    .vazio-icon { font-size: 36px; margin-bottom: 8px; }

    /* EVENTOS PROXIMOS */
    .ev-item {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 20px; border-bottom: 1px solid var(--borda);
      transition: background .15s;
    }
    .ev-item:hover { background: var(--fundo); }
    .ev-item:last-child { border-bottom: none; }
    .ev-data-box {
      width: 46px; height: 46px; border-radius: 12px;
      background: linear-gradient(135deg, var(--cor)22, var(--cor)11);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      flex-shrink: 0; border: 1px solid var(--cor)33;
    }
    .ev-dia { font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 800; color: var(--cor); line-height: 1; }
    .ev-mes { font-size: 10px; font-weight: 700; color: var(--cor); text-transform: uppercase; letter-spacing: .4px; }
    .ev-info { flex: 1; min-width: 0; }
    .ev-nome { font-weight: 700; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ev-local { font-size: 12px; color: var(--texto2); margin-top: 2px; }
    .ev-badge { font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 20px; background: var(--cor)18; color: var(--cor); white-space: nowrap; }

    @media(max-width:1100px) { .stats-grid{grid-template-columns:repeat(2,1fr);} .quick-grid{grid-template-columns:repeat(3,1fr);} .bottom-grid{grid-template-columns:1fr;} }
    @media(max-width:600px) { .stats-grid{grid-template-columns:1fr 1fr;} .quick-grid{grid-template-columns:repeat(2,1fr);} }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'dashboard' }) %>
  <main class="main">
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- HERO -->
      <div class="hero">
        <div class="hero-left">
          <div class="hero-tag">🏥 Painel de Controle</div>
          <h1>Olá, <%= usuario.nome.split(' ')[0] %>! 👋</h1>
          <p><%= config.org_nome || 'Liga Acadêmica de Urologia' %> — <%= new Date(new Date().toLocaleString('en-US',{timeZone:'America/Asuncion'})).toLocaleDateString('pt-BR', {weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></p>
        </div>
        <div class="hero-actions">
          <button onclick="abrirPerfil()" class="btn-ghost">👤 Meu Perfil</button>
          <a href="/cobrancas" class="btn-white">⚡ Gerar Cobranças</a>
        </div>
      </div>

      <!-- STATS -->
      <div class="stats-grid">
        <div class="stat-card azul">
          <div class="glow"></div>
          <div class="stat-icon">👥</div>
          <div class="stat-lbl">Total de Membros</div>
          <div class="stat-val"><%= stats.total %></div>
          <div class="stat-sub">membros ativos</div>
        </div>
        <div class="stat-card verde">
          <div class="glow"></div>
          <div class="stat-icon">✅</div>
          <div class="stat-lbl">Pagamentos em Dia</div>
          <div class="stat-val"><%= stats.pagos %></div>
          <div class="stat-sub">R$ <%= Number(stats.totalRecebido).toLocaleString('pt-BR',{minimumFractionDigits:2}) %> recebido</div>
        </div>
        <div class="stat-card amarelo">
          <div class="glow"></div>
          <div class="stat-icon">⏳</div>
          <div class="stat-lbl">Pendentes</div>
          <div class="stat-val"><%= stats.pendentes %></div>
          <div class="stat-sub">R$ <%= Number(stats.totalPendente).toLocaleString('pt-BR',{minimumFractionDigits:2}) %> a receber</div>
        </div>
        <div class="stat-card verm">
          <div class="glow"></div>
          <div class="stat-icon">⚠️</div>
          <div class="stat-lbl">Em Atraso</div>
          <div class="stat-val"><%= stats.atrasados %></div>
          <div class="stat-sub">R$ <%= Number(stats.totalAtrasado).toLocaleString('pt-BR',{minimumFractionDigits:2}) %> inadimplente</div>
        </div>
      </div>

      <!-- ACESSO RÁPIDO -->
      <div class="quick-grid">
        <a href="/ligantes" class="quick-card q0"><div class="quick-icon">🎓</div><div class="quick-lbl">Ligantes</div></a>
        <a href="/frequencia" class="quick-card q1"><div class="quick-icon">📋</div><div class="quick-lbl">Frequência</div></a>
        <a href="/eventos" class="quick-card q2"><div class="quick-icon">🎟️</div><div class="quick-lbl">Eventos</div></a>
        <a href="/cobrancas" class="quick-card q3"><div class="quick-icon">💰</div><div class="quick-lbl">Cobranças</div></a>
        <a href="/marketing" class="quick-card q4"><div class="quick-icon">📣</div><div class="quick-lbl">Marketing</div></a>
        <a href="/aniversarios" class="quick-card q5"><div class="quick-icon">🎂</div><div class="quick-lbl">Aniversários</div></a>
      </div>

      <!-- BOTTOM GRID -->
      <div class="bottom-grid">

        <!-- COBRANÇAS -->
        <div class="card">
          <div class="card-head">
            <div class="card-title">📋 Cobranças Recentes</div>
            <a href="/cobrancas" class="card-link">Ver todas →</a>
          </div>
          <% const totalM = Number(stats.total)||1; const pagosN = Number(stats.pagos)||0; const pct = Math.round((pagosN/totalM)*100); %>
          <div class="prog-wrap">
            <div class="prog-top">
              <span>Taxa de pagamento este mês</span>
              <span class="prog-pct"><%= pct %>%</span>
            </div>
            <div class="prog-bar"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
          </div>
          <% if (recentes.length === 0) { %>
            <div class="vazio"><div class="vazio-icon">📭</div>Nenhuma cobrança ainda</div>
          <% } else { %>
          <table class="cob-table">
            <thead><tr><th>Membro</th><th>Vencimento</th><th>Valor</th><th>Status</th></tr></thead>
            <tbody>
              <% recentes.forEach(c => {
                const venc = new Date(c.data_vencimento + 'T12:00:00');
                const hoje = new Date();
                const atras = c.status === 'atrasado';
              %>
              <tr>
                <td>
                  <div class="mem-cell">
                    <div class="mem-av"><%= c.nome.substring(0,2).toUpperCase() %></div>
                    <div>
                      <div class="mem-nome"><%= c.nome.split(' ').slice(0,2).join(' ') %></div>
                      <div class="mem-ref"><%= c.referencia %></div>
                    </div>
                  </div>
                </td>
                <td><span class="venc-txt <%= atras ? 'atrasado' : '' %>"><%= venc.toLocaleDateString('pt-BR') %></span></td>
                <td style="font-weight:700;font-size:13px">R$ <%= Number(c.valor_desconto||c.valor_cheio||0).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></td>
                <td>
                  <% if(c.status==='pago'){ %><span class="badge pago">✅ Pago</span>
                  <% } else if(c.status==='atrasado'){ %><span class="badge atrasado">⚠️ Atrasado</span>
                  <% } else { %><span class="badge pendente">⏳ Pendente</span><% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>

        <!-- ANIVERSÁRIOS -->
        <div class="card">
          <div class="card-head">
            <div class="card-title">🎂 Próximos Aniversários</div>
            <a href="/aniversarios" class="card-link">Ver todos →</a>
          </div>
          <div class="aniv-list">
            <% if (aniversariantes.length === 0) { %>
              <div class="vazio"><div class="vazio-icon">🎈</div>Nenhum aniversariante cadastrado</div>
            <% } %>
            <% aniversariantes.forEach(m => {
              const hoje_md = new Date(new Date().toLocaleString('en-US',{timeZone:'America/Asuncion'})).toLocaleDateString('pt-BR',{month:'2-digit',day:'2-digit'}).split('/').reverse().join('-');
              const md = m.data_nascimento ? m.data_nascimento.substring(5) : '';
              const isHoje = md === hoje_md;
              const dataFmt = new Date(m.data_nascimento + 'T12:00:00').toLocaleDateString('pt-BR',{day:'numeric',month:'long'});
              const fotoUrl = m.foto_chave ? '/' + (m.tipo==='diretivo'?'diretivos':'ligantes') + '/' + m.id + '/foto' : null;
            %>
            <div class="aniv-item">
              <div class="aniv-foto <%= isHoje ? 'hoje-foto' : '' %>">
                <% if(fotoUrl){ %>
                  <img src="<%= fotoUrl %>" alt="<%= m.nome %>">
                <% } else { %>
                  <div class="no-foto">🎂</div>
                <% } %>
              </div>
              <div class="aniv-info">
                <div class="aniv-nome"><%= m.nome.split(' ').slice(0,3).join(' ') %></div>
                <div class="aniv-data"><%= dataFmt %></div>
                <div class="aniv-tipo"><%= m.tipo === 'diretivo' ? '⭐ Diretivo' : '🎓 Ligante' %></div>
              </div>
              <% if(isHoje){ %><span class="badge-hoje">🎉 Hoje!</span><% } %>
            </div>
            <% }) %>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>

<!-- MODAL PERFIL -->
<div id="modalPerfil" class="modal-overlay" style="display:none">
  <div class="modal" style="max-width:480px">
    <div class="modal-header">
      <div class="modal-titulo">👤 Meu Perfil</div>
      <button onclick="fecharPerfil()" style="background:none;border:none;font-size:20px;cursor:pointer;color:#666">✕</button>
    </div>
    <div class="info-box" style="margin-bottom:20px">
      <strong>Usuário:</strong> <%= usuario.nome %><br>
      <strong>E-mail:</strong> <%= usuario.email %><br>
      <strong>Perfil:</strong> <span style="text-transform:capitalize"><%= usuario.perfil %></span>
    </div>
    <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--borda)">
      <button onclick="mostrarTab('senha')" id="tab-senha" style="padding:8px 16px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:600;color:var(--cor);border-bottom:2px solid var(--cor);font-family:inherit">🔒 Alterar Senha</button>
      <button onclick="mostrarTab('email')" id="tab-email" style="padding:8px 16px;border:none;background:none;cursor:pointer;font-size:13px;font-weight:500;color:var(--texto2);border-bottom:2px solid transparent;font-family:inherit">📧 Alterar E-mail</button>
    </div>
    <div id="form-senha">
      <form action="/minha-senha" method="POST">
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="campo"><label class="label">Senha atual</label><input type="password" name="senha_atual" class="input" required placeholder="Digite sua senha atual"></div>
          <div class="campo"><label class="label">Nova senha</label><input type="password" name="nova_senha" class="input" required placeholder="Mínimo 8 caracteres" minlength="8"></div>
          <div class="campo"><label class="label">Confirmar nova senha</label><input type="password" name="confirmar_senha" class="input" required placeholder="Repita a nova senha"></div>
          <button type="submit" class="btn btn-primario" style="width:100%;justify-content:center">🔒 Alterar senha</button>
        </div>
      </form>
    </div>
    <div id="form-email" style="display:none">
      <form action="/meu-email" method="POST">
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="campo"><label class="label">Novo e-mail</label><input type="email" name="novo_email" class="input" required placeholder="novo@email.com"></div>
          <div class="campo"><label class="label">Confirme sua senha</label><input type="password" name="senha_confirmacao" class="input" required placeholder="Digite sua senha para confirmar"></div>
          <button type="submit" class="btn btn-primario" style="width:100%;justify-content:center">📧 Alterar e-mail</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
// Animar barra de progresso
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('progFill').style.width = '<%= pct %>%';
  }, 300);
});
function abrirPerfil() { document.getElementById('modalPerfil').style.display = 'flex'; }
function fecharPerfil() { document.getElementById('modalPerfil').style.display = 'none'; }
function mostrarTab(tab) {
  document.getElementById('form-senha').style.display = tab === 'senha' ? 'block' : 'none';
  document.getElementById('form-email').style.display = tab === 'email' ? 'block' : 'none';
  document.getElementById('tab-senha').style.color = tab === 'senha' ? 'var(--cor)' : 'var(--texto2)';
  document.getElementById('tab-senha').style.borderBottomColor = tab === 'senha' ? 'var(--cor)' : 'transparent';
  document.getElementById('tab-email').style.color = tab === 'email' ? 'var(--cor)' : 'var(--texto2)';
  document.getElementById('tab-email').style.borderBottomColor = tab === 'email' ? 'var(--cor)' : 'transparent';
}
document.getElementById('modalPerfil').addEventListener('click', function(e) { if(e.target===this) fecharPerfil(); });
<% if (erro && erro.length > 0) { %>window.addEventListener('load', () => abrirPerfil());<% } %>
</script>
</body>
</html>
