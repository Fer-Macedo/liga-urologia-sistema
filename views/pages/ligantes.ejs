<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }
    .stats-row { display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px; }
    .stat-mini { background:var(--card);border:1.5px solid var(--borda);border-radius:12px;padding:14px 18px;text-align:center; }
    .stat-mini .num { font-size:28px;font-weight:700; }
    .stat-mini .lab { font-size:12px;color:var(--texto2);margin-top:2px; }
    .filtros-row { display:flex;gap:10px;align-items:center;margin-bottom:16px;flex-wrap:wrap; }
    .ligantes-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px; }
    .ligante-card { background:var(--card);border:1.5px solid var(--borda);border-radius:12px;padding:16px;transition:all 0.15s;cursor:pointer;position:relative; }
    .ligante-card:hover { border-color:var(--cor-primaria);box-shadow:0 4px 16px rgba(0,0,0,0.08);transform:translateY(-1px); }
    .ligante-card.inativo { opacity:0.6;border-style:dashed; }
    .ligante-foto { width:48px;height:48px;border-radius:50%;background:var(--fundo);border:2px solid var(--borda);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0; }
    .ligante-foto img { width:48px;height:48px;border-radius:50%;object-fit:cover; }
    .ligante-header { display:flex;gap:12px;align-items:center;margin-bottom:10px; }
    .ligante-nome { font-size:14px;font-weight:700;line-height:1.3; }
    .ligante-sub { font-size:11px;color:var(--texto2);margin-top:2px; }
    .ligante-info-grid { display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:11px; }
    .ligante-info-item { display:flex;flex-direction:column;gap:1px; }
    .info-label { color:var(--texto2);font-weight:600;text-transform:uppercase;font-size:10px;letter-spacing:0.3px; }
    .info-valor { color:var(--texto);font-weight:500; }
    .badge-status { position:absolute;top:10px;right:10px;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700; }
    .badge-ativo { background:#dcfce7;color:#166534; }
    .badge-inativo { background:#fee2e2;color:#991b1b; }
    .card-acoes { display:flex;gap:6px;margin-top:10px;padding-top:10px;border-top:1px solid var(--borda); }

    /* Modal detalhes/edição */
    .modal-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center; }
    .modal-overlay.aberto { display:flex; }
    .modal-grande { background:var(--card);border-radius:16px;padding:28px;max-width:700px;width:95%;max-height:90vh;overflow-y:auto; }
    .modal-tabs { display:flex;gap:0;margin-bottom:20px;border-bottom:1.5px solid var(--borda); }
    .modal-tab { padding:8px 18px;font-size:13px;font-weight:600;cursor:pointer;color:var(--texto2);border-bottom:2.5px solid transparent;margin-bottom:-1.5px; }
    .modal-tab.ativo { color:var(--cor-primaria);border-color:var(--cor-primaria); }
    .tab-content { display:none; }
    .tab-content.ativo { display:block; }
    .form-grid-2 { display:grid;grid-template-columns:1fr 1fr;gap:12px; }
    .campo-full { grid-column:1/-1; }
    .detalhe-linha { display:flex;flex-direction:column;gap:2px;margin-bottom:12px; }
    .detalhe-label { font-size:11px;font-weight:700;color:var(--texto2);text-transform:uppercase; }
    .detalhe-valor { font-size:13px;color:var(--texto); }
    .sem-ligantes { text-align:center;padding:60px;color:var(--texto2);grid-column:1/-1; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'ligantes' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">🎓 Ligantes</h1>
      <div class="topbar-acoes">
        <a href="/ligantes/relatorio" class="btn">📊 Relatório</a>
        <a href="/cadastro-ligante" target="_blank" class="btn btn-primario">🔗 Link de Cadastro</a>
      </div>
    </div>
    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok">✅ <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro">❌ <%= erro[0] %></div><% } %>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-mini">
          <div class="num" style="color:var(--cor-primaria)"><%= total %></div>
          <div class="lab">Total de ligantes</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#16a34a"><%= ativos %></div>
          <div class="lab">Ativos</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#dc2626"><%= inativos %></div>
          <div class="lab">Inativos</div>
        </div>
      </div>

      <!-- Filtros -->
      <div class="filtros-row">
        <input type="text" id="busca-input" class="input" placeholder="🔍 Buscar por nome, email ou turma..." style="flex:1;max-width:400px" oninput="buscar(this.value)">
        <select class="input" id="filtro-status" style="width:160px" onchange="filtrarStatus(this.value)">
          <option value="todos">Todos</option>
          <option value="ativo">Somente ativos</option>
          <option value="inativo">Somente inativos</option>
        </select>
        <span id="contador" style="font-size:13px;color:var(--texto2)"><%= ligantes.length %> exibidos</span>
      </div>

      <!-- Grid de ligantes -->
      <div class="ligantes-grid" id="grid-ligantes">
        <% if (ligantes.length === 0) { %>
        <div class="sem-ligantes">
          <div style="font-size:48px;margin-bottom:12px">🎓</div>
          <div style="font-size:15px;font-weight:600">Nenhum ligante cadastrado</div>
          <a href="/cadastro-ligante" target="_blank" class="btn btn-primario" style="margin-top:16px;display:inline-block">🔗 Abrir formulário</a>
        </div>
        <% } %>
        <% ligantes.forEach(l => { %>
        <div class="ligante-card <%= l.ativo == 0 ? 'inativo' : '' %>"
          data-nome="<%= (l.nome||'').toLowerCase() %>"
          data-email="<%= (l.email||'').toLowerCase() %>"
          data-turma="<%= (l.turma||'').toLowerCase() %>"
          data-status="<%= l.ativo == 0 ? 'inativo' : 'ativo' %>"
          onclick="abrirDetalhe(<%= l.id %>)">
          <span class="badge-status <%= l.ativo == 0 ? 'badge-inativo' : 'badge-ativo' %>">
            <%= l.ativo == 0 ? 'Inativo' : 'Ativo' %>
          </span>
          <div class="ligante-header">
            <div class="ligante-foto">
              <% if (l.foto_chave) { %>
                <img src="/ligantes/<%= l.id %>/foto" alt="<%= l.nome %>">
              <% } else { %>👤<% } %>
            </div>
            <div>
              <div class="ligante-nome"><%= l.nome %></div>
              <div class="ligante-sub">📧 <%= l.email || '—' %></div>
              <div class="ligante-sub">📱 <%= l.whatsapp || '—' %></div>
            </div>
          </div>
          <div class="ligante-info-grid">
            <div class="ligante-info-item">
              <span class="info-label">Semestre</span>
              <span class="info-valor"><%= l.semestre || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Turma</span>
              <span class="info-valor"><%= l.turma || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">RG/CI</span>
              <span class="info-valor"><%= l.rg || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Catraca</span>
              <span class="info-valor"><%= l.catraca || '—' %></span>
            </div>
          </div>
          <div class="card-acoes" onclick="event.stopPropagation()">
            <button class="btn btn-primario" style="font-size:11px;padding:4px 10px" onclick="abrirDetalhe(<%= l.id %>)">👁 Ver detalhes</button>
            <a href="/ligantes/<%= l.id %>/editar" class="btn" style="font-size:11px;padding:4px 10px">✏️ Editar</a>
            <% if (usuario.perfil === 'admin') { %>
            <form action="/ligantes/<%= l.id %>/deletar" method="POST" onsubmit="return confirm('Excluir este ligante?')" style="display:inline">
              <button class="btn" style="font-size:11px;padding:4px 10px;color:var(--vermelho)">🗑</button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<!-- Modal detalhes -->
<div class="modal-overlay" id="modal-detalhe" onclick="fecharModalClick(event)">
  <div class="modal-grande">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <span style="font-size:16px;font-weight:700" id="modal-titulo">Detalhes do Ligante</span>
      <button onclick="document.getElementById('modal-detalhe').classList.remove('aberto')" style="background:none;border:none;font-size:22px;cursor:pointer">✕</button>
    </div>
    <div class="modal-tabs">
      <div class="modal-tab ativo" onclick="trocarTab('dados')">📋 Dados</div>
      <div class="modal-tab" onclick="trocarTab('perfil')">💡 Perfil</div>
    </div>
    <div id="tab-dados" class="tab-content ativo" id="detalhe-corpo"></div>
    <div id="tab-perfil" class="tab-content"></div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const ligantes = <%- JSON.stringify(ligantes) %>;

function buscar(termo) {
  const t = termo.toLowerCase().trim();
  let vis = 0;
  document.querySelectorAll('.ligante-card').forEach(c => {
    const match = !t || c.dataset.nome.includes(t) || c.dataset.email.includes(t) || c.dataset.turma.includes(t);
    const statusOk = checkStatus(c);
    c.style.display = (match && statusOk) ? '' : 'none';
    if (match && statusOk) vis++;
  });
  document.getElementById('contador').textContent = vis + ' exibidos';
}

function filtrarStatus(val) {
  let vis = 0;
  const busca = document.getElementById('busca-input').value.toLowerCase().trim();
  document.querySelectorAll('.ligante-card').forEach(c => {
    const statusOk = val === 'todos' || c.dataset.status === val;
    const buscaOk = !busca || c.dataset.nome.includes(busca) || c.dataset.email.includes(busca) || c.dataset.turma.includes(busca);
    c.style.display = (statusOk && buscaOk) ? '' : 'none';
    if (statusOk && buscaOk) vis++;
  });
  document.getElementById('contador').textContent = vis + ' exibidos';
}

function checkStatus(card) {
  const val = document.getElementById('filtro-status').value;
  return val === 'todos' || card.dataset.status === val;
}

function trocarTab(tab) {
  document.querySelectorAll('.modal-tab').forEach((t,i) => t.classList.toggle('ativo', (i===0&&tab==='dados')||(i===1&&tab==='perfil')));
  document.getElementById('tab-dados').classList.toggle('ativo', tab==='dados');
  document.getElementById('tab-perfil').classList.toggle('ativo', tab==='perfil');
}

function abrirDetalhe(id) {
  const l = ligantes.find(x => x.id === id);
  if (!l) return;
  document.getElementById('modal-titulo').textContent = l.nome;

  document.getElementById('tab-dados').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      ${campo('Nome completo', l.nome)}
      ${campo('E-mail', l.email)}
      ${campo('WhatsApp', l.whatsapp)}
      ${campo('Nascimento', l.data_nascimento ? new Date(l.data_nascimento).toLocaleDateString('pt-BR') : '—')}
      ${campo('Sexo', l.sexo)}
      ${campo('RG/CI/DNI', l.rg)}
      ${campo('CPF', l.cpf)}
      ${campo('Semestre', l.semestre)}
      ${campo('Turma', l.turma)}
      ${campo('Catraca', l.catraca)}
      ${campo('ORCID', l.orcid)}
      ${campo('Formação', l.tem_formacao === 'Sim' ? 'Sim — ' + (l.qual_formacao||'') : l.tem_formacao||'—')}
      ${campo('Status', l.ativo == 0 ? '🔴 Inativo' : '🟢 Ativo', true)}
      ${campo('Cadastrado em', new Date(l.criado_em).toLocaleString('pt-BR'), true)}
    </div>
    <div style="margin-top:16px;display:flex;gap:8px">
      <a href="/ligantes/${id}/editar" class="btn btn-primario">✏️ Editar dados</a>
      <form action="/ligantes/${id}/toggle" method="POST" style="display:inline">
        <button class="btn" style="color:${l.ativo==0?'#16a34a':'#dc2626'}">${l.ativo==0?'✅ Marcar como ativo':'⏸ Marcar como inativo'}</button>
      </form>
    </div>
  `;

  document.getElementById('tab-perfil').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:12px">
      ${campoFull('Habilidades', l.habilidades)}
      ${campoFull('Aceita cargo', l.aceita_cargo + (l.qual_cargo ? ' — ' + l.qual_cargo : ''))}
      ${campoFull('Contribuição em grupo', l.contribuicao_grupo)}
      ${campoFull('Ideia inovadora', l.ideia_inovadora)}
      ${campoFull('Tema de interesse', l.tema_interesse)}
      ${campoFull('Por que a LAURO?', l.porque_lauro)}
      ${campoFull('Apresentação', l.apresentacao)}
    </div>
  `;

  document.getElementById('modal-detalhe').classList.add('aberto');
  trocarTab('dados');
}

function campo(label, valor, full) {
  return `<div class="detalhe-linha ${full?'style="grid-column:1/-1"':''}">
    <span class="detalhe-label">${label}</span>
    <span class="detalhe-valor">${valor||'—'}</span>
  </div>`;
}

function campoFull(label, valor) {
  return `<div class="detalhe-linha">
    <span class="detalhe-label">${label}</span>
    <span class="detalhe-valor">${valor||'—'}</span>
  </div>`;
}

function fecharModalClick(e) {
  if (e.target === document.getElementById('modal-detalhe')) {
    document.getElementById('modal-detalhe').classList.remove('aberto');
  }
}
</script>
</body>
</html>
