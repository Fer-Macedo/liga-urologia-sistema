<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ligantes — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 20px;
    }
    .stat-mini {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 20px 22px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .stat-mini::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--cor-primaria), #06b6d4);
    }
    .stat-mini .num {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -.02em;
    }
    .stat-mini .lab {
      font-size: 12px;
      color: var(--texto2);
      margin-top: 4px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .filtros-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }

    .ligantes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 14px;
    }

    .ligante-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 18px;
      transition: all 0.18s ease;
      cursor: pointer;
      position: relative;
    }
    .ligante-card:hover {
      border-color: var(--cor-primaria);
      box-shadow: 0 6px 20px rgba(26,86,219,.10);
      transform: translateY(-2px);
    }
    .ligante-card.inativo {
      opacity: 0.6;
      border-style: dashed;
    }

    .ligante-foto {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: var(--fundo);
      border: 2px solid var(--borda);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
      overflow: hidden;
    }
    .ligante-foto img {
      width: 52px; height: 52px;
      border-radius: 12px;
      object-fit: cover;
    }
    .ligante-header {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    .ligante-nome {
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -.01em;
    }
    .ligante-sub {
      font-size: 11.5px;
      color: var(--texto2);
      margin-top: 2px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .ligante-info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 12px;
    }
    .ligante-info-item { display: flex; flex-direction: column; gap: 1px; }
    .info-label {
      color: var(--texto2);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 9.5px;
      letter-spacing: .06em;
    }
    .info-valor { color: var(--texto); font-weight: 600; font-size: 13px; }

    .badge-status {
      position: absolute;
      top: 12px; right: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 10.5px;
      font-weight: 700;
    }
    .badge-ativo { background: #dcfce7; color: #166534; }
    .badge-inativo { background: #fee2e2; color: #991b1b; }

    @keyframes piscar { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.7;transform:scale(1.05)} }
    .modal-titulo { font-family:'Plus Jakarta Sans','Outfit',sans-serif !important;font-weight:700 !important;font-size:18px !important; }
    .modal { font-family:'Plus Jakarta Sans','Outfit',sans-serif !important; }
    .card-acoes {
      display: flex;
      gap: 6px;
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid var(--borda);
      flex-wrap: wrap;
    }
    .card-acoes .btn {
      font-size: 12px !important;
      padding: 6px 12px !important;
    }
    .btn-icon-danger {
      padding: 6px 10px !important;
      background: transparent !important;
      border: 1px solid var(--borda) !important;
      border-radius: 9px !important;
      color: var(--vermelho, #ef4444) !important;
      cursor: pointer;
      transition: all .15s ease;
      font-size: 14px;
      line-height: 1;
    }
    .btn-icon-danger:hover {
      background: #fee2e2 !important;
      border-color: #fecaca !important;
    }

    .sem-ligantes {
      text-align: center;
      padding: 60px;
      color: var(--texto2);
      grid-column: 1/-1;
    }
    .sem-ligantes .icon {
      font-size: 48px;
      margin-bottom: 12px;
    }

    /* MODAL DETALHES */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.55); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(3px); }
    .modal-overlay.aberto { display: flex; }
    .modal-grande {
      background: var(--card);
      border-radius: 18px;
      padding: 28px;
      max-width: 680px;
      width: 95%;
      max-height: 88vh;
      overflow-y: auto;
      box-shadow: 0 24px 60px rgba(15,23,42,.18);
      animation: popIn .18s ease;
    }
    @keyframes popIn {
      from { opacity: 0; transform: scale(.96); }
      to   { opacity: 1; transform: scale(1); }
    }
    .modal-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 20px;
      border-bottom: 1.5px solid var(--borda);
    }
    .modal-tab {
      padding: 8px 18px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      color: var(--texto2);
      border-bottom: 2.5px solid transparent;
      margin-bottom: -1.5px;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      font-family: inherit;
      transition: all .15s;
    }
    .modal-tab.ativo { color: var(--cor-primaria); border-bottom-color: var(--cor-primaria); }
    .tab-content { display: none; }
    .tab-content.ativo { display: block; }
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .detalhe-linha { display: flex; flex-direction: column; gap: 2px; margin-bottom: 12px; }
    .detalhe-label { font-size: 10.5px; font-weight: 700; color: var(--texto2); text-transform: uppercase; letter-spacing: .06em; }
    .detalhe-valor { font-size: 13.5px; color: var(--texto); font-weight: 500; }
  
    /* === REDESIGN LIGANTES — foto como hero === */
    .stat-mini { border-radius:0!important; }
    .stat-mini::before { background:var(--cor-primaria)!important; }
    .ligante-card { border-radius:0!important; padding:0!important; overflow:hidden; transition:transform .15s ease, box-shadow .15s ease!important; }
    .ligante-card:hover { transform:translateY(-3px)!important; box-shadow:0 8px 28px rgba(0,0,0,.13)!important; border-color:transparent!important; }
    .ligante-foto-hero { height:195px; position:relative; overflow:hidden; background:linear-gradient(135deg,#1a3410,#253d18); flex-shrink:0; }
    .ligante-foto-hero img { width:100%; height:100%; object-fit:cover; object-position:top center; transition:transform .3s ease; display:block; }
    .ligante-card:hover .ligante-foto-hero img { transform:scale(1.05); }
    .ligante-foto-initials { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:56px; font-weight:800; color:rgba(255,255,255,.55); letter-spacing:-.02em; }
    .ligante-foto-overlay { position:absolute; bottom:0; left:0; right:0; padding:32px 14px 12px; background:linear-gradient(transparent,rgba(0,0,0,.75)); }
    .ligante-nome { font-size:15px; font-weight:700; color:#fff; line-height:1.2; letter-spacing:-.01em; text-shadow:0 1px 4px rgba(0,0,0,.4); }
    .ligante-sub-foto { font-size:11px; color:rgba(255,255,255,.7); margin-top:3px; }
    .badge-status { border-radius:0!important; top:10px!important; right:10px!important; font-size:10px!important; padding:3px 9px!important; }
    .ligante-body { padding:14px 16px 12px; }
    .ligante-sub-body { font-size:12px; color:var(--texto2); margin-bottom:10px; display:flex; align-items:center; gap:5px; }
    .ligante-info-grid { margin-bottom:10px!important; }
    .card-acoes { margin-top:8px!important; padding-top:10px!important; }
    .card-acoes .btn { border-radius:0!important; font-size:12px!important; padding:6px 12px!important; transition:transform .12s ease, box-shadow .12s ease!important; }
    .card-acoes .btn:hover { transform:translateY(-1px)!important; box-shadow:0 3px 8px rgba(0,0,0,.15)!important; }
    .btn-icon-danger { border-radius:0!important; }
    .modal-grande { border-radius:0!important; }
    .badge-pendente { background:#fef3c7; color:#92400e; border-radius:0!important; }

    .fil-btn { display:inline-flex; align-items:center; gap:5px; font-size:12px; font-weight:600; padding:7px 14px; border:1.5px solid var(--borda); background:#fff; color:var(--texto); text-decoration:none; transition:transform .12s ease, box-shadow .12s ease, background .12s ease, color .12s ease, border-color .12s ease; }
    .fil-btn:hover { background:#f0f7eb; border-color:#253d18; color:#253d18; transform:translateY(-1px); box-shadow:0 3px 8px rgba(37,61,24,.15); text-decoration:none; }
    .fil-btn.fil-ativo { background:linear-gradient(135deg,#1a3410,#253d18); color:#fff!important; border-color:transparent; box-shadow:0 2px 8px rgba(37,61,24,.25); }
    .fil-btn.fil-ativo:hover { opacity:.9; transform:translateY(-1px); box-shadow:0 4px 12px rgba(37,61,24,.35); }
    .fil-btn.fil-pendente { background:#f59e0b; color:#fff!important; border-color:transparent; animation:piscar 1.2s ease-in-out infinite; }
    .fil-btn.fil-pendente:hover { background:#d97706; animation:none; transform:translateY(-1px); }
    .fil-btn.fil-ok { background:#22c55e; color:#fff!important; border-color:#16a34a; }
    .fil-btn.fil-ok:hover { background:#16a34a; transform:translateY(-1px); }
    .pag-wrap { display:flex; gap:5px; align-items:center; justify-content:center; padding:24px 0 8px; flex-wrap:wrap; }
    .pag-btn { width:36px; height:36px; border:1.5px solid var(--borda); background:#fff; color:var(--texto); font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform .12s ease, background .12s ease, border-color .12s ease, color .12s ease, box-shadow .12s ease; }
    .pag-btn:hover:not(:disabled) { background:#f0f7eb; border-color:#253d18; color:#253d18; transform:translateY(-1px); box-shadow:0 3px 8px rgba(37,61,24,.15); }
    .pag-btn.pag-ativo { background:linear-gradient(135deg,#1a3410,#253d18); color:#fff; border-color:transparent; box-shadow:0 2px 8px rgba(37,61,24,.25); }
    .pag-btn.pn { width:auto; padding:0 14px; font-size:12px; gap:5px; }
    .pag-ellipsis { font-size:14px; color:var(--texto2); padding:0 2px; display:flex; align-items:center; height:36px; }
    .pag-info { font-size:12px; color:var(--texto2); padding:0 8px; white-space:nowrap; }

    .modal-grande { border-radius:0!important; }
    .modal-tab { border-radius:0!important; }
    .modal-tabs { border-radius:0!important; }
    .card-acoes .btn { border-radius:0!important; display:inline-flex!important; align-items:center!important; gap:5px!important; }
    .btn-icon-danger { border-radius:0!important; }

    /* Botoes com tracos retos + hover */
    .btn { border-radius:0!important; transition:transform .12s ease, box-shadow .12s ease, background .12s ease, opacity .12s ease, border-color .12s ease!important; }
    .btn:hover { transform:translateY(-2px)!important; box-shadow:0 4px 10px rgba(0,0,0,.15)!important; }
    .btn-primario:hover { box-shadow:0 4px 12px rgba(26,86,219,.3)!important; }
    .topbar-acoes .btn { display:inline-flex!important; align-items:center!important; gap:6px!important; }
</style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'ligantes' }) %>
  <main class="main">

    <div class="topbar">
      <h1 class="page-titulo"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg> Ligantes</h1>
      <div class="topbar-acoes">
        <a href="/ligantes/relatorio" class="btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Relatório</a>
        <a href="/cadastro-ligante" target="_blank" class="btn btn-primario"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>Link de Cadastro</a>
      </div>
    </div>

    <div class="content">
      <% if (msg && msg.length > 0) { %><div class="alerta alerta-ok"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> <%= msg[0] %></div><% } %>
      <% if (erro && erro.length > 0) { %><div class="alerta alerta-erro"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> <%= erro[0] %></div><% } %>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-mini">
          <div class="num" style="color:var(--cor-primaria)"><%= total %></div>
          <div class="lab">Total de ligantes</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#16a34a"><%= ativos %></div>
          <div class="lab">Ativos</div>
        </div>
        <div class="stat-mini">
          <div class="num" style="color:#dc2626"><%= inativos %></div>
          <div class="lab">Inativos</div>
        </div>
      </div>

      <!-- FILTROS -->
      <div class="filtros-row">
        <input type="text" id="busca-input" class="input"
          placeholder="Buscar por nome, email ou turma..."
          style="flex:1;max-width:380px"
          oninput="buscar(this.value)">
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <% const sf = typeof statusFiltro !== 'undefined' ? statusFiltro : 'ativos'; %>
          <a href="/ligantes?status=ativos" class="fil-btn <%= sf==='ativos'||!sf?'fil-ativo':'' %>">Ativos</a>
          <a href="/ligantes?status=inativos" class="fil-btn <%= sf==='inativos'?'fil-ativo':'' %>">Inativos</a>
          <% if(typeof pendentesCount!=='undefined'&&pendentesCount>0){ %>
          <a href="/ligantes?status=pendente" class="fil-btn fil-pendente"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg> Pendentes (<%= pendentesCount %>)</a>
          <% } else { %>
          <a href="/ligantes?status=pendente" class="fil-btn fil-ok"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Pendentes</a>
          <% } %>
          <a href="/ligantes?status=todos" class="fil-btn <%= sf==='todos'?'fil-ativo':'' %>">Todos</a>
        </div>
        <span id="contador" style="font-size:13px;color:var(--texto2);white-space:nowrap"><%= ligantes.length %> exibidos</span>
      </div>

      <!-- GRID -->
      <div class="ligantes-grid" id="grid-ligantes">
        <% if (ligantes.length === 0) { %>
          <div class="sem-ligantes">
            <div class="icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg></div>
            <div style="font-size:15px;font-weight:600;margin-bottom:8px">Nenhum ligante cadastrado</div>
            <a href="/cadastro-ligante" target="_blank" class="btn btn-primario"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Abrir formulário</a>
          </div>
        <% } %>

        <% ligantes.forEach(l => { %>
        <div class="ligante-card <%= l.ativo == 0 ? 'inativo' : '' %>"
          data-nome="<%= (l.nome||'').toLowerCase() %>"
          data-email="<%= (l.email||'').toLowerCase() %>"
          data-turma="<%= (l.turma||'').toLowerCase() %>"
          data-status="<%= l.ativo == 0 ? 'inativo' : 'ativo' %>"
          data-ligante-id="<%= l.id %>" class="btn-abrir-detalhe-card">

          <div class="ligante-foto-hero">
            <% if (l.foto_chave) { %>
              <img src="/ligantes/<%= l.id %>/foto" alt="<%= l.nome %>">
            <% } else { %>
              <div class="ligante-foto-initials"><%= (l.nome||'?').trim().split(/\s+/).filter(n=>n).map(n=>n[0]).join('').substring(0,2).toUpperCase() %></div>
            <% } %>
            <div class="ligante-foto-overlay">
              <div class="ligante-nome"><%= l.nome %></div>
              <% if(l.email){ %><div class="ligante-sub-foto"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg> <%= l.email %></div><% } %>
            </div>
            <span class="badge-status <%= l.ativo == 0 ? 'badge-inativo' : 'badge-ativo' %>"><%= l.ativo == 0 ? 'Inativo' : 'Ativo' %></span>
          </div>
          <div class="ligante-body">
            <% if(l.whatsapp){ %><div class="ligante-sub-body"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg> <%= l.whatsapp %></div><% } %>

          <div class="ligante-info-grid">
            <div class="ligante-info-item">
              <span class="info-label">Semestre</span>
              <span class="info-valor"><%= l.semestre || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Turma</span>
              <span class="info-valor"><%= l.turma || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">RG/CI</span>
              <span class="info-valor"><%= l.rg || '—' %></span>
            </div>
            <div class="ligante-info-item">
              <span class="info-label">Catraca</span>
              <span class="info-valor"><%= l.catraca || '—' %></span>
            </div>
          </div>

          <div class="card-acoes">
            <button class="btn btn-primario btn-abrir-detalhe-card" data-ligante-id="<%= l.id %>"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Detalhes</button>
            <a href="/ligantes/<%= l.id %>/editar" class="btn" style="display:inline-flex;align-items:center;gap:5px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Editar</a>
            <% if(typeof statusFiltro!=='undefined' && statusFiltro==='pendente' && l.pendente){ %>
            <button class="btn" style="background:#22c55e;color:white;border:none;font-weight:600;font-size:12px" onclick="if(confirm('Liberar este ligante?')) { const f=document.createElement('form');f.method='POST';f.action='/ligantes/<%= l.id %>/aprovar';document.body.append(f);f.submit(); }"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Liberar</button>
            <a href="/ligantes/<%= l.id %>/excluir-pendente" class="btn" style="background:#ef4444;color:white;border:none;font-weight:600;font-size:12px" onclick="return confirm('Recusar e excluir permanentemente?')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Recusar</a>
            <% } %>
            <% if (usuario.perfil === 'admin' && statusFiltro !== 'pendente') { %>
            <form action="/ligantes/<%= l.id %>/deletar" method="POST"
              onsubmit="return confirm('Excluir este ligante?')"
              style="display:inline;margin:0">
              <button type="submit" class="btn-icon-danger" style="display:inline-flex;align-items:center;justify-content:center"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
            </form>
            <% } %>
          </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<div class="pag-wrap" id="paginacao"></div>

<!-- MODAL DETALHES -->
<div class="modal-overlay" id="modal-detalhe" onclick="fecharModalClick(event)">
  <div class="modal-grande">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0;padding-bottom:14px;border-bottom:1.5px solid var(--borda);margin-bottom:16px">
      <span style="font-size:17px;font-weight:700;color:var(--texto)" id="modal-titulo">Detalhes</span>
      <button id="btn-fechar-modal-detalhe" style="background:#f1f5f9;border:none;width:30px;height:30px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--texto2)" onmouseover="this.style.background='#fee2e2';this.style.color='#dc2626'" onmouseout="this.style.background='#f1f5f9';this.style.color=''"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="modal-tabs">
      <button class="modal-tab ativo" onclick="trocarTab('dados', this)" style="display:inline-flex;align-items:center;gap:6px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>Dados</button>
      <button class="modal-tab" onclick="trocarTab('perfil', this)" style="display:inline-flex;align-items:center;gap:6px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>Perfil</button>
    </div>
    <div id="tab-dados" class="tab-content ativo"></div>
    <div id="tab-perfil" class="tab-content"></div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
const ligantes = <%- JSON.stringify(ligantes) %>;

function buscar(termo) {
  const t = termo.toLowerCase().trim();
  let vis = 0;
  document.querySelectorAll('.ligante-card').forEach(c => {
    const match = !t || c.dataset.nome.includes(t) || c.dataset.email.includes(t) || c.dataset.turma.includes(t);
    c.style.display = match ? '' : 'none';
    if (match) vis++;
  });
  document.getElementById('contador').textContent = vis + ' exibidos';
}

function trocarTab(tab, btn) {
  document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('ativo'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('ativo'));
  btn.classList.add('ativo');
  document.getElementById('tab-' + tab).classList.add('ativo');
}

function campo(label, valor) {
  return `<div class="detalhe-linha">
    <span class="detalhe-label">${label}</span>
    <span class="detalhe-valor">${valor || '—'}</span>
  </div>`;
}

document.addEventListener('click', function(e) {
  var btn = e.target.closest('.btn-abrir-detalhe, .btn-abrir-detalhe-card');
  if(btn) { e.stopPropagation(); abrirDetalhe(btn.dataset.liganteId); }
  if(e.target.closest('#btn-fechar-modal-detalhe')) {
    document.getElementById('modal-detalhe').classList.remove('aberto');
  }
});
function abrirDetalhe(id) {
  const l = ligantes.find(x => String(x.id) === String(id));
  if (!l) return;
  document.getElementById('modal-titulo').textContent = l.nome;

  // Foto + botão download (só exibe se tiver foto)
  const fotoHtml = l.foto_chave ? `
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;padding:16px;background:var(--fundo);border-radius:12px;border:1px solid var(--borda)">
      <img src="/ligantes/${id}/foto"
        style="width:72px;height:72px;border-radius:12px;object-fit:cover;border:2px solid var(--borda);flex-shrink:0"
        alt="Foto de ${l.nome}">
      <div>
        <div style="font-weight:700;font-size:14px;margin-bottom:6px">${l.nome.split(' ')[0]}</div>
        <a href="/ligantes/${id}/foto" download="${l.nome.replace(/ /g,'_')}_foto"
          target="_blank"
          style="display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:linear-gradient(135deg,#1a56db,#1e3a8a);color:white;border-radius:9px;font-size:12.5px;font-weight:600;text-decoration:none">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Baixar foto
        </a>
        <div style="font-size:11px;color:var(--texto2);margin-top:5px">
          Clique em "Baixar foto" — abrirá em nova aba para salvar
        </div>
      </div>
    </div>` : `
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:14px 16px;background:var(--fundo);border-radius:12px;border:1px solid var(--borda);color:var(--texto2);font-size:13px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <span>Este ligante não anexou foto no cadastro.</span>
    </div>`;

  document.getElementById('tab-dados').innerHTML = fotoHtml + `
    <div class="form-grid-2">
      ${campo('Nome completo', l.nome)}
      ${campo('E-mail', l.email)}
      ${campo('WhatsApp', l.whatsapp)}
      ${campo('Nascimento', l.data_nascimento ? new Date(String(l.data_nascimento).substring(0,10)+'T12:00:00').toLocaleDateString('pt-BR') : null)}
      ${campo('Sexo', l.sexo)}
      ${campo('RG/CI/DNI', l.rg)}
      ${campo('CPF', l.cpf)}
      ${campo('Semestre', l.semestre)}
      ${campo('Turma', l.turma)}
      ${campo('Catraca', l.catraca)}
      ${campo('ORCID', l.orcid)}
      ${campo('Formação', l.tem_formacao === 'Sim' ? 'Sim — ' + (l.qual_formacao||'') : l.tem_formacao)}
      ${campo('Status', l.ativo == 0 ? '<span style="display:inline-block;width:8px;height:8px;background:#dc2626;border-radius:50%;flex-shrink:0"></span> Inativo' : '<span style="display:inline-block;width:8px;height:8px;background:#16a34a;border-radius:50%;flex-shrink:0"></span> Ativo')}
      ${campo('Cadastrado em', new Date(l.criado_em).toLocaleString('pt-BR'))}
    </div>
    <div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
      <a href="/ligantes/${id}/editar" class="btn btn-primario" style="display:inline-flex;align-items:center;gap:5px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Editar dados</a>
      ${l.ativo==0?
        `<form action="/ligantes/${id}/toggle" method="POST" style="display:inline;margin:0"><button class="btn" style="color:#16a34a;display:inline-flex;align-items:center;gap:5px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Reativar</button></form>`
        :`<button class="btn" style="color:#dc2626" onclick="document.getElementById('modal-detalhe').classList.remove('aberto');abrirInativL(${id})" style="display:inline-flex;align-items:center;gap:5px"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>Inativar</button>`
      }
    </div>`;

  document.getElementById('tab-perfil').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:10px">
      ${campo('Habilidades', l.habilidades)}
      ${campo('Aceita cargo', l.aceita_cargo + (l.qual_cargo ? ' — ' + l.qual_cargo : ''))}
      ${campo('Contribuição em grupo', l.contribuicao_grupo)}
      ${campo('Ideia inovadora', l.ideia_inovadora)}
      ${campo('Tema de interesse', l.tema_interesse)}
      ${campo('Por que a LAURO?', l.porque_lauro)}
      ${campo('Apresentação', l.apresentacao)}
    </div>`;

  document.getElementById('modal-detalhe').classList.add('aberto');
}

function fecharModalClick(e) {
  if (e.target === document.getElementById('modal-detalhe'))
    document.getElementById('modal-detalhe').classList.remove('aberto');
}
</script>

<div class="modal-overlay" id="modal-inativ-l" style="display:none">
  <div class="modal" style="max-width:460px">
    <div class="modal-header">
      <span class="modal-titulo">Inativar ligante</span>
      <button class="icon-btn" onclick="fecharModal('modal-inativ-l')">&#x2715;</button>
    </div>
    <p style="font-size:13px;color:var(--texto2);margin:0 0 16px;line-height:1.6">
      Ao inativar, o ligante nao receberao mais notificacoes do sistema.
    </p>
    <div class="campo" style="margin-bottom:12px">
      <label class="label">Motivo *</label>
      <select id="sel-motivo-l" class="input" onchange="atualizarMotivoL()">
        <option value="">Selecione...</option>
        <option>Desligamento voluntario</option>
        <option>Desvinculacao</option>
        <option>Conclusao de curso</option>
        <option>Transferencia de instituicao</option>
        <option>Desempenho insatisfatorio</option>
        <option>Outro</option>
      </select>
    </div>
    <div id="outro-l" style="display:none;margin-bottom:12px">
      <label class="label">Especifique *</label>
      <textarea id="txt-outro-l" class="input" rows="2" oninput="atualizarMotivoL()"></textarea>
    </div>
    <form id="form-inativ-l" action="" method="POST">
      <input type="hidden" name="motivo" id="motivo-l">
      <div class="modal-footer" style="padding:0;margin-top:8px">
        <button type="button" class="btn" onclick="fecharModal('modal-inativ-l')">Cancelar</button>
        <button type="submit" class="btn btn-primario" onclick="return validarL()"
          style="background:linear-gradient(135deg,#dc2626,#b91c1c)">Confirmar</button>
      </div>
    </form>
  </div>
</div>
<script>
function abrirInativL(id){
  document.getElementById('form-inativ-l').action='/ligantes/'+id+'/toggle';
  document.getElementById('sel-motivo-l').value='';
  document.getElementById('motivo-l').value='';
  document.getElementById('outro-l').style.display='none';
  abrirModal('modal-inativ-l');
}
function atualizarMotivoL(){
  const s=document.getElementById('sel-motivo-l').value;
  document.getElementById('outro-l').style.display=s==='Outro'?'':'none';
  document.getElementById('motivo-l').value=s==='Outro'?document.getElementById('txt-outro-l').value:s;
}
function validarL(){
  if(!document.getElementById('motivo-l').value){alert('Informe o motivo.');return false;}
  return true;
}

// ── PAGINAÇÃO 24/página ─────────────────────────────────────────────────────
var _pag=1,_PER=24,_qB='';
window.buscar=function(q){
  _qB=(q||'').toLowerCase().trim(); _pag=1; _pagOK();
};
function _visCards(){
  return Array.from(document.querySelectorAll('.ligante-card')).filter(function(c){
    if(!_qB)return true;
    return (c.dataset.nome||'').includes(_qB)||(c.dataset.email||'').includes(_qB)||(c.dataset.turma||'').includes(_qB);
  });
}
function _pagOK(){
  var all=Array.from(document.querySelectorAll('.ligante-card'));
  var vis=_visCards();
  all.forEach(function(c){c.style.display='none';});
  vis.slice((_pag-1)*_PER,_pag*_PER).forEach(function(c){c.style.display='';});
  var cont=document.getElementById('contador');
  if(cont)cont.textContent=vis.length+' exibidos';
  _pagRender(vis.length);
}
function _pagRender(total){
  var wrap=document.getElementById('paginacao');if(!wrap)return;
  var tp=Math.ceil(total/_PER);
  if(tp<=1){wrap.innerHTML='';return;}
  var h='';
  h+='<button class="pag-btn pn" onclick="_irPag('+(_pag-1)+')" '+(_pag<=1?'disabled style="opacity:.35;cursor:default"':'')+'>'+'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg> Anterior</button>';
  for(var p=1;p<=tp;p++){
    if(p===1||p===tp||Math.abs(p-_pag)<=1){
      h+='<button class="pag-btn'+(_pag===p?' pag-ativo':'')+'" onclick="_irPag('+p+')">'+p+'</button>';
    }else if((p===2&&_pag>3)||(p===tp-1&&_pag<tp-2)){
      h+='<span class="pag-ellipsis">…</span>';
    }
  }
  h+='<button class="pag-btn pn" onclick="_irPag('+(_pag+1)+')" '+(_pag>=tp?'disabled style="opacity:.35;cursor:default"':'')+'>Próximo <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>';
  h+='<span class="pag-info">Página '+_pag+' de '+tp+'</span>';
  wrap.innerHTML=h;
}
function _irPag(p){
  var tp=Math.ceil(_visCards().length/_PER);
  if(p<1||p>tp)return; _pag=p; _pagOK();
  var g=document.getElementById('grid-ligantes');
  if(g)window.scrollTo({top:g.offsetTop-80,behavior:'smooth'});
}
document.addEventListener('DOMContentLoaded',function(){_pagOK();});
</script>
</body>
</html>
