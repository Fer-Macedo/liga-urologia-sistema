<!-- ANIVERSÁRIOS -->
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aniversários — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>:root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }</style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'aniversarios' }) %>
  <main class="main">
    <div class="topbar"><h1 class="page-titulo">Aniversários</h1></div>
    <div class="content">
      <% if (aniversariantes.length === 0) { %>
        <div class="vazio">Nenhum membro com data de nascimento cadastrada.</div>
      <% } %>
      <div class="aniv-lista">
        <% aniversariantes.forEach(m => {
          const md = m.data_nascimento ? m.data_nascimento.substring(5) : '';
          const isHoje = md === hoje;
        %>
        <div class="aniv-card <%= isHoje ? 'hoje' : '' %>">
          <div class="aniv-icone">🎂</div>
          <div class="aniv-info">
            <div class="aniv-nome"><%= m.nome %></div>
            <div class="aniv-data">
              <%= new Date(m.data_nascimento+'T12:00:00').toLocaleDateString('pt-BR',{day:'numeric',month:'long'}) %>
              <% if (m.email) { %> · <%= m.email %><% } %>
            </div>
          </div>
          <% if (isHoje) { %><span class="badge azul">Hoje!</span><% } %>
        </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>
<script src="/js/app.js"></script>
</body></html>
