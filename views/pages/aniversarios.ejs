<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aniversários — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
  <style>
    :root { --cor-primaria: <%= config.org_cor || '#1a56db' %>; }

    .aniv-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 12px;
    }

    .aniv-card {
      background: var(--card);
      border: 1px solid var(--borda);
      border-radius: 14px;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: all .15s ease;
    }
    .aniv-card:hover {
      border-color: var(--cor-primaria);
      box-shadow: 0 4px 16px rgba(26,86,219,.08);
    }
    .aniv-card.hoje {
      border-color: #f59e0b;
      background: linear-gradient(135deg, #fffbeb, var(--card));
      box-shadow: 0 4px 20px rgba(245,158,11,.12);
    }

    .aniv-avatar {
      width: 46px; height: 46px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--cor-primaria), #6366f1);
      color: white;
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .aniv-card.hoje .aniv-avatar {
      background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .aniv-info { flex: 1; min-width: 0; }
    .aniv-nome {
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--texto);
      margin-bottom: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .aniv-data {
      font-size: 12.5px;
      color: var(--texto2);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .aniv-tipo {
      font-size: 10.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
      border-radius: 999px;
      padding: 2px 8px;
    }
    .aniv-tipo.ligante {
      background: #eff6ff;
      color: #1d4ed8;
      border: 1px solid #bfdbfe;
    }
    .aniv-tipo.diretivo {
      background: #f5f3ff;
      color: #6d28d9;
      border: 1px solid #ddd6fe;
    }

    .badge-hoje {
      background: #fef3c7;
      color: #92400e;
      border: 1px solid #fde68a;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .mes-header {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--texto2);
      padding: 6px 0 10px;
      border-bottom: 1px solid var(--borda);
      margin-bottom: 12px;
      margin-top: 24px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .mes-header:first-of-type { margin-top: 0; }
    .mes-count {
      background: var(--fundo);
      border: 1px solid var(--borda);
      border-radius: 999px;
      padding: 1px 8px;
      font-size: 10px;
    }

    .vazio {
      text-align: center;
      padding: 60px;
      color: var(--texto2);
      font-size: 14px;
    }

    .filtros-row {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'aniversarios' }) %>
  <main class="main">
    <div class="topbar">
      <h1 class="page-titulo">Aniversários</h1>
      <div class="topbar-acoes">
        <span style="font-size:13px;color:var(--texto2)"><%= aniversariantes.length %> cadastros com data</span>
      </div>
    </div>

    <div class="content">
      <% if (aniversariantes.length === 0) { %>
        <div class="vazio">Nenhum cadastro com data de nascimento encontrado.</div>
      <% } else { %>

        <!-- FILTRO DE BUSCA -->
        <div class="filtros-row">
          <input type="text" class="input" placeholder="Buscar por nome..."
            id="busca" oninput="buscar(this.value)"
            style="max-width:300px;font-size:13px;padding:7px 12px">
          <span id="contador" style="font-size:13px;color:var(--texto2)"><%= aniversariantes.length %> pessoas</span>
        </div>

        <%
          // Separar aniversariantes de hoje dos demais
          const hoje_aniv = aniversariantes.filter(m => m.data_nascimento && m.data_nascimento.substring(5) === hoje);
          const outros = aniversariantes.filter(m => !m.data_nascimento || m.data_nascimento.substring(5) !== hoje);

          // Agrupar por mês
          const meses = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
          const grupos = {};
          outros.forEach(m => {
            if (!m.data_nascimento) return;
            const mesIdx = parseInt(m.data_nascimento.substring(5,7)) - 1;
            const mesNome = meses[mesIdx];
            if (!grupos[mesNome]) grupos[mesNome] = [];
            grupos[mesNome].push(m);
          });
        %>

        <!-- HOJE -->
        <% if (hoje_aniv.length > 0) { %>
          <div class="mes-header" style="color:#92400e;border-color:#fde68a">
            Hoje
            <span class="mes-count" style="background:#fef3c7;border-color:#fde68a;color:#92400e"><%= hoje_aniv.length %></span>
          </div>
          <div class="aniv-grid" style="margin-bottom:8px" id="grupo-hoje">
            <% hoje_aniv.forEach(m => { %>
            <div class="aniv-card hoje" data-nome="<%= m.nome.toLowerCase() %>">
              <div class="aniv-avatar"><%= m.nome.substring(0,2).toUpperCase() %></div>
              <div class="aniv-info">
                <div class="aniv-nome"><%= m.nome %></div>
                <div class="aniv-data">
                  <%= new Date(m.data_nascimento+'T12:00:00').toLocaleDateString('pt-BR',{day:'numeric',month:'long'}) %>
                  <span class="aniv-tipo <%= m.tipo === 'diretivo' ? 'diretivo' : 'ligante' %>"><%= m.tipo === 'diretivo' ? 'Diretivo' : 'Ligante' %></span>
                </div>
              </div>
              <span class="badge-hoje">Hoje</span>
            </div>
            <% }) %>
          </div>
        <% } %>

        <!-- POR MÊS -->
        <div id="lista-meses">
        <% Object.entries(grupos).forEach(([mes, pessoas]) => { %>
          <div class="mes-bloco" data-mes="<%= mes %>">
            <div class="mes-header">
              <%= mes %>
              <span class="mes-count"><%= pessoas.length %></span>
            </div>
            <div class="aniv-grid" style="margin-bottom:8px">
              <% pessoas.forEach(m => { %>
              <div class="aniv-card" data-nome="<%= m.nome.toLowerCase() %>">
                <div class="aniv-avatar"><%= m.nome.substring(0,2).toUpperCase() %></div>
                <div class="aniv-info">
                  <div class="aniv-nome"><%= m.nome %></div>
                  <div class="aniv-data">
                    <%= new Date(m.data_nascimento+'T12:00:00').toLocaleDateString('pt-BR',{day:'numeric',month:'long'}) %>
                    <span class="aniv-tipo <%= m.tipo === 'diretivo' ? 'diretivo' : 'ligante' %>"><%= m.tipo === 'diretivo' ? 'Diretivo' : 'Ligante' %></span>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
        </div>

      <% } %>
    </div>
  </main>
</div>

<script src="/js/app.js"></script>
<script>
function buscar(termo) {
  const t = termo.toLowerCase().trim();
  let vis = 0;
  document.querySelectorAll('.aniv-card').forEach(c => {
    const ok = !t || c.dataset.nome.includes(t);
    c.style.display = ok ? '' : 'none';
    if (ok) vis++;
  });
  document.getElementById('contador').textContent = vis + ' pessoas';

  // Esconder blocos de mês vazios
  document.querySelectorAll('.mes-bloco').forEach(bloco => {
    const visíveis = bloco.querySelectorAll('.aniv-card:not([style*="none"])').length;
    bloco.style.display = visíveis > 0 ? '' : 'none';
  });
}
</script>
</body>
</html>
