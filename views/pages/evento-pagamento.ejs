<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pagamento — <%= evento.nome %></title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
  <style>
    :root {
      --cor: <%= evento.cor_tema || '#1a3d2b' %>;
      --cor2: <%= evento.cor_tema ? evento.cor_tema + 'dd' : '#1a3d2b' %>;
      --bg: #f5f5f0;
      --card: #ffffff;
      --border: #e5e7eb;
      --text: #111827;
      --muted: #6b7280;
      --pix: #0F6E56;
      --card-pay: #1a3d2b;
      --success: #16a34a;
      --radius: 4px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    .header {
      background: var(--cor);
      padding: 18px 24px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .header-logo {
      width: 44px; height: 44px;
      background: transparent;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      border: none;
      overflow: hidden;
    }
    .header-info h1 { color: #fff; font-size: 15px; font-weight: 600; }
    .header-info p  { color: rgba(255,255,255,0.65); font-size: 12px; }

    /* ── LAYOUT ── */
    .container {
      max-width: 860px;
      margin: 0 auto;
      padding: 32px 20px 60px;
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
    }
    @media (max-width: 720px) {
      .container { grid-template-columns: 1fr; }
      .sidebar { order: -1; }
    }

    /* ── CARDS ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .card-header {
      padding: 16px 22px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 10px;
      border-left: 3px solid var(--cor);
    }
    .card-header h2 { font-size: 15px; font-weight: 600; }
    .card-body { padding: 22px; }

    /* ── STEPS ── */
    .steps {
      display: flex;
      align-items: center;
      gap: 0;
      margin-bottom: 28px;
    }
    .step {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: var(--muted);
    }
    .step.active { color: var(--cor); font-weight: 600; }
    .step.done { color: var(--cor); }
    .step-num {
      width: 26px; height: 26px;
      border-radius: 4px;
      background: var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700;
    }
    .step.active .step-num { background: var(--cor); color: #fff; }
    .step.done .step-num { background: var(--cor); color: #fff; }
    .step-line { flex: 1; height: 2px; background: var(--border); margin: 0 8px; min-width: 20px; }
    .step-line.done { background: var(--cor); }

    /* ── MÉTODO TABS ── */
    .method-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 24px;
    }
    .method-tab {
      border: 2px solid var(--border);
      border-radius: 4px;
      padding: 16px;
      cursor: pointer;
      transition: all .2s;
      text-align: center;
      background: var(--card);
    }
    .method-tab:hover { border-color: var(--cor); }
    .method-tab.active-pix { border-color: var(--pix); background: #f0fdfb; }
    .method-tab.active-card { border-color: var(--card-pay); background: #f0f1ff; }
    .method-tab .icon { font-size: 28px; margin-bottom: 6px; }
    .method-tab .label { font-size: 13px; font-weight: 600; color: var(--text); }
    .method-tab .sublabel { font-size: 11px; color: var(--muted); margin-top: 2px; }

    /* ── PIX BLOCK ── */
    #pix-block { display: none; }
    #pix-block.show { display: block; }

    .pix-timer {
      display: flex; align-items: center; justify-content: space-between;
      background: #f0fdfb;
      border: 1px solid #a7f3d0;
      border-radius: 4px;
      padding: 12px 16px;
      margin-bottom: 20px;
    }
    .pix-timer-left { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #065f46; }
    .pix-timer-count { font-family: 'JetBrains Mono', monospace; font-size: 20px; font-weight: 700; color: var(--pix); }

    .pix-qr-wrap {
      display: flex; flex-direction: column; align-items: center;
      gap: 16px; margin-bottom: 20px;
    }
    .pix-qr-img {
      width: 200px; height: 200px;
      border: 3px solid var(--pix);
      border-radius: 4px;
      object-fit: contain;
      background: #fff;
    }
    .pix-qr-placeholder {
      width: 200px; height: 200px;
      border: 3px dashed var(--border);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 8px;
      color: var(--muted); font-size: 13px;
    }

    .pix-copy-label { font-size: 12px; color: var(--muted); margin-bottom: 6px; font-weight: 500; }
    .pix-copy-wrap {
      display: flex; gap: 8px;
    }
    .pix-copy-input {
      flex: 1;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      padding: 10px 12px;
      border: 1px solid var(--border);
      border-radius: 2px;
      background: #f9faf7;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      cursor: pointer;
    }
    .btn-copy {
      padding: 10px 16px;
      background: var(--pix);
      color: #fff;
      border: none;
      border-radius: 2px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity .2s;
      white-space: nowrap;
    }
    .btn-copy:hover { opacity: .85; }
    .btn-copy.copied { background: var(--success); }

    .pix-status {
      margin-top: 20px;
      padding: 14px 16px;
      border-radius: 4px;
      background: #fefce8;
      border: 1px solid #fde68a;
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: #78350f;
    }
    .pix-status .dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #fbbf24;
      animation: pulse 1.2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity:1; transform:scale(1); }
      50% { opacity:.5; transform:scale(1.3); }
    }

    /* ── CARTÃO BLOCK ── */
    #card-block { display: none; }
    #card-block.show { display: block; }

    .card-form-grid {
      display: grid; gap: 14px;
    }
    .field-group { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: .5px; }
    .field input, .field select {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid var(--border);
      border-radius: 2px;
      font-family: 'Sora', sans-serif;
      font-size: 14px;
      color: var(--text);
      background: #fff;
      transition: border-color .2s;
      outline: none;
    }
    .field input:focus, .field select:focus { border-color: var(--card-pay); }
    .field input.mono { font-family: 'JetBrains Mono', monospace; letter-spacing: 2px; }

    .card-preview {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      border-radius: 4px;
      padding: 22px;
      margin-bottom: 20px;
      position: relative;
      overflow: hidden;
      min-height: 130px;
    }
    .card-preview::before {
      content: '';
      position: absolute; top: -30px; right: -30px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
    }
    .card-preview-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 18px; color: #fff;
      letter-spacing: 4px;
      margin-bottom: 16px;
    }
    .card-preview-row { display: flex; justify-content: space-between; align-items: flex-end; }
    .card-preview-label { font-size: 9px; color: rgba(255,255,255,.5); text-transform: uppercase; margin-bottom: 2px; }
    .card-preview-val { font-size: 13px; color: #fff; font-weight: 500; }

    .btn-pagar {
      transition: background .2s, transform .15s, box-shadow .2s;
      width: 100%;
      padding: 14px;
      background: var(--card-pay);
      color: #fff;
      border: none;
      border-radius: 4px;
      font-family: 'Sora', sans-serif;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s, transform .1s;
      margin-top: 8px;
    }
    .btn-pagar:hover { opacity: .9; }
    .btn-pagar:active { transform: scale(.98); }
    .btn-pagar:disabled { opacity: .5; cursor: not-allowed; }

    /* ── SUCESSO ── */
    #sucesso-block { display: none; }
    #sucesso-block.show { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 32px 22px; }
    .sucesso-icon {
      width: 80px; height: 80px;
      background: #dcfce7;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 36px;
      margin-bottom: 20px;
      animation: popIn .5s cubic-bezier(.34,1.56,.64,1);
    }
    @keyframes popIn { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    #sucesso-block h2 { font-size: 20px; font-weight: 700; color: var(--success); margin-bottom: 8px; }
    #sucesso-block p { font-size: 14px; color: var(--muted); line-height: 1.6; }
    .sucesso-codigo {
      margin: 16px 0;
      padding: 10px 20px;
      background: #f0fdf4;
      border: 1px solid #86efac;
      border-radius: 2px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: #166534;
      font-weight: 600;
    }

    /* ── SIDEBAR ── */
    .sidebar {}
    .resumo-evento { padding: 0; }
    .resumo-banner {
      width: 100%; height: 140px;
      object-fit: cover;
      background: var(--cor);
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,.4); font-size: 32px;
    }
    .resumo-banner img { width: 100%; height: 140px; object-fit: cover; }
    .resumo-info { padding: 18px 20px; }
    .resumo-nome { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .resumo-sub { font-size: 12px; color: var(--muted); margin-bottom: 16px; }
    .resumo-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
    .resumo-row:last-child { border-bottom: none; }
    .resumo-row .key { color: var(--muted); }
    .resumo-row .val { font-weight: 600; }
    .resumo-total { font-size: 16px !important; }
    .resumo-total .val { color: var(--cor); font-size: 20px; }

    .seguro-badge {
      margin-top: 16px;
      padding: 10px 14px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 2px;
      display: flex; align-items: center; gap: 8px;
      font-size: 11px; color: #166534;
    }

    /* ── ERRO ── */
    .erro-msg {
      display: none;
      background: #fef2f2; border: 1px solid #fecaca;
      border-radius: 2px; padding: 12px 16px;
      font-size: 13px; color: #dc2626;
      margin-top: 12px;
    }
    .erro-msg.show { display: block; }

    /* ── LOADING ── */
    .loading-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.4);
      z-index: 999;
      align-items: center; justify-content: center;
      flex-direction: column; gap: 16px;
    }
    .loading-overlay.show { display: flex; }
    .spinner {
      width: 48px; height: 48px;
      border: 4px solid rgba(255,255,255,.2);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-overlay p { color: #fff; font-size: 14px; font-weight: 500; }
  
    input[type=text]:hover, input[type=number]:hover, select:hover { border-color: #9ca3af; }
    .card { transition: box-shadow .2s; }
    .sidebar .card { border-top: 3px solid var(--cor); }
    .pix-copy-btn { transition: background .2s, transform .15s !important; }
    .pix-copy-btn:hover { transform: translateY(-1px) !important; }
    .header-info h1 { font-size: 16px; font-weight: 700; letter-spacing: -.3px; }
    .header-info p { font-size: 11px; color: rgba(255,255,255,0.6); letter-spacing: .5px; text-transform: uppercase; }

  </style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-logo"><img src="https://sistema.lauroucpcde.com/img/logo-lauro.png" width="36" height="36" style="border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,0.3)" onerror="this.parentElement.innerHTML='<svg style=width:20px;height:20px;fill:white viewBox=0 0 24 24><path d=M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z/></svg>'"></div>
  <div class="header-info">
    <h1><%= config.org_nome || 'Liga Acadêmica de Urologia' %></h1>
    <p>Pagamento seguro</p>
  </div>
</div>

<!-- LOADING -->
<div class="loading-overlay" id="loading">
  <div class="spinner"></div>
  <p id="loading-txt">Processando pagamento…</p>
</div>

<div class="container">
  <!-- COLUNA PRINCIPAL -->
  <div>
    <!-- STEPS -->
    <div class="steps" style="margin-bottom:24px">
      <div class="step done">
        <div class="step-num"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><polyline points="20 6 9 17 4 12"/></svg></div>
        <span>Dados</span>
      </div>
      <div class="step-line done"></div>
      <div class="step active" id="step2">
        <div class="step-num">2</div>
        <span>Pagamento</span>
      </div>
      <div class="step-line" id="line3"></div>
      <div class="step" id="step3">
        <div class="step-num">3</div>
        <span>Confirmação</span>
      </div>
    </div>

    <!-- CARD PAGAMENTO -->
    <div class="card" id="payment-card">
      <div class="card-header">
        <svg style="width:20px;height:20px;fill:var(--card-pay)" viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
        <h2>Escolha a forma de pagamento</h2>
      </div>
      <div class="card-body">

        <!-- MÉTODO TABS -->
        <div class="method-tabs">
          <div class="method-tab" id="tab-pix" onclick="selectMethod('pix')">
            <div class="icon"><svg style="width:28px;height:28px;fill:#32bcad" viewBox="0 0 24 24"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg></div>
            <div class="label">PIX</div>
            <div class="sublabel">Aprovação imediata</div>
          </div>
          <div class="method-tab" id="tab-card" onclick="selectMethod('card')">
            <div class="icon"><svg style="width:28px;height:28px;fill:#5a67d8" viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-2 .89-2 2v12c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg></div>
            <div class="label">Cartão de Crédito</div>
            <div class="sublabel">Até 12x</div>
          </div>
        </div>

        <!-- PIX BLOCK -->
        <div id="pix-block">
          <% if (pixData && pixData.pix_copia_cola) { %>
            <!-- Timer -->
            <div class="pix-timer">
              <div class="pix-timer-left"><svg style="width:15px;height:15px;fill:#065f46;flex-shrink:0" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg> Expira em</div>
              <div class="pix-timer-count" id="timer">15:00</div>
            </div>

            <!-- QR Code gerado no navegador -->
            <div class="pix-qr-wrap">
              <div id="qr-canvas" style="
                width:200px;height:200px;
                border:3px solid var(--pix);
                border-radius:12px;
                background:#fff;
                display:flex;align-items:center;justify-content:center;
                overflow:hidden;
              "></div>
            </div>

            <!-- Copia e cola -->
            <div class="pix-copy-label">Código PIX copia e cola</div>
            <div class="pix-copy-wrap">
              <input class="pix-copy-input" id="pix-code" value="<%= pixData.pix_copia_cola %>" readonly onclick="this.select()">
              <button class="btn-copy" id="btn-copy" onclick="copiarPix()">Copiar</button>
            </div>

            <!-- Status aguardando -->
            <div class="pix-status" id="pix-status-box">
              <div class="dot"></div>
              <span>Aguardando pagamento… verificando automaticamente</span>
            </div>

          <% } else { %>
            <div style="text-align:center;padding:32px;color:var(--muted)">
              <div style="display:flex;align-items:center;justify-content:center;margin-bottom:12px">
                <svg style="width:40px;height:40px;fill:#d97706" viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
              </div>
              <p style="font-size:14px">Não foi possível gerar o PIX.<br>Tente o cartão de crédito ou entre em contato.</p>
            </div>
          <% } %>
        </div>

        <!-- CARTÃO BLOCK -->
        <div id="card-block">
          <!-- Preview do cartão -->
          <div class="card-preview">
            <div class="card-preview-num" id="prev-num">•••• •••• •••• ••••</div>
            <div class="card-preview-row">
              <div>
                <div class="card-preview-label">Titular</div>
                <div class="card-preview-val" id="prev-nome">SEU NOME</div>
              </div>
              <div>
                <div class="card-preview-label">Validade</div>
                <div class="card-preview-val" id="prev-exp">MM/AA</div>
              </div>
            </div>
          </div>

          <div class="card-form-grid">
            <div class="field">
              <label>Número do Cartão</label>
              <input type="text" id="cc-num" class="mono" maxlength="19" placeholder="0000 0000 0000 0000" oninput="fmtCartao(this)" autocomplete="cc-number">
            </div>
            <div class="field">
              <label>Titular do Cartão</label>
              <input type="text" id="cc-nome" placeholder="NOME COMO NO CARTÃO" oninput="fmtNome(this)" autocomplete="cc-name" style="text-transform:uppercase">
            </div>
            <div class="field-group">
              <div class="field">
                <label>Validade</label>
                <input type="text" id="cc-exp" class="mono" maxlength="5" placeholder="MM/AA" oninput="fmtExp(this)" autocomplete="cc-exp">
              </div>
              <div class="field">
                <label>CVV</label>
                <input type="text" id="cc-cvv" class="mono" maxlength="4" placeholder="•••" autocomplete="cc-csc">
              </div>
            </div>
            <div class="field">
              <label>CPF do Titular</label>
              <input type="text" id="cc-cpf" class="mono" maxlength="14" placeholder="000.000.000-00" oninput="fmtCpf(this)">
            </div>
            <div class="field">
              <label>Parcelas</label>
              <select id="cc-parcelas">
                <option value="1">1x de R$ <%= parseFloat(lote.preco).toFixed(2).replace('.',',') %> (sem juros)</option>
              </select>
            </div>
          </div>

          <div class="erro-msg" id="card-erro"></div>

          <button class="btn-pagar" onclick="pagarCartao()" id="btn-pagar">
            <svg style="width:16px;height:16px;fill:white;vertical-align:middle;margin-right:6px" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
            Pagar R$ <%= parseFloat(lote.preco).toFixed(2).replace('.',',') %>
          </button>
        </div>

      </div><!-- card-body -->
    </div><!-- card -->

    <!-- SUCESSO -->
    <div class="card" id="sucesso-card" style="display:none">
      <div id="sucesso-block" class="show">
        <div class="sucesso-icon">
          <svg style="width:38px;height:38px;fill:#16a34a" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        </div>
        <h2>Pagamento confirmado!</h2>
        <p>Sua inscrição em <strong><%= evento.nome %></strong> está confirmada.<br>Enviamos o e-mail de confirmação para você.</p>
        <div class="sucesso-codigo" id="sucesso-codigo"><%= qrcode %></div>
        <p style="font-size:12px;color:var(--muted);margin-bottom:24px">Guarde seu código de inscrição para o check-in no evento.</p>

        <% if(evento.wpp_grupo){ %>
        <a href="<%= evento.wpp_grupo %>" target="_blank" style="display:inline-flex;align-items:center;gap:10px;background:#25d366;color:white;padding:13px 24px;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px;margin-bottom:10px;width:100%;justify-content:center">
          <svg style="width:18px;height:18px;fill:white;flex-shrink:0" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Entrar no Grupo do Evento
        </a>
        <% } %>

        <a href="/inscricao/<%= evento.id %>" style="display:inline-flex;align-items:center;gap:10px;background:var(--cor);color:white;padding:13px 24px;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px;margin-bottom:10px;width:100%;justify-content:center">
          <svg style="width:18px;height:18px;fill:white;flex-shrink:0" viewBox="0 0 24 24"><path d="M20 12c0-1.1.9-2 2-2V6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v4c1.1 0 2 .9 2 2s-.9 2-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2z"/></svg>
          Realizar Nova Inscrição
        </a>

        <a href="/inscricao/<%= evento.id %>" style="display:inline-flex;align-items:center;gap:10px;background:var(--border);color:var(--text);padding:13px 24px;border-radius:10px;text-decoration:none;font-weight:600;font-size:14px;width:100%;justify-content:center">
          <svg style="width:18px;height:18px;fill:var(--text);flex-shrink:0" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
          Voltar à Página do Evento
        </a>
      </div>
    </div>

  </div><!-- col principal -->

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="card resumo-evento">
      <% if (evento.banner_chave) { %>
        <img src="/eventos/<%= evento.id %>/banner" alt="Banner" style="width:100%;height:140px;object-fit:cover">
      <% } else { %>
        <div class="resumo-banner" style="background:var(--cor);display:flex;align-items:center;justify-content:center">
          <svg style="width:40px;height:40px;fill:rgba(255,255,255,.4)" viewBox="0 0 24 24"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
        </div>
      <% } %>
      <div class="resumo-info">
        <div class="resumo-nome"><%= evento.nome %></div>
        <div class="resumo-sub">
          <% if (evento.data_inicio) { %>
            <span style="display:inline-flex;align-items:center;gap:4px">
              <svg style="width:12px;height:12px;fill:var(--muted);flex-shrink:0" viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM5 8V6h14v2H5z"/></svg>
              <%= new Date(evento.data_inicio).toLocaleDateString('pt-BR', {day:'2-digit',month:'long',year:'numeric',timeZone:'UTC'}) %>
            </span>
          <% } %>
          <% if (evento.local) { %>
            &nbsp;·&nbsp;
            <span style="display:inline-flex;align-items:center;gap:4px">
              <svg style="width:12px;height:12px;fill:var(--muted);flex-shrink:0" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <%= evento.local %>
            </span>
          <% } %>
        </div>

        <div class="resumo-row">
          <span class="key">Inscrito</span>
          <span class="val"><%= inscricao.nome %></span>
        </div>
        <div class="resumo-row">
          <span class="key">Lote</span>
          <span class="val"><%= lote.nome %></span>
        </div>
        <div class="resumo-row resumo-total">
          <span class="key">Total</span>
          <span class="val">R$ <%= parseFloat(lote.preco).toFixed(2).replace('.',',') %></span>
        </div>

        <div class="seguro-badge">
          <svg style="width:14px;height:14px;fill:#16a34a;flex-shrink:0" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
          Pagamento seguro via PagBank
        </div>
      </div>
    </div>
  </div>

</div><!-- container -->

<script>
  const PIX_TEXTO = '<%= pixData && pixData.pix_copia_cola ? pixData.pix_copia_cola.replace(/'/g, "\\'") : "" %>';
  const INSCRICAO_ID = '<%= inscricao.id %>';
  const TEM_PIX = <%= pixData && pixData.pix_copia_cola ? 'true' : 'false' %>;
  let pollingInterval = null;
  let timerInterval = null;
  let segundos = 15 * 60;

  // ── MÉTODO
  function selectMethod(m) {
    document.getElementById('tab-pix').className = 'method-tab' + (m==='pix' ? ' active-pix' : '');
    document.getElementById('tab-card').className = 'method-tab' + (m==='card' ? ' active-card' : '');
    document.getElementById('pix-block').className = 'show' === 'show' && m==='pix' ? 'show' : '';
    document.getElementById('card-block').className = m==='card' ? 'show' : '';

    if (m === 'pix') {
      document.getElementById('pix-block').classList.add('show');
      document.getElementById('card-block').classList.remove('show');
      if (TEM_PIX) iniciarPolling();
    } else {
      document.getElementById('card-block').classList.add('show');
      document.getElementById('pix-block').classList.remove('show');
      pararPolling();
    }
  }

  window.onload = function() {
    // Gerar QR Code PIX no navegador
    if (TEM_PIX && PIX_TEXTO && document.getElementById('qr-canvas')) {
      try {
        new QRCode(document.getElementById('qr-canvas'), {
          text: PIX_TEXTO,
          width: 194,
          height: 194,
          colorDark: '#1a3d2b',
          colorLight: '#ffffff',
          correctLevel: QRCode.CorrectLevel.M
        });
      } catch(e) { console.warn('QRCode erro:', e); }
    }

    if (TEM_PIX) {
      selectMethod('pix');
      iniciarTimer();
    } else {
      selectMethod('card');
    }
  };

  // ── TIMER
  function iniciarTimer() {
    timerInterval = setInterval(function() {
      segundos--;
      if (segundos <= 0) { clearInterval(timerInterval); document.getElementById('timer').textContent = '00:00'; return; }
      const m = Math.floor(segundos / 60);
      const s = segundos % 60;
      document.getElementById('timer').textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    }, 1000);
  }

  // ── COPIAR PIX
  function copiarPix() {
    const input = document.getElementById('pix-code');
    navigator.clipboard.writeText(input.value).then(function() {
      const btn = document.getElementById('btn-copy');
      btn.textContent = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><polyline points="20 6 9 17 4 12"/></svg> Copiado!';
      btn.classList.add('copied');
      setTimeout(function() { btn.textContent = 'Copiar'; btn.classList.remove('copied'); }, 2000);
    }).catch(function() {
      input.select(); document.execCommand('copy');
    });
  }

  // ── POLLING STATUS PIX
  function iniciarPolling() {
    if (pollingInterval) return;
    pollingInterval = setInterval(verificarPagamento, 4000);
  }
  function pararPolling() {
    if (pollingInterval) { clearInterval(pollingInterval); pollingInterval = null; }
  }

  async function verificarPagamento() {
    try {
      const r = await fetch('/pagamento/' + INSCRICAO_ID + '/status');
      const data = await r.json();
      if (data.pago) {
        pararPolling();
        clearInterval(timerInterval);
        mostrarSucesso();
      }
    } catch(e) { /* silencioso */ }
  }

  // ── SUCESSO
  function mostrarSucesso() {
    document.getElementById('payment-card').style.display = 'none';
    document.getElementById('sucesso-card').style.display = 'block';
    // Atualizar steps
    document.getElementById('step2').className = 'step done';
    document.getElementById('step2').querySelector('.step-num').textContent = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><polyline points="20 6 9 17 4 12"/></svg>';
    document.getElementById('line3').className = 'step-line done';
    document.getElementById('step3').className = 'step active';
  }

  // ── FORMATOS CARTÃO
  function fmtCartao(el) {
    let v = el.value.replace(/\D/g,'').substring(0,16);
    el.value = v.replace(/(\d{4})(?=\d)/g,'$1 ');
    document.getElementById('prev-num').textContent = (v + '................').substring(0,16).replace(/(\d{4})(?=\d)/g,'$1 ') || '•••• •••• •••• ••••';
  }
  function fmtNome(el) {
    el.value = el.value.toUpperCase();
    document.getElementById('prev-nome').textContent = el.value || 'SEU NOME';
  }
  function fmtExp(el) {
    let v = el.value.replace(/\D/g,'');
    if (v.length >= 2) v = v.substring(0,2) + '/' + v.substring(2,4);
    el.value = v;
    document.getElementById('prev-exp').textContent = el.value || 'MM/AA';
  }
  function fmtCpf(el) {
    let v = el.value.replace(/\D/g,'').substring(0,11);
    v = v.replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d{1,2})$/,'$1-$2');
    el.value = v;
  }

  // ── PAGAR CARTÃO
  async function pagarCartao() {
    const num = document.getElementById('cc-num').value.replace(/\D/g,'');
    const nome = document.getElementById('cc-nome').value.trim();
    const exp = document.getElementById('cc-exp').value;
    const cvv = document.getElementById('cc-cvv').value.replace(/\D/g,'');
    const cpf = document.getElementById('cc-cpf').value.replace(/\D/g,'');
    const parcelas = document.getElementById('cc-parcelas').value;

    const erro = document.getElementById('card-erro');
    erro.className = 'erro-msg';

    if (num.length < 13) return mostrarErro('Número do cartão inválido.');
    if (nome.length < 3) return mostrarErro('Digite o nome como está no cartão.');
    if (exp.length < 5) return mostrarErro('Validade inválida.');
    if (cvv.length < 3) return mostrarErro('CVV inválido.');
    if (cpf.length < 11) return mostrarErro('CPF do titular inválido.');

    const [mesStr, anoStr] = exp.split('/');
    const mes = parseInt(mesStr);
    const ano = 2000 + parseInt(anoStr);

    document.getElementById('loading').classList.add('show');
    document.getElementById('loading-txt').textContent = 'Processando cartão…';
    document.getElementById('btn-pagar').disabled = true;

    try {
      const r = await fetch('/pagamento/' + INSCRICAO_ID + '/cartao', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ num, nome, mes, ano, cvv, cpf, parcelas })
      });
      const data = await r.json();
      document.getElementById('loading').classList.remove('show');

      if (data.ok) {
        mostrarSucesso();
      } else {
        document.getElementById('btn-pagar').disabled = false;
        mostrarErro(data.erro || 'Pagamento recusado. Verifique os dados e tente novamente.');
      }
    } catch(e) {
      document.getElementById('loading').classList.remove('show');
      document.getElementById('btn-pagar').disabled = false;
      mostrarErro('Erro de conexão. Tente novamente.');
    }
  }

  function mostrarErro(msg) {
    const el = document.getElementById('card-erro');
    el.textContent = msg;
    el.innerHTML = '<svg style="width:14px;height:14px;fill:#dc2626;vertical-align:middle;margin-right:5px" viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>' + msg;
    el.className = 'erro-msg show';
  }
</script>
</body>
</html>
