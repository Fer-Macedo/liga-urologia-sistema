<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
let chartsCarregados=false, chartMensalInst, chartSemanalInst, chartAnualInst, chartCatInst;
const cVerde='#1a3410', cVerdeCl='rgba(26,61,16,.15)', cVerm='#dc2626', cVermCl='rgba(220,38,38,.12)';

async function abrirGraficos(){
  document.getElementById('modalGraficos').style.display='flex';
  if(chartsCarregados) return;
  document.getElementById('grafico-loading').style.display='block';
  document.getElementById('grafico-mensal').style.display='none';
  try {
    const d=await fetch('/fluxo-caixa/graficos-data').then(r=>r.json());
    chartsCarregados=true;
    document.getElementById('grafico-loading').style.display='none';
    document.getElementById('grafico-mensal').style.display='block';

    // MENSAL
    const mLabels=d.mensal.map(x=>{const[y,m]=x.mes.split('-');return['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'][parseInt(m)-1]+'/'+y.slice(2)});
    chartMensalInst=new Chart(document.getElementById('chartMensal'),{type:'bar',data:{labels:mLabels,datasets:[
      {label:'Entradas',data:d.mensal.map(x=>parseFloat(x.entradas)||0),backgroundColor:'rgba(22,163,74,.7)',borderColor:'#16a34a',borderWidth:2,borderRadius:0},
      {label:'Saídas',data:d.mensal.map(x=>parseFloat(x.saidas)||0),backgroundColor:'rgba(220,38,38,.65)',borderColor:'#dc2626',borderWidth:2,borderRadius:0}
    ]},options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'R$'+v.toLocaleString('pt-BR')}}}}});

    // SEMANAL
    chartSemanalInst=new Chart(document.getElementById('chartSemanal'),{type:'line',data:{labels:d.semanal.map(x=>x.semana),datasets:[
      {label:'Entradas',data:d.semanal.map(x=>parseFloat(x.entradas)||0),borderColor:'#16a34a',backgroundColor:'rgba(22,163,74,.1)',tension:.4,fill:true,pointRadius:5},
      {label:'Saídas',data:d.semanal.map(x=>parseFloat(x.saidas)||0),borderColor:'#dc2626',backgroundColor:'rgba(220,38,38,.08)',tension:.4,fill:true,pointRadius:5}
    ]},options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'R$'+v.toLocaleString('pt-BR')}}}}});

    // ANUAL
    chartAnualInst=new Chart(document.getElementById('chartAnual'),{type:'bar',data:{labels:d.anual.map(x=>x.ano),datasets:[
      {label:'Entradas',data:d.anual.map(x=>parseFloat(x.entradas)||0),backgroundColor:'rgba(22,163,74,.7)',borderColor:'#16a34a',borderWidth:2,borderRadius:0},
      {label:'Saídas',data:d.anual.map(x=>parseFloat(x.saidas)||0),backgroundColor:'rgba(220,38,38,.65)',borderColor:'#dc2626',borderWidth:2,borderRadius:0}
    ]},options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'R$'+v.toLocaleString('pt-BR')}}}}});

    // CATEGORIAS
    const cats=d.categorias.filter(x=>x.tipo==='S');
    chartCatInst=new Chart(document.getElementById('chartCat'),{type:'doughnut',data:{
      labels:cats.map(x=>x.categoria||'Sem categoria'),
      datasets:[{data:cats.map(x=>parseFloat(x.total)||0),backgroundColor:['#dc2626','#f59e0b','#3b82f6','#8b5cf6','#10b981','#ef4444','#6366f1','#14b8a6'],borderWidth:2}]
    },options:{responsive:true,plugins:{legend:{position:'right'},title:{display:true,text:'Saídas por Categoria — Mês Atual'}}}});
  } catch(e){ document.getElementById('grafico-loading').innerHTML='Erro ao carregar: '+e.message; }
}
function fecharGraficos(){ document.getElementById('modalGraficos').style.display='none'; }
function trocarAba(aba){
  ['mensal','semanal','anual','categorias'].forEach(a=>{
    document.getElementById('grafico-'+a).style.display=a===aba?'block':'none';
    const btn=document.getElementById('aba-'+a);
    btn.style.color=a===aba?'#1a3410':'#6b7280';
    btn.style.borderBottom=a===aba?'3px solid #1a3410':'3px solid transparent';
    btn.style.fontWeight=a===aba?'700':'600';
  });
}
document.getElementById('modalGraficos').addEventListener('click',function(e){if(e.target===this)fecharGraficos();});

// Selecao multipla
document.getElementById('sel-todos').addEventListener('change',function(){
  document.querySelectorAll('.sel-item').forEach(function(cb){cb.checked=this.checked;},this);
  atualizarBarra();
});
document.addEventListener('change',function(e){
  if(e.target.classList.contains('sel-item')) atualizarBarra();
});
function atualizarBarra(){
  var sels=document.querySelectorAll('.sel-item:checked');
  var barra=document.getElementById('barra-selecao');
  var count=document.getElementById('sel-count');
  var inputs=document.getElementById('inputs-ids');
  if(sels.length>0){
    barra.style.display='flex';
    count.textContent=sels.length+' selecionado(s)';
    inputs.innerHTML='';
    sels.forEach(function(cb){
      var inp=document.createElement('input');
      inp.type='hidden'; inp.name='ids'; inp.value=cb.value;
      inputs.appendChild(inp);
    });
  } else {
    barra.style.display='none';
  }
}
function limparSelecao(){
  document.querySelectorAll('.sel-item').forEach(function(cb){cb.checked=false;});
  document.getElementById('sel-todos').checked=false;
  document.getElementById('barra-selecao').style.display='none';
}
</script>
