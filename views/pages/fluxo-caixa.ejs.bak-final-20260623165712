<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <link rel="shortcut icon" href="/favicon.ico"><link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png"><link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"><link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fluxo de Caixa — <%= config.org_nome %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin-modern.css">
<style>
.fc-page { padding: 28px 32px; max-width: 1400px; }
.fc-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px; }
.fc-titulo { font-size:22px; font-weight:700; color:#1a2e0e; display:flex; align-items:center; gap:10px; }
.fc-titulo svg { color:#2b6803; }
.fc-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
.fc-filtro { display:flex; align-items:center; gap:8px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:6px 14px; }
.fc-filtro select { border:none; background:transparent; font-size:14px; color:#374151; font-weight:600; cursor:pointer; outline:none; }
.fc-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:16px; margin-bottom:28px; }
.fc-card { background:#fff; border-radius:12px; padding:20px 22px; box-shadow:0 1px 4px rgba(0,0,0,.07); border-top:4px solid transparent; }
.fc-card.entrada { border-color:#16a34a; } .fc-card.saida { border-color:#dc2626; }
.fc-card.saldo-p { border-color:#2b6803; } .fc-card.saldo-n { border-color:#dc2626; }
.fc-card.lanctos { border-color:#3b82f6; }
.fc-card-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:#6b7280; margin-bottom:8px; }
.fc-card-valor { font-size:24px; font-weight:800; line-height:1; }
.fc-card.entrada .fc-card-valor { color:#16a34a; } .fc-card.saida .fc-card-valor { color:#dc2626; }
.fc-card.saldo-p .fc-card-valor { color:#2b6803; } .fc-card.saldo-n .fc-card-valor { color:#dc2626; }
.fc-card.lanctos .fc-card-valor { color:#3b82f6; }
.fc-card-sub { font-size:12px; color:#9ca3af; margin-top:5px; }
.btn-entrada { background:#16a34a; color:#fff; border:none; border-radius:8px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; transition:.2s; }
.btn-entrada:hover { background:#15803d; }
.btn-saida { background:#dc2626; color:#fff; border:none; border-radius:8px; padding:9px 18px; font-size:14px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; transition:.2s; }
.btn-saida:hover { background:#b91c1c; }
.btn-export { background:#fff; color:#374151; border:1px solid #d1d5db; border-radius:8px; padding:9px 16px; font-size:14px; cursor:pointer; display:flex; align-items:center; gap:6px; }
.btn-export:hover { background:#f9fafb; }
.fc-table-wrap { background:#fff; border-radius:12px; box-shadow:0 1px 4px rgba(0,0,0,.07); overflow:hidden; }
.fc-table-header { display:flex; align-items:center; justify-content:space-between; padding:16px 22px; border-bottom:1px solid #f1f5f9; gap:12px; flex-wrap:wrap; }
.fc-table-title { font-size:15px; font-weight:700; color:#1a2e0e; }
.fc-search { display:flex; align-items:center; gap:8px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:7px 12px; }
.fc-search input { border:none; background:transparent; outline:none; font-size:13px; color:#374151; width:180px; }
.fc-filter-tipo { display:flex; gap:6px; }
.fc-filter-tipo button { background:#f1f5f9; border:none; border-radius:6px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer; color:#6b7280; transition:.2s; }
.fc-filter-tipo button.at { background:#374151; color:#fff; }
.fc-filter-tipo button.ae { background:#16a34a; color:#fff; }
.fc-filter-tipo button.as { background:#dc2626; color:#fff; }
table.fc-table { width:100%; border-collapse:collapse; }
table.fc-table thead th { background:#f8fafc; padding:11px 16px; text-align:left; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#6b7280; border-bottom:1px solid #e9eef4; white-space:nowrap; }
table.fc-table tbody tr { border-bottom:1px solid #f1f5f9; transition:.15s; }
table.fc-table tbody tr:last-child { border-bottom:none; }
table.fc-table tbody tr:hover { background:#f8fafc; }
table.fc-table td { padding:12px 16px; font-size:13px; color:#374151; vertical-align:middle; }
.badge-tipo { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; white-space:nowrap; }
.badge-tipo.E { background:#dcfce7; color:#16a34a; } .badge-tipo.S { background:#fee2e2; color:#dc2626; }
.badge-cat { background:#f1f5f9; color:#475569; padding:2px 9px; border-radius:6px; font-size:11px; font-weight:600; white-space:nowrap; }
.nf-btn { display:inline-flex; align-items:center; gap:4px; color:#2b6803; font-size:12px; font-weight:600; cursor:pointer; background:#f0f7eb; padding:3px 9px; border-radius:6px; border:none; }
.nf-btn:hover { background:#dbefd3; }
.nf-sem { color:#d1d5db; font-size:12px; }
.col-docs { width:100px; white-space:nowrap; }
.col-acoes { width:80px; white-space:nowrap; text-align:right; }
.docs-grupo { display:inline-flex; align-items:center; gap:2px; background:#f0fdf4; border:1px solid #bbf7d0; padding:2px 5px; margin-bottom:2px; }
.docs-grupo:last-child { margin-bottom:0; }
.docs-wrap { display:flex; flex-direction:column; align-items:flex-start; gap:2px; }
.fc-acoes { display:flex; gap:3px; align-items:center; justify-content:flex-end; flex-wrap:nowrap; white-space:nowrap; }
.btn-icon { border:none; background:transparent; cursor:pointer; padding:5px 7px; border-radius:6px; color:#9ca3af; transition:.2s; }
.btn-icon:hover { background:#f1f5f9; color:#2b6803; }
.btn-icon.del:hover { color:#dc2626; background:#fee2e2; }
.fc-empty { text-align:center; padding:56px; color:#9ca3af; }
.fc-empty svg { display:block; margin:0 auto 12px; opacity:.25; }
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1000; align-items:center; justify-content:center; padding:20px; }
.modal-overlay.open { display:flex; }
.modal-box { background:#fff; border-radius:16px; width:100%; max-width:560px; box-shadow:0 20px 60px rgba(0,0,0,.2); max-height:92vh; overflow-y:auto; }
.modal-head { padding:20px 24px; border-radius:16px 16px 0 0; display:flex; align-items:center; justify-content:space-between; }
.modal-head.hentrada { background:linear-gradient(135deg,#16a34a,#15803d); }
.modal-head.hsaida { background:linear-gradient(135deg,#dc2626,#b91c1c); }
.modal-head h3 { color:#fff; font-size:17px; font-weight:700; margin:0; }
.modal-close { background:rgba(255,255,255,.2); border:none; color:#fff; border-radius:8px; width:32px; height:32px; cursor:pointer; font-size:20px; display:flex; align-items:center; justify-content:center; }
.modal-close:hover { background:rgba(255,255,255,.35); }
.modal-body { padding:24px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px; }
.form-row.full { grid-template-columns:1fr; }
.form-group { display:flex; flex-direction:column; gap:5px; }
.form-group label { font-size:11px; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:.4px; }
.form-group input, .form-group select, .form-group textarea { border:1.5px solid #e2e8f0; border-radius:8px; padding:9px 12px; font-size:14px; color:#1f2937; transition:.2s; background:#fafafa; font-family:inherit; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline:none; border-color:#2b6803; background:#fff; }
.form-group textarea { resize:vertical; min-height:72px; }
.upload-area { border:2px dashed #d1d5db; border-radius:10px; padding:20px; text-align:center; cursor:pointer; transition:.2s; background:#fafafa; position:relative; }
.upload-area:hover { border-color:#2b6803; background:#f0f7eb; }
.upload-area input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
.upload-label { font-size:13px; color:#6b7280; pointer-events:none; }
.upload-label span { display:block; font-size:11px; color:#9ca3af; margin-top:3px; }
.upload-preview { display:none; margin-top:10px; align-items:center; gap:10px; background:#f0f7eb; border-radius:8px; padding:8px 12px; }
.upload-preview-nome { font-size:12px; color:#2b6803; font-weight:600; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.upload-preview-del { background:none; border:none; color:#dc2626; cursor:pointer; font-size:18px; padding:0 4px; line-height:1; }
.modal-footer { display:flex; justify-content:flex-end; gap:10px; padding:0 24px 24px; }
.btn-cancelar { background:#f1f5f9; color:#374151; border:none; border-radius:8px; padding:10px 20px; font-size:14px; font-weight:600; cursor:pointer; }
.btn-cancelar:hover { background:#e5e7eb; }
.btn-salvar { border:none; border-radius:8px; padding:10px 24px; font-size:14px; font-weight:700; cursor:pointer; color:#fff; }
.btn-salvar.se { background:#16a34a; } .btn-salvar.se:hover { background:#15803d; }
.btn-salvar.ss { background:#dc2626; } .btn-salvar.ss:hover { background:#b91c1c; }
.modal-nf-box { background:#fff; border-radius:16px; width:100%; max-width:700px; max-height:90vh; overflow-y:auto; }
.modal-nf-head { padding:18px 22px; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; }
.modal-nf-head h3 { font-size:15px; font-weight:700; color:#1a2e0e; margin:0; }
.modal-nf-body { padding:22px; text-align:center; }
.modal-nf-body img { max-width:100%; border-radius:10px; border:1px solid #e2e8f0; max-height:65vh; object-fit:contain; }
.nf-pdf-link { display:inline-flex; align-items:center; gap:8px; background:#f0f7eb; color:#2b6803; padding:14px 24px; border-radius:10px; font-weight:700; text-decoration:none; font-size:14px; margin-top:12px; }
.nf-pdf-link:hover { background:#dbefd3; }
.flash-msg { padding:12px 18px; border-radius:8px; margin-bottom:16px; font-size:14px; font-weight:600; }
.flash-msg.ok { background:#dcfce7; color:#15803d; border:1px solid #bbf7d0; }
.flash-msg.err { background:#fee2e2; color:#b91c1c; border:1px solid #fecaca; }
@media(max-width:640px){ .fc-page{padding:16px;} .form-row{grid-template-columns:1fr;} .fc-cards{grid-template-columns:1fr 1fr;} }

    /* === PADRÃO VERDE ESCURO — Fluxo de Caixa === */
    * { border-radius:0!important; }
    .stat-card, .stat-box { border-radius:0!important; transition:transform .12s ease, box-shadow .12s ease; }
    .stat-card:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(0,0,0,.1); }
    .card, .table-wrap, .lancamentos-card { border-radius:0!important; }
    .fil-btn { border-radius:0!important; }
    .fil-btn.fil-ativo, .fil-btn.ativo { background:linear-gradient(135deg,#1a3410,#253d18)!important; color:#fff!important; border-color:#1a3410!important; }
    .fil-btn:hover { border-color:#253d18!important; color:#1a3410!important; background:#f0f7eb!important; }
    table thead th { background:linear-gradient(135deg,#1a3410,#253d18)!important; color:#fff!important; border-bottom:none!important; }
    table tbody tr:hover { background:#f0f7eb!important; }
    .badge { border-radius:0!important; }
    .modal-box { border-radius:0!important; }
    .modal-head { border-radius:0!important; background:linear-gradient(135deg,#1a3410,#253d18)!important; }
    .modal-close { border-radius:0!important; }
    input, select, textarea { border-radius:0!important; }
    input:focus, select:focus, textarea:focus { border-color:#1a3410!important; box-shadow:0 0 0 3px rgba(37,61,24,.1)!important; }
    .btn { border-radius:0!important; }
    .btn-entrada { background:linear-gradient(135deg,#166534,#16a34a)!important; border-radius:0!important; }
    .btn-saida { background:linear-gradient(135deg,#991b1b,#dc2626)!important; border-radius:0!important; }
    select.mes-select { border-radius:0!important; }
</style>
</head>
<body>
<div class="layout">
  <%- include('../partials/sidebar', { paginaAtual: 'fluxo-caixa' }) %>
  <main class="main">


<div class="fc-page">
  <% if(msg&&msg.length){ %><div class="flash-msg ok"><%= msg[0] %></div><% } %>
  <% if(erro&&erro.length){ %><div class="flash-msg err"><%= erro[0] %></div><% } %>

  <div class="fc-header">
    <div class="fc-titulo">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      Fluxo de Caixa
    </div>
    <div class="fc-actions">
      <div class="fc-filtro">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <select id="filtroMes" onchange="filtrarMes()">
          <% const mesesNomes=['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
             const hoje=new Date();
             for(let a=hoje.getFullYear();a>=hoje.getFullYear()-2;a--){
               const mMax=(a===hoje.getFullYear())?hoje.getMonth():11;
               for(let m=mMax;m>=0;m--){
                 const val=`${a}-${String(m+1).padStart(2,'0')}`;
                 const sel=val===mesAtual?'selected':''; %>
            <option value="<%= val %>" <%= sel %>><%= mesesNomes[m] %> <%= a %></option>
          <% }} %>
        </select>
      </div>
      <button class="btn-export" onclick="abrirGraficos()" style="background:#1a3410;color:#fff;border-color:#1a3410">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Gráficos
      </button>
      <button class="btn-export" onclick="exportarCSV()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Exportar CSV
      </button>
      <button class="btn-entrada" onclick="abrirModal('entrada')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nova Entrada
      </button>
      <button class="btn-saida" onclick="abrirModal('saida')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nova Saída
      </button>
    </div>
  </div>

  <div class="fc-cards">
    <div class="fc-card entrada">
      <div class="fc-card-label">Total Entradas</div>
      <div class="fc-card-valor">R$ <%= totalEntradas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
      <div class="fc-card-sub"><%= qtdEntradas %> lançamento<%= qtdEntradas!==1?'s':'' %></div>
    </div>
    <div class="fc-card saida">
      <div class="fc-card-label">Total Saídas</div>
      <div class="fc-card-valor">R$ <%= totalSaidas.toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
      <div class="fc-card-sub"><%= qtdSaidas %> lançamento<%= qtdSaidas!==1?'s':'' %></div>
    </div>
    <div class="fc-card <%= saldoAcumulado>=0?'saldo-p':'saldo-n' %>">
      <div class="fc-card-label">Saldo Acumulado</div>
      <div class="fc-card-valor"><%= saldoAcumulado<0?'-':'' %>R$ <%= Math.abs(saldoAcumulado).toLocaleString('pt-BR',{minimumFractionDigits:2}) %></div>
      <div class="fc-card-sub" style="font-size:10px;color:#6b7280">Mes: <%=saldo>=0?'+':''%>R$ <%=saldo.toLocaleString('pt-BR',{minimumFractionDigits:2})%> &nbsp;|&nbsp; Anterior: R$ <%=saldoAnterior.toLocaleString('pt-BR',{minimumFractionDigits:2})%></div>
    </div>
    <div class="fc-card lanctos">
      <div class="fc-card-label">Lançamentos</div>
      <div class="fc-card-valor"><%= qtdEntradas+qtdSaidas %></div>
      <div class="fc-card-sub">no mês selecionado</div>
    </div>
  </div>

  <div class="fc-table-wrap">
    <div class="fc-table-header">
      <div class="fc-table-title">Lançamentos — <%= mesNome %></div>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <div class="fc-filter-tipo">
          <button id="btnT" class="at" onclick="filtroTipo('T',this)">Todos</button>
          <button id="btnE" onclick="filtroTipo('E',this)">Entradas</button>
          <button id="btnS" onclick="filtroTipo('S',this)">Saídas</button>
        </div>
        <div class="fc-search">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="buscaTxt" placeholder="Buscar descrição..." oninput="buscar()">
        </div>
      </div>
    </div>

    <% if(lancamentos.length===0){ %>
      <div class="fc-empty">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <p>Nenhum lançamento neste mês.</p>
      </div>
    <% } else { %>
    <div id="barra-selecao" style="display:none;align-items:center;gap:10px;margin-bottom:10px;padding:10px 14px;background:#fef2f2;border:1px solid #fecaca;border-radius:4px">
      <span id="sel-count" style="font-size:13px;font-weight:600;color:#b91c1c">0 selecionados</span>
      <form method="POST" action="/fluxo-caixa/excluir-lote" id="form-excluir-lote" onsubmit="return confirm('Excluir todos os itens selecionados?')">
        <input type="hidden" name="mes" value="<%=mesAtual%>">
        <div id="inputs-ids"></div>
        <button type="submit" style="padding:6px 14px;background:#dc2626;color:white;border:none;font-size:12px;font-weight:700;cursor:pointer;border-radius:4px;font-family:inherit">Excluir selecionados</button>
      </form>
      <button onclick="limparSelecao()" style="padding:6px 14px;background:#fff;border:1px solid #e5e7eb;font-size:12px;cursor:pointer;border-radius:4px;font-family:inherit">Cancelar</button>
    </div>
    <div>
    <table class="fc-table">
      <thead>
        <tr>
          <th style="width:32px"><input type="checkbox" id="sel-todos" title="Selecionar todos" style="cursor:pointer;width:15px;height:15px;accent-color:var(--cor-primaria)"></th>
          <th>Data</th><th>Tipo</th><th>Categoria</th><th>Descrição</th>
          <th style="text-align:right">Valor</th><th>Método</th><th class="col-docs">Documentos</th><th>Observações</th><th class="col-acoes"></th>
        </tr>
      </thead>
      <tbody id="corpoTabela">
        <% lancamentos.forEach(function(l){ 
          var dt=new Date(l.data_lancamento);
          dt.setMinutes(dt.getMinutes()+dt.getTimezoneOffset());
          var dtStr=dt.toLocaleDateString('pt-BR');
          var lJson=JSON.stringify(l).replace(/"/g,'&quot;');
        %>
        <tr data-tipo="<%= l.tipo %>" data-desc="<%= l.descricao.toLowerCase().replace(/"/g,'') %>">
          <td><input type="checkbox" class="sel-item" value="<%= l.id %>" style="cursor:pointer;width:15px;height:15px;accent-color:var(--cor-primaria)"></td>
          <td style="white-space:nowrap"><%= dtStr %></td>
          <td>
            <span class="badge-tipo <%= l.tipo %>">
              <% if(l.tipo==='E'){ %>+ Entrada<% }else{ %>− Saída<% } %>
            </span>
          </td>
          <td><span class="badge-cat"><%= l.categoria %></span></td>
          <td style="max-width:260px"><%= l.descricao %></td>
          <td style="text-align:right;font-weight:700;color:<%= l.tipo==='E'?'#16a34a':'#dc2626' %>">
            <%= l.tipo==='S'?'-':'' %>R$ <%= parseFloat(l.valor).toLocaleString('pt-BR',{minimumFractionDigits:2}) %>
          </td>
          <td class="col-docs">
            <% if(l.nf_chave){ %>
              <div class="docs-wrap">
                <div class="docs-grupo" title="<%=l.nf_nome_original||''%>">
                  <button class="btn-icon" title="Visualizar" onclick="visualizarNF('<%=l.nf_chave%>')">
