<script>
const mesAtual='<%= mesAtual %>';
function filtrarMes(){ window.location.href='/fluxo-caixa?mes='+document.getElementById('filtroMes').value; }
function filtroTipo(t,btn){
  document.querySelectorAll('.fc-filter-tipo button').forEach(b=>b.className='');
  btn.className=t==='T'?'at':t==='E'?'ae':'as';
  document.querySelectorAll('#corpoTabela tr').forEach(tr=>{ tr.style.display=(t==='T'||tr.dataset.tipo===t)?'':'none'; });
}
function buscar(){ const q=document.getElementById('buscaTxt').value.toLowerCase(); document.querySelectorAll('#corpoTabela tr').forEach(tr=>{ tr.style.display=tr.dataset.desc.includes(q)?'':'none'; }); }
function abrirModal(tipo){
  const isE=tipo==='entrada';
  document.getElementById('formLancamento').action='/fluxo-caixa/novo';
  document.getElementById('fId').value='';
  document.getElementById('formLancamento').reset();
  document.getElementById('uploadPreview').style.display='none';
  document.getElementById('modalHead').className='modal-head h'+tipo;
  document.getElementById('modalTitulo').textContent=isE?'+ Nova Entrada':'− Nova Saída';
  document.getElementById('fTipo').value=isE?'E':'S';
  document.getElementById('fNF').dataset.existente='';
  atualizarObrigatoriedadeNF();
  document.getElementById('btnSalvar').className='btn-salvar '+(isE?'se':'ss');
  document.getElementById('btnSalvar').textContent='Salvar '+(isE?'Entrada':'Saída');
  document.getElementById('fData').value=new Date().toISOString().split('T')[0];
  document.getElementById('modalLancamento').classList.add('open');
}
function editarLancamento(l){
  const isE=l.tipo==='E';
  document.getElementById('formLancamento').action='/fluxo-caixa/'+l.id+'/editar';
  document.getElementById('fId').value=l.id;
  document.getElementById('modalHead').className='modal-head h'+(isE?'entrada':'saida');
  document.getElementById('modalTitulo').textContent='Editar Lançamento';
  document.getElementById('fTipo').value=l.tipo;
  document.getElementById('btnSalvar').className='btn-salvar '+(isE?'se':'ss');
  const nfInput = document.getElementById('fNF');
  if(nfInput) nfInput.dataset.existente = l.nf_chave ? '1' : '';
  atualizarObrigatoriedadeNF();
  document.getElementById('btnSalvar').textContent='Salvar';
  const d=new Date(l.data_lancamento); d.setMinutes(d.getMinutes()+d.getTimezoneOffset());
  document.getElementById('fData').value=d.toISOString().split('T')[0];
  document.getElementById('fValor').value=parseFloat(l.valor);
  document.getElementById('fDesc').value=l.descricao;
  document.getElementById('fCat').value=l.categoria;
  document.getElementById('fObs').value=l.observacoes||'';
  document.getElementById('uploadPreview').style.display='none';
  document.getElementById('modalLancamento').classList.add('open');
}
function fecharModal(){ document.getElementById('modalLancamento').classList.remove('open'); }
function validarESalvar() {
  const tipo = document.getElementById('fTipo').value;
  const nf1 = document.getElementById('fNF');
  const nf1Existente = document.getElementById('fNF').dataset.existente;
  const temArquivo = (nf1 && nf1.files && nf1.files.length > 0) || nf1Existente;
  if (tipo === 'S' && !temArquivo) {
    alert('Para lançamentos de SAÍDA é obrigatório anexar ao menos um comprovante ou nota fiscal!');
    document.getElementById('fNF').focus();
    return;
  }
  document.getElementById('formLancamento').submit();
}
function atualizarObrigatoriedadeNF() {
  const tipo = document.getElementById('fTipo').value;
  const span = document.getElementById('nfObrigatorio');
  if(span) span.style.display = tipo === 'S' ? 'inline' : 'none';
}
function previewNF(inp){ if(inp.files&&inp.files[0]){ document.getElementById('uploadNome').textContent=inp.files[0].name; document.getElementById('uploadPreview').style.display='flex'; } }
function previewNF2(inp){ if(inp.files&&inp.files[0]){ document.getElementById('uploadNome2').style.display='none'; document.getElementById('uploadNome2txt').textContent=inp.files[0].name; document.getElementById('uploadPreview2').style.display='flex'; } }
function visualizarNF(chave) {
  if(!chave) return;
  window.open('/fluxo-caixa/doc/visualizar?chave='+encodeURIComponent(chave), '_blank');
}
function baixarNF(chave, nome) {
  if(!chave) return;
  window.location.href='/fluxo-caixa/doc/baixar?chave='+encodeURIComponent(chave)+'&nome='+encodeURIComponent(nome||'documento');
}
function removerNF(){ document.getElementById('fNF').value=''; document.getElementById('uploadPreview').style.display='none'; }
function excluir(id,desc){ if(!confirm('Excluir: "'+desc+'"?\nEsta ação não pode ser desfeita.'))return; const f=document.createElement('form');f.method='POST';f.action='/fluxo-caixa/'+id+'/excluir';document.body.appendChild(f);f.submit(); }
async function verNF(id,nome){
  document.getElementById('nfTitulo').textContent=nome;
  document.getElementById('nfConteudo').innerHTML='<p style="color:#9ca3af;padding:24px">Carregando...</p>';
  document.getElementById('modalNF').classList.add('open');
  try{
    const r=await fetch('/fluxo-caixa/'+id+'/nf-url');
    const data=await r.json();
    if(data.url){
      const ext=(data.nome||'').split('.').pop().toLowerCase();
      if(ext==='pdf') document.getElementById('nfConteudo').innerHTML=`<a href="${data.url}" target="_blank" class="nf-pdf-link">Abrir PDF em nova aba</a>`;
      else document.getElementById('nfConteudo').innerHTML=`<img src="${data.url}" alt="NF"><br><a href="${data.url}" target="_blank" class="nf-pdf-link" style="margin-top:12px;display:inline-flex">Abrir em nova aba</a>`;
    }else{ document.getElementById('nfConteudo').innerHTML='<p style="color:#dc2626">Arquivo não encontrado.</p>'; }
  }catch(e){ document.getElementById('nfConteudo').innerHTML='<p style="color:#dc2626">Erro ao carregar.</p>'; }
}
function fecharNF(){ document.getElementById('modalNF').classList.remove('open'); }
function exportarCSV(){
  const rows=[['Data','Tipo','Categoria','Descrição','Valor','Observações']];
  document.querySelectorAll('#corpoTabela tr').forEach(tr=>{
    if(tr.style.display==='none')return;
    const tds=tr.querySelectorAll('td'); if(tds.length<7)return;
    rows.push([tds[0].textContent.trim(),tds[1].textContent.trim(),tds[2].textContent.trim(),tds[3].textContent.trim(),tds[4].textContent.trim(),tds[6].textContent.trim()]);
  });
  const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
  const a=document.createElement('a'); a.href='data:text/csv;charset=utf-8,\uFEFF'+encodeURIComponent(csv); a.download='fluxo-caixa-<%=mesAtual%>.csv'; a.click();
}
document.getElementById('modalLancamento').addEventListener('click',e=>{if(e.target===e.currentTarget)fecharModal();});
document.getElementById('modalNF').addEventListener('click',e=>{if(e.target===e.currentTarget)fecharNF();});
</script>
  </main>
</div>

